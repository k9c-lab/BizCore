@model BizCore.Models.Entities.ReceivingHeader
@{
    Layout = null;
    var companyName = ViewData["PrintCompanyName"] as string ?? "BizCore Co., Ltd.";
    var companyAddress = ViewData["PrintCompanyAddress"] as string ?? "-";
    var companyTaxId = ViewData["PrintCompanyTaxId"] as string ?? "-";
    var companyPhone = ViewData["PrintCompanyPhone"] as string ?? "-";
    var companyEmail = ViewData["PrintCompanyEmail"] as string ?? "-";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Receiving @Model.ReceivingNo</title>
    <style>
        @@page { size: A4; margin: 14mm; }
        * { box-sizing: border-box; }
        body {
            margin: 0;
            font-family: "Segoe UI", Tahoma, sans-serif;
            color: #111827;
            background: #fff;
            font-size: 11.5px;
            line-height: 1.35;
        }
        .print-shell {
            width: 100%;
            min-height: calc(297mm - 28mm);
            display: flex;
            flex-direction: column;
        }
        .screen-actions {
            display: flex;
            justify-content: flex-end;
            margin: 0 0 10px;
        }
        .screen-actions button {
            border: 1px solid #cbd5e1;
            background: #fff;
            color: #111827;
            border-radius: 6px;
            padding: 6px 10px;
            font: inherit;
        }
        .print-header {
            display: flex;
            justify-content: space-between;
            gap: 24px;
            padding-bottom: 14px;
            border-bottom: 2px solid #d1d5db;
        }
        .company-block { max-width: 58%; }
        .company-name {
            margin: 0 0 6px;
            font-size: 20px;
            font-weight: 700;
            letter-spacing: 0.02em;
        }
        .company-line, .meta-label, .section-label, .summary-label, .signature-label {
            color: #6b7280;
        }
        .company-meta-grid {
            display: grid;
            gap: 2px;
            margin-top: 8px;
        }
        .document-block {
            min-width: 280px;
            text-align: right;
        }
        .document-title {
            margin: 0;
            font-size: 23px;
            font-weight: 700;
        }
        .document-meta {
            width: 100%;
            border-collapse: collapse;
            margin-top: 10px;
        }
        .document-meta td {
            padding: 2px 0 2px 16px;
            vertical-align: top;
        }
        .document-meta td:first-child { white-space: nowrap; }
        .print-section { margin-top: 18px; }
        .party-section {
            border: 1px solid #d1d5db;
            border-radius: 8px;
            padding: 12px 14px;
        }
        .party-grid {
            display: grid;
            grid-template-columns: minmax(0, 1.4fr) minmax(180px, 0.8fr);
            gap: 12px 20px;
        }
        .party-name {
            font-size: 14px;
            font-weight: 700;
            margin-top: 2px;
        }
        .party-value, .remark-value, .signature-date {
            white-space: pre-wrap;
        }
        .line-table {
            width: 100%;
            border-collapse: collapse;
            table-layout: fixed;
        }
        .line-table th, .line-table td {
            border: 1px solid #d1d5db;
            padding: 7px 8px;
            vertical-align: top;
        }
        .line-table th {
            background: #f3f4f6;
            font-weight: 700;
            text-align: center;
            font-size: 11px;
        }
        .col-no { width: 42px; text-align: center; }
        .col-description { width: auto; white-space: pre-wrap; word-break: break-word; }
        .col-qty, .col-price, .col-total { width: 78px; text-align: right; }
        .col-serials { width: 130px; white-space: pre-wrap; word-break: break-word; }
        .summary-wrap {
            display: flex;
            justify-content: flex-end;
            margin-top: 14px;
        }
        .summary-table {
            min-width: 280px;
            border-collapse: collapse;
        }
        .summary-table td {
            padding: 4px 0 4px 18px;
        }
        .summary-table td:first-child {
            text-align: left;
            color: #4b5563;
        }
        .summary-table td:last-child {
            text-align: right;
            min-width: 120px;
        }
        .summary-total td {
            padding-top: 8px;
            border-top: 2px solid #9ca3af;
            font-weight: 700;
            font-size: 14px;
        }
        .remark-box {
            border: 1px solid #d1d5db;
            border-radius: 8px;
            padding: 10px 14px;
            min-height: 78px;
        }
        .signature-grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 28px;
            margin-top: auto;
            padding-top: 28px;
        }
        .signature-box { text-align: center; }
        .signature-line {
            margin: 44px auto 8px;
            width: 88%;
            border-bottom: 1px solid #111827;
        }
        @@media print {
            body {
                -webkit-print-color-adjust: exact;
                print-color-adjust: exact;
            }
            .screen-actions { display: none; }
        }
    </style>
</head>
<body>
    <div class="print-shell">
        <div class="screen-actions">
            <button type="button" onclick="window.print()">Print</button>
        </div>

        <header class="print-header">
            <div class="company-block">
                <h1 class="company-name">@companyName</h1>
                <div class="company-meta-grid">
                    <div class="company-line">@companyAddress</div>
                    <div class="company-line">Tax ID: @companyTaxId</div>
                    <div class="company-line">Phone: @companyPhone</div>
                    <div class="company-line">Email: @companyEmail</div>
                </div>
            </div>
            <div class="document-block">
                <h2 class="document-title">Goods Receiving</h2>
                <table class="document-meta">
                    <tr><td class="meta-label">Receiving No.</td><td>@Model.ReceivingNo</td></tr>
                    <tr><td class="meta-label">Receive Date</td><td>@Model.ReceiveDate.ToString("dd/MM/yyyy")</td></tr>
                    <tr><td class="meta-label">PO No.</td><td>@Model.PurchaseOrderHeader?.PONo</td></tr>
                    <tr><td class="meta-label">Delivery Note</td><td>@(string.IsNullOrWhiteSpace(Model.DeliveryNoteNo) ? "-" : Model.DeliveryNoteNo)</td></tr>
                    <tr><td class="meta-label">Status</td><td>@Model.Status</td></tr>
                </table>
            </div>
        </header>

        <section class="print-section party-section">
            <div class="party-grid">
                <div>
                    <div class="section-label">Supplier Name</div>
                    <div class="party-name">@Model.Supplier?.SupplierName</div>
                </div>
                <div>
                    <div class="section-label">Tax ID</div>
                    <div class="party-value">@(string.IsNullOrWhiteSpace(Model.Supplier?.TaxId) ? "-" : Model.Supplier!.TaxId)</div>
                </div>
                <div style="grid-column: 1 / -1;">
                    <div class="section-label">Supplier Address</div>
                    <div class="party-value">@(string.IsNullOrWhiteSpace(Model.Supplier?.Address) ? "-" : Model.Supplier!.Address)</div>
                </div>
                <div>
                    <div class="section-label">Phone</div>
                    <div class="party-value">@(string.IsNullOrWhiteSpace(Model.Supplier?.PhoneNumber) ? "-" : Model.Supplier!.PhoneNumber)</div>
                </div>
                <div>
                    <div class="section-label">Email</div>
                    <div class="party-value">@(string.IsNullOrWhiteSpace(Model.Supplier?.Email) ? "-" : Model.Supplier!.Email)</div>
                </div>
            </div>
        </section>

        <section class="print-section">
            <table class="line-table">
                <thead>
                    <tr>
                        <th class="col-no">No</th>
                        <th class="col-description">Description</th>
                        <th class="col-qty">Ordered</th>
                        <th class="col-qty">Received</th>
                        <th class="col-price">Unit Price</th>
                        <th class="col-total">Line Total</th>
                        <th class="col-serials">Serials</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var line in Model.ReceivingDetails.OrderBy(x => x.LineNumber))
                {
                    var poLine = line.PurchaseOrderDetail;
                    var serialText = line.ReceivingSerials.Any()
                        ? string.Join("\n", line.ReceivingSerials.OrderBy(x => x.SerialNo).Select(x => x.SerialNo))
                        : "-";
                    var description = string.Join("\n", new[]
                    {
                        $"{line.Item?.ItemCode} - {line.Item?.ItemName}",
                        string.IsNullOrWhiteSpace(line.Remark) ? string.Empty : line.Remark
                    }.Where(x => !string.IsNullOrWhiteSpace(x)));
                    <tr>
                        <td class="col-no">@line.LineNumber</td>
                        <td class="col-description">@description</td>
                        <td class="col-qty">@((poLine?.Qty ?? 0m).ToString("N2"))</td>
                        <td class="col-qty">@line.QtyReceived.ToString("N2")</td>
                        <td class="col-price">@((poLine?.UnitPrice ?? 0m).ToString("N2"))</td>
                        <td class="col-total">@((poLine?.LineTotal ?? 0m).ToString("N2"))</td>
                        <td class="col-serials">@serialText</td>
                    </tr>
                }
                </tbody>
            </table>

            <div class="summary-wrap">
                <table class="summary-table">
                    <tr><td class="summary-label">PO Subtotal</td><td>@((Model.PurchaseOrderHeader?.Subtotal ?? 0m).ToString("N2"))</td></tr>
                    <tr><td class="summary-label">PO Discount</td><td>@((Model.PurchaseOrderHeader?.DiscountAmount ?? 0m).ToString("N2"))</td></tr>
                    <tr><td class="summary-label">PO VAT</td><td>@((Model.PurchaseOrderHeader?.VatAmount ?? 0m).ToString("N2"))</td></tr>
                    <tr class="summary-total"><td>PO Total</td><td>@((Model.PurchaseOrderHeader?.TotalAmount ?? 0m).ToString("N2"))</td></tr>
                </table>
            </div>
        </section>

        <section class="print-section">
            <div class="remark-box">
                <div class="section-label">Remark</div>
                <div class="remark-value">@(string.IsNullOrWhiteSpace(Model.Remark) ? "-" : Model.Remark)</div>
            </div>
        </section>

        <section class="signature-grid">
            <div class="signature-box">
                <div class="signature-label">Received By</div>
                <div class="signature-line"></div>
                <div>............................................................</div>
                <div class="signature-date">Date ........ / ........ / ........</div>
            </div>
            <div class="signature-box">
                <div class="signature-label">Checked / Approved By</div>
                <div class="signature-line"></div>
                <div>............................................................</div>
                <div class="signature-date">Date ........ / ........ / ........</div>
            </div>
        </section>
    </div>
    <script>
        window.addEventListener("load", () => {
            window.print();
        });
    </script>
</body>
</html>
