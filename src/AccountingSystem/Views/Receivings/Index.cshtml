@inject IUserPermissionService PermissionService
@model BizCore.Models.ViewModels.PaginatedList<BizCore.Models.Entities.ReceivingHeader>

@{
    ViewData["Title"] = "ใบรับสินค้า";
    var search = ViewData["Search"] as string;
    var status = ViewData["Status"] as string;
    var dateFrom = ViewData["DateFrom"] as string;
    var dateTo = ViewData["DateTo"] as string;
}

<div class="page-header">
    <div>
        <div class="page-eyebrow">งานจัดซื้อ</div>
        <h1 class="page-title">ใบรับสินค้า</h1>
        <p class="page-subtitle">ติดตามเอกสารรับสินค้าจากหน้านี้ และไปดำเนินการต่อที่หน้ารายละเอียดเอกสารตาม pattern หลักของระบบ</p>
    </div>
</div>

<div class="workflow-info mb-3">
    การสร้างใบรับสินค้าให้เริ่มจากปุ่ม <strong>รับสินค้า</strong> ที่หน้าใบสั่งซื้อซึ่งได้รับอนุมัติแล้ว
</div>

@if (TempData["ReceivingNotice"] is string notice)
{
    @await Html.PartialAsync("_Notice", notice)
}

<div class="card content-card table-card">
    <div class="table-card-header">
        <div>
            <h2 class="section-title">รายการใบรับสินค้า</h2>
        </div>
        <div class="table-meta">@Model.TotalCount รายการ</div>
    </div>
    <div class="card-body">
        <form method="get" class="list-filter-bar">
            <div class="list-filter-field grow">
                <label class="form-label" for="search">ค้นหา</label>
                <input id="search" name="search" value="@search" class="form-control" placeholder="เลขที่ใบรับสินค้า, เลขที่ PO, ผู้จำหน่าย, หมายเหตุ หรือเลขผู้เสียภาษี" />
            </div>
            <div class="list-filter-field">
                <label class="form-label" for="status">สถานะ</label>
                <select id="status" name="status" class="form-select">
                    <option value="">ทั้งหมด</option>
                    <option value="Draft" selected="@(status == "Draft")">Draft</option>
                    <option value="Posted" selected="@(status == "Posted")">Posted</option>
                    <option value="Cancelled" selected="@(status == "Cancelled")">Cancelled</option>
                </select>
            </div>
            <div class="list-filter-field">
                <label class="form-label" for="dateFrom">จากวันที่</label>
                <input id="dateFrom" name="dateFrom" value="@dateFrom" type="date" class="form-control" />
            </div>
            <div class="list-filter-field">
                <label class="form-label" for="dateTo">ถึงวันที่</label>
                <input id="dateTo" name="dateTo" value="@dateTo" type="date" class="form-control" />
            </div>
            <div class="list-filter-actions">
                <a asp-action="Index" class="btn btn-outline-secondary">ล้างตัวกรอง</a>
                <button type="submit" class="btn btn-primary">ค้นหา</button>
            </div>
        </form>
        <div class="table-responsive">
            <table class="table entity-table align-middle">
                <thead>
                    <tr>
                        <th>เลขที่ใบรับสินค้า</th>
                        <th>วันที่</th>
                        <th>เลขที่ใบสั่งซื้อ</th>
                        <th>ผู้จำหน่าย</th>
                        <th>สาขา</th>
                        <th>สถานะ</th>
                        <th class="text-end">การทำงาน</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.Any())
                {
                    @foreach (var receiving in Model)
                    {
                        <tr>
                            <td><span class="code-chip">@receiving.ReceivingNo</span></td>
                            <td>@receiving.ReceiveDate.ToString("dd/MM/yyyy")</td>
                            <td>@(receiving.PurchaseOrderHeader?.PONo ?? "-")</td>
                            <td>
                                <div class="fw-semibold">@receiving.Supplier?.SupplierName</div>
                                <div class="table-meta">เลขผู้เสียภาษี: @(string.IsNullOrWhiteSpace(receiving.Supplier?.TaxId) ? "-" : receiving.Supplier!.TaxId)</div>
                            </td>
                            <td>@(receiving.Branch?.BranchName ?? "-")</td>
                            <td>@await Html.PartialAsync("_StatusPill", receiving.Status)</td>
                            <td class="text-end">
                                <div class="table-actions">
                                    <a asp-action="Details" asp-route-id="@receiving.ReceivingId" class="btn btn-sm btn-outline-secondary">รายละเอียด</a>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="7" class="table-empty">ยังไม่มีรายการใบรับสินค้า</td></tr>
                }
                </tbody>
            </table>
        </div>
        <partial name="_Pager" model="Model.Pagination" />
    </div>
</div>
