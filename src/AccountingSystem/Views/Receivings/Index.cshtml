@inject IUserPermissionService PermissionService
@model BizCore.Models.ViewModels.PaginatedList<BizCore.Models.Entities.ReceivingHeader>

@{
    ViewData["Title"] = "Receivings";
    var search = ViewData["Search"] as string;
    var status = ViewData["Status"] as string;
    var dateFrom = ViewData["DateFrom"] as string;
    var dateTo = ViewData["DateTo"] as string;
    var canEditReceiving = PermissionService.HasPermission(User, "Receiving.Edit");
    var canCancelReceiving = PermissionService.HasPermission(User, "Receiving.Cancel");
}

<div class="page-header">
    <div>
        <div class="page-eyebrow">Purchasing Module</div>
        <h1 class="page-title">Receivings</h1>
        <p class="page-subtitle">Post incoming goods against purchase orders and update stock plus serials.</p>
    </div>
</div>

<div class="workflow-info mb-3">
    Create receiving documents from an approved purchase order by using the Receive Goods action.
</div>

@if (TempData["ReceivingNotice"] is string notice)
{
    @await Html.PartialAsync("_Notice", notice)
}

<div class="card content-card table-card">
    <div class="table-card-header">
        <div>
            <h2 class="section-title">Receiving Register</h2>
            <p class="section-subtitle">Draft and posted receiving documents. Only posted documents update stock and serial records.</p>
        </div>
        <div class="table-meta">@Model.TotalCount records</div>
    </div>
    <div class="card-body">
        <form method="get" class="list-filter-bar">
            <div class="list-filter-field grow">
                <label class="form-label" for="search">Search</label>
                <input id="search" name="search" value="@search" class="form-control" placeholder="Receiving no., PO no., supplier, remark, or tax ID" />
            </div>
            <div class="list-filter-field">
                <label class="form-label" for="status">Status</label>
                <select id="status" name="status" class="form-select">
                    <option value="">All</option>
                    <option value="Draft" selected="@(status == "Draft")">Draft</option>
                    <option value="Posted" selected="@(status == "Posted")">Posted</option>
                    <option value="Cancelled" selected="@(status == "Cancelled")">Cancelled</option>
                </select>
            </div>
            <div class="list-filter-field">
                <label class="form-label" for="dateFrom">From</label>
                <input id="dateFrom" name="dateFrom" value="@dateFrom" type="date" class="form-control" />
            </div>
            <div class="list-filter-field">
                <label class="form-label" for="dateTo">To</label>
                <input id="dateTo" name="dateTo" value="@dateTo" type="date" class="form-control" />
            </div>
            <div class="list-filter-actions">
                <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
                <button type="submit" class="btn btn-primary">Search</button>
            </div>
        </form>
        <div class="table-responsive">
            <table class="table entity-table align-middle">
                <thead>
                    <tr>
                        <th>Receiving No.</th>
                        <th>Date</th>
                        <th>PO No.</th>
                        <th>Supplier</th>
                        <th>Branch</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.Any())
                {
                    @foreach (var receiving in Model)
                    {
                        var isDraft = receiving.Status == "Draft";
                        var isPosted = receiving.Status == "Posted";
                        var isCancelled = receiving.Status == "Cancelled";
                        <tr>
                            <td><span class="code-chip">@receiving.ReceivingNo</span></td>
                            <td>@receiving.ReceiveDate.ToString("dd MMM yyyy")</td>
                            <td>@receiving.PurchaseOrderHeader?.PONo</td>
                            <td class="fw-semibold">@receiving.Supplier?.SupplierName</td>
                            <td>@(receiving.Branch?.BranchName ?? "-")</td>
                            <td>@await Html.PartialAsync("_StatusPill", receiving.Status)</td>
                            <td class="text-end">
                                <div class="table-actions">
                                    <a asp-action="Details" asp-route-id="@receiving.ReceivingId" class="btn btn-sm btn-outline-secondary">View</a>
                                    @if (isDraft && canEditReceiving)
                                    {
                                        <a asp-action="Edit" asp-route-id="@receiving.ReceivingId" class="btn btn-sm btn-outline-primary">Edit Draft</a>
                                        <button type="button" class="btn btn-sm btn-outline-secondary" disabled title="Print is available after receiving is posted.">Print</button>
                                    }
                                    else if (isDraft)
                                    {
                                        <button type="button" class="btn btn-sm btn-outline-secondary" disabled title="You do not have permission to edit receiving documents.">Edit Draft</button>
                                        <button type="button" class="btn btn-sm btn-outline-secondary" disabled title="Print is available after receiving is posted.">Print</button>
                                    }
                                    else if (isPosted)
                                    {
                                        <button type="button" class="btn btn-sm btn-outline-secondary" onclick="window.open('@Url.Action("Print", new { id = receiving.ReceivingId })', '_blank', 'noopener');">Print</button>
                                    }
                                    else
                                    {
                                        <button type="button" class="btn btn-sm btn-outline-secondary" disabled title="Print is available after receiving is posted.">Print</button>
                                    }
                                    @if (canCancelReceiving && (isDraft || isPosted))
                                    {
                                        <form asp-action="Cancel" asp-route-id="@receiving.ReceivingId" method="post" class="d-inline confirm-popover-form">
                                            @Html.AntiForgeryToken()
                                            <div class="confirm-popover-shell">
                                                <button type="button"
                                                        class="btn btn-sm btn-outline-danger js-confirm-popover-toggle"
                                                        data-confirm-target="cancelReceivingListConfirm_@receiving.ReceivingId"
                                                        aria-expanded="false">
                                                    Cancel
                                                </button>
                                                <div class="confirm-popover" id="cancelReceivingListConfirm_@receiving.ReceivingId" hidden>
                                                    <div class="confirm-popover-title">Cancel this receiving?</div>
                                                    <div class="confirm-popover-text">Optional reason helps explain why this receiving document was cancelled.</div>
                                                    <div class="confirm-popover-field">
                                                        <label class="confirm-popover-label" for="cancelReceivingListReason_@receiving.ReceivingId">Cancel Reason</label>
                                                        <textarea id="cancelReceivingListReason_@receiving.ReceivingId" name="cancelReason" class="form-control" rows="3" placeholder="Optional reason"></textarea>
                                                    </div>
                                                    <div class="confirm-popover-actions">
                                                        <button type="submit" class="btn btn-sm btn-outline-danger">Confirm</button>
                                                        <button type="button" class="btn btn-sm btn-outline-secondary js-confirm-popover-cancel">Cancel</button>
                                                    </div>
                                                </div>
                                            </div>
                                        </form>
                                    }
                                    else if (isDraft || isPosted)
                                    {
                                        <button type="button" class="btn btn-sm btn-outline-secondary" disabled title="You do not have permission to cancel receiving documents.">Cancel</button>
                                    }
                                    else
                                    {
                                        <button type="button" class="btn btn-sm btn-outline-secondary" disabled title="Cancelled receiving documents are read-only.">Cancel</button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="7" class="table-empty">No receiving transactions yet. Post goods receipt from a PO.</td></tr>
                }
                </tbody>
            </table>
        </div>
        <partial name="_Pager" model="Model.Pagination" />
    </div>
</div>
