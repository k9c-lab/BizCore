@inject IUserPermissionService PermissionService
@model BizCore.Models.ViewModels.ReceivingFormViewModel

@{
    var isEdit = Model.ReceivingId.HasValue;
    var formAction = isEdit ? "Edit" : "Create";
    var pageTitle = isEdit ? "แก้ไขใบรับสินค้าฉบับร่าง" : "สร้างใบรับสินค้า";
    ViewData["Title"] = pageTitle;
    var selectedPo = Model.PurchaseOrderLookup.FirstOrDefault(x => x.PurchaseOrderId == Model.PurchaseOrderId);
    var canPostPermission = PermissionService.HasPermission(User, "Receiving.Post");
    var canPost = canPostPermission && Model.PurchaseOrderLookup.Any() && Model.PurchaseOrderId.HasValue;
    var canSaveDraft = Model.PurchaseOrderLookup.Any() && Model.PurchaseOrderId.HasValue;
    var postBlockedReason = canPost
        ? string.Empty
        : !canPostPermission
            ? "คุณไม่มีสิทธิ์โพสต์ใบรับสินค้า"
            : "ยังโพสต์ใบรับสินค้าไม่ได้ เพราะไม่มีใบสั่งซื้อที่ยังรับสินค้าได้";
    var hasSelectedPo = Model.PurchaseOrderId.HasValue;
    var startFromPoMessage = "เริ่มรับสินค้าจากใบสั่งซื้อที่อนุมัติแล้ว โดยใช้ปุ่ม รับสินค้า จากหน้าใบสั่งซื้อ";
    var backLabel = isEdit ? "กลับไปรายละเอียดใบรับสินค้า" : "กลับไปรายการใบรับสินค้า";
}

<div class="page-header">
    <div>
        <div class="page-eyebrow">งานจัดซื้อ</div>
        <h1 class="page-title">@pageTitle</h1>
        <p class="page-subtitle">@(isEdit ? "แก้ไขได้เฉพาะใบรับสินค้าสถานะ Draft และค่อยไปโพสต์หรือยกเลิกจากหน้ารายละเอียดเอกสาร" : "บันทึกใบรับสินค้าเป็นฉบับร่างก่อน หรือโพสต์ทันทีเมื่อข้อมูลครบถ้วน")</p>
    </div>
    <div class="page-actions">
        <button type="submit" form="receivingForm" class="btn btn-outline-primary px-4" name="command" value="SaveDraft" id="topSaveDraftButton" disabled="@(!canSaveDraft)">บันทึกฉบับร่าง</button>
        <button type="submit" form="receivingForm" class="btn btn-primary px-4" name="command" value="Post" id="topPostReceivingButton" disabled="@(!canPost)" data-can-post-permission="@canPostPermission.ToString().ToLowerInvariant()">โพสต์ใบรับสินค้า</button>
        @if (isEdit)
        {
            <a asp-action="Details" asp-route-id="@Model.ReceivingId" class="btn btn-outline-secondary">@backLabel</a>
        }
        else
        {
            <a asp-action="Index" class="btn btn-outline-secondary">@backLabel</a>
        }
    </div>
</div>

@if (!hasSelectedPo || !canPost)
{
    <div class="workflow-info mb-3">
        @if (!hasSelectedPo)
        {
            <div>@startFromPoMessage</div>
        }
        @if (!canPost)
        {
            <div>@postBlockedReason</div>
        }
    </div>
}

<div class="card content-card">
    <div class="card-body">
        <form asp-action="@formAction" asp-route-id="@Model.ReceivingId" method="post" id="receivingForm">
            <input type="hidden" asp-for="ReceivingId" />
            <input type="hidden" asp-for="Status" />
            <input type="hidden" asp-for="BranchId" />
            <div asp-validation-summary="All" class="form-alert"></div>
            <div class="form-shell">
                <div class="form-section quotation-header-section">
                    <div class="form-section-title">ข้อมูลหัวเอกสาร</div>
                    <div class="row g-2 quotation-header-grid">
                        <div class="col-lg-3 col-md-6">
                            <label asp-for="ReceivingNo" class="detail-label"></label>
                            <input asp-for="ReceivingNo" class="form-control readonly-detail" readonly />
                        </div>
                        <div class="col-lg-3 col-md-6">
                            <label asp-for="ReceiveDate" class="detail-label"></label>
                            <input asp-for="ReceiveDate" class="form-control" />
                            <span asp-validation-for="ReceiveDate" class="text-danger"></span>
                        </div>
                        <div class="col-lg-3 col-md-6">
                            <label asp-for="PurchaseOrderId" class="detail-label"></label>
                            <select asp-for="PurchaseOrderId" asp-items="Model.PurchaseOrderOptions" class="form-select" id="receivingPurchaseOrder">
                                <option value="">เลือกใบสั่งซื้อ</option>
                            </select>
                            <span asp-validation-for="PurchaseOrderId" class="text-danger"></span>
                        </div>
                        <div class="col-lg-3 col-md-6">
                            <label asp-for="DeliveryNoteNo" class="detail-label"></label>
                            <input asp-for="DeliveryNoteNo" class="form-control" />
                            <span asp-validation-for="DeliveryNoteNo" class="text-danger"></span>
                        </div>
                        <div class="col-md-3">
                            <div class="detail-label">สถานะ</div>
                            <div class="readonly-detail-status">@await Html.PartialAsync("_StatusPill", isEdit ? Model.Status : "Draft")</div>
                        </div>
                        <div class="col-md-3">
                            <div class="detail-label">เลขที่ใบสั่งซื้อ</div>
                            <div class="form-control readonly-detail" id="receivingPoNo">@(selectedPo?.PONo ?? "-")</div>
                        </div>
                        <div class="col-md-3">
                            <label asp-for="SupplierId" class="detail-label"></label>
                            <input asp-for="SupplierId" class="form-control readonly-detail" id="receivingSupplierId" readonly />
                        </div>
                        <div class="col-md-3">
                            <div class="detail-label">ผู้จำหน่าย</div>
                            <div class="form-control readonly-detail" id="receivingSupplierName">@(selectedPo?.SupplierName ?? "-")</div>
                        </div>
                        <div class="col-md-3">
                            <div class="detail-label">สาขา</div>
                            <div class="form-control readonly-detail" id="receivingBranchName">@(selectedPo?.BranchName ?? Model.BranchName ?? "-")</div>
                        </div>
                        <div class="col-12">
                            <label asp-for="Remark" class="detail-label"></label>
                            <textarea asp-for="Remark" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="Remark" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="quotation-party-grid">
                    <div class="quotation-party-column">
                        <div class="quotation-info-card">
                            <div class="quotation-info-card-title">ข้อมูลใบสั่งซื้อ</div>
                            <div class="quotation-info-grid">
                                <div class="quotation-info-field">
                                    <span class="quotation-info-label">เลขที่ใบสั่งซื้อ</span>
                                    <span class="quotation-info-value" id="poInfoNo">@(selectedPo?.PONo ?? "-")</span>
                                </div>
                                <div class="quotation-info-field">
                                    <span class="quotation-info-label">ผู้จำหน่าย</span>
                                    <span class="quotation-info-value" id="poInfoSupplier">@(selectedPo?.SupplierName ?? "-")</span>
                                </div>
                            </div>
                            <div class="quotation-info-grid">
                                <div class="quotation-info-field">
                                    <span class="quotation-info-label">ประเภทภาษี</span>
                                    <span class="quotation-info-value" id="receivingVatType">@(selectedPo is null ? "-" : BizCore.Utilities.VatModeHelper.GetDisplayLabel(selectedPo.VatType))</span>
                                </div>
                                <div class="quotation-info-field">
                                    <span class="quotation-info-label">รายการคงเหลือ</span>
                                    <span class="quotation-info-value" id="receivingOpenLines">@(selectedPo?.Lines.Count.ToString() ?? "0")</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="quotation-party-column">
                        <div class="quotation-info-card">
                            <div class="quotation-info-card-title">สรุปมูลค่าใบสั่งซื้อ</div>
                            <div class="quotation-summary-stack">
                                <div class="quotation-summary-row">
                                    <span class="quotation-summary-name">ยอดก่อนภาษี</span>
                                    <span class="quotation-summary-amount" id="receivingSubtotal">@((selectedPo?.Subtotal ?? 0m).ToString("N2"))</span>
                                </div>
                                <div class="quotation-summary-row">
                                    <span class="quotation-summary-name">VAT</span>
                                    <span class="quotation-summary-amount" id="receivingVatAmount">@((selectedPo?.VatAmount ?? 0m).ToString("N2"))</span>
                                </div>
                                <div class="quotation-summary-row total">
                                    <span class="quotation-summary-name">ยอดรวมทั้งสิ้น</span>
                                    <span class="quotation-summary-amount" id="receivingTotalAmount">@((selectedPo?.TotalAmount ?? 0m).ToString("N2"))</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="form-section">
                    <div class="d-flex justify-content-between align-items-center gap-2 mb-3 flex-wrap">
                        <div>
                            <div class="form-section-title mb-1">รายการรับสินค้า</div>
                            <div class="table-meta">ระบุจำนวนรับเข้าตาม allocation ของสาขา และถ้าเป็นสินค้าคุม serial ต้องใส่ serial ให้ครบตามจำนวนรับ</div>
                        </div>
                    </div>
                    <div class="receiving-lines-stack" id="receivingLineBody">
                            @for (var i = 0; i < Model.Details.Count; i++)
                            {
                                <div class="receiving-line-card receiving-line-row">
                                    <input type="hidden" name="Details[@i].PurchaseOrderDetailId" value="@Model.Details[i].PurchaseOrderDetailId" />
                                    <input type="hidden" name="Details[@i].PurchaseOrderAllocationId" value="@Model.Details[i].PurchaseOrderAllocationId" />
                                    <input type="hidden" name="Details[@i].AllocationBranchId" value="@Model.Details[i].AllocationBranchId" />
                                    <input type="hidden" name="Details[@i].AllocationBranchName" value="@Model.Details[i].AllocationBranchName" />
                                    <input type="hidden" name="Details[@i].ItemId" value="@Model.Details[i].ItemId" />
                                    <input type="hidden" name="Details[@i].LineNumber" value="@Model.Details[i].LineNumber" />
                                    <input type="hidden" name="Details[@i].ItemCode" value="@Model.Details[i].ItemCode" />
                                    <input type="hidden" name="Details[@i].ItemName" value="@Model.Details[i].ItemName" />
                                    <input type="hidden" name="Details[@i].IsSerialControlled" value="@Model.Details[i].IsSerialControlled.ToString().ToLowerInvariant()" />
                                    <input type="hidden" name="Details[@i].TrackStock" value="@Model.Details[i].TrackStock.ToString().ToLowerInvariant()" />
                                    <input type="hidden" name="Details[@i].OrderedQty" value="@Model.Details[i].OrderedQty" />
                                    <input type="hidden" name="Details[@i].ReceivedQty" value="@Model.Details[i].ReceivedQty" />
                                    <input type="hidden" name="Details[@i].RemainingQty" value="@Model.Details[i].RemainingQty" />
                                    <input type="hidden" name="Details[@i].UnitPrice" value="@Model.Details[i].UnitPrice" />
                                    <input type="hidden" name="Details[@i].LineTotal" value="@Model.Details[i].LineTotal" />

                                    <div class="receiving-line-header">
                                        <div>
                                            <div class="receiving-line-title">@Model.Details[i].ItemCode - @Model.Details[i].ItemName</div>
                                            <div class="table-meta">PO Line @Model.Details[i].LineNumber | Deliver to @(string.IsNullOrWhiteSpace(Model.Details[i].AllocationBranchName) ? Model.BranchName : Model.Details[i].AllocationBranchName)</div>
                                        </div>
                                        <div class="receiving-line-status-wrap">
                                            <span class="badge-soft">@(Model.Details[i].IsSerialControlled ? "คุม Serial" : "รับสินค้าแบบปกติ")</span>
                                            <span class="receiving-line-status is-muted js-line-status">ยังไม่รับ</span>
                                        </div>
                                    </div>
                                    <div class="receiving-line-hint is-muted js-line-hint">กรอกจำนวนรับเข้าเพื่อรวมรายการนี้ในเอกสารรับสินค้า</div>

                                    <div class="receiving-line-metrics">
                                        <div class="receiving-line-metric">
                                            <span>สั่งซื้อ</span>
                                            <strong>@Model.Details[i].OrderedQty.ToString("N2")</strong>
                                        </div>
                                        <div class="receiving-line-metric">
                                            <span>รับแล้ว</span>
                                            <strong>@Model.Details[i].ReceivedQty.ToString("N2")</strong>
                                        </div>
                                        <div class="receiving-line-metric">
                                            <span>คงเหลือ</span>
                                            <strong>@Model.Details[i].RemainingQty.ToString("N2")</strong>
                                        </div>
                                        <div class="receiving-line-metric">
                                            <span>ราคาต่อหน่วย</span>
                                            <strong>@Model.Details[i].UnitPrice.ToString("N2")</strong>
                                        </div>
                                        <div class="receiving-line-metric">
                                            <span>รวมเงิน</span>
                                            <strong>@Model.Details[i].LineTotal.ToString("N2")</strong>
                                        </div>
                                    </div>

                                    <div class="receiving-line-entry-grid">
                                        <div class="receiving-entry-block">
                                            <label class="detail-label">จำนวนรับเข้า</label>
                                        <input type="number" step="1" min="0" data-qty-min="0" max="@Model.Details[i].RemainingQty.ToString("0.##")" name="Details[@i].QtyReceivedInput" value="@Model.Details[i].QtyReceivedInput.ToString("0.##")" class="form-control js-receive-qty js-integer-qty" />
                                        <span class="text-danger field-validation-valid" data-valmsg-for="Details[@i].QtyReceivedInput" data-valmsg-replace="true"></span>
                                        </div>

                                        <div class="receiving-entry-block">
                                            <div class="detail-label">ประกันผู้จำหน่าย</div>
                                        @if (Model.Details[i].IsSerialControlled)
                                        {
                                            <div class="row g-2">
                                                <div class="col-6">
                                                    <input type="date" name="Details[@i].SupplierWarrantyStartDate" value="@Model.Details[i].SupplierWarrantyStartDate?.ToString("yyyy-MM-dd")" class="form-control" title="วันเริ่มต้นประกันผู้จำหน่าย" />
                                                    <span class="text-danger field-validation-valid" data-valmsg-for="Details[@i].SupplierWarrantyStartDate" data-valmsg-replace="true"></span>
                                                </div>
                                                <div class="col-6">
                                                    <input type="date" name="Details[@i].SupplierWarrantyEndDate" value="@Model.Details[i].SupplierWarrantyEndDate?.ToString("yyyy-MM-dd")" class="form-control" title="วันสิ้นสุดประกันผู้จำหน่าย" />
                                                    <span class="text-danger field-validation-valid" data-valmsg-for="Details[@i].SupplierWarrantyEndDate" data-valmsg-replace="true"></span>
                                                </div>
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="table-meta">ไม่จำเป็น</span>
                                        }
                                        </div>

                                        <div class="receiving-entry-block receiving-entry-wide">
                                            <label class="detail-label">หมายเหตุ</label>
                                        <input type="text" name="Details[@i].Remark" value="@Model.Details[i].Remark" class="form-control mb-2" placeholder="หมายเหตุ" />
                                        @if (Model.Details[i].IsSerialControlled)
                                        {
                                            <div class="detail-label mt-2">หมายเลข Serial</div>
                                            <input type="hidden" name="Details[@i].SerialEntryText" value="" />
                                            <div class="serial-stack js-serial-stack" data-line-index="@i">
                                            @for (var s = 0; s < Math.Max(Model.Details[i].Serials.Count, 1); s++)
                                            {
                                                <input type="text" name="Details[@i].Serials[@s].SerialNo" value="@(s < Model.Details[i].Serials.Count ? Model.Details[i].Serials[s].SerialNo : string.Empty)" class="form-control js-serial-input" placeholder="Serial @(s + 1)" />
                                            }
                                            </div>
                                            <div class="table-meta text-danger js-serial-count">จำนวน serial ต้องเท่ากับจำนวนรับเข้า</div>
                                            <span class="text-danger field-validation-valid" data-valmsg-for="Details[@i].SerialEntryText" data-valmsg-replace="true"></span>
                                            <span class="text-danger field-validation-valid" data-valmsg-for="Details[@i].Serials" data-valmsg-replace="true"></span>
                                        }
                                        else
                                        {
                                            <span class="table-meta">ไม่ต้องระบุ serial</span>
                                        }
                                        </div>
                                    </div>
                                </div>
                            }
                    </div>
                    <span asp-validation-for="Details" class="text-danger"></span>
                </div>
            </div>

            <div class="form-actions mt-3">
                <span class="table-meta" id="receivingPostReason">บันทึกฉบับร่างจะยังแก้ไขเอกสารนี้ได้ ส่วนการโพสต์จะอัปเดตสต๊อกและสร้าง serial record ทันที</span>
                <div class="page-actions">
                    @if (isEdit)
                    {
                        <a asp-action="Details" asp-route-id="@Model.ReceivingId" class="btn btn-outline-secondary">@backLabel</a>
                    }
                    else
                    {
                        <a asp-action="Index" class="btn btn-outline-secondary">@backLabel</a>
                    }
                    <button type="submit" class="btn btn-outline-primary px-4" name="command" value="SaveDraft" id="saveDraftButton" disabled="@(!canSaveDraft)">บันทึกฉบับร่าง</button>
                    <button type="submit" class="btn btn-primary px-4" name="command" value="Post" id="postReceivingButton" disabled="@(!canPost)" data-can-post-permission="@canPostPermission.ToString().ToLowerInvariant()">โพสต์ใบรับสินค้า</button>
                </div>
            </div>
        </form>
    </div>
</div>

<script type="application/json" id="receivingPOLookup">@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.PurchaseOrderLookup))</script>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (() => {
            const lookup = JSON.parse(document.getElementById("receivingPOLookup").textContent);
            const poSelect = document.getElementById("receivingPurchaseOrder");
            const supplierInput = document.getElementById("receivingSupplierId");
            const lineBody = document.getElementById("receivingLineBody");
            const saveDraftButton = document.getElementById("saveDraftButton");
            const postButton = document.getElementById("postReceivingButton");
            const topPostButton = document.getElementById("topPostReceivingButton");
            const canPostPermission = postButton?.dataset.canPostPermission === "true";
            const postReason = document.getElementById("receivingPostReason");

            const money = value => Number(value || 0).toFixed(2);
            const escapeHtml = value => String(value ?? "")
                .replace(/&/g, "&amp;")
                .replace(/</g, "&lt;")
                .replace(/>/g, "&gt;")
                .replace(/"/g, "&quot;")
                .replace(/'/g, "&#39;");

            const getSerialInputs = row => [...row.querySelectorAll(".js-serial-input")];

            const serialCount = row => getSerialInputs(row)
                .map(input => input.value.trim())
                .filter(Boolean)
                .length;

            const targetSerialCount = qtyValue => {
                const qty = Number.parseFloat(qtyValue || "0");
                return Number.isInteger(qty) && qty > 0 ? qty : 1;
            };

            const buildSerialInput = (lineIndex, serialIndex, value = "") =>
                `<input type="text" name="Details[${lineIndex}].Serials[${serialIndex}].SerialNo" value="${escapeHtml(value)}" class="form-control js-serial-input" placeholder="Serial ${serialIndex + 1}" />`;

            const getLineLabel = row => row.querySelector(".receiving-line-title")?.textContent?.trim() || "รายการรับสินค้า";

            const setLineStatus = (row, status, message, tone) => {
                const badge = row.querySelector(".js-line-status");
                const hint = row.querySelector(".js-line-hint");
                if (badge) {
                    badge.textContent = status;
                    badge.classList.remove("is-ready", "is-warning", "is-muted");
                    badge.classList.add(tone === "ready" ? "is-ready" : tone === "warning" ? "is-warning" : "is-muted");
                }
                if (hint) {
                    hint.textContent = message;
                    hint.classList.remove("is-ready", "is-warning", "is-muted");
                    hint.classList.add(tone === "ready" ? "is-ready" : tone === "warning" ? "is-warning" : "is-muted");
                }
            };

            const syncSerialInputs = row => {
                const stack = row.querySelector(".js-serial-stack");
                const qtyInput = row.querySelector(".js-receive-qty");
                if (!stack || !qtyInput) {
                    return;
                }

                const lineIndex = Number.parseInt(stack.dataset.lineIndex || "0", 10);
                const existingValues = getSerialInputs(row).map(input => input.value);
                const nextCount = targetSerialCount(qtyInput.value);
                stack.innerHTML = Array.from({ length: nextCount }, (_, index) =>
                    buildSerialInput(lineIndex, index, existingValues[index] || "")).join("");
            };

            const updatePostState = () => {
                const selected = lookup.find(x => String(x.PurchaseOrderId) === String(poSelect.value));
                let reason = "";

                if (!canPostPermission) {
                    reason = "คุณไม่มีสิทธิ์โพสต์ใบรับสินค้า";
                } else if (!selected) {
                    reason = "กรุณาเลือกใบสั่งซื้อก่อนโพสต์ใบรับสินค้า";
                } else {
                    let totalQty = 0;
                    lineBody.querySelectorAll(".receiving-line-row").forEach(row => {
                        const lineLabel = getLineLabel(row);
                        const qtyInput = row.querySelector(".js-receive-qty");
                        const qty = Number.parseFloat(qtyInput?.value || "0");
                        const remaining = Number.parseFloat(qtyInput?.max || "0");
                        if (Number.isFinite(qty)) {
                            totalQty += qty;
                        }

                        if (qty < 0 && !reason) {
                            reason = `ยังโพสต์ไม่ได้: ${lineLabel} มีจำนวนรับเข้าติดลบ`;
                        }

                        if (qty > remaining && !reason) {
                            reason = `ยังโพสต์ไม่ได้: ${lineLabel} มีจำนวนรับเข้ามากกว่าจำนวนคงเหลือ`;
                        }

                        const isSerial = row.querySelector('input[name$=".IsSerialControlled"]')?.value === "true";
                        const countLabel = row.querySelector(".js-serial-count");
                        let lineStatus = "พร้อม";
                        let lineMessage = "รายการนี้พร้อมสำหรับการโพสต์";
                        let lineTone = "ready";

                        if (qty <= 0) {
                            lineStatus = "ยังไม่รับ";
                            lineMessage = "กรอกจำนวนรับเข้าเพื่อรวมรายการนี้ในเอกสารรับสินค้า";
                            lineTone = "muted";
                        } else if (qty < 0) {
                            lineStatus = "จำนวนไม่ถูกต้อง";
                            lineMessage = "จำนวนรับเข้าต้องไม่ติดลบ";
                            lineTone = "warning";
                        } else if (qty > remaining) {
                            lineStatus = "จำนวนไม่ถูกต้อง";
                            lineMessage = `จำนวนรับเข้าต้องไม่เกินจำนวนคงเหลือ (${money(remaining)})`;
                            lineTone = "warning";
                        }

                        if (isSerial && countLabel) {
                            const count = serialCount(row);
                            const isReceivingLine = qty > 0;
                            const matchesQty = isReceivingLine && count === qty && Number.isInteger(qty);
                            countLabel.textContent = isReceivingLine
                                ? `จำนวน serial: ${count} ต้องเท่ากับจำนวนรับเข้า`
                                : "ต้องระบุ serial เมื่อมีจำนวนรับเข้ามากกว่า 0";
                            countLabel.classList.toggle("text-danger", isReceivingLine && !matchesQty);
                            countLabel.classList.toggle("text-success", matchesQty);
                            countLabel.classList.toggle("text-muted", !isReceivingLine);

                            if (!isReceivingLine) {
                                setLineStatus(row, lineStatus, lineMessage, lineTone);
                                return;
                            }

                            if (qty > 0 && !Number.isInteger(qty) && !reason) {
                                reason = `ยังโพสต์ไม่ได้: ${lineLabel} เป็นสินค้าคุม serial จึงต้องรับเข้าเป็นจำนวนเต็ม`;
                            }

                            if (qty > 0 && !Number.isInteger(qty)) {
                                lineStatus = "จำนวนไม่ถูกต้อง";
                                lineMessage = "สินค้าคุม serial ต้องรับเข้าเป็นจำนวนเต็ม";
                                lineTone = "warning";
                            }

                            if (qty > 0 && count !== qty && !reason) {
                                reason = `ยังโพสต์ไม่ได้: ${lineLabel} ต้องมี serial ${qty} รายการ แต่ตอนนี้มี ${count}`;
                            }

                            if (qty > 0 && count !== qty && Number.isInteger(qty)) {
                                lineStatus = "Serial ไม่ครบ";
                                lineMessage = `กรอก serial ให้ครบ ${qty} รายการ ตอนนี้มี ${count}`;
                                lineTone = "warning";
                            }

                        }

                        setLineStatus(row, lineStatus, lineMessage, lineTone);
                    });

                    if (totalQty <= 0) {
                        reason = "ยังโพสต์ไม่ได้: กรุณากรอกจำนวนรับเข้าอย่างน้อย 1 รายการ";
                    }
                }

                if (saveDraftButton) {
                    saveDraftButton.disabled = !selected;
                }
                postButton.disabled = Boolean(reason);
                if (topPostButton) {
                    topPostButton.disabled = Boolean(reason);
                }
                postReason.textContent = reason || "พร้อมโพสต์ การโพสต์จะอัปเดตสต๊อกและสร้าง serial record ทันทีในรายการที่ต้องใช้";
            };

            const renderLines = poId => {
                const selected = lookup.find(x => String(x.PurchaseOrderId) === String(poId));
                supplierInput.value = selected ? selected.SupplierId : "";
                document.getElementById("BranchId").value = selected?.BranchId || "";
                document.getElementById("receivingPoNo").textContent = selected?.PONo || "-";
                document.getElementById("receivingSupplierName").textContent = selected?.SupplierName || "-";
                document.getElementById("receivingBranchName").textContent = selected?.BranchName || "-";
                document.getElementById("poInfoNo").textContent = selected?.PONo || "-";
                document.getElementById("poInfoSupplier").textContent = selected?.SupplierName || "-";
                document.getElementById("receivingVatType").textContent = !selected
                    ? "-"
                    : selected.VatType === "VATExclusive"
                        ? "ราคายังไม่รวม VAT"
                        : selected.VatType === "VATInclusive"
                            ? "ราคารวม VAT"
                            : "ไม่มี VAT";
                document.getElementById("receivingOpenLines").textContent = selected ? String(selected.Lines.length) : "0";
                document.getElementById("receivingSubtotal").textContent = selected ? money(selected.Subtotal) : "0.00";
                document.getElementById("receivingVatAmount").textContent = selected ? money(selected.VatAmount) : "0.00";
                document.getElementById("receivingTotalAmount").textContent = selected ? money(selected.TotalAmount) : "0.00";
                lineBody.innerHTML = "";

                if (!selected) {
                    updatePostState();
                    return;
                }

                selected.Lines.forEach((line, index) => {
                    const card = document.createElement("div");
                    card.className = "receiving-line-card receiving-line-row";
                    card.innerHTML = `
                            <input type="hidden" name="Details[${index}].PurchaseOrderDetailId" value="${line.PurchaseOrderDetailId}" />
                            <input type="hidden" name="Details[${index}].PurchaseOrderAllocationId" value="${line.PurchaseOrderAllocationId || ""}" />
                            <input type="hidden" name="Details[${index}].AllocationBranchId" value="${line.AllocationBranchId || ""}" />
                            <input type="hidden" name="Details[${index}].AllocationBranchName" value="${escapeHtml(line.AllocationBranchName || "")}" />
                            <input type="hidden" name="Details[${index}].ItemId" value="${line.ItemId}" />
                            <input type="hidden" name="Details[${index}].LineNumber" value="${line.LineNumber}" />
                            <input type="hidden" name="Details[${index}].ItemCode" value="${escapeHtml(line.ItemCode)}" />
                            <input type="hidden" name="Details[${index}].ItemName" value="${escapeHtml(line.ItemName)}" />
                            <input type="hidden" name="Details[${index}].IsSerialControlled" value="${String(line.IsSerialControlled).toLowerCase()}" />
                            <input type="hidden" name="Details[${index}].TrackStock" value="${String(line.TrackStock).toLowerCase()}" />
                            <input type="hidden" name="Details[${index}].OrderedQty" value="${line.OrderedQty}" />
                            <input type="hidden" name="Details[${index}].ReceivedQty" value="${line.ReceivedQty}" />
                            <input type="hidden" name="Details[${index}].RemainingQty" value="${line.RemainingQty}" />
                            <input type="hidden" name="Details[${index}].UnitPrice" value="${line.UnitPrice}" />
                            <input type="hidden" name="Details[${index}].LineTotal" value="${line.LineTotal}" />
                            <div class="receiving-line-header">
                                <div>
                                    <div class="receiving-line-title">${escapeHtml(line.ItemCode)} - ${escapeHtml(line.ItemName)}</div>
                                    <div class="table-meta">PO Line ${line.LineNumber} | ส่งเข้าที่ ${escapeHtml(line.AllocationBranchName || selected.BranchName || "-")}</div>
                                </div>
                                <div class="receiving-line-status-wrap">
                                    <span class="badge-soft">${line.IsSerialControlled ? "คุม Serial" : "รับสินค้าแบบปกติ"}</span>
                                    <span class="receiving-line-status is-muted js-line-status">ยังไม่รับ</span>
                                </div>
                            </div>
                            <div class="receiving-line-hint is-muted js-line-hint">กรอกจำนวนรับเข้าเพื่อรวมรายการนี้ในเอกสารรับสินค้า</div>
                            <div class="receiving-line-metrics">
                                <div class="receiving-line-metric"><span>สั่งซื้อ</span><strong>${money(line.OrderedQty)}</strong></div>
                                <div class="receiving-line-metric"><span>รับแล้ว</span><strong>${money(line.ReceivedQty)}</strong></div>
                                <div class="receiving-line-metric"><span>คงเหลือ</span><strong>${money(line.RemainingQty)}</strong></div>
                                <div class="receiving-line-metric"><span>ราคาต่อหน่วย</span><strong>${money(line.UnitPrice)}</strong></div>
                                <div class="receiving-line-metric"><span>รวมเงิน</span><strong>${money(line.LineTotal)}</strong></div>
                            </div>
                            <div class="receiving-line-entry-grid">
                                <div class="receiving-entry-block">
                                    <label class="detail-label">จำนวนรับเข้า</label>
                                    <input type="number" step="1" min="0" data-qty-min="0" max="${line.RemainingQty}" name="Details[${index}].QtyReceivedInput" value="0" class="form-control js-receive-qty js-integer-qty" />
                                    <span class="text-danger field-validation-valid" data-valmsg-for="Details[${index}].QtyReceivedInput" data-valmsg-replace="true"></span>
                                </div>
                                <div class="receiving-entry-block">
                                    <div class="detail-label">ประกันผู้จำหน่าย</div>
                                    ${line.IsSerialControlled
                                        ? `<div class="row g-2">
                                                <div class="col-6">
                                                    <input type="date" name="Details[${index}].SupplierWarrantyStartDate" class="form-control" title="วันเริ่มต้นประกันผู้จำหน่าย" />
                                                    <span class="text-danger field-validation-valid" data-valmsg-for="Details[${index}].SupplierWarrantyStartDate" data-valmsg-replace="true"></span>
                                                </div>
                                                <div class="col-6">
                                                    <input type="date" name="Details[${index}].SupplierWarrantyEndDate" class="form-control" title="วันสิ้นสุดประกันผู้จำหน่าย" />
                                                    <span class="text-danger field-validation-valid" data-valmsg-for="Details[${index}].SupplierWarrantyEndDate" data-valmsg-replace="true"></span>
                                                </div>
                                           </div>`
                                        : '<span class="table-meta">ไม่จำเป็น</span>'}
                                </div>
                                <div class="receiving-entry-block receiving-entry-wide">
                                    <label class="detail-label">หมายเหตุ</label>
                                    <input type="text" name="Details[${index}].Remark" class="form-control mb-2" placeholder="หมายเหตุ" />
                                    ${line.IsSerialControlled
                                        ? `<div class="detail-label mt-2">หมายเลข Serial</div>
                                           <input type="hidden" name="Details[${index}].SerialEntryText" value="" />
                                           <div class="serial-stack js-serial-stack" data-line-index="${index}">
                                               ${buildSerialInput(index, 0)}
                                           </div>
                                           <div class="table-meta text-danger js-serial-count">จำนวน serial ต้องเท่ากับจำนวนรับเข้า</div>
                                           <span class="text-danger field-validation-valid" data-valmsg-for="Details[${index}].SerialEntryText" data-valmsg-replace="true"></span>
                                           <span class="text-danger field-validation-valid" data-valmsg-for="Details[${index}].Serials" data-valmsg-replace="true"></span>`
                                        : '<span class="table-meta">ไม่ต้องระบุ serial</span>'}
                                </div>
                            </div>`;
                    lineBody.appendChild(card);
                });

                updatePostState();
            };

            lineBody.addEventListener("input", event => {
                const row = event.target.closest(".receiving-line-row");
                if (event.target.classList.contains("js-receive-qty") && row) {
                    syncSerialInputs(row);
                }

                updatePostState();
            });

            lineBody.addEventListener("paste", event => {
                const input = event.target.closest(".js-serial-input");
                if (!input) {
                    return;
                }

                const pastedText = event.clipboardData?.getData("text") || "";
                const serials = pastedText
                    .split(/\r?\n/)
                    .map(x => x.trim())
                    .filter(Boolean);
                if (serials.length <= 1) {
                    return;
                }

                event.preventDefault();
                const row = input.closest(".receiving-line-row");
                const stack = row.querySelector(".js-serial-stack");
                const lineIndex = Number.parseInt(stack.dataset.lineIndex || "0", 10);
                stack.innerHTML = serials.map((serial, index) => buildSerialInput(lineIndex, index, serial)).join("");
                updatePostState();
            });

            poSelect.addEventListener("change", e => renderLines(e.target.value));
            lineBody.querySelectorAll(".receiving-line-row").forEach(syncSerialInputs);
            updatePostState();
        })();
    </script>
}

