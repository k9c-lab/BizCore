@model BizCore.Models.Entities.ReceivingHeader

@{
    ViewData["Title"] = "Receiving Details";
    var isDraft = Model.Status == "Draft";
    var isPosted = Model.Status == "Posted";
    var isCancelled = Model.Status == "Cancelled";
    var hasPermissionClaims = User.HasClaim(x => x.Type == "Permission");
    var oldReceivingOperatorFallback = !hasPermissionClaims && (User.IsInRole("BranchAdmin") || User.IsInRole("Warehouse"));
    var canEditPermission = User.IsInRole("Admin") || User.HasClaim("Permission", "Receiving.Edit") || oldReceivingOperatorFallback;
    var canPostPermission = User.IsInRole("Admin") || User.HasClaim("Permission", "Receiving.Post") || oldReceivingOperatorFallback;
    var canCancelPermission = User.IsInRole("Admin") || User.HasClaim("Permission", "Receiving.Cancel") || oldReceivingOperatorFallback;
    var canEdit = canEditPermission && isDraft;
    var editBlockedReason = canEdit
        ? string.Empty
        : !canEditPermission
            ? "You do not have permission to edit receiving documents."
            : $"Edit Receiving is available only for Draft documents. Current status is {Model.Status}.";
    var canPost = canPostPermission && isDraft;
    var postBlockedReason = canPost
        ? string.Empty
        : !canPostPermission
            ? "You do not have permission to post receiving documents."
            : $"Post Receiving is available only for Draft documents. Current status is {Model.Status}.";
    var canCancel = canCancelPermission && (isDraft || isPosted);
    var cancelBlockedReason = !canCancelPermission
        ? "You do not have permission to cancel receiving documents."
        : isCancelled
        ? "Cancelled receiving documents are read-only."
        : $"Cancel Receiving is available only for Draft or Posted receiving documents. Current status is {Model.Status}.";
}

<div class="page-header">
    <div>
        <div class="page-eyebrow">Purchasing Module</div>
        <h1 class="page-title">Receiving Details</h1>
        <p class="page-subtitle">@(isDraft ? "Draft receiving document. Stock and PO received quantities have not been updated yet." : isCancelled ? "Cancelled receiving document kept for history." : "Posted goods receipt that already updated stock and created serials where required.")</p>
    </div>
    <div class="page-actions">
        @if (isDraft)
        {
            @if (canEdit)
            {
                <a asp-action="Edit" asp-route-id="@Model.ReceivingId" class="btn btn-primary">Edit Draft</a>
            }
            else
            {
                <button type="button" class="btn btn-outline-secondary" disabled title="@editBlockedReason">Edit Draft</button>
            }
            @if (canPost)
            {
                <form asp-action="Post" asp-route-id="@Model.ReceivingId" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-success" onclick="return confirm('Post this receiving document? Stock and serial records will be updated.');">Post Receiving</button>
                </form>
            }
            else
            {
                <button type="button" class="btn btn-outline-secondary" disabled title="@postBlockedReason">Post Receiving</button>
            }
            <button type="button" class="btn btn-outline-secondary" disabled title="Print is available after receiving is posted.">Print</button>
        }
        else if (isPosted)
        {
            <button type="button" class="btn btn-outline-secondary" onclick="window.open('@Url.Action("Print", new { id = Model.ReceivingId })', '_blank', 'noopener');">Print</button>
        }
        @if (canCancel)
        {
            <form asp-action="Cancel" asp-route-id="@Model.ReceivingId" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <input type="hidden" name="cancelReason" />
                <button type="submit" class="btn btn-outline-danger" onclick="const reason = prompt('Reason for cancelling this receiving document (optional):'); if (reason === null) return false; this.form.cancelReason.value = reason; return confirm('Cancel this receiving document?');">Cancel Receiving</button>
            </form>
        }
        else
        {
            <button type="button" class="btn btn-outline-secondary" disabled title="@cancelBlockedReason">Cancel Receiving</button>
        }
        <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
    </div>
</div>

@if (TempData["ReceivingNotice"] is string notice)
{
    @await Html.PartialAsync("_Notice", notice)
}

<div class="card content-card">
    <div class="card-body">
        <div class="form-shell">
            <div class="form-section quotation-header-section">
                <div class="form-section-title">Receiving Header</div>
                <div class="row g-2 quotation-header-grid">
                    <div class="col-lg-3 col-md-6">
                        <div class="detail-label">Receiving No.</div>
                        <div class="form-control readonly-detail">@Model.ReceivingNo</div>
                    </div>
                    <div class="col-lg-3 col-md-6">
                        <div class="detail-label">Receive Date</div>
                        <div class="form-control readonly-detail">@Model.ReceiveDate.ToString("dd MMM yyyy")</div>
                    </div>
                    <div class="col-lg-3 col-md-6">
                        <div class="detail-label">PO No.</div>
                        <div class="form-control readonly-detail">@Model.PurchaseOrderHeader?.PONo</div>
                    </div>
                    <div class="col-lg-3 col-md-6">
                        <div class="detail-label">Delivery Note</div>
                        <div class="form-control readonly-detail">@(string.IsNullOrWhiteSpace(Model.DeliveryNoteNo) ? "-" : Model.DeliveryNoteNo)</div>
                    </div>
                    <div class="col-md-3">
                        <div class="detail-label">VAT Type</div>
                        <div class="form-control readonly-detail">@Model.PurchaseOrderHeader?.VatType</div>
                    </div>
                    <div class="col-md-3">
                        <div class="detail-label">Subtotal</div>
                        <div class="form-control readonly-detail">@((Model.PurchaseOrderHeader?.Subtotal ?? 0m).ToString("N2"))</div>
                    </div>
                    <div class="col-md-3">
                        <div class="detail-label">VAT</div>
                        <div class="form-control readonly-detail">@((Model.PurchaseOrderHeader?.VatAmount ?? 0m).ToString("N2"))</div>
                    </div>
                    <div class="col-md-3">
                        <div class="detail-label">Status</div>
                        <div class="readonly-detail-status">@await Html.PartialAsync("_StatusPill", Model.Status)</div>
                    </div>
                    <div class="col-md-3">
                        <div class="detail-label">Branch</div>
                        <div class="form-control readonly-detail">@(Model.Branch?.BranchName ?? "-")</div>
                    </div>
                    <div class="col-12">
                        <div class="detail-label">Remark</div>
                        <div class="form-control readonly-detail readonly-detail-multiline">@(string.IsNullOrWhiteSpace(Model.Remark) ? "-" : Model.Remark)</div>
                    </div>
                </div>
            </div>

            <div class="quotation-party-grid">
                <div class="quotation-party-column">
                    <div class="quotation-info-card">
                        <div class="quotation-info-card-title">Supplier Information</div>
                        <div class="quotation-info-grid">
                            <div class="quotation-info-field">
                                <span class="quotation-info-label">Supplier Name</span>
                                <span class="quotation-info-value">@Model.Supplier?.SupplierName</span>
                            </div>
                            <div class="quotation-info-field">
                                <span class="quotation-info-label">Tax ID</span>
                                <span class="quotation-info-value">@(string.IsNullOrWhiteSpace(Model.Supplier?.TaxId) ? "-" : Model.Supplier!.TaxId)</span>
                            </div>
                        </div>
                        <div class="quotation-info-grid">
                            <div class="quotation-info-field">
                                <span class="quotation-info-label">Phone</span>
                                <span class="quotation-info-value">@(string.IsNullOrWhiteSpace(Model.Supplier?.PhoneNumber) ? "-" : Model.Supplier!.PhoneNumber)</span>
                            </div>
                            <div class="quotation-info-field">
                                <span class="quotation-info-label">Email</span>
                                <span class="quotation-info-value">@(string.IsNullOrWhiteSpace(Model.Supplier?.Email) ? "-" : Model.Supplier!.Email)</span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="quotation-party-column">
                    <div class="quotation-info-card">
                        <div class="quotation-info-card-title">PO Financial Summary</div>
                        <div class="quotation-summary-stack">
                            <div class="quotation-summary-row">
                                <span class="quotation-summary-name">Subtotal</span>
                                <span class="quotation-summary-amount">@((Model.PurchaseOrderHeader?.Subtotal ?? 0m).ToString("N2"))</span>
                            </div>
                            <div class="quotation-summary-row">
                                <span class="quotation-summary-name">VAT</span>
                                <span class="quotation-summary-amount">@((Model.PurchaseOrderHeader?.VatAmount ?? 0m).ToString("N2"))</span>
                            </div>
                            <div class="quotation-summary-row total">
                                <span class="quotation-summary-name">Total</span>
                                <span class="quotation-summary-amount">@((Model.PurchaseOrderHeader?.TotalAmount ?? 0m).ToString("N2"))</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="form-section">
                <div class="d-flex justify-content-between align-items-center gap-2 mb-3 flex-wrap">
                    <div>
                        <div class="form-section-title mb-1">Receiving Lines</div>
                        <div class="table-meta">@(isDraft ? $"{Model.ReceivingDetails.Count} draft line(s). Posting will update stock and create serial records." : isCancelled ? $"{Model.ReceivingDetails.Count} cancelled line(s). This document is read-only." : $"{Model.ReceivingDetails.Count} line(s). Stock increments and serial creation happened when this document was posted.")</div>
                    </div>
                </div>

                <div class="table-responsive">
                    <table class="table entity-table quote-editor-table align-middle">
                        <thead>
                            <tr>
                                <th style="width: 6%;">#</th>
                                <th>Item</th>
                                <th style="width: 9%;">Ordered</th>
                                <th style="width: 9%;">Received</th>
                                <th style="width: 9%;">Remaining</th>
                                <th style="width: 10%;">Unit Price</th>
                                <th style="width: 10%;">Line Total</th>
                                <th style="width: 18%;">Serials</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var line in Model.ReceivingDetails.OrderBy(x => x.LineNumber))
                        {
                            var poLine = line.PurchaseOrderDetail;
                            var remaining = poLine is null ? 0m : poLine.Qty - poLine.ReceivedQty;
                            <tr>
                                <td>@line.LineNumber</td>
                                <td>
                                    <div class="fw-semibold">@line.Item?.ItemCode - @line.Item?.ItemName</div>
                                    <div class="table-meta">@(string.IsNullOrWhiteSpace(line.Remark) ? "No remark" : line.Remark)</div>
                                </td>
                                <td>@((poLine?.Qty ?? 0m).ToString("N2"))</td>
                                <td>@line.QtyReceived.ToString("N2")</td>
                                <td>@remaining.ToString("N2")</td>
                                <td>@((poLine?.UnitPrice ?? 0m).ToString("N2"))</td>
                                <td>@((poLine?.LineTotal ?? 0m).ToString("N2"))</td>
                                <td>
                                    @if (line.ReceivingSerials.Any())
                                    {
                                        <div class="serial-stack">
                                        @foreach (var serial in line.ReceivingSerials.OrderBy(x => x.SerialNo))
                                        {
                                            <span>@serial.SerialNo</span>
                                        }
                                        </div>
                                    }
                                    else
                                    {
                                        <span>-</span>
                                    }
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="form-section document-history-section">
                <div class="form-section-title">Document History</div>
                <div class="document-history-list">
                    <div class="document-history-row">
                        <span class="document-history-label">Created</span>
                        <span class="document-history-value">@(Model.CreatedByUser?.DisplayName ?? "-")</span>
                        <span class="document-history-meta">@Model.CreatedDate.ToString("dd MMM yyyy HH:mm")</span>
                    </div>
                    <div class="document-history-row">
                        <span class="document-history-label">Updated</span>
                        <span class="document-history-value">@(Model.UpdatedByUser?.DisplayName ?? "-")</span>
                        <span class="document-history-meta">@(Model.UpdatedDate?.ToString("dd MMM yyyy HH:mm") ?? "-")</span>
                    </div>
                    <div class="document-history-row">
                        <span class="document-history-label">Posted</span>
                        <span class="document-history-value">@(Model.PostedByUser?.DisplayName ?? "-")</span>
                        <span class="document-history-meta">@(Model.PostedDate?.ToString("dd MMM yyyy HH:mm") ?? "-")</span>
                    </div>
                    <div class="document-history-row">
                        <span class="document-history-label">Cancelled</span>
                        <span class="document-history-value">@(Model.CancelledByUser?.DisplayName ?? "-")</span>
                        <span class="document-history-meta">@(Model.CancelledDate?.ToString("dd MMM yyyy HH:mm") ?? "-")</span>
                    </div>
                </div>
                @if (isCancelled)
                {
                    <div class="document-history-reason">
                        <span class="document-history-label">Cancel Reason</span>
                        <span class="document-history-value">@(string.IsNullOrWhiteSpace(Model.CancelReason) ? "-" : Model.CancelReason)</span>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
