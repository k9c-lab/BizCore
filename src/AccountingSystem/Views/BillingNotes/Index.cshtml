@model BizCore.Models.ViewModels.PaginatedList<BizCore.Models.Entities.BillingNoteHeader>

@{
    ViewData["Title"] = "ใบวางบิล";
    var search = ViewData["Search"] as string;
    var status = ViewData["Status"] as string;
    var dateFrom = ViewData["DateFrom"] as string;
    var dateTo = ViewData["DateTo"] as string;
}

<div class="page-header">
    <div>
        <div class="page-eyebrow">งานขาย</div>
        <h1 class="page-title">ใบวางบิล</h1>
        <p class="page-subtitle">รวมใบแจ้งหนี้หลายใบและสรุปยอดตามสิทธิการรักษาหรือตามรายการสินค้า</p>
    </div>
    <div class="page-actions">
        <a asp-action="Create" class="btn btn-primary px-4">สร้างใบวางบิล</a>
    </div>
</div>

<div class="card content-card table-card">
    <div class="table-card-header">
        <div>
            <h2 class="section-title">รายการใบวางบิล</h2>
        </div>
        <div class="table-meta">@Model.TotalCount รายการ</div>
    </div>
    <div class="card-body">
        <form method="get" class="list-filter-bar">
            <div class="list-filter-field grow">
                <label class="form-label" for="search">ค้นหา</label>
                <input id="search" name="search" value="@search" class="form-control" placeholder="เลขที่ใบวางบิล หรือลูกค้า" />
            </div>
            <div class="list-filter-field">
                <label class="form-label" for="status">สถานะ</label>
                <select id="status" name="status" class="form-select">
                    <option value="">ทั้งหมด</option>
                    <option value="Draft" selected="@(status == "Draft")">ฉบับร่าง</option>
                    <option value="Issued" selected="@(status == "Issued")">ออกแล้ว</option>
                    <option value="Cancelled" selected="@(status == "Cancelled")">ยกเลิก</option>
                </select>
            </div>
            <div class="list-filter-field">
                <label class="form-label" for="dateFrom">จากวันที่</label>
                <input id="dateFrom" name="dateFrom" type="date" value="@dateFrom" class="form-control" />
            </div>
            <div class="list-filter-field">
                <label class="form-label" for="dateTo">ถึงวันที่</label>
                <input id="dateTo" name="dateTo" type="date" value="@dateTo" class="form-control" />
            </div>
            <div class="list-filter-actions">
                <a asp-action="Index" class="btn btn-outline-secondary">ล้างค่า</a>
                <button type="submit" class="btn btn-primary">ค้นหา</button>
            </div>
        </form>

        <div class="table-responsive">
            <table class="table entity-table align-middle">
                <thead>
                    <tr>
                        <th>เลขที่ใบวางบิล</th>
                        <th>วันที่</th>
                        <th>ลูกค้า</th>
                        <th>สาขา</th>
                        <th>จำนวนใบแจ้งหนี้</th>
                        <th>ยอดรวม</th>
                        <th>สถานะ</th>
                        <th class="text-end">การทำงาน</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><span class="code-chip">@item.BillingNoteNo</span></td>
                            <td>@item.BillingNoteDate.ToString("dd/MM/yyyy")</td>
                            <td class="fw-semibold">@item.Customer?.CustomerName</td>
                            <td>@(item.Branch?.BranchName ?? "-")</td>
                            <td>@item.InvoiceCount</td>
                            <td>@item.TotalAmount.ToString("N2")</td>
                            <td>
                                <div class="d-flex flex-column gap-1">
                                    <span>@await Html.PartialAsync("_StatusPill", item.Status)</span>
                                    <span class="text-muted small">ชำระแล้ว @item.PaidAmount.ToString("N2") / @item.TotalAmount.ToString("N2")</span>
                                </div>
                            </td>
                            <td class="text-end">
                                <div class="table-actions">
                                    <a asp-action="Details" asp-route-id="@item.BillingNoteId" class="btn btn-sm btn-outline-secondary">ดูรายละเอียด</a>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="8" class="table-empty">ยังไม่มีใบวางบิล</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
        <partial name="_Pager" model="Model.Pagination" />
    </div>
</div>
