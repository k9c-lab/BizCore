@model BizCore.Models.Entities.PriceLevel

@{
    ViewData["Title"] = "Create Price Level";
}

<div class="page-header">
    <div>
        <div class="page-eyebrow">Sales Setup</div>
        <h1 class="page-title">Create Price Level</h1>
        </div>
    <div class="page-actions">
        <button type="submit" form="priceLevelForm" class="btn btn-primary px-4">Save Price Level</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
    </div>
</div>

<div class="card content-card">
    <div class="card-body">
        <form asp-action="Create" method="post" id="priceLevelForm">
            <partial name="_Form" model="Model" />
            <div class="form-actions mt-3">
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                <button type="submit" class="btn btn-primary px-4">Save Price Level</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

