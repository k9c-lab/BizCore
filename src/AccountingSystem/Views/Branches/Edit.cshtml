@model BizCore.Models.Entities.Branch

@{
    ViewData["Title"] = "Edit Branch";
}

<div class="page-header">
    <div>
        <div class="page-eyebrow">Master Data</div>
        <h1 class="page-title">Edit Branch</h1>
        <p class="page-subtitle">Update branch contact information and active status.</p>
    </div>
    <div class="page-actions">
        <button type="submit" form="branchForm" class="btn btn-primary px-4">Save Changes</button>
        <a asp-action="Details" asp-route-id="@Model.BranchId" class="btn btn-outline-secondary">Back</a>
    </div>
</div>

<div class="card content-card">
    <div class="card-body">
        <form asp-action="Edit" method="post" id="branchForm">
            <partial name="_Form" model="Model" />
            <div class="form-actions mt-3">
                <span class="table-meta">Inactive branches remain visible for history but should not be used for new transactions later.</span>
                <div class="page-actions">
                    <a asp-action="Details" asp-route-id="@Model.BranchId" class="btn btn-outline-secondary">Cancel</a>
                    <button type="submit" class="btn btn-primary px-4">Save Changes</button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
