@model BizCore.Models.Entities.Branch

@{
    ViewData["Title"] = "แก้ไขสาขา";
}

<div class="page-header">
    <div>
        <div class="page-eyebrow">ข้อมูลหลัก</div>
        <h1 class="page-title">แก้ไขสาขา</h1>
        </div>
    <div class="page-actions">
        <button type="submit" form="branchForm" class="btn btn-primary px-4">บันทึกการเปลี่ยนแปลง</button>
        <a asp-action="Details" asp-route-id="@Model.BranchId" class="btn btn-outline-secondary">กลับ</a>
    </div>
</div>

<div class="card content-card">
    <div class="card-body">
        <form asp-action="Edit" method="post" id="branchForm">
            <partial name="_Form" model="Model" />
            <div class="form-actions mt-3">
                <span class="table-meta">สาขาที่ปิดใช้งานแล้วยังแสดงในประวัติได้ แต่ไม่ควรใช้กับรายการใหม่</span>
                <div class="page-actions">
                    <a asp-action="Details" asp-route-id="@Model.BranchId" class="btn btn-outline-secondary">ยกเลิก</a>
                    <button type="submit" class="btn btn-primary px-4">บันทึกการเปลี่ยนแปลง</button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

