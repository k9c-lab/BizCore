@model BizCore.Models.Entities.Branch

@{
    ViewData["Title"] = "เพิ่มสาขา";
}

<div class="page-header">
    <div>
        <div class="page-eyebrow">ข้อมูลหลัก</div>
        <h1 class="page-title">เพิ่มสาขา</h1>
        </div>
    <div class="page-actions">
        <button type="submit" form="branchForm" class="btn btn-primary px-4">บันทึกสาขา</button>
        <a asp-action="Index" class="btn btn-outline-secondary">กลับไปรายการ</a>
    </div>
</div>

<div class="card content-card">
    <div class="card-body">
        <form asp-action="Create" method="post" id="branchForm">
            <partial name="_Form" model="Model" />
            <div class="form-actions mt-3">
                <span class="table-meta">สาขาจะถูกใช้เป็นตำแหน่งเก็บสต็อกในงาน inventory</span>
                <div class="page-actions">
                    <a asp-action="Index" class="btn btn-outline-secondary">ยกเลิก</a>
                    <button type="submit" class="btn btn-primary px-4">บันทึกสาขา</button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

