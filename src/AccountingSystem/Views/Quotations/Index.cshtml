@model BizCore.Models.ViewModels.PaginatedList<BizCore.Models.Entities.QuotationHeader>

@{
    ViewData["Title"] = "ใบเสนอราคา";
    var paymentStatusMap = ViewData["PaymentStatusMap"] as IReadOnlyDictionary<int, BizCore.Models.ViewModels.QuotationPaymentStatusViewModel>
        ?? new Dictionary<int, BizCore.Models.ViewModels.QuotationPaymentStatusViewModel>();
    var search = ViewData["Search"] as string;
    var status = ViewData["Status"] as string;
    var dateFrom = ViewData["DateFrom"] as string;
    var dateTo = ViewData["DateTo"] as string;
}

<div class="page-header">
    <div>
        <div class="page-eyebrow">งานขาย</div>
        <h1 class="page-title">ใบเสนอราคา</h1>
        </div>
    <div class="page-actions">
        <a asp-action="Create" class="btn btn-primary px-4">สร้างใบเสนอราคา</a>
    </div>
</div>

<div class="card content-card table-card">
    <div class="table-card-header">
        <div>
            <h2 class="section-title">รายการใบเสนอราคา</h2>
            </div>
        <div class="table-meta">@Model.TotalCount รายการ</div>
    </div>
    <div class="card-body">
        <form method="get" class="list-filter-bar">
            <div class="list-filter-field grow">
                <label class="form-label" for="search">ค้นหา</label>
                <input id="search" name="search" value="@search" class="form-control" placeholder="เลขที่เอกสาร, เลขอ้างอิง, ลูกค้า หรือพนักงานขาย" />
            </div>
            <div class="list-filter-field">
                <label class="form-label" for="status">สถานะ</label>
                <select id="status" name="status" class="form-select">
                    <option value="">ทั้งหมด</option>
                    <option value="Draft" selected="@(status == "Draft")">ฉบับร่าง</option>
                    <option value="Approved" selected="@(status == "Approved")">อนุมัติแล้ว</option>
                    <option value="Converted" selected="@(status == "Converted")">แปลงแล้ว</option>
                    <option value="Cancelled" selected="@(status == "Cancelled")">ยกเลิกแล้ว</option>
                </select>
            </div>
            <div class="list-filter-field">
                <label class="form-label" for="dateFrom">จากวันที่</label>
                <input id="dateFrom" name="dateFrom" value="@dateFrom" type="date" class="form-control" />
            </div>
            <div class="list-filter-field">
                <label class="form-label" for="dateTo">ถึงวันที่</label>
                <input id="dateTo" name="dateTo" value="@dateTo" type="date" class="form-control" />
            </div>
            <div class="list-filter-actions">
                <a asp-action="Index" class="btn btn-outline-secondary">ล้างค่า</a>
                <button type="submit" class="btn btn-primary">ค้นหา</button>
            </div>
        </form>
        <div class="table-responsive">
            <table class="table entity-table align-middle">
                <thead>
                    <tr>
                        <th>เลขที่ใบเสนอราคา</th>
                        <th>เลขอ้างอิง</th>
                        <th>วันที่</th>
                        <th>ลูกค้า</th>
                        <th>พนักงานขาย</th>
                        <th>ยอดรวม</th>
                        <th>สถานะ</th>
                        <th>สถานะการออกบิล</th>
                        <th class="text-end">การทำงาน</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.Any())
                {
                    @foreach (var quotation in Model)
                    {
                        var paymentStatus = paymentStatusMap.TryGetValue(quotation.QuotationHeaderId, out var summary)
                            ? summary
                            : new BizCore.Models.ViewModels.QuotationPaymentStatusViewModel
                            {
                                QuotationHeaderId = quotation.QuotationHeaderId,
                                QuotationTotalAmount = quotation.TotalAmount,
                                RemainingAmount = quotation.TotalAmount,
                                Status = "NotInvoiced"
                            };
                        <tr>
                            <td><span class="code-chip">@quotation.QuotationNumber</span></td>
                            <td>@(string.IsNullOrWhiteSpace(quotation.ReferenceNo) ? "-" : quotation.ReferenceNo)</td>
                            <td>@quotation.QuotationDate.ToString("dd MMM yyyy")</td>
                            <td class="fw-semibold">@quotation.Customer?.CustomerName</td>
                            <td>@quotation.Salesperson?.SalespersonName</td>
                            <td>@quotation.TotalAmount.ToString("N2")</td>
                            <td>@await Html.PartialAsync("_StatusPill", quotation.Status)</td>
                            <td>
                                <div>@await Html.PartialAsync("_StatusPill", paymentStatus.Status)</div>
                                <div class="table-meta">ออกบิลแล้ว @paymentStatus.InvoicedAmount.ToString("N2") / @quotation.TotalAmount.ToString("N2")</div>
                            </td>
                            <td class="text-end">
                                <div class="table-actions">
                                    <a asp-action="Details" asp-route-id="@quotation.QuotationHeaderId" class="btn btn-sm btn-outline-secondary">ดูรายละเอียด</a>
                                    <button type="button" class="btn btn-sm btn-outline-secondary" onclick="window.open('@Url.Action("Print", new { id = quotation.QuotationHeaderId })', '_blank', 'noopener');">พิมพ์</button>
                                    @if (quotation.Status == "Draft")
                                    {
                                        <a asp-action="Edit" asp-route-id="@quotation.QuotationHeaderId" class="btn btn-sm btn-outline-primary">แก้ไข</a>
                                        <form asp-action="Approve" asp-route-id="@quotation.QuotationHeaderId" method="post" class="d-inline confirm-popover-form">
                                            @Html.AntiForgeryToken()
                                            <div class="confirm-popover-shell">
                                                <button type="button"
                                                        class="btn btn-sm btn-outline-primary js-confirm-popover-toggle"
                                                        data-confirm-target="approveQuotationConfirm_@quotation.QuotationHeaderId"
                                                        aria-expanded="false">
                                                    อนุมัติ
                                                </button>
                                                <div class="confirm-popover" id="approveQuotationConfirm_@quotation.QuotationHeaderId" hidden>
                                                    <div class="confirm-popover-title">อนุมัติใบเสนอราคานี้หรือไม่?</div>
                                                    <div class="confirm-popover-text">เมื่ออนุมัติแล้ว จะสามารถนำใบเสนอราคานี้ไปสร้างใบแจ้งหนี้ได้</div>
                                                    <div class="confirm-popover-actions">
                                                        <button type="submit" class="btn btn-sm btn-outline-primary">ยืนยัน</button>
                                                        <button type="button" class="btn btn-sm btn-outline-secondary js-confirm-popover-cancel">ยกเลิก</button>
                                                    </div>
                                                </div>
                                            </div>
                                        </form>
                                    }
                                    @if (quotation.Status == "Approved" || quotation.Status == "Converted")
                                    {
                                        <form asp-action="ConvertToInvoice" asp-route-id="@quotation.QuotationHeaderId" method="post" class="d-inline confirm-popover-form">
                                            @Html.AntiForgeryToken()
                                            <div class="confirm-popover-shell">
                                                <button type="button"
                                                        class="btn btn-sm btn-primary js-confirm-popover-toggle"
                                                        data-confirm-target="convertQuotationConfirm_@quotation.QuotationHeaderId"
                                                        aria-expanded="false">
                                                    สร้างใบแจ้งหนี้
                                                </button>
                                                <div class="confirm-popover" id="convertQuotationConfirm_@quotation.QuotationHeaderId" hidden>
                                                    <div class="confirm-popover-title">สร้างใบแจ้งหนี้จากใบเสนอราคานี้หรือไม่?</div>
                                                    <div class="confirm-popover-text">ระบบจะเปิดเอกสารใบแจ้งหนี้ฉบับร่างเพื่อให้ตรวจสอบก่อนออกเอกสาร</div>
                                                    <div class="confirm-popover-actions">
                                                        <button type="submit" class="btn btn-sm btn-outline-primary">ยืนยัน</button>
                                                        <button type="button" class="btn btn-sm btn-outline-secondary js-confirm-popover-cancel">ยกเลิก</button>
                                                    </div>
                                                </div>
                                            </div>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="9" class="table-empty">ยังไม่มีใบเสนอราคา เริ่มสร้างเอกสารแรกเพื่อใช้งานส่วนงานขายได้เลย</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
        <partial name="_Pager" model="Model.Pagination" />
    </div>
</div>

