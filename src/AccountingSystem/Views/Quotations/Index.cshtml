@model BizCore.Models.ViewModels.PaginatedList<BizCore.Models.Entities.QuotationHeader>

@{
    ViewData["Title"] = "Quotations";
    var paymentStatusMap = ViewData["PaymentStatusMap"] as IReadOnlyDictionary<int, BizCore.Models.ViewModels.QuotationPaymentStatusViewModel>
        ?? new Dictionary<int, BizCore.Models.ViewModels.QuotationPaymentStatusViewModel>();
    var search = ViewData["Search"] as string;
    var status = ViewData["Status"] as string;
    var dateFrom = ViewData["DateFrom"] as string;
    var dateTo = ViewData["DateTo"] as string;
}

<div class="page-header">
    <div>
        <div class="page-eyebrow">Sales Module</div>
        <h1 class="page-title">Quotations</h1>
        <p class="page-subtitle">Create and manage quotations before invoice, with VAT calculation and conversion to draft invoice.</p>
    </div>
    <div class="page-actions">
        <a asp-action="Create" class="btn btn-primary px-4">New Quotation</a>
    </div>
</div>

<div class="card content-card table-card">
    <div class="table-card-header">
        <div>
            <h2 class="section-title">Quotation Register</h2>
            <p class="section-subtitle">Approved quotations can be used to prefill invoices, and the same quotation can be reused when needed.</p>
        </div>
        <div class="table-meta">@Model.TotalCount records</div>
    </div>
    <div class="card-body">
        <form method="get" class="list-filter-bar">
            <div class="list-filter-field grow">
                <label class="form-label" for="search">Search</label>
                <input id="search" name="search" value="@search" class="form-control" placeholder="Quotation no., reference, customer, or salesperson" />
            </div>
            <div class="list-filter-field">
                <label class="form-label" for="status">Status</label>
                <select id="status" name="status" class="form-select">
                    <option value="">All</option>
                    <option value="Draft" selected="@(status == "Draft")">Draft</option>
                    <option value="Approved" selected="@(status == "Approved")">Approved</option>
                    <option value="Converted" selected="@(status == "Converted")">Converted</option>
                    <option value="Cancelled" selected="@(status == "Cancelled")">Cancelled</option>
                </select>
            </div>
            <div class="list-filter-field">
                <label class="form-label" for="dateFrom">From</label>
                <input id="dateFrom" name="dateFrom" value="@dateFrom" type="date" class="form-control" />
            </div>
            <div class="list-filter-field">
                <label class="form-label" for="dateTo">To</label>
                <input id="dateTo" name="dateTo" value="@dateTo" type="date" class="form-control" />
            </div>
            <div class="list-filter-actions">
                <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
                <button type="submit" class="btn btn-primary">Search</button>
            </div>
        </form>
        <div class="table-responsive">
            <table class="table entity-table align-middle">
                <thead>
                    <tr>
                        <th>Quotation No.</th>
                        <th>Reference No.</th>
                        <th>Date</th>
                        <th>Customer</th>
                        <th>Salesperson</th>
                        <th>Total</th>
                        <th>Status</th>
                        <th>Invoice Coverage</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.Any())
                {
                    @foreach (var quotation in Model)
                    {
                        var paymentStatus = paymentStatusMap.TryGetValue(quotation.QuotationHeaderId, out var summary)
                            ? summary
                            : new BizCore.Models.ViewModels.QuotationPaymentStatusViewModel
                            {
                                QuotationHeaderId = quotation.QuotationHeaderId,
                                QuotationTotalAmount = quotation.TotalAmount,
                                RemainingAmount = quotation.TotalAmount,
                                Status = "Not Invoiced"
                            };
                        <tr>
                            <td><span class="code-chip">@quotation.QuotationNumber</span></td>
                            <td>@(string.IsNullOrWhiteSpace(quotation.ReferenceNo) ? "-" : quotation.ReferenceNo)</td>
                            <td>@quotation.QuotationDate.ToString("dd MMM yyyy")</td>
                            <td class="fw-semibold">@quotation.Customer?.CustomerName</td>
                            <td>@quotation.Salesperson?.SalespersonName</td>
                            <td>@quotation.TotalAmount.ToString("N2")</td>
                            <td>@await Html.PartialAsync("_StatusPill", quotation.Status)</td>
                            <td>
                                <div>@await Html.PartialAsync("_StatusPill", paymentStatus.Status)</div>
                                <div class="table-meta">Invoiced @paymentStatus.InvoicedAmount.ToString("N2") / @quotation.TotalAmount.ToString("N2")</div>
                            </td>
                            <td class="text-end">
                                <div class="table-actions">
                                    <a asp-action="Details" asp-route-id="@quotation.QuotationHeaderId" class="btn btn-sm btn-outline-secondary">View</a>
                                    <button type="button" class="btn btn-sm btn-outline-secondary" onclick="window.open('@Url.Action("Print", new { id = quotation.QuotationHeaderId })', '_blank', 'noopener');">Print</button>
                                    @if (quotation.Status == "Draft")
                                    {
                                        <a asp-action="Edit" asp-route-id="@quotation.QuotationHeaderId" class="btn btn-sm btn-outline-primary">Edit</a>
                                        <form asp-action="Approve" asp-route-id="@quotation.QuotationHeaderId" method="post" class="d-inline confirm-popover-form">
                                            @Html.AntiForgeryToken()
                                            <div class="confirm-popover-shell">
                                                <button type="button"
                                                        class="btn btn-sm btn-outline-primary js-confirm-popover-toggle"
                                                        data-confirm-target="approveQuotationConfirm_@quotation.QuotationHeaderId"
                                                        aria-expanded="false">
                                                    Approve
                                                </button>
                                                <div class="confirm-popover" id="approveQuotationConfirm_@quotation.QuotationHeaderId" hidden>
                                                    <div class="confirm-popover-title">Approve this quotation?</div>
                                                    <div class="confirm-popover-text">This will approve the quotation and allow it to be converted into an invoice.</div>
                                                    <div class="confirm-popover-actions">
                                                        <button type="submit" class="btn btn-sm btn-outline-primary">Confirm</button>
                                                        <button type="button" class="btn btn-sm btn-outline-secondary js-confirm-popover-cancel">Cancel</button>
                                                    </div>
                                                </div>
                                            </div>
                                        </form>
                                    }
                                    @if (quotation.Status == "Approved" || quotation.Status == "Converted")
                                    {
                                        <form asp-action="ConvertToInvoice" asp-route-id="@quotation.QuotationHeaderId" method="post" class="d-inline confirm-popover-form">
                                            @Html.AntiForgeryToken()
                                            <div class="confirm-popover-shell">
                                                <button type="button"
                                                        class="btn btn-sm btn-primary js-confirm-popover-toggle"
                                                        data-confirm-target="convertQuotationConfirm_@quotation.QuotationHeaderId"
                                                        aria-expanded="false">
                                                    Convert
                                                </button>
                                                <div class="confirm-popover" id="convertQuotationConfirm_@quotation.QuotationHeaderId" hidden>
                                                    <div class="confirm-popover-title">Convert this quotation?</div>
                                                    <div class="confirm-popover-text">This will open the quotation into a draft invoice flow for further review before issuing.</div>
                                                    <div class="confirm-popover-actions">
                                                        <button type="submit" class="btn btn-sm btn-outline-primary">Confirm</button>
                                                        <button type="button" class="btn btn-sm btn-outline-secondary js-confirm-popover-cancel">Cancel</button>
                                                    </div>
                                                </div>
                                            </div>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="9" class="table-empty">No quotations yet. Create the first quotation to start the sales module.</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
        <partial name="_Pager" model="Model.Pagination" />
    </div>
</div>
