@model BizCore.Models.Entities.QuotationHeader

@{
    ViewData["Title"] = "รายละเอียดใบเสนอราคา";
    var paymentStatus = ViewData["PaymentStatus"] as BizCore.Models.ViewModels.QuotationPaymentStatusViewModel
        ?? new BizCore.Models.ViewModels.QuotationPaymentStatusViewModel
        {
            QuotationHeaderId = Model.QuotationHeaderId,
            QuotationTotalAmount = Model.TotalAmount,
            RemainingAmount = Model.TotalAmount,
            Status = "NotInvoiced"
        };
    var appliedDiscount = Model.DiscountMode == "Header" ? Model.HeaderDiscountAmount : Model.DiscountAmount;
    var vatSummary = BizCore.Utilities.VatModeHelper.ComputeSummaryBreakdown(Model.Subtotal, appliedDiscount, Model.VatType);
    var netAfterDiscount = vatSummary.NetBeforeVat;
    var statusLabel = Model.Status switch
    {
        "Draft" => "ฉบับร่าง",
        "Approved" => "อนุมัติแล้ว",
        "Converted" => "แปลงแล้ว",
        "Cancelled" => "ยกเลิกแล้ว",
        _ => Model.Status
    };
    var discountModeLabel = Model.DiscountMode switch
    {
        "Line" => "ส่วนลดรายบรรทัด",
        "Header" => "ส่วนลดท้ายเอกสาร",
        _ => Model.DiscountMode
    };
    var vatTypeLabel = BizCore.Utilities.VatModeHelper.GetDisplayLabel(Model.VatType);
    var headerDiscountTypeLabel = Model.HeaderDiscountType switch
    {
        "Amount" => "จำนวนเงิน",
        "Percent" => "เปอร์เซ็นต์",
        _ => Model.HeaderDiscountType
    };
    var headerDiscountDisplay = Model.DiscountMode == "Header"
        ? Model.HeaderDiscountType == "Percent"
            ? $"{Model.HeaderDiscountPercent:N2}% ({Model.HeaderDiscountAmount:N2})"
            : Model.HeaderDiscountAmount.ToString("N2")
        : "-";
    var canApprove = Model.Status == "Draft";
    var approveBlockedReason = Model.Status == "Draft" ? string.Empty : $"อนุมัติได้เฉพาะใบเสนอราคาฉบับร่าง สถานะปัจจุบันคือ {statusLabel}";
    var canConvert = Model.Status == "Approved" || Model.Status == "Converted";
    var convertBlockedReason = canConvert ? string.Empty : $"จะสร้างใบแจ้งหนี้ได้หลังจากอนุมัติแล้วเท่านั้น สถานะปัจจุบันคือ {statusLabel}";
}

@if (TempData["QuotationNotice"] is string notice && !string.IsNullOrWhiteSpace(notice))
{
    @await Html.PartialAsync("_Notice", notice)
}

<div class="page-header">
    <div>
        <div class="page-eyebrow">งานขาย</div>
        <h1 class="page-title">รายละเอียดใบเสนอราคา</h1>
        <p class="page-subtitle">ตรวจสอบรายละเอียด ยอดรวม VAT และความพร้อมก่อนสร้างใบแจ้งหนี้</p>
    </div>
    <div class="page-actions">
        @if (canApprove)
        {
            <a asp-action="Edit" asp-route-id="@Model.QuotationHeaderId" class="btn btn-primary">แก้ไขใบเสนอราคา</a>
            <form asp-action="Approve" asp-route-id="@Model.QuotationHeaderId" method="post" class="d-inline confirm-popover-form">
                @Html.AntiForgeryToken()
                <div class="confirm-popover-shell">
                    <button type="button"
                            class="btn btn-primary js-confirm-popover-toggle"
                            data-confirm-target="approveQuotationDetailsConfirm_@Model.QuotationHeaderId"
                            aria-expanded="false">
                        อนุมัติ
                    </button>
                    <div class="confirm-popover" id="approveQuotationDetailsConfirm_@Model.QuotationHeaderId" hidden>
                        <div class="confirm-popover-title">อนุมัติใบเสนอราคานี้หรือไม่?</div>
                        <div class="confirm-popover-text">เมื่ออนุมัติแล้ว จะสามารถนำไปสร้างใบแจ้งหนี้ได้</div>
                        <div class="confirm-popover-actions">
                            <button type="submit" class="btn btn-sm btn-outline-primary">ยืนยัน</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary js-confirm-popover-cancel">ยกเลิก</button>
                        </div>
                    </div>
                </div>
            </form>
        }
        else
        {
            <button type="button" class="btn btn-outline-secondary" disabled title="@approveBlockedReason">อนุมัติ</button>
        }
        <button type="button" class="btn btn-outline-secondary" onclick="window.open('@Url.Action("Print", new { id = Model.QuotationHeaderId })', '_blank', 'noopener');">พิมพ์</button>
        @if (canConvert)
        {
            <form asp-action="ConvertToInvoice" asp-route-id="@Model.QuotationHeaderId" method="post" class="d-inline confirm-popover-form">
                @Html.AntiForgeryToken()
                <div class="confirm-popover-shell">
                    <button type="button"
                            class="btn btn-primary js-confirm-popover-toggle"
                            data-confirm-target="convertQuotationDetailsConfirm_@Model.QuotationHeaderId"
                            aria-expanded="false">
                        สร้างใบแจ้งหนี้
                    </button>
                    <div class="confirm-popover" id="convertQuotationDetailsConfirm_@Model.QuotationHeaderId" hidden>
                        <div class="confirm-popover-title">สร้างใบแจ้งหนี้จากใบเสนอราคานี้หรือไม่?</div>
                        <div class="confirm-popover-text">ระบบจะเปิดเป็นใบแจ้งหนี้ฉบับร่างเพื่อให้ตรวจสอบก่อนออกเอกสาร</div>
                        <div class="confirm-popover-actions">
                            <button type="submit" class="btn btn-sm btn-outline-primary">ยืนยัน</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary js-confirm-popover-cancel">ยกเลิก</button>
                        </div>
                    </div>
                </div>
            </form>
        }
        else
        {
            <button type="button" class="btn btn-outline-secondary" disabled title="@convertBlockedReason">สร้างใบแจ้งหนี้</button>
        }
        <a asp-action="Index" class="btn btn-outline-secondary">กลับไปรายการใบเสนอราคา</a>
    </div>
</div>

@if (!canApprove || !canConvert)
{
    <div class="workflow-info mb-3">
        @if (!canApprove)
        {
            <div>@approveBlockedReason</div>
        }
        @if (!canConvert)
        {
            <div>@convertBlockedReason</div>
        }
    </div>
}

<div class="card content-card">
    <div class="card-body">
        <div class="form-shell">
            <div class="form-section quotation-header-section">
                <div class="form-section-title">ข้อมูลหัวเอกสาร</div>
                <div class="quotation-header-stack">
                    <div class="quotation-header-card">
                        <div class="quotation-header-card-title">ข้อมูลเอกสาร</div>
                        <div class="row g-2 quotation-header-grid">
                            <div class="col-lg-4 col-md-6">
                                <div class="detail-label">เลขที่ใบเสนอราคา</div>
                                <div class="form-control readonly-detail">@Model.QuotationNumber</div>
                            </div>
                            <div class="col-lg-4 col-md-6">
                                <div class="detail-label">วันที่เอกสาร</div>
                                <div class="form-control readonly-detail">@Model.QuotationDate.ToString("dd MMM yyyy")</div>
                            </div>
                            <div class="col-lg-4 col-md-6">
                                <div class="detail-label">เลขอ้างอิง</div>
                                <div class="form-control readonly-detail">@(string.IsNullOrWhiteSpace(Model.ReferenceNo) ? "-" : Model.ReferenceNo)</div>
                            </div>
                            <div class="col-lg-8 col-md-7">
                                <div class="detail-label">วันหมดอายุ</div>
                                <div class="form-control readonly-detail">@(Model.ExpiryDate?.ToString("dd MMM yyyy") ?? "ไม่กำหนดวันหมดอายุ")</div>
                            </div>
                            <div class="col-lg-4 col-md-5">
                                <div class="detail-label">สถานะ</div>
                                <div class="readonly-detail-status">@await Html.PartialAsync("_StatusPill", Model.Status)</div>
                            </div>
                        </div>
                    </div>

                    <div class="quotation-header-card">
                        <div class="quotation-header-card-title">ราคาและเงื่อนไขการอนุมัติ</div>
                        <div class="row g-2 quotation-header-grid">
                            <div class="col-lg-4 col-md-6">
                                <div class="detail-label">สาขา</div>
                                <div class="form-control readonly-detail">@Model.Branch?.BranchName</div>
                            </div>
                            <div class="col-lg-4 col-md-6">
                                <div class="detail-label">รูปแบบส่วนลด</div>
                                <div class="form-control readonly-detail">@discountModeLabel</div>
                            </div>
                            <div class="col-lg-4 col-md-6">
                                <div class="detail-label">ประเภท VAT</div>
                                <div class="form-control readonly-detail">@vatTypeLabel</div>
                            </div>
                            <div class="col-lg-4 col-md-6">
                                <div class="detail-label">ประเภทส่วนลดท้ายเอกสาร</div>
                                <div class="form-control readonly-detail">@headerDiscountTypeLabel</div>
                            </div>
                            <div class="col-lg-4 col-md-6">
                                <div class="detail-label">ส่วนลดท้ายเอกสาร</div>
                                <div class="form-control readonly-detail">@headerDiscountDisplay</div>
                            </div>
                            <div class="col-lg-4 col-md-6">
                                <div class="detail-label">ส่วนลดที่ใช้จริง</div>
                                <div class="form-control readonly-detail">@vatSummary.DiscountBeforeVat.ToString("N2")</div>
                            </div>
                        </div>
                        <div class="quotation-summary-strip">
                            <div class="quotation-summary-chip">
                                <span>มูลค่าก่อนส่วนลด</span>
                                <strong>@vatSummary.SubtotalBeforeVat.ToString("N2")</strong>
                            </div>
                            <div class="quotation-summary-chip">
                                <span>ส่วนลด</span>
                                <strong>@vatSummary.DiscountBeforeVat.ToString("N2")</strong>
                            </div>
                            <div class="quotation-summary-chip">
                                <span>ยอดสุทธิหลังหักส่วนลด</span>
                                <strong>@netAfterDiscount.ToString("N2")</strong>
                            </div>
                            <div class="quotation-summary-chip">
                                <span>VAT</span>
                                <strong>@Model.VatAmount.ToString("N2")</strong>
                            </div>
                            <div class="quotation-summary-chip is-total">
                                <span>ยอดรวมทั้งสิ้น</span>
                                <strong>@Model.TotalAmount.ToString("N2")</strong>
                            </div>
                        </div>
                    </div>

                    <div class="quotation-header-card">
                        <div class="quotation-header-card-title">หมายเหตุ</div>
                        <div class="row g-2 quotation-header-grid">
                            <div class="col-12">
                                <div class="detail-label">หมายเหตุ</div>
                                <div class="form-control readonly-detail readonly-detail-multiline">@(string.IsNullOrWhiteSpace(Model.Remarks) ? "-" : Model.Remarks)</div>
                            </div>
                        </div>
                    </div>

                    <div class="quotation-header-card">
                        <div class="quotation-header-card-title">สถานะการออกใบแจ้งหนี้</div>
                        <div class="row g-2 quotation-header-grid">
                            <div class="col-lg-4 col-md-6">
                                <div class="detail-label">สถานะการออกบิล</div>
                                <div class="readonly-detail-status">@await Html.PartialAsync("_StatusPill", paymentStatus.Status)</div>
                            </div>
                            <div class="col-lg-4 col-md-6">
                                <div class="detail-label">ยอดที่ออกบิลแล้ว</div>
                                <div class="form-control readonly-detail">@paymentStatus.InvoicedAmount.ToString("N2")</div>
                            </div>
                            <div class="col-lg-4 col-md-6">
                                <div class="detail-label">ยอดรวมใบเสนอราคา</div>
                                <div class="form-control readonly-detail">@paymentStatus.QuotationTotalAmount.ToString("N2")</div>
                            </div>
                            <div class="col-lg-4 col-md-6">
                                <div class="detail-label">ยอดคงเหลือที่ยังไม่ได้ออกบิล</div>
                                <div class="form-control readonly-detail">@paymentStatus.RemainingAmount.ToString("N2")</div>
                            </div>
                            <div class="col-lg-4 col-md-6">
                                <div class="detail-label">จำนวนใบแจ้งหนี้ที่อ้างอิง</div>
                                <div class="form-control readonly-detail">@paymentStatus.InvoiceCount.ToString("N0")</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="quotation-party-grid">
                <div class="quotation-party-column">
                    <div class="quotation-info-card">
                        <div class="quotation-info-card-title">ข้อมูลลูกค้า</div>
                        <div class="quotation-info-grid">
                            <div class="quotation-info-field">
                                <span class="quotation-info-label">ชื่อลูกค้า</span>
                                <span class="quotation-info-value">@Model.Customer?.CustomerName</span>
                            </div>
                            <div class="quotation-info-field">
                                <span class="quotation-info-label">เลขประจำตัวผู้เสียภาษี</span>
                                <span class="quotation-info-value">@(string.IsNullOrWhiteSpace(Model.Customer?.TaxId) ? "-" : Model.Customer!.TaxId)</span>
                            </div>
                        </div>
                        <div class="quotation-info-grid">
                            <div class="quotation-info-field">
                                <span class="quotation-info-label">โทรศัพท์</span>
                                <span class="quotation-info-value">@(string.IsNullOrWhiteSpace(Model.Customer?.PhoneNumber) ? "-" : Model.Customer!.PhoneNumber)</span>
                            </div>
                            <div class="quotation-info-field">
                                <span class="quotation-info-label">อีเมล</span>
                                <span class="quotation-info-value">@(string.IsNullOrWhiteSpace(Model.Customer?.Email) ? "-" : Model.Customer!.Email)</span>
                            </div>
                        </div>
                        <div class="quotation-info-field">
                            <span class="quotation-info-label">ที่อยู่</span>
                            <span class="quotation-info-value">@(string.IsNullOrWhiteSpace(Model.Customer?.Address) ? "-" : Model.Customer!.Address)</span>
                        </div>
                    </div>
                </div>

                <div class="quotation-party-column">
                    <div class="quotation-info-card">
                        <div class="quotation-info-card-title">ข้อมูลพนักงานขาย</div>
                        <div class="quotation-info-field">
                            <span class="quotation-info-label">ชื่อพนักงานขาย</span>
                            <span class="quotation-info-value">@(string.IsNullOrWhiteSpace(Model.Salesperson?.SalespersonName) ? "-" : Model.Salesperson!.SalespersonName)</span>
                        </div>
                        <div class="quotation-info-grid">
                            <div class="quotation-info-field">
                                <span class="quotation-info-label">โทรศัพท์</span>
                                <span class="quotation-info-value">@(string.IsNullOrWhiteSpace(Model.Salesperson?.PhoneNumber) ? "-" : Model.Salesperson!.PhoneNumber)</span>
                            </div>
                            <div class="quotation-info-field">
                                <span class="quotation-info-label">อีเมล</span>
                                <span class="quotation-info-value">@(string.IsNullOrWhiteSpace(Model.Salesperson?.Email) ? "-" : Model.Salesperson!.Email)</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="form-section quotation-lines-section">
                <div class="d-flex justify-content-between align-items-center gap-2 mb-3 flex-wrap">
                    <div>
                        <div class="form-section-title mb-1">รายการสินค้า/บริการ</div>
                        <div class="table-meta">@Model.QuotationDetails.Count รายการ รองรับคำอธิบายหลายบรรทัด</div>
                    </div>
                </div>

                <div class="table-responsive">
                    <table class="table entity-table quote-editor-table align-middle">
                        <thead>
                            <tr>
                                <th style="width: 6%;">#</th>
                                <th style="width: 24%;">สินค้า</th>
                                <th>รายละเอียด</th>
                                <th style="width: 10%;">จำนวน</th>
                                <th style="width: 12%;">ราคาต่อหน่วย</th>
                                <th style="width: 14%;">ประเภทส่วนลด</th>
                                <th style="width: 12%;">ส่วนลด</th>
                                <th style="width: 12%;">ราคาสุทธิ</th>
                                <th style="width: 12%;">รวมบรรทัด</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var line in Model.QuotationDetails.OrderBy(x => x.LineNumber))
                        {
                            <tr>
                                <td>@line.LineNumber</td>
                                <td>
                                    <div class="fw-semibold">@line.Item?.ItemName</div>
                                    <div class="table-meta">@line.Item?.ItemCode</div>
                                </td>
                                <td class="quote-notes">@(string.IsNullOrWhiteSpace(line.Description) ? "-" : line.Description)</td>
                                <td>@line.Quantity.ToString("N2")</td>
                                <td>@line.UnitPrice.ToString("N2")</td>
                                <td>@(line.DiscountType == "Percent" ? $"{line.DiscountPercent:N2}% ({line.DiscountAmount:N2})" : "จำนวนเงิน")</td>
                                <td>@line.DiscountAmount.ToString("N2")</td>
                                <td>@(line.Quantity > 0 ? (line.LineTotal / line.Quantity).ToString("N2") : "0.00")</td>
                                <td>@line.LineTotal.ToString("N2")</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>

                <div class="quotation-summary-wrap">
                    <div class="quotation-summary-stack">
                        <div class="quotation-summary-row">
                            <span class="quotation-summary-name">มูลค่าก่อนส่วนลด</span>
                            <span class="quotation-summary-amount">@vatSummary.SubtotalBeforeVat.ToString("N2")</span>
                        </div>
                        <div class="quotation-summary-row">
                            <span class="quotation-summary-name">ส่วนลด</span>
                            <span class="quotation-summary-amount">@vatSummary.DiscountBeforeVat.ToString("N2")</span>
                        </div>
                        <div class="quotation-summary-row">
                            <span class="quotation-summary-name">ยอดสุทธิหลังหักส่วนลด</span>
                            <span class="quotation-summary-amount">@netAfterDiscount.ToString("N2")</span>
                        </div>
                        <div class="quotation-summary-row">
                            <span class="quotation-summary-name">VAT</span>
                            <span class="quotation-summary-amount">@Model.VatAmount.ToString("N2")</span>
                        </div>
                        <div class="quotation-summary-row total">
                            <span class="quotation-summary-name">ยอดรวมทั้งสิ้น</span>
                            <span class="quotation-summary-amount">@Model.TotalAmount.ToString("N2")</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="form-section document-history-section">
                <div class="form-section-title">ประวัติเอกสาร</div>
                <div class="document-history-list">
                    <div class="document-history-row">
                        <span class="document-history-label">สร้างโดย</span>
                        <span class="document-history-value">@(Model.CreatedByUser?.DisplayName ?? "-")</span>
                        <span class="document-history-meta">@Model.CreatedDate.ToString("dd MMM yyyy HH:mm")</span>
                    </div>
                    <div class="document-history-row">
                        <span class="document-history-label">แก้ไขล่าสุด</span>
                        <span class="document-history-value">@(Model.UpdatedByUser?.DisplayName ?? "-")</span>
                        <span class="document-history-meta">@(Model.UpdatedDate?.ToString("dd MMM yyyy HH:mm") ?? "-")</span>
                    </div>
                    <div class="document-history-row">
                        <span class="document-history-label">อนุมัติโดย</span>
                        <span class="document-history-value">@(Model.ApprovedByUser?.DisplayName ?? "-")</span>
                        <span class="document-history-meta">@(Model.ApprovedDate?.ToString("dd MMM yyyy HH:mm") ?? "-")</span>
                    </div>
                    <div class="document-history-row">
                        <span class="document-history-label">สร้างใบแจ้งหนี้โดย</span>
                        <span class="document-history-value">@(Model.ConvertedByUser?.DisplayName ?? "-")</span>
                        <span class="document-history-meta">@(Model.ConvertedDate?.ToString("dd MMM yyyy HH:mm") ?? "-")</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
