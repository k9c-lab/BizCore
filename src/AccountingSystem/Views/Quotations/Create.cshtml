@model BizCore.Models.ViewModels.QuotationFormViewModel

@{
    ViewData["Title"] = "สร้างใบเสนอราคา";
}

<div class="page-header">
    <div>
        <div class="page-eyebrow">งานขาย</div>
        <h1 class="page-title">สร้างใบเสนอราคา</h1>
        </div>
    <div class="page-actions">
        <button type="submit" form="quotationForm" class="btn btn-primary px-4">บันทึกฉบับร่าง</button>
        <a asp-action="Index" class="btn btn-outline-secondary">กลับไปรายการใบเสนอราคา</a>
    </div>
</div>

<div class="card content-card">
    <div class="card-body">
        <div class="pricing-path-card mb-3">
            <div class="pricing-path-title">แหล่งที่มาของราคาในใบเสนอราคา</div>
            <div class="pricing-path-text">
                @if (Model.ShowPriceLevelSelector)
                {
                    <span>โหมดปัจจุบัน: <strong>หลายระดับราคา</strong> กำหนดราคาขายใน <a asp-controller="Items" asp-action="Index">ข้อมูลหลัก &gt; สินค้า</a> จากนั้นเลือก Price Level ที่หัวเอกสาร แล้วระบบจะดึงราคาของแต่ละรายการจากระดับราคานั้น โดยถ้าไม่มีราคาจะ fallback ไปที่ราคาปกติของสินค้า</span>
                }
                else
                {
                    <span>โหมดปัจจุบัน: <strong>ราคาเดียว</strong> ราคาขายหลักของสินค้าจะถูกดูแลใน <a asp-controller="Items" asp-action="Index">ข้อมูลหลัก &gt; สินค้า</a> แล้วคัดลอกมาใส่ในใบเสนอราคาเพื่อให้ตรวจสอบหรือปรับแก้ได้ตามต้องการ</span>
                }
            </div>
        </div>
        <form asp-action="Create" method="post" id="quotationForm">
            <partial name="_Form" model="Model" />
            <div class="form-actions mt-3">
                <span class="table-meta">การบันทึกในขั้นตอนนี้จะเก็บเฉพาะใบเสนอราคา ยังไม่มีการตัดสต็อกหรือเลือก Serial</span>
                <div class="page-actions">
                    <a asp-action="Index" class="btn btn-outline-secondary">ยกเลิก</a>
                    <button type="submit" class="btn btn-primary px-4">บันทึกฉบับร่าง</button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (() => {
            const itemLookup = JSON.parse(document.getElementById("quotationItemLookupData").textContent);
            const customerLookup = JSON.parse(document.getElementById("quotationCustomerLookupData").textContent);
            const salespersonLookup = JSON.parse(document.getElementById("quotationSalespersonLookupData").textContent);
            const itemMap = Object.fromEntries(itemLookup.map(item => [String(item.ItemId), item]));
            const itemDisplayMap = Object.fromEntries(itemLookup.map(item => [item.DisplayText.toLowerCase(), item]));
            const customerMap = Object.fromEntries(customerLookup.map(customer => [String(customer.CustomerId), customer]));
            const salespersonMap = Object.fromEntries(salespersonLookup.map(salesperson => [String(salesperson.SalespersonId), salesperson]));
            const lineBody = document.getElementById("quotationLineBody");
            const addButton = document.getElementById("addQuotationLine");
            const discountModeInput = document.getElementById("DiscountMode");
            const headerDiscountTypeInput = document.getElementById("HeaderDiscountType");
            const vatTypeInput = document.getElementById("VatType");
            const headerDiscountInput = document.getElementById("HeaderDiscountAmount");
            const headerDiscountPercentInput = document.getElementById("HeaderDiscountPercent");
            const expiryInput = document.getElementById("ExpiryDate");
            const noExpiryInput = document.getElementById("quotationNoExpiry");
            const customerInput = document.getElementById("CustomerId");
            const customerSearch = document.getElementById("quotationCustomerSearch");
            const customerResults = document.getElementById("quotationCustomerResults");
            const salespersonSelect = document.getElementById("SalespersonId");
            const headerDiscountHelp = document.getElementById("quotationHeaderDiscountHelp");
            const headerDiscountPercentHelp = document.getElementById("quotationHeaderDiscountPercentHelp");
            const discountModeText = document.getElementById("quotationDiscountModeText");
            const branchInput = document.getElementById("BranchId");
            const pricingModeInput = document.getElementById("quotationPricingMode");
            const priceLevelInput = document.getElementById("PriceLevelId");
            const branchStockUrl = '@Url.Action("BranchStock", "Quotations")';

            const createRow = index => {
                const mainRow = document.createElement("tr");
                mainRow.className = "quotation-line-row quotation-line-row-main";
                mainRow.innerHTML = `
                    <td>
                        <input type="hidden" name="Details[${index}].QuotationDetailId" value="" />
                        <input type="hidden" class="js-line-number" name="Details[${index}].LineNumber" value="${index + 1}" />
                        <input type="hidden" name="Details[${index}].ItemId" id="Details_${index}__ItemId" value="" class="js-item-id" />
                        <div class="search-dropdown">
                            <input type="text"
                                   id="Details_${index}__ItemSearch"
                                   class="form-control js-item-search"
                                   autocomplete="off"
                                   placeholder="ค้นหาจากรหัส ชื่อ หรือ Part Number" />
                            <div id="quotationItemResults_${index}" class="search-dropdown-menu search-dropdown-menu-wide js-item-results" style="display:none;"></div>
                        </div>
                        <div class="table-meta js-stock-hint"></div>
                        <span class="text-danger field-validation-valid" data-valmsg-for="Details[${index}].ItemId" data-valmsg-replace="true"></span>
                    </td>
                    <td>
                        <input type="number" step="1" min="1" data-qty-min="1" name="Details[${index}].Quantity" id="Details_${index}__Quantity" value="1" class="form-control js-line-quantity js-integer-qty" />
                        <span class="text-danger field-validation-valid" data-valmsg-for="Details[${index}].Quantity" data-valmsg-replace="true"></span>
                    </td>
                    <td>
                        <input type="number" step="0.01" min="0" name="Details[${index}].UnitPrice" id="Details_${index}__UnitPrice" value="0" class="form-control js-line-unit-price" />
                        <span class="text-danger field-validation-valid" data-valmsg-for="Details[${index}].UnitPrice" data-valmsg-replace="true"></span>
                    </td>
                    <td>
                        <select name="Details[${index}].DiscountType" class="form-select js-line-discount-type">
                            <option value="Amount" selected>จำนวนเงิน</option>
                            <option value="Percent">เปอร์เซ็นต์</option>
                        </select>
                        <span class="text-danger field-validation-valid" data-valmsg-for="Details[${index}].DiscountType" data-valmsg-replace="true"></span>
                    </td>
                    <td>
                        <input type="number" step="0.01" min="0" max="100" name="Details[${index}].DiscountPercent" id="Details_${index}__DiscountPercent" value="0" class="form-control js-line-discount-percent" />
                        <span class="text-danger field-validation-valid" data-valmsg-for="Details[${index}].DiscountPercent" data-valmsg-replace="true"></span>
                    </td>
                    <td>
                        <input type="number" step="0.01" min="0" name="Details[${index}].DiscountAmount" id="Details_${index}__DiscountAmount" value="0" class="form-control js-line-discount" />
                        <span class="text-danger field-validation-valid" data-valmsg-for="Details[${index}].DiscountAmount" data-valmsg-replace="true"></span>
                    </td>
                    <td>
                        <input type="number" step="0.01" name="Details[${index}].NetUnitPrice" value="0" class="form-control js-line-net-price" readonly />
                    </td>
                    <td>
                        <input type="number" step="0.01" name="Details[${index}].LineTotal" id="Details_${index}__LineTotal" value="0" class="form-control js-line-total" readonly />
                    </td>
                    <td class="text-end">
                        <button type="button" class="btn btn-sm btn-outline-danger js-remove-line">Remove</button>
                    </td>`;

                const detailRow = document.createElement("tr");
                detailRow.className = "quotation-line-row quotation-line-row-detail";
                detailRow.innerHTML = `
                    <td colspan="9">
                        <label class="form-label">รายละเอียด</label>
                        <textarea name="Details[${index}].Description" id="Details_${index}__Description" class="form-control js-line-description" rows="3"></textarea>
                        <span class="text-danger field-validation-valid" data-valmsg-for="Details[${index}].Description" data-valmsg-replace="true"></span>
                    </td>`;

                return [mainRow, detailRow];
            };

            const reindexRows = () => {
                [...lineBody.querySelectorAll(".quotation-line-row-main")].forEach((row, index) => {
                    const detailRow = row.nextElementSibling;
                    [row, detailRow].forEach(section => {
                        section?.querySelectorAll("input, textarea, span[data-valmsg-for], .js-item-results").forEach(element => {
                            if (element.name) {
                                element.name = element.name.replace(/Details\[\d+\]/g, `Details[${index}]`);
                            }

                            if (element.id) {
                                element.id = element.id.replace(/Details_\d+__/g, `Details_${index}__`).replace(/quotationItemResults_\d+/g, `quotationItemResults_${index}`);
                            }

                            const field = element.getAttribute("data-valmsg-for");
                            if (field) {
                                element.setAttribute("data-valmsg-for", field.replace(/Details\[\d+\]/g, `Details[${index}]`));
                            }
                        });
                    });

                    row.querySelector(".js-line-number").value = String(index + 1);
                });
            };

            const getValue = value => value && value.trim() ? value : "-";
            const hasSelectedBranch = () => branchInput && branchInput.value && branchInput.value.trim();
            const isMultiPriceMode = () => pricingModeInput && pricingModeInput.value === "MultiPrice";
            const getSelectedPriceLevelId = () => priceLevelInput && priceLevelInput.value ? String(priceLevelInput.value) : "";
            const getResolvedUnitPrice = item => {
                if (!item) {
                    return 0;
                }

                const levelId = getSelectedPriceLevelId();
                if (isMultiPriceMode() && levelId && item.PriceLevelPrices && Object.prototype.hasOwnProperty.call(item.PriceLevelPrices, levelId)) {
                    const levelPrice = Number(item.PriceLevelPrices[levelId] || 0);
                    if (levelPrice > 0) {
                        return levelPrice;
                    }
                }

                return Number(item.UnitPrice || 0);
            };
            const formatStockHint = item => {
                if (!item || !item.TrackStock) {
                    return "";
                }

                if (!hasSelectedBranch()) {
                    return "เลือกสาขาเพื่อดูสต็อก";
                }

                const stock = Number(item.CurrentStock || 0);
                return `สต็อกในสาขา: ${stock.toFixed(2)}`;
            };

            const refreshBranchStock = async () => {
                if (!branchInput || !hasSelectedBranch()) {
                    itemLookup.forEach(item => item.CurrentStock = 0);
                    lineBody.querySelectorAll(".quotation-line-row-main").forEach(row => updateLine(row, false));
                    return;
                }

                try {
                    const response = await fetch(`${branchStockUrl}?branchId=${encodeURIComponent(branchInput.value)}`);
                    if (!response.ok) {
                        return;
                    }

                    const stockRows = await response.json();
                    const stockMap = Object.fromEntries(stockRows.map(row => [String(row.itemId ?? row.ItemId), Number(row.currentStock ?? row.CurrentStock ?? 0)]));
                    itemLookup.forEach(item => item.CurrentStock = stockMap[String(item.ItemId)] || 0);
                    lineBody.querySelectorAll(".quotation-line-row-main").forEach(row => updateLine(row, false));
                } catch {
                    // Keep the last known stock hint if the lookup refresh fails.
                }
            };

            const hideCustomerResults = () => {
                customerResults.style.display = "none";
                customerResults.innerHTML = "";
            };

            const renderCustomerResults = query => {
                const keyword = (query || "").trim().toLowerCase();
                const matches = customerLookup
                    .filter(customer =>
                        !keyword ||
                        (customer.CustomerCode || "").toLowerCase().includes(keyword) ||
                        customer.CustomerName.toLowerCase().includes(keyword) ||
                        (customer.TaxId || "").toLowerCase().includes(keyword))
                    .slice(0, keyword ? 12 : 20);

                if (matches.length === 0) {
                    customerResults.innerHTML = `<div class="search-dropdown-empty">ไม่พบลูกค้าที่ตรงกับคำค้น</div>`;
                    customerResults.style.display = "";
                    return;
                }

                customerResults.innerHTML = matches
                    .map(customer => `
                        <button type="button" class="search-dropdown-option" data-customer-id="${customer.CustomerId}">
                            <span class="search-dropdown-title">${customer.CustomerCode || "-"} - ${customer.CustomerName}</span>
                            <span class="search-dropdown-meta">Tax ID: ${customer.TaxId || "-"} | ${customer.Phone || "-"}</span>
                        </button>`)
                    .join("");
                customerResults.style.display = "";
            };

            const selectCustomer = customer => {
                customerInput.value = customer.CustomerId;
                customerSearch.value = `${customer.CustomerCode || "-"} - ${customer.CustomerName}`;
                customerSearch.dataset.selectedCustomerId = String(customer.CustomerId);
                hideCustomerResults();
                updateCustomerInfo();
            };

            const hideItemResults = row => {
                const results = row.querySelector(".js-item-results");
                if (results) {
                    results.style.display = "none";
                    results.innerHTML = "";
                }
            };

            const hideAllItemResults = () => {
                lineBody.querySelectorAll(".js-item-results").forEach(results => {
                    results.style.display = "none";
                    results.innerHTML = "";
                });
            };

            const renderItemResults = (row, query) => {
                const results = row.querySelector(".js-item-results");
                if (!results) {
                    return;
                }

                const keyword = (query || "").trim().toLowerCase();
                const matches = itemLookup
                    .filter(item =>
                        !keyword ||
                        item.ItemCode.toLowerCase().includes(keyword) ||
                        item.ItemName.toLowerCase().includes(keyword) ||
                        (item.PartNumber || "").toLowerCase().includes(keyword))
                    .slice(0, keyword ? 12 : 20);

                if (matches.length === 0) {
                    results.innerHTML = `<div class="search-dropdown-empty">ไม่พบสินค้าที่ตรงกับคำค้น</div>`;
                    results.style.display = "";
                    return;
                }

                results.innerHTML = matches
                    .map(item => `
                        <button type="button" class="search-dropdown-option" data-item-id="${item.ItemId}">
                            <span class="search-dropdown-title">${item.ItemCode} - ${item.ItemName}</span>
                            <span class="search-dropdown-meta">${item.PartNumber || "-"} | ${item.ItemType || "Product"} | ${getResolvedUnitPrice(item).toFixed(2)}</span>
                        </button>`)
                    .join("");
                results.style.display = "";
            };

            const selectItemForRow = (row, item) => {
                row.querySelector(".js-item-id").value = item.ItemId;
                row.querySelector(".js-item-search").value = item.DisplayText;
                hideItemResults(row);
                updateLine(row, true);
                updateSummary();
            };

            const updateCustomerInfo = () => {
                const customer = customerMap[customerInput.value];

                document.getElementById("quotationCustomerName").textContent = getValue(customer?.CustomerName);
                document.getElementById("quotationCustomerTaxId").textContent = getValue(customer?.TaxId);
                document.getElementById("quotationCustomerPhone").textContent = getValue(customer?.Phone);
                document.getElementById("quotationCustomerEmail").textContent = getValue(customer?.Email);
                document.getElementById("quotationCustomerBillingAddress").textContent = getValue(customer?.BillingAddress);
            };

            const updateSalespersonInfo = () => {
                const salesperson = salespersonMap[salespersonSelect.value];
                const getValue = value => value && value.trim() ? value : "-";

                document.getElementById("quotationSalespersonName").textContent = getValue(salesperson?.SalespersonName);
                document.getElementById("quotationSalespersonPhone").textContent = getValue(salesperson?.Phone);
                document.getElementById("quotationSalespersonEmail").textContent = getValue(salesperson?.Email);
            };

            const updateExpiryState = () => {
                expiryInput.disabled = noExpiryInput.checked;
                if (noExpiryInput.checked) {
                    expiryInput.value = "";
                }
            };

            const updateDiscountModeState = () => {
                const isLineMode = discountModeInput.value === "Line";
                    headerDiscountInput.disabled = isLineMode || headerDiscountTypeInput.value === "Percent";
                    headerDiscountPercentInput.disabled = isLineMode || headerDiscountTypeInput.value !== "Percent";
                    if (isLineMode) {
                        headerDiscountInput.value = "0";
                        headerDiscountPercentInput.value = "0";
                        headerDiscountHelp.textContent = "ปิดใช้งานเมื่อเลือกส่วนลดรายบรรทัด";
                        headerDiscountPercentHelp.textContent = "ปิดใช้งานเมื่อเลือกส่วนลดรายบรรทัด";
                        discountModeText.textContent = "โหมดส่วนลดรายบรรทัด: กำหนดส่วนลดในแต่ละรายการ และปิดส่วนลดท้ายเอกสาร";
                    } else {
                        if (headerDiscountTypeInput.value === "Percent") {
                            headerDiscountHelp.textContent = "ระบบจะคำนวณจากเปอร์เซ็นต์ส่วนลดท้ายเอกสารให้อัตโนมัติ";
                            headerDiscountPercentHelp.textContent = "คำนวณจากยอดก่อน VAT";
                        } else {
                            headerDiscountHelp.textContent = "ใช้ได้เฉพาะเมื่อเลือกส่วนลดท้ายเอกสาร";
                            headerDiscountPercentHelp.textContent = "ปิดใช้งานเมื่อประเภทส่วนลดเป็นจำนวนเงิน";
                            headerDiscountPercentInput.value = "0";
                        }
                        discountModeText.textContent = "โหมดส่วนลดท้ายเอกสาร: ปิดส่วนลดรายบรรทัด และคำนวณส่วนลดรวมก่อน VAT";
                    }

                    lineBody.querySelectorAll(".quotation-line-row-main").forEach(row => {
                        const lineDiscountTypeInput = row.querySelector(".js-line-discount-type");
                        const lineDiscountPercentInput = row.querySelector(".js-line-discount-percent");
                        const lineDiscountInput = row.querySelector(".js-line-discount");
                        lineDiscountTypeInput.disabled = !isLineMode;
                        lineDiscountPercentInput.disabled = !isLineMode || lineDiscountTypeInput.value !== "Percent";
                        lineDiscountInput.disabled = !isLineMode || lineDiscountTypeInput.value === "Percent";
                        if (!isLineMode) {
                            lineDiscountTypeInput.value = "Amount";
                            lineDiscountPercentInput.value = "0";
                            lineDiscountInput.value = "0";
                        }
                        updateLine(row, false);
                });
            };

            const resolveItem = row => {
                const itemIdInput = row.querySelector(".js-item-id");
                const searchInput = row.querySelector(".js-item-search");
                const fromId = itemIdInput.value ? itemMap[itemIdInput.value] : null;
                if (fromId) {
                    return fromId;
                }
                return itemDisplayMap[(searchInput.value || "").trim().toLowerCase()] ?? null;
            };

            const updateLine = (row, syncItemFields) => {
                const itemIdInput = row.querySelector(".js-item-id");
                const itemSearch = row.querySelector(".js-item-search");
                const detailRow = row.nextElementSibling;
                const description = detailRow.querySelector(".js-line-description");
                const quantity = row.querySelector(".js-line-quantity");
                const unitPrice = row.querySelector(".js-line-unit-price");
                const discountType = row.querySelector(".js-line-discount-type");
                const discountPercent = row.querySelector(".js-line-discount-percent");
                const discount = row.querySelector(".js-line-discount");
                const netPrice = row.querySelector(".js-line-net-price");
                const total = row.querySelector(".js-line-total");
                const stockHint = row.querySelector(".js-stock-hint");
                const selectedItem = resolveItem(row);
                const isLineMode = discountModeInput.value === "Line";
                const previousAutoPrice = parseFloat(row.dataset.resolvedUnitPrice || "0");

                itemIdInput.value = selectedItem ? selectedItem.ItemId : "";
                if (selectedItem && syncItemFields) {
                    itemSearch.value = selectedItem.DisplayText;
                }

                if (selectedItem) {
                    const resolvedPrice = getResolvedUnitPrice(selectedItem);
                    const currentPrice = parseFloat(unitPrice.value || "0");
                    if (syncItemFields) {
                        description.value = selectedItem.ItemName;
                    }

                    if (currentPrice <= 0 || Math.abs(currentPrice - previousAutoPrice) < 0.0001) {
                        unitPrice.value = resolvedPrice.toFixed(2);
                    }

                    row.dataset.resolvedUnitPrice = resolvedPrice.toFixed(2);
                } else {
                    row.dataset.resolvedUnitPrice = "";
                }

                if (selectedItem && syncItemFields) {
                    description.value = selectedItem.ItemName;
                }

                if (stockHint) {
                    stockHint.textContent = formatStockHint(selectedItem);
                }

                const qty = parseFloat(quantity.value || "0");
                const price = parseFloat(unitPrice.value || "0");
                const gross = qty * price;
                let discountValue = 0;
                if (isLineMode) {
                    if (discountType.value === "Percent") {
                        const percentValue = parseFloat(discountPercent.value || "0");
                        discountValue = Math.min(Math.max(gross * percentValue / 100, 0), gross);
                        discount.value = discountValue.toFixed(2);
                    } else {
                        discountValue = parseFloat(discount.value || "0");
                        const normalizedPercent = gross > 0 ? (discountValue / gross) * 100 : 0;
                        discountPercent.value = normalizedPercent.toFixed(4);
                    }
                }
                const lineTotal = Math.max((qty * price) - discountValue, 0);
                const netUnitPrice = qty > 0 ? lineTotal / qty : 0;
                netPrice.value = netUnitPrice.toFixed(2);
                total.value = lineTotal.toFixed(2);
            };

            const updateSummary = () => {
                let subtotal = 0;
                let discount = 0;
                const isLineMode = discountModeInput.value === "Line";
                let headerDiscount = parseFloat(headerDiscountInput.value || "0");

                lineBody.querySelectorAll(".quotation-line-row-main").forEach(row => {
                    const qty = parseFloat(row.querySelector(".js-line-quantity").value || "0");
                    const price = parseFloat(row.querySelector(".js-line-unit-price").value || "0");
                    const discountValue = isLineMode ? parseFloat(row.querySelector(".js-line-discount").value || "0") : 0;
                    if (isLineMode) {
                        subtotal += Math.max((qty * price) - discountValue, 0);
                        discount += discountValue;
                    } else {
                        subtotal += qty * price;
                    }
                });

                if (!isLineMode) {
                    if (headerDiscountTypeInput.value === "Percent") {
                        const headerPercent = parseFloat(headerDiscountPercentInput.value || "0");
                        headerDiscount = Math.min(Math.max(subtotal * headerPercent / 100, 0), subtotal);
                        headerDiscountInput.value = headerDiscount.toFixed(2);
                    } else {
                        const headerPercent = subtotal > 0 ? (headerDiscount / subtotal) * 100 : 0;
                        headerDiscountPercentInput.value = headerPercent.toFixed(4);
                    }
                }

                const netBeforeVat = isLineMode ? subtotal : Math.max(subtotal - headerDiscount, 0);
                const vat = vatTypeInput.value === "VAT" ? (netBeforeVat * 0.07) : 0;
                document.getElementById("quotationHeaderSubtotal").textContent = subtotal.toFixed(2);
                document.getElementById("quotationHeaderDiscount").textContent = (isLineMode ? discount : headerDiscount).toFixed(2);
                document.getElementById("quotationHeaderNet").textContent = netBeforeVat.toFixed(2);
                document.getElementById("quotationHeaderVat").textContent = vat.toFixed(2);
                document.getElementById("quotationHeaderTotal").textContent = (netBeforeVat + vat).toFixed(2);
                document.getElementById("quotationSubtotal").textContent = subtotal.toFixed(2);
                document.getElementById("quotationDiscount").textContent = (isLineMode ? discount : headerDiscount).toFixed(2);
                document.getElementById("quotationNet").textContent = netBeforeVat.toFixed(2);
                document.getElementById("quotationVat").textContent = vat.toFixed(2);
                document.getElementById("quotationTotal").textContent = (netBeforeVat + vat).toFixed(2);
            };

            const refreshAutoPricedRows = () => {
                lineBody.querySelectorAll(".quotation-line-row-main").forEach(row => {
                    updateLine(row, false);
                });
                updateSummary();
            };

            lineBody.addEventListener("click", event => {
                if (!event.target.classList.contains("js-remove-line")) {
                    return;
                }

                const rows = lineBody.querySelectorAll(".quotation-line-row-main");
                if (rows.length === 1) {
                    return;
                }

                const mainRow = event.target.closest(".quotation-line-row-main");
                const detailRow = mainRow.nextElementSibling;
                detailRow?.remove();
                mainRow.remove();
                reindexRows();
                updateSummary();
            });

            addButton.addEventListener("click", () => {
                const rows = createRow(lineBody.querySelectorAll(".quotation-line-row-main").length);
                rows.forEach(row => lineBody.appendChild(row));
                updateDiscountModeState();
            });

            discountModeInput.addEventListener("change", () => {
                updateDiscountModeState();
                updateSummary();
            });
            headerDiscountTypeInput.addEventListener("change", () => {
                updateDiscountModeState();
                updateSummary();
            });
            vatTypeInput.addEventListener("change", updateSummary);
            headerDiscountInput.addEventListener("input", updateSummary);
            headerDiscountPercentInput.addEventListener("input", updateSummary);
            salespersonSelect.addEventListener("change", updateSalespersonInfo);
            noExpiryInput.addEventListener("change", updateExpiryState);
            branchInput?.addEventListener("change", refreshBranchStock);
            priceLevelInput?.addEventListener("change", refreshAutoPricedRows);

            customerSearch.addEventListener("input", () => {
                delete customerSearch.dataset.selectedCustomerId;
                customerInput.value = "";
                updateCustomerInfo();
                renderCustomerResults(customerSearch.value);
            });

            customerSearch.addEventListener("focus", () => {
                renderCustomerResults(customerSearch.value);
            });

            customerSearch.addEventListener("change", () => {
                const selectedId = customerSearch.dataset.selectedCustomerId;
                if (selectedId && customerMap[selectedId]) {
                    selectCustomer(customerMap[selectedId]);
                    return;
                }

                const match = customerLookup.find(customer =>
                    `${customer.CustomerCode || "-"} - ${customer.CustomerName}`.toLowerCase() === (customerSearch.value || "").trim().toLowerCase() ||
                    customer.CustomerName.toLowerCase() === (customerSearch.value || "").trim().toLowerCase());
                if (match) {
                    selectCustomer(match);
                } else {
                    customerInput.value = "";
                    updateCustomerInfo();
                }
            });

            customerResults.addEventListener("click", event => {
                const option = event.target.closest(".search-dropdown-option");
                if (!option) {
                    return;
                }

                const customer = customerMap[option.dataset.customerId];
                if (customer) {
                    selectCustomer(customer);
                }
            });

            lineBody.querySelectorAll(".quotation-line-row-main").forEach(row => updateLine(row, false));
            lineBody.addEventListener("input", event => {
                if (event.target.classList.contains("js-item-search")) {
                    const row = event.target.closest(".quotation-line-row-main");
                    row.querySelector(".js-item-id").value = "";
                    renderItemResults(row, event.target.value);
                    updateLine(row, false);
                    updateSummary();
                    return;
                }

                const row = event.target.closest(".quotation-line-row-main");
                if (!row) {
                    return;
                }

                updateLine(row, false);
                updateSummary();
            });

            lineBody.addEventListener("change", event => {
                const row = event.target.closest(".quotation-line-row-main");
                if (!row) {
                    return;
                }

                if (event.target.classList.contains("js-line-discount-type")) {
                    updateDiscountModeState();
                } else {
                    updateLine(row, false);
                }
                updateSummary();
            });

            lineBody.addEventListener("focusin", event => {
                if (event.target.classList.contains("js-item-search")) {
                    const row = event.target.closest(".quotation-line-row-main");
                    renderItemResults(row, event.target.value);
                }
            });

            lineBody.addEventListener("click", event => {
                const option = event.target.closest(".search-dropdown-option");
                if (option && option.dataset.itemId) {
                    const row = option.closest(".quotation-line-row-main");
                    const item = itemMap[option.dataset.itemId];
                    if (row && item) {
                        selectItemForRow(row, item);
                    }
                    return;
                }
            });

            document.addEventListener("click", event => {
                const clickedCustomer = event.target === customerSearch || customerResults.contains(event.target);
                if (!clickedCustomer) {
                    hideCustomerResults();
                }

                const clickedItem = event.target.closest(".search-dropdown");
                if (!clickedItem || !lineBody.contains(clickedItem)) {
                    hideAllItemResults();
                }
            });

            if (customerInput.value && customerMap[customerInput.value]) {
                const customer = customerMap[customerInput.value];
                customerSearch.value = `${customer.CustomerCode || "-"} - ${customer.CustomerName}`;
                customerSearch.dataset.selectedCustomerId = customerInput.value;
            }
            updateCustomerInfo();
            updateSalespersonInfo();
            updateExpiryState();
            updateDiscountModeState();
            updateSummary();
        })();
    </script>
}
