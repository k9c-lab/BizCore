@model BizCore.Models.ViewModels.RolePermissionPageViewModel

@{
    ViewData["Title"] = "Role Permissions";
}

@if (TempData["RolePermissionNotice"] is string notice && !string.IsNullOrWhiteSpace(notice))
{
    @await Html.PartialAsync("_Notice", notice)
}

<div class="page-header">
    <div>
        <div class="page-eyebrow">Administration</div>
        <h1 class="page-title">Role Permissions</h1>
        <p class="page-subtitle">จัดสิทธิ์เป็นหมวดหลัก แล้วแยกตามเมนูย่อยเพื่อให้มองภาพรวมและกำหนดสิทธิ์ได้ง่ายขึ้น</p>
    </div>
    <div class="page-actions">
        <a asp-controller="Users" asp-action="Index" class="btn btn-outline-secondary">Users</a>
    </div>
</div>

<div class="card content-card">
    <div class="card-body">
        <form method="get" class="list-filter-bar mb-4">
            <div class="list-filter-field">
                <label class="form-label" for="role">Role</label>
                <select id="role" name="role" asp-for="SelectedRole" asp-items="Model.RoleOptions" class="form-select" onchange="this.form.submit()"></select>
            </div>
            <div class="list-filter-actions">
                <button type="submit" class="btn btn-primary">Load</button>
            </div>
        </form>

        <form asp-action="Save" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="selectedRole" value="@Model.SelectedRole" />

            <div class="permission-page-summary">
                <div class="permission-summary-card">
                    <span class="permission-summary-label">Role</span>
                    <strong class="permission-summary-value">@Model.SelectedRole</strong>
                </div>
                <div class="permission-summary-card">
                    <span class="permission-summary-label">Granted</span>
                    <strong class="permission-summary-value">@Model.GrantedCount / @Model.PermissionCount</strong>
                </div>
                <div class="permission-summary-card">
                    <span class="permission-summary-label">Sections</span>
                    <strong class="permission-summary-value">@Model.Modules.Count</strong>
                </div>
            </div>

            <div class="form-shell">
                @foreach (var module in Model.Modules)
                {
                    <section class="permission-module-card">
                        <div class="permission-module-header">
                            <div>
                                <div class="permission-module-title">@module.Module</div>
                                @if (!string.IsNullOrWhiteSpace(module.Description))
                                {
                                    <div class="permission-module-text">@module.Description</div>
                                }
                            </div>
                            <div class="permission-module-meta">@module.GrantedCount / @module.PermissionCount selected</div>
                        </div>

                        <div class="permission-group-grid">
                            @foreach (var group in module.Groups)
                            {
                                <div class="permission-group-card" data-permission-group>
                                    <div class="permission-group-header">
                                        <div>
                                            <div class="permission-group-title">@group.Title</div>
                                            <div class="permission-group-meta">@group.GrantedCount / @group.PermissionCount selected</div>
                                        </div>
                                        <div class="permission-group-actions">
                                            <button type="button" class="btn btn-sm btn-outline-secondary" data-group-toggle="all">All</button>
                                            <button type="button" class="btn btn-sm btn-outline-secondary" data-group-toggle="none">None</button>
                                        </div>
                                    </div>

                                    <div class="permission-item-stack">
                                        @foreach (var permission in group.Permissions)
                                        {
                                            <label class="permission-option permission-option-compact">
                                                <input class="form-check-input" type="checkbox" name="permissionIds" value="@permission.PermissionId" checked="@permission.IsGranted" />
                                                <span class="permission-option-content">
                                                    <span class="permission-option-topline">
                                                        <strong>@permission.DisplayName</strong>
                                                        <span class="permission-kind-badge">@permission.KindLabel</span>
                                                    </span>
                                                    <small>@permission.Name</small>
                                                    <span class="permission-code">@permission.Code</span>
                                                </span>
                                            </label>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    </section>
                }
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary px-4">Save Permissions</button>
                <a asp-action="Index" asp-route-role="@Model.SelectedRole" class="btn btn-outline-secondary">Reset</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("click", function (event) {
            const button = event.target.closest("[data-group-toggle]");
            if (!button) {
                return;
            }

            const group = button.closest("[data-permission-group]");
            if (!group) {
                return;
            }

            const shouldCheck = button.getAttribute("data-group-toggle") === "all";
            const checkboxes = group.querySelectorAll("input[type='checkbox'][name='permissionIds']");
            checkboxes.forEach(function (checkbox) {
                checkbox.checked = shouldCheck;
            });
        });
    </script>
}
