@model BizCore.Models.ViewModels.CustomerClaimFormViewModel

@{
    ViewData["Title"] = "New Customer Claim";
}

<div class="page-header">
    <div>
        <div class="page-eyebrow">Warranty Module</div>
        <h1 class="page-title">New Customer Claim</h1>
        <p class="page-subtitle">Create a customer warranty claim from the selected sold serial.</p>
    </div>
    <div class="page-actions">
        <a asp-action="Index" class="btn btn-outline-secondary">Back to Claims</a>
    </div>
</div>

@if (Model.IsClaimBlocked)
{
    <div class="workflow-info mb-3">@Model.ClaimBlockMessage</div>
}

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()
    <input asp-for="SerialId" type="hidden" />

    <div class="card content-card">
        <div class="card-body form-shell">
            <div asp-validation-summary="ModelOnly" class="form-alert"></div>

            <div class="form-section">
                <div class="form-section-title">Claim Information</div>
                <div class="detail-grid">
                    <div class="detail-item"><span class="detail-label">Claim No.</span><p class="detail-value">@Model.CustomerClaimNo</p></div>
                    <div class="detail-item"><span class="detail-label">Current Serial Status</span><p class="detail-value">@Model.CurrentSerialStatus</p></div>
                    <div class="detail-item">
                        <label asp-for="CustomerClaimDate" class="detail-label"></label>
                        <input asp-for="CustomerClaimDate" type="date" class="form-control" />
                        <span asp-validation-for="CustomerClaimDate" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div class="form-section">
                <div class="form-section-title">Customer</div>
                <div class="quotation-info-card">
                    <div class="quotation-info-card-title">Customer Information</div>
                    <div class="quotation-info-grid">
                        <div class="quotation-info-field">
                            <span class="quotation-info-label">Customer Name</span>
                            <span class="quotation-info-value">@Model.CustomerName</span>
                        </div>
                        <div class="quotation-info-field">
                            <span class="quotation-info-label">Customer Code</span>
                            <span class="quotation-info-value">@Model.CustomerCode</span>
                        </div>
                    </div>
                    <div class="quotation-info-field">
                        <span class="quotation-info-label">Invoice No.</span>
                        <span class="quotation-info-value">@Model.InvoiceNo</span>
                    </div>
                </div>
            </div>

            <div class="form-section">
                <div class="form-section-title">Serial / Item</div>
                <div class="quotation-info-card">
                    <div class="quotation-info-card-title">Serial / Item Information</div>
                    <div class="quotation-info-grid">
                        <div class="quotation-info-field">
                            <span class="quotation-info-label">Serial No.</span>
                            <span class="quotation-info-value">@Model.SerialNo</span>
                        </div>
                        <div class="quotation-info-field">
                            <span class="quotation-info-label">Serial Status</span>
                            <span class="quotation-info-value">@Model.CurrentSerialStatus</span>
                        </div>
                    </div>
                    <div class="quotation-info-grid">
                        <div class="quotation-info-field">
                            <span class="quotation-info-label">Item</span>
                            <span class="quotation-info-value">@Model.ItemCode - @Model.ItemName</span>
                        </div>
                        <div class="quotation-info-field">
                            <span class="quotation-info-label">Part Number</span>
                            <span class="quotation-info-value">@(string.IsNullOrWhiteSpace(Model.PartNumber) ? "-" : Model.PartNumber)</span>
                        </div>
                    </div>
                    <div class="quotation-info-field">
                        <span class="quotation-info-label">Customer Warranty</span>
                        <span class="quotation-info-value">@(Model.CustomerWarrantyStartDate?.ToString("dd MMM yyyy") ?? "-") to @(Model.CustomerWarrantyEndDate?.ToString("dd MMM yyyy") ?? "-")</span>
                    </div>
                </div>
            </div>

            <div class="form-section">
                <div class="form-section-title">Problem</div>
                <div class="row g-3">
                    <div class="col-12">
                        <label asp-for="ProblemDescription" class="form-label"></label>
                        <textarea asp-for="ProblemDescription" class="form-control" rows="4"></textarea>
                        <span asp-validation-for="ProblemDescription" class="text-danger"></span>
                    </div>
                    <div class="col-12">
                        <label asp-for="Remark" class="form-label"></label>
                        <textarea asp-for="Remark" class="form-control" rows="2"></textarea>
                        <span asp-validation-for="Remark" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div class="form-actions">
                <span class="table-meta">Saving this claim changes the serial status to CustomerClaim.</span>
                <div class="page-actions">
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    @if (Model.IsClaimBlocked)
                    {
                        <button type="submit" class="btn btn-primary px-4" disabled>Save Claim</button>
                    }
                    else
                    {
                        <button type="submit" class="btn btn-primary px-4">Save Claim</button>
                    }
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
