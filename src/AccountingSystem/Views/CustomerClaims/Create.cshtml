@model BizCore.Models.ViewModels.CustomerClaimFormViewModel

@{
    ViewData["Title"] = "สร้างเคลมลูกค้า";
}

<div class="page-header">
    <div>
        <div class="page-eyebrow">โมดูลรับประกัน</div>
        <h1 class="page-title">สร้างเคลมลูกค้า</h1>
        </div>
    <div class="page-actions">
        <a asp-action="Index" class="btn btn-outline-secondary">กลับไปรายการเคลม</a>
    </div>
</div>

@if (Model.IsClaimBlocked)
{
    <div class="workflow-info workflow-info-danger mb-3">@Model.ClaimBlockMessage</div>
}

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()
    <input asp-for="SerialId" type="hidden" />

    <div class="card content-card">
        <div class="card-body form-shell">
            <div asp-validation-summary="All" class="form-alert"></div>

            <div class="form-section">
                <div class="form-section-title">ข้อมูลเคลม</div>
                <div class="detail-grid">
                    <div class="detail-item"><span class="detail-label">เลขที่เคลม</span><p class="detail-value">@Model.CustomerClaimNo</p></div>
                    <div class="detail-item"><span class="detail-label">สถานะ Serial ปัจจุบัน</span><p class="detail-value">@Model.CurrentSerialStatus</p></div>
                    <div class="detail-item">
                        <label asp-for="CustomerClaimDate" class="detail-label"></label>
                        <input asp-for="CustomerClaimDate" type="date" class="form-control" />
                        <span asp-validation-for="CustomerClaimDate" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div class="form-section">
                <div class="form-section-title">ลูกค้า</div>
                <div class="quotation-info-card">
                    <div class="quotation-info-card-title">ข้อมูลลูกค้า</div>
                    <div class="quotation-info-grid">
                        <div class="quotation-info-field">
                            <span class="quotation-info-label">ชื่อลูกค้า</span>
                            <span class="quotation-info-value">@Model.CustomerName</span>
                        </div>
                        <div class="quotation-info-field">
                            <span class="quotation-info-label">รหัสลูกค้า</span>
                            <span class="quotation-info-value">@Model.CustomerCode</span>
                        </div>
                    </div>
                    <div class="quotation-info-field">
                        <span class="quotation-info-label">เลขที่ใบแจ้งหนี้</span>
                        <span class="quotation-info-value">@Model.InvoiceNo</span>
                    </div>
                </div>
            </div>

            <div class="form-section">
                <div class="form-section-title">Serial / สินค้า</div>
                <div class="quotation-info-card">
                    <div class="quotation-info-card-title">ข้อมูล Serial / สินค้า</div>
                    <div class="quotation-info-grid">
                        <div class="quotation-info-field">
                            <span class="quotation-info-label">หมายเลข Serial</span>
                            <span class="quotation-info-value">@Model.SerialNo</span>
                        </div>
                        <div class="quotation-info-field">
                            <span class="quotation-info-label">สถานะ Serial</span>
                            <span class="quotation-info-value">@Model.CurrentSerialStatus</span>
                        </div>
                    </div>
                    <div class="quotation-info-grid">
                        <div class="quotation-info-field">
                            <span class="quotation-info-label">สินค้า</span>
                            <span class="quotation-info-value">@Model.ItemCode - @Model.ItemName</span>
                        </div>
                        <div class="quotation-info-field">
                            <span class="quotation-info-label">Part Number</span>
                            <span class="quotation-info-value">@(string.IsNullOrWhiteSpace(Model.PartNumber) ? "-" : Model.PartNumber)</span>
                        </div>
                    </div>
                    <div class="quotation-info-field">
                        <span class="quotation-info-label">ประกันลูกค้า</span>
                        <span class="quotation-info-value">@(Model.CustomerWarrantyStartDate?.ToString("dd MMM yyyy") ?? "-") ถึง @(Model.CustomerWarrantyEndDate?.ToString("dd MMM yyyy") ?? "-")</span>
                    </div>
                </div>
            </div>

            <div class="form-section">
                <div class="form-section-title">อาการ / หมายเหตุ</div>
                <div class="row g-3">
                    <div class="col-12">
                        <label asp-for="ProblemDescription" class="form-label"></label>
                        <textarea asp-for="ProblemDescription" class="form-control" rows="4"></textarea>
                        <span asp-validation-for="ProblemDescription" class="text-danger"></span>
                    </div>
                    <div class="col-12">
                        <label asp-for="Remark" class="form-label"></label>
                        <textarea asp-for="Remark" class="form-control" rows="2"></textarea>
                        <span asp-validation-for="Remark" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div class="form-actions">
                <span class="table-meta">เมื่อบันทึก ระบบจะเปลี่ยนสถานะ Serial เป็น `CustomerClaim`</span>
                <div class="page-actions">
                    <a asp-action="Index" class="btn btn-outline-secondary">ยกเลิก</a>
                    @if (Model.IsClaimBlocked)
                    {
                        <button type="submit" class="btn btn-primary px-4" disabled>บันทึกเคลม</button>
                    }
                    else
                    {
                        <button type="submit" class="btn btn-primary px-4">บันทึกเคลม</button>
                    }
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

