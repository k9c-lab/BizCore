@model BizCore.Models.Entities.CustomerClaimHeader

@{
    ViewData["Title"] = "รายละเอียดเคลมลูกค้า";
    var line = Model.CustomerClaimDetails.FirstOrDefault();
    var serial = line?.SerialNumber;
    var replacementSerial = line?.ReplacementSerialNumber;
    var linkedSupplierClaimId = ViewData["LinkedSupplierClaimId"] is int supplierClaimId ? supplierClaimId : (int?)null;
    var linkedSupplierClaimStatus = ViewData["LinkedSupplierClaimStatus"] as string;
    var replacementSerialOptions = ViewData["ReplacementSerialOptions"] as IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem> ?? Enumerable.Empty<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>();
    var today = DateTime.Today;
    var dateValue = today.ToString("yyyy-MM-dd");
    var canReceiveItem = Model.Status == "Open";
    var receiveBlockedReason = canReceiveItem ? string.Empty : "รับสินค้าได้เฉพาะเคลมลูกค้าที่เพิ่งเปิดใหม่";
    var sendStatusAllowed = Model.Status == "Received" || Model.Status == "Repairing";
    var sendSupplierBlockedReason = string.Empty;
    if (!sendStatusAllowed)
    {
        sendSupplierBlockedReason = Model.Status == "Open"
            ? "กรุณารับสินค้าจากลูกค้าก่อนส่งเคลมผู้ขาย"
            : "ส่งเคลมผู้ขายได้หลังจากรับสินค้าจากลูกค้าแล้วเท่านั้น";
    }
    else if (linkedSupplierClaimId.HasValue)
    {
        sendSupplierBlockedReason = "เคลมลูกค้านี้ถูกผูกกับเคลมผู้ขายแล้ว";
    }
    else if (serial?.SupplierId == null)
    {
        sendSupplierBlockedReason = "ยังส่งเคลมผู้ขายไม่ได้ เพราะ Serial นี้ยังไม่ผูกกับผู้ขาย";
    }
    else if (serial.SupplierWarrantyStartDate.HasValue && today < serial.SupplierWarrantyStartDate.Value.Date)
    {
        sendSupplierBlockedReason = "ยังส่งเคลมผู้ขายไม่ได้ เพราะประกันผู้ขายยังไม่เริ่มต้น";
    }
    else if (serial.SupplierWarrantyEndDate.HasValue && today > serial.SupplierWarrantyEndDate.Value.Date)
    {
        sendSupplierBlockedReason = "ยังส่งเคลมผู้ขายไม่ได้ เพราะประกันผู้ขายหมดอายุแล้ว";
    }
    var canSendToSupplier = string.IsNullOrWhiteSpace(sendSupplierBlockedReason);
    var hasReplacement = line?.ReplacementSerialId.HasValue == true;
    var canReject = !hasReplacement &&
        (Model.Status == "Open" || Model.Status == "Received" || Model.Status == "Repairing" || Model.Status == "SentToSupplier" || Model.Status == "ReadyToReturn");
    var rejectBlockedReason = canReject ? string.Empty : hasReplacement ? "ยังปฏิเสธเคลมไม่ได้ เพราะมีการกำหนด Serial ทดแทนแล้ว" : "ปฏิเสธเคลมได้ก่อนคืนลูกค้า ปิดเคลม หรือยกเลิกเท่านั้น";
    var canRepairComplete = Model.Status == "Received" || Model.Status == "Repairing";
    var repairCompleteBlockedReason = canRepairComplete ? string.Empty : "ทำรายการพร้อมคืนได้หลังจากรับสินค้าจากลูกค้าแล้วเท่านั้น";
    var canReturn = Model.Status == "ReadyToReturn";
    var returnBlockedReason = canReturn ? string.Empty : "คืนลูกค้าได้หลังจากเคลมอยู่ในสถานะพร้อมคืนลูกค้าเท่านั้น";
    var canClose = Model.Status == "ReturnedToCustomer" || Model.Status == "Rejected";
    var closeBlockedReason = canClose ? string.Empty : "ปิดเคลมได้หลังจากคืนลูกค้าหรือปฏิเสธเคลมแล้วเท่านั้น";
    var canCancel = !hasReplacement && (Model.Status == "Open" || Model.Status == "Received" || Model.Status == "Repairing" || Model.Status == "ReadyToReturn");
    var cancelBlockedReason = canCancel ? string.Empty : hasReplacement ? "ยังยกเลิกเคลมไม่ได้ เพราะมีการกำหนด Serial ทดแทนแล้ว" : "ยกเลิกเคลมได้ก่อนจบขั้นตอนส่งคืนผู้ขาย/ลูกค้าเท่านั้น";
    var canAssignReplacement = !hasReplacement &&
        (Model.Status == "Received" || Model.Status == "Repairing" || Model.Status == "SentToSupplier" || Model.Status == "ReadyToReturn") &&
        replacementSerialOptions.Any();
    var replacementBlockedReason = hasReplacement
        ? "มีการกำหนด Serial ทดแทนแล้ว"
        : !(Model.Status == "Received" || Model.Status == "Repairing" || Model.Status == "SentToSupplier" || Model.Status == "ReadyToReturn")
            ? "กำหนด Serial ทดแทนได้เฉพาะช่วงที่เคลมยังดำเนินการอยู่และก่อนคืนลูกค้า"
            : !replacementSerialOptions.Any()
                ? "ไม่พบ Serial ทดแทนสถานะ InStock สำหรับสินค้านี้"
                : string.Empty;
    var canShowHandling = Model.Status == "Received" ||
        Model.Status == "Repairing" ||
        Model.Status == "SentToSupplier" ||
        Model.Status == "ReadyToReturn" ||
        linkedSupplierClaimId.HasValue ||
        replacementSerial is not null;
    var workflowReasons = new[]
    {
        canReceiveItem ? string.Empty : receiveBlockedReason,
        canReturn ? string.Empty : returnBlockedReason,
        canClose ? string.Empty : closeBlockedReason,
        canCancel ? string.Empty : cancelBlockedReason
    }
    .Where(x => !string.IsNullOrWhiteSpace(x))
    .Distinct()
    .ToList();
}

@if (TempData["CustomerClaimNotice"] is string notice && !string.IsNullOrWhiteSpace(notice))
{
    @await Html.PartialAsync("_Notice", notice)
}

<div class="page-header">
    <div>
        <div class="page-eyebrow">โมดูลรับประกัน</div>
        <h1 class="page-title">@Model.CustomerClaimNo</h1>
        <p class="page-subtitle">เคลมลูกค้าสำหรับสินค้าที่ขายแล้วและควบคุม Serial</p>
    </div>
    <div class="page-actions">
        <a asp-action="Index" class="btn btn-outline-secondary">กลับ</a>
        @if (canReceiveItem)
        {
            <form asp-action="ReceiveItem" asp-route-id="@Model.CustomerClaimId" method="post" class="d-inline confirm-popover-form">
                @Html.AntiForgeryToken()
                <div class="confirm-popover-shell">
                    <button type="button" class="btn btn-outline-primary js-confirm-popover-toggle" data-confirm-target="receiveCustomerClaimConfirm_@Model.CustomerClaimId" aria-expanded="false">รับสินค้า</button>
                    <div class="confirm-popover" id="receiveCustomerClaimConfirm_@Model.CustomerClaimId" hidden>
                        <div class="confirm-popover-title">รับสินค้านี้เข้ากระบวนการเคลมหรือไม่?</div>
                        <div class="confirm-popover-text">ระบบจะบันทึกว่ารับสินค้าจากลูกค้าเข้าสู่กระบวนการเคลมแล้ว</div>
                        <div class="confirm-popover-actions">
                            <button type="submit" class="btn btn-sm btn-outline-primary">ยืนยัน</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary js-confirm-popover-cancel">ปิด</button>
                        </div>
                    </div>
                </div>
            </form>
        }
        else
        {
            <button type="button" class="btn btn-outline-secondary" disabled title="@receiveBlockedReason">รับสินค้า</button>
        }
        @if (linkedSupplierClaimId.HasValue)
        {
            <a asp-controller="SupplierClaims" asp-action="Details" asp-route-id="@linkedSupplierClaimId.Value" class="btn btn-outline-primary">เคลมผู้ขาย</a>
        }
        @if (canReturn)
        {
            <form asp-action="ReturnToCustomer" asp-route-id="@Model.CustomerClaimId" method="post" class="d-inline-flex align-items-center gap-2 confirm-popover-form">
                @Html.AntiForgeryToken()
                <input type="date" name="returnedDate" value="@dateValue" class="form-control form-control-sm" title="วันที่คืน" />
                <div class="confirm-popover-shell">
                    <button type="button" class="btn btn-outline-success js-confirm-popover-toggle" data-confirm-target="returnCustomerClaimConfirm_@Model.CustomerClaimId" aria-expanded="false">คืนลูกค้า</button>
                    <div class="confirm-popover" id="returnCustomerClaimConfirm_@Model.CustomerClaimId" hidden>
                        <div class="confirm-popover-title">คืนสินค้านี้ให้ลูกค้าหรือไม่?</div>
                        <div class="confirm-popover-text">สามารถระบุหมายเหตุผลลัพธ์เพิ่มเติมเพื่อบันทึกการคืนสินค้าได้</div>
                        <div class="confirm-popover-field">
                            <label class="confirm-popover-label" for="returnCustomerClaimRemark_@Model.CustomerClaimId">หมายเหตุผลลัพธ์</label>
                            <textarea id="returnCustomerClaimRemark_@Model.CustomerClaimId" name="resolutionRemark" class="form-control" rows="3" placeholder="ระบุหมายเหตุเพิ่มเติม (ถ้ามี)"></textarea>
                        </div>
                        <div class="confirm-popover-actions">
                            <button type="submit" class="btn btn-sm btn-outline-success">ยืนยัน</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary js-confirm-popover-cancel">ปิด</button>
                        </div>
                    </div>
                </div>
            </form>
        }
        else
        {
            <button type="button" class="btn btn-outline-secondary" disabled title="@returnBlockedReason">คืนลูกค้า</button>
        }
        @if (canClose)
        {
            <form asp-action="CloseClaim" asp-route-id="@Model.CustomerClaimId" method="post" class="d-inline-flex align-items-center gap-2 confirm-popover-form">
                @Html.AntiForgeryToken()
                <input type="date" name="closedDate" value="@dateValue" class="form-control form-control-sm" title="วันที่ปิดเคลม" />
                <div class="confirm-popover-shell">
                    <button type="button" class="btn btn-primary js-confirm-popover-toggle" data-confirm-target="closeCustomerClaimConfirm_@Model.CustomerClaimId" aria-expanded="false">ปิดเคลม</button>
                    <div class="confirm-popover" id="closeCustomerClaimConfirm_@Model.CustomerClaimId" hidden>
                        <div class="confirm-popover-title">ปิดเคลมลูกค้านี้หรือไม่?</div>
                        <div class="confirm-popover-text">ระบบจะปิดเคลมหลังจากคืนลูกค้าหรือปฏิเสธเคลมเสร็จแล้ว</div>
                        <div class="confirm-popover-actions">
                            <button type="submit" class="btn btn-sm btn-outline-primary">ยืนยัน</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary js-confirm-popover-cancel">ปิด</button>
                        </div>
                    </div>
                </div>
            </form>
        }
        else
        {
            <button type="button" class="btn btn-outline-secondary" disabled title="@closeBlockedReason">ปิดเคลม</button>
        }
        @if (canCancel)
        {
            <form asp-action="Cancel" asp-route-id="@Model.CustomerClaimId" method="post" class="d-inline confirm-popover-form">
                @Html.AntiForgeryToken()
                <div class="confirm-popover-shell">
                    <button type="button" class="btn btn-outline-danger js-confirm-popover-toggle" data-confirm-target="cancelCustomerClaimConfirm_@Model.CustomerClaimId" aria-expanded="false">ยกเลิกเคลม</button>
                    <div class="confirm-popover" id="cancelCustomerClaimConfirm_@Model.CustomerClaimId" hidden>
                        <div class="confirm-popover-title">ยกเลิกเคลมลูกค้านี้หรือไม่?</div>
                        <div class="confirm-popover-text">ระบบจะยกเลิกเคลมและคืนสถานะ Serial เดิมเป็น Sold</div>
                        <div class="confirm-popover-field">
                            <label class="confirm-popover-label" for="cancelCustomerClaimReason_@Model.CustomerClaimId">เหตุผลที่ยกเลิก</label>
                            <textarea id="cancelCustomerClaimReason_@Model.CustomerClaimId" name="cancelReason" class="form-control" rows="3" placeholder="ระบุเหตุผลเพิ่มเติม (ถ้ามี)"></textarea>
                        </div>
                        <div class="confirm-popover-actions">
                            <button type="submit" class="btn btn-sm btn-outline-danger">ยืนยัน</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary js-confirm-popover-cancel">ปิด</button>
                        </div>
                    </div>
                </div>
            </form>
        }
        else
        {
            <button type="button" class="btn btn-outline-secondary" disabled title="@cancelBlockedReason">ยกเลิกเคลม</button>
        }
    </div>
</div>

@if (workflowReasons.Any())
{
    <div class="workflow-info mb-3">
        @foreach (var reason in workflowReasons)
        {
            <div>@reason</div>
        }
    </div>
}

<div class="card content-card">
    <div class="card-body form-shell">
        <div class="form-section">
            <div class="form-section-title">ข้อมูลเคลม</div>
            <div class="detail-grid">
                <div class="detail-item"><span class="detail-label">เลขที่เคลม</span><p class="detail-value">@Model.CustomerClaimNo</p></div>
                <div class="detail-item"><span class="detail-label">วันที่เคลม</span><p class="detail-value">@Model.CustomerClaimDate.ToString("dd MMM yyyy")</p></div>
                <div class="detail-item"><span class="detail-label">สถานะ</span><p class="detail-value"><span class="status-pill @(Model.Status == "Open" ? "active" : "inactive")">@(Model.Status == "Open" ? "เปิดเคลม" : Model.Status == "Received" ? "รับสินค้าแล้ว" : Model.Status == "SentToSupplier" ? "ส่งเคลมผู้ขาย" : Model.Status == "Repairing" ? "กำลังซ่อม" : Model.Status == "ReadyToReturn" ? "พร้อมคืนลูกค้า" : Model.Status == "ReturnedToCustomer" ? "คืนลูกค้าแล้ว" : Model.Status == "Rejected" ? "ปฏิเสธเคลม" : Model.Status == "Closed" ? "ปิดเคลม" : Model.Status == "Cancelled" ? "ยกเลิก" : Model.Status)</span></p></div>
                <div class="detail-item"><span class="detail-label">เลขที่ใบแจ้งหนี้</span><p class="detail-value">@(Model.InvoiceHeader?.InvoiceNo ?? "-")</p></div>
            </div>
        </div>

        <div class="form-section">
            <div class="form-section-title">Customer</div>
            <div class="quotation-info-card">
                <div class="quotation-info-card-title">Customer Information</div>
                <div class="quotation-info-grid">
                    <div class="quotation-info-field">
                        <span class="quotation-info-label">Customer Name</span>
                        <span class="quotation-info-value">@Model.Customer?.CustomerName</span>
                    </div>
                    <div class="quotation-info-field">
                        <span class="quotation-info-label">Customer Code</span>
                        <span class="quotation-info-value">@(Model.Customer?.CustomerCode ?? "-")</span>
                    </div>
                </div>
                <div class="quotation-info-grid">
                    <div class="quotation-info-field">
                        <span class="quotation-info-label">Phone</span>
                        <span class="quotation-info-value">@(string.IsNullOrWhiteSpace(Model.Customer?.PhoneNumber) ? "-" : Model.Customer!.PhoneNumber)</span>
                    </div>
                    <div class="quotation-info-field">
                        <span class="quotation-info-label">Email</span>
                        <span class="quotation-info-value">@(string.IsNullOrWhiteSpace(Model.Customer?.Email) ? "-" : Model.Customer!.Email)</span>
                    </div>
                </div>
                <div class="quotation-info-field">
                    <span class="quotation-info-label">Address</span>
                    <span class="quotation-info-value">@(string.IsNullOrWhiteSpace(Model.Customer?.Address) ? "-" : Model.Customer!.Address)</span>
                </div>
            </div>
        </div>

        <div class="form-section">
            <div class="form-section-title">Serial / Item</div>
            <div class="quotation-info-card">
                <div class="quotation-info-card-title">Serial / Item Information</div>
                <div class="quotation-info-grid">
                    <div class="quotation-info-field">
                        <span class="quotation-info-label">Serial No.</span>
                        <span class="quotation-info-value">@line?.SerialNumber?.SerialNo</span>
                    </div>
                    <div class="quotation-info-field">
                        <span class="quotation-info-label">Serial Status</span>
                        <span class="quotation-info-value">@line?.SerialNumber?.Status</span>
                    </div>
                </div>
                <div class="quotation-info-grid">
                    <div class="quotation-info-field">
                        <span class="quotation-info-label">Item</span>
                        <span class="quotation-info-value">@line?.Item?.ItemCode - @line?.Item?.ItemName</span>
                    </div>
                    <div class="quotation-info-field">
                        <span class="quotation-info-label">Part Number</span>
                        <span class="quotation-info-value">@(string.IsNullOrWhiteSpace(line?.Item?.PartNumber) ? "-" : line.Item.PartNumber)</span>
                    </div>
                </div>
                <div class="quotation-info-field">
                    <span class="quotation-info-label">Customer Warranty</span>
                    <span class="quotation-info-value">@(line?.SerialNumber?.CustomerWarrantyStartDate?.ToString("dd MMM yyyy") ?? "-") to @(line?.SerialNumber?.CustomerWarrantyEndDate?.ToString("dd MMM yyyy") ?? "-")</span>
                </div>
            </div>
        </div>

        @if (canShowHandling)
        {
            <div class="form-section">
                <div class="form-section-title">Claim Handling</div>
                <div class="quotation-party-grid">
                    <div class="quotation-party-column">
                        <div class="quotation-info-card">
                            <div class="quotation-info-card-title">Send To Supplier Repair</div>
                            @if (linkedSupplierClaimId.HasValue)
                            {
                                <div class="quotation-info-grid">
                                    <div class="quotation-info-field">
                                        <span class="quotation-info-label">Supplier Claim</span>
                                        <span class="quotation-info-value">
                                            <a asp-controller="SupplierClaims" asp-action="Details" asp-route-id="@linkedSupplierClaimId.Value">#@linkedSupplierClaimId.Value</a>
                                        </span>
                                    </div>
                                    <div class="quotation-info-field">
                                        <span class="quotation-info-label">Status</span>
                                        <span class="quotation-info-value">@(linkedSupplierClaimStatus ?? "-")</span>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <form asp-action="SendToSupplier" asp-route-id="@Model.CustomerClaimId" method="post" class="row g-2 align-items-end confirm-popover-form">
                                    @Html.AntiForgeryToken()
                                    <div class="col">
                                        <label class="quotation-info-label" for="sentToSupplierDate">Sent Date</label>
                                        <input id="sentToSupplierDate" name="sentToSupplierDate" type="date" value="@dateValue" class="form-control" disabled="@(!canSendToSupplier)" />
                                    </div>
                                    <div class="col-auto">
                                        <div class="confirm-popover-shell">
                                            <button type="button" class="btn btn-outline-primary js-confirm-popover-toggle" disabled="@(!canSendToSupplier)" title="@sendSupplierBlockedReason" data-confirm-target="sendSupplierCustomerClaimConfirm_@Model.CustomerClaimId" aria-expanded="false">Send Supplier</button>
                                            <div class="confirm-popover" id="sendSupplierCustomerClaimConfirm_@Model.CustomerClaimId" hidden>
                                                <div class="confirm-popover-title">Send this item to supplier?</div>
                                                <div class="confirm-popover-text">This will create a linked supplier claim for the claimed serial.</div>
                                                <div class="confirm-popover-actions">
                                                    <button type="submit" class="btn btn-sm btn-outline-primary">Confirm</button>
                                                    <button type="button" class="btn btn-sm btn-outline-secondary js-confirm-popover-cancel">Cancel</button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </form>
                                @if (!string.IsNullOrWhiteSpace(sendSupplierBlockedReason))
                                {
                                    <div class="form-text">@sendSupplierBlockedReason</div>
                                }
                            }
                        </div>
                    </div>

                    <div class="quotation-party-column">
                        <div class="quotation-info-card">
                            <div class="quotation-info-card-title">Replace For Customer</div>
                            @if (replacementSerial is not null)
                            {
                                <div class="quotation-info-grid">
                                    <div class="quotation-info-field">
                                        <span class="quotation-info-label">Replacement Serial</span>
                                        <span class="quotation-info-value">@replacementSerial.SerialNo</span>
                                    </div>
                                    <div class="quotation-info-field">
                                        <span class="quotation-info-label">Status</span>
                                        <span class="quotation-info-value">@replacementSerial.Status</span>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <form asp-action="AssignReplacement" asp-route-id="@Model.CustomerClaimId" method="post" class="row g-2 align-items-end confirm-popover-form">
                                    @Html.AntiForgeryToken()
                                    <div class="col">
                                        <label class="quotation-info-label" for="replacementSerialId">Replacement Serial</label>
                                        <select id="replacementSerialId" name="replacementSerialId" class="form-select" disabled="@(!canAssignReplacement)">
                                            <option value="">Select replacement serial</option>
                                            @foreach (var option in replacementSerialOptions)
                                            {
                                                <option value="@option.Value">@option.Text</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="col-auto">
                                        <div class="confirm-popover-shell">
                                            <button type="button" class="btn btn-outline-primary js-confirm-popover-toggle" disabled="@(!canAssignReplacement)" title="@replacementBlockedReason" data-confirm-target="assignReplacementCustomerClaimConfirm_@Model.CustomerClaimId" aria-expanded="false">Assign Replacement</button>
                                            <div class="confirm-popover" id="assignReplacementCustomerClaimConfirm_@Model.CustomerClaimId" hidden>
                                                <div class="confirm-popover-title">Assign this replacement serial?</div>
                                                <div class="confirm-popover-text">This will link the selected replacement serial to the customer claim.</div>
                                                <div class="confirm-popover-actions">
                                                    <button type="submit" class="btn btn-sm btn-outline-primary">Confirm</button>
                                                    <button type="button" class="btn btn-sm btn-outline-secondary js-confirm-popover-cancel">Cancel</button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </form>
                                @if (!string.IsNullOrWhiteSpace(replacementBlockedReason))
                                {
                                    <div class="form-text">@replacementBlockedReason</div>
                                }
                            }
                        </div>
                    </div>

                    <div class="quotation-party-column">
                        <div class="quotation-info-card">
                            <div class="quotation-info-card-title">Reject Claim</div>
                            <form asp-action="RejectClaim" asp-route-id="@Model.CustomerClaimId" method="post" class="row g-2 align-items-end confirm-popover-form">
                                @Html.AntiForgeryToken()
                                <div class="col">
                                    <label class="quotation-info-label" for="rejectResolutionRemark">Reject Reason</label>
                                    <input id="rejectResolutionRemark" name="resolutionRemark" class="form-control" disabled="@(!canReject)" />
                                </div>
                                <div class="col-auto">
                                    <div class="confirm-popover-shell">
                                        <button type="button" class="btn btn-outline-danger js-confirm-popover-toggle" disabled="@(!canReject)" title="@rejectBlockedReason" data-confirm-target="rejectCustomerClaimConfirm_@Model.CustomerClaimId" aria-expanded="false">Reject</button>
                                        <div class="confirm-popover" id="rejectCustomerClaimConfirm_@Model.CustomerClaimId" hidden>
                                            <div class="confirm-popover-title">Reject this customer claim?</div>
                                            <div class="confirm-popover-text">This will reject the claim and restore the original serial status to Sold.</div>
                                            <div class="confirm-popover-actions">
                                                <button type="submit" class="btn btn-sm btn-outline-danger">Confirm</button>
                                                <button type="button" class="btn btn-sm btn-outline-secondary js-confirm-popover-cancel">Cancel</button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>
                            @if (!string.IsNullOrWhiteSpace(rejectBlockedReason))
                            {
                                <div class="form-text">@rejectBlockedReason</div>
                            }
                        </div>
                    </div>

                    <div class="quotation-party-column">
                        <div class="quotation-info-card">
                            <div class="quotation-info-card-title">Repair Complete / Ready To Return</div>
                            <form asp-action="RepairComplete" asp-route-id="@Model.CustomerClaimId" method="post" class="row g-2 align-items-end confirm-popover-form">
                                @Html.AntiForgeryToken()
                                <div class="col">
                                    <label class="quotation-info-label" for="readyResolutionRemark">Result Remark</label>
                                    <input id="readyResolutionRemark" name="resolutionRemark" class="form-control" disabled="@(!canRepairComplete)" />
                                </div>
                                <div class="col-auto">
                                    <div class="confirm-popover-shell">
                                        <button type="button" class="btn btn-outline-primary js-confirm-popover-toggle" disabled="@(!canRepairComplete)" title="@repairCompleteBlockedReason" data-confirm-target="readyCustomerClaimConfirm_@Model.CustomerClaimId" aria-expanded="false">Mark Ready</button>
                                        <div class="confirm-popover" id="readyCustomerClaimConfirm_@Model.CustomerClaimId" hidden>
                                            <div class="confirm-popover-title">Mark this claim ready?</div>
                                            <div class="confirm-popover-text">This will move the customer claim to Ready To Return.</div>
                                            <div class="confirm-popover-actions">
                                                <button type="submit" class="btn btn-sm btn-outline-primary">Confirm</button>
                                                <button type="button" class="btn btn-sm btn-outline-secondary js-confirm-popover-cancel">Cancel</button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>
                            @if (!string.IsNullOrWhiteSpace(repairCompleteBlockedReason))
                            {
                                <div class="form-text">@repairCompleteBlockedReason</div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }

        <div class="form-section">
            <div class="form-section-title">Problem / Result</div>
            <div class="detail-grid">
                <div class="detail-item"><span class="detail-label">Problem Description</span><p class="detail-value quote-notes">@(string.IsNullOrWhiteSpace(Model.ProblemDescription) ? "-" : Model.ProblemDescription)</p></div>
                <div class="detail-item"><span class="detail-label">Line Remark</span><p class="detail-value quote-notes">@(string.IsNullOrWhiteSpace(line?.LineRemark) ? "-" : line.LineRemark)</p></div>
                <div class="detail-item"><span class="detail-label">Resolution Remark</span><p class="detail-value quote-notes">@(string.IsNullOrWhiteSpace(Model.ResolutionRemark) ? "-" : Model.ResolutionRemark)</p></div>
            </div>
        </div>

        <div class="form-section document-history-section">
            <div class="form-section-title">Document History</div>
            <div class="document-history-list">
                <div class="document-history-row">
                    <span class="document-history-label">Created</span>
                    <span class="document-history-value">@(Model.CreatedByUser?.DisplayName ?? "-")</span>
                    <span class="document-history-meta">@Model.CreatedDate.ToString("dd MMM yyyy HH:mm")</span>
                </div>
                <div class="document-history-row">
                    <span class="document-history-label">Updated</span>
                    <span class="document-history-value">@(Model.UpdatedByUser?.DisplayName ?? "-")</span>
                    <span class="document-history-meta">@(Model.UpdatedDate?.ToString("dd MMM yyyy HH:mm") ?? "-")</span>
                </div>
                <div class="document-history-row">
                    <span class="document-history-label">Received</span>
                    <span class="document-history-value">@(Model.ReceivedByUser?.DisplayName ?? "-")</span>
                    <span class="document-history-meta">@(Model.ReceivedDate?.ToString("dd MMM yyyy HH:mm") ?? "-")</span>
                </div>
                <div class="document-history-row">
                    <span class="document-history-label">Sent To Supplier</span>
                    <span class="document-history-value">@(Model.SentToSupplierByUser?.DisplayName ?? "-")</span>
                    <span class="document-history-meta">@(Model.SentToSupplierDate?.ToString("dd MMM yyyy HH:mm") ?? "-")</span>
                </div>
                <div class="document-history-row">
                    <span class="document-history-label">Resolved</span>
                    <span class="document-history-value">@(Model.ResolvedByUser?.DisplayName ?? "-")</span>
                    <span class="document-history-meta">@(Model.ResolvedDate?.ToString("dd MMM yyyy HH:mm") ?? "-")</span>
                </div>
                <div class="document-history-row">
                    <span class="document-history-label">Returned</span>
                    <span class="document-history-value">@(Model.ReturnedByUser?.DisplayName ?? "-")</span>
                    <span class="document-history-meta">@(Model.ReturnedDate?.ToString("dd MMM yyyy HH:mm") ?? "-")</span>
                </div>
                <div class="document-history-row">
                    <span class="document-history-label">Closed</span>
                    <span class="document-history-value">@(Model.ClosedByUser?.DisplayName ?? "-")</span>
                    <span class="document-history-meta">@(Model.ClosedDate?.ToString("dd MMM yyyy HH:mm") ?? "-")</span>
                </div>
                <div class="document-history-row">
                    <span class="document-history-label">Cancelled</span>
                    <span class="document-history-value">@(Model.CancelledByUser?.DisplayName ?? "-")</span>
                    <span class="document-history-meta">@(Model.CancelledDate?.ToString("dd MMM yyyy HH:mm") ?? "-")</span>
                </div>
                @if (Model.Status == "Cancelled")
                {
                    <div class="document-history-reason">
                        <span class="document-history-label">Cancel Reason</span>
                        <span class="document-history-value">@(string.IsNullOrWhiteSpace(Model.CancelReason) ? "-" : Model.CancelReason)</span>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
