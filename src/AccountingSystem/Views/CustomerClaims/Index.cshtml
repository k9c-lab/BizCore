@model BizCore.Models.ViewModels.PaginatedList<BizCore.Models.Entities.CustomerClaimHeader>

@{
    ViewData["Title"] = "Customer Claims";
    var search = ViewData["Search"] as string;
    var status = ViewData["Status"] as string;
    var dateFrom = ViewData["DateFrom"] as string;
    var dateTo = ViewData["DateTo"] as string;
}

@if (TempData["CustomerClaimNotice"] is string notice && !string.IsNullOrWhiteSpace(notice))
{
    @await Html.PartialAsync("_Notice", notice)
}

<div class="page-header">
    <div>
        <div class="page-eyebrow">Warranty Module</div>
        <h1 class="page-title">Customer Claims</h1>
        <p class="page-subtitle">Track customer warranty claims for sold serial-controlled items.</p>
    </div>
</div>

<div class="card content-card table-card">
    <div class="table-card-header">
        <div>
            <h2 class="section-title">Customer Claim Register</h2>
            <p class="section-subtitle">Create claims from eligible sold serials in Serial Inquiry or Stock Inquiry.</p>
        </div>
        <div class="table-meta">@Model.TotalCount record(s)</div>
    </div>
    <div class="card-body">
        <form method="get" class="list-filter-bar">
            <div class="list-filter-field grow">
                <label class="form-label" for="search">Search</label>
                <input id="search" name="search" value="@search" class="form-control" placeholder="Claim no., customer, serial, item, invoice, or problem" />
            </div>
            <div class="list-filter-field">
                <label class="form-label" for="status">Status</label>
                <select id="status" name="status" class="form-select">
                    <option value="">All</option>
                    <option value="Open" selected="@(status == "Open")">Open</option>
                    <option value="Received" selected="@(status == "Received")">Received</option>
                    <option value="SentToSupplier" selected="@(status == "SentToSupplier")">Sent To Supplier</option>
                    <option value="Repairing" selected="@(status == "Repairing")">Repairing</option>
                    <option value="ReadyToReturn" selected="@(status == "ReadyToReturn")">Ready To Return</option>
                    <option value="ReturnedToCustomer" selected="@(status == "ReturnedToCustomer")">Returned To Customer</option>
                    <option value="Rejected" selected="@(status == "Rejected")">Rejected</option>
                    <option value="Closed" selected="@(status == "Closed")">Closed</option>
                    <option value="Cancelled" selected="@(status == "Cancelled")">Cancelled</option>
                </select>
            </div>
            <div class="list-filter-field">
                <label class="form-label" for="dateFrom">From</label>
                <input id="dateFrom" name="dateFrom" value="@dateFrom" type="date" class="form-control" />
            </div>
            <div class="list-filter-field">
                <label class="form-label" for="dateTo">To</label>
                <input id="dateTo" name="dateTo" value="@dateTo" type="date" class="form-control" />
            </div>
            <div class="list-filter-actions">
                <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
                <button type="submit" class="btn btn-primary">Search</button>
            </div>
        </form>

        <div class="table-responsive">
            <table class="table entity-table align-middle">
                <thead>
                    <tr>
                        <th>Claim No.</th>
                        <th>Claim Date</th>
                        <th>Customer</th>
                        <th>Serial No.</th>
                        <th>Item</th>
                        <th>Invoice</th>
                        <th>Status</th>
                        <th class="text-end">Action</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.Any())
                {
                    @foreach (var claim in Model)
                    {
                        var line = claim.CustomerClaimDetails.FirstOrDefault();
                        <tr>
                            <td><span class="code-chip">@claim.CustomerClaimNo</span></td>
                            <td>@claim.CustomerClaimDate.ToString("dd MMM yyyy")</td>
                            <td class="fw-semibold">@claim.Customer?.CustomerName</td>
                            <td>@line?.SerialNumber?.SerialNo</td>
                            <td>@line?.Item?.ItemName</td>
                            <td>@(claim.InvoiceHeader?.InvoiceNo ?? "-")</td>
                            <td><span class="status-pill @(claim.Status == "Open" ? "active" : "inactive")">@claim.Status</span></td>
                            <td class="text-end">
                                <a asp-action="Details" asp-route-id="@claim.CustomerClaimId" class="btn btn-sm btn-outline-secondary">View</a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="8" class="table-empty">No customer claims yet. Start from an eligible sold serial.</td></tr>
                }
                </tbody>
            </table>
        </div>
        <partial name="_Pager" model="Model.Pagination" />
    </div>
</div>
