@model BizCore.Models.ViewModels.FinancialOverviewViewModel

@{
    ViewData["Title"] = "Financial Overview";
    var arPercent = Model.ArCollectedPercent < 0 ? 0 : Model.ArCollectedPercent > 100 ? 100 : Model.ArCollectedPercent;
    var apPercent = Model.ApPaidPercent < 0 ? 0 : Model.ApPaidPercent > 100 ? 100 : Model.ApPaidPercent;
}

<div class="page-header">
    <div>
        <div class="page-eyebrow">Financial Summary</div>
        <h1 class="page-title">Financial Overview</h1>
        <p class="page-subtitle">Cash collection and supplier payment snapshot for @Model.BranchName.</p>
    </div>
    <div class="page-actions">
        <a asp-controller="Reports" asp-action="Index" class="btn btn-outline-secondary">Open Reports</a>
    </div>
</div>

<div class="card content-card table-card mb-3">
    <div class="card-body">
        <form method="get" class="list-filter-bar">
            <div class="list-filter-field">
                <label class="form-label" for="dateFrom">From</label>
                <input id="dateFrom" name="dateFrom" value="@Model.DateFrom.ToString("yyyy-MM-dd")" type="date" class="form-control" />
            </div>
            <div class="list-filter-field">
                <label class="form-label" for="dateTo">To</label>
                <input id="dateTo" name="dateTo" value="@Model.DateTo.ToString("yyyy-MM-dd")" type="date" class="form-control" />
            </div>
            @if (Model.CanAccessAllBranches)
            {
                <div class="list-filter-field">
                    <label class="form-label" for="branchId">Branch</label>
                    <select id="branchId" name="branchId" asp-items="Model.BranchOptions" class="form-select"></select>
                </div>
            }
            <div class="list-filter-actions">
                <a asp-action="Index" class="btn btn-outline-secondary">This Month</a>
                <button type="submit" class="btn btn-primary">Run</button>
            </div>
        </form>
    </div>
</div>

<div class="quote-summary-grid mb-3">
    <div class="quote-summary-card">
        <span class="quote-summary-label">Revenue / AR Base</span>
        <p class="quote-summary-value">@Model.RevenueTotal.ToString("N2")</p>
    </div>
    <div class="quote-summary-card">
        <span class="quote-summary-label">Collected AR</span>
        <p class="quote-summary-value">@Model.CollectedAr.ToString("N2")</p>
    </div>
    <div class="quote-summary-card">
        <span class="quote-summary-label">Outstanding AR</span>
        <p class="quote-summary-value">@Model.OutstandingAr.ToString("N2")</p>
    </div>
    <div class="quote-summary-card">
        <span class="quote-summary-label">Purchase / AP Base</span>
        <p class="quote-summary-value">@Model.PurchaseBase.ToString("N2")</p>
    </div>
    <div class="quote-summary-card">
        <span class="quote-summary-label">Paid AP</span>
        <p class="quote-summary-value">@Model.PaidAp.ToString("N2")</p>
    </div>
    <div class="quote-summary-card">
        <span class="quote-summary-label">Outstanding AP</span>
        <p class="quote-summary-value">@Model.OutstandingAp.ToString("N2")</p>
    </div>
</div>

<div class="quotation-party-grid mb-3">
    <div class="quotation-party-column">
        <div class="card content-card h-100">
            <div class="card-body">
                <div class="table-card-header px-0 pt-0">
                    <div>
                        <h2 class="section-title">Receivables Mix</h2>
                        <p class="section-subtitle">Collected vs outstanding customer receivables.</p>
                    </div>
                </div>
                <div class="financial-donut-shell">
                    <div class="financial-donut" style="--pct:@arPercent; --fill:#2563eb; --rest:#dbeafe;">
                        <div class="financial-donut-center">
                            <strong>@arPercent.ToString("N0")%</strong>
                            <span>Collected</span>
                        </div>
                    </div>
                    <div class="financial-donut-legend">
                        <div class="financial-legend-row">
                            <span class="financial-legend-dot collected"></span>
                            <span>Collected AR</span>
                            <strong>@Model.CollectedAr.ToString("N2")</strong>
                        </div>
                        <div class="financial-legend-row">
                            <span class="financial-legend-dot outstanding"></span>
                            <span>Outstanding AR</span>
                            <strong>@Model.OutstandingAr.ToString("N2")</strong>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="quotation-party-column">
        <div class="card content-card h-100">
            <div class="card-body">
                <div class="table-card-header px-0 pt-0">
                    <div>
                        <h2 class="section-title">Payables Mix</h2>
                        <p class="section-subtitle">Paid vs outstanding supplier payables.</p>
                    </div>
                </div>
                <div class="financial-donut-shell">
                    <div class="financial-donut" style="--pct:@apPercent; --fill:#16a34a; --rest:#dcfce7;">
                        <div class="financial-donut-center">
                            <strong>@apPercent.ToString("N0")%</strong>
                            <span>Paid</span>
                        </div>
                    </div>
                    <div class="financial-donut-legend">
                        <div class="financial-legend-row">
                            <span class="financial-legend-dot paid"></span>
                            <span>Paid AP</span>
                            <strong>@Model.PaidAp.ToString("N2")</strong>
                        </div>
                        <div class="financial-legend-row">
                            <span class="financial-legend-dot unpaid"></span>
                            <span>Outstanding AP</span>
                            <strong>@Model.OutstandingAp.ToString("N2")</strong>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card content-card table-card mb-3">
    <div class="table-card-header">
        <div>
            <h2 class="section-title">Outstanding Receivables</h2>
            <p class="section-subtitle">Customer invoices that still have balance to collect.</p>
        </div>
        <div class="table-meta">@Model.ReceivableRows.Count row(s)</div>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table entity-table align-middle">
                <thead>
                    <tr>
                        <th>Customer</th>
                        <th>Invoice</th>
                        <th>Branch</th>
                        <th class="text-end">Total</th>
                        <th class="text-end">Collected</th>
                        <th class="text-end">Outstanding</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var row in Model.ReceivableRows)
                {
                    <tr>
                        <td>@row.CustomerName</td>
                        <td>
                            <a asp-controller="Invoices" asp-action="Details" asp-route-id="@row.InvoiceId">@row.InvoiceNo</a>
                            <div class="table-meta">@row.InvoiceDate.ToString("dd MMM yyyy")</div>
                        </td>
                        <td>@row.BranchName</td>
                        <td class="text-end">@row.TotalAmount.ToString("N2")</td>
                        <td class="text-end">@row.PaidAmount.ToString("N2")</td>
                        <td class="text-end fw-semibold">@row.BalanceAmount.ToString("N2")</td>
                    </tr>
                }
                @if (!Model.ReceivableRows.Any())
                {
                    <tr><td colspan="6" class="table-empty">No outstanding receivables found.</td></tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="card content-card table-card mb-3">
    <div class="table-card-header">
        <div>
            <h2 class="section-title">Outstanding Payables</h2>
            <p class="section-subtitle">Supplier purchase orders that still have balance to pay.</p>
        </div>
        <div class="table-meta">@Model.PayableRows.Count row(s)</div>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table entity-table align-middle">
                <thead>
                    <tr>
                        <th>Supplier</th>
                        <th>PO</th>
                        <th>Branch</th>
                        <th class="text-end">Total</th>
                        <th class="text-end">Paid</th>
                        <th class="text-end">Outstanding</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var row in Model.PayableRows)
                {
                    <tr>
                        <td>@row.SupplierName</td>
                        <td>
                            <a asp-controller="PurchaseOrders" asp-action="Details" asp-route-id="@row.PurchaseOrderId">@row.PONo</a>
                            <div class="table-meta">@row.PODate.ToString("dd MMM yyyy")</div>
                        </td>
                        <td>@row.BranchName</td>
                        <td class="text-end">@row.TotalAmount.ToString("N2")</td>
                        <td class="text-end">@row.PaidAmount.ToString("N2")</td>
                        <td class="text-end fw-semibold">@row.BalanceAmount.ToString("N2")</td>
                    </tr>
                }
                @if (!Model.PayableRows.Any())
                {
                    <tr><td colspan="6" class="table-empty">No outstanding payables found.</td></tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="quotation-party-grid">
    <div class="quotation-party-column">
        <div class="card content-card table-card h-100">
            <div class="table-card-header">
                <div>
                    <h2 class="section-title">Receivables by Customer</h2>
                    <p class="section-subtitle">Which customers still owe the most.</p>
                </div>
                <div class="table-meta">@Model.ReceivableCustomerRows.Count row(s)</div>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table entity-table align-middle">
                        <thead>
                            <tr>
                                <th>Customer</th>
                                <th class="text-end">Invoices</th>
                                <th class="text-end">Total</th>
                                <th class="text-end">Collected</th>
                                <th class="text-end">Outstanding</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var row in Model.ReceivableCustomerRows)
                        {
                            <tr>
                                <td>@row.PartyName</td>
                                <td class="text-end">@row.DocumentCount</td>
                                <td class="text-end">@row.TotalAmount.ToString("N2")</td>
                                <td class="text-end">@row.PaidAmount.ToString("N2")</td>
                                <td class="text-end fw-semibold">@row.BalanceAmount.ToString("N2")</td>
                            </tr>
                        }
                        @if (!Model.ReceivableCustomerRows.Any())
                        {
                            <tr><td colspan="5" class="table-empty">No outstanding customer balances found.</td></tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
    <div class="quotation-party-column">
        <div class="card content-card table-card h-100">
            <div class="table-card-header">
                <div>
                    <h2 class="section-title">Payables by Supplier</h2>
                    <p class="section-subtitle">Which suppliers still have open balance.</p>
                </div>
                <div class="table-meta">@Model.PayableSupplierRows.Count row(s)</div>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table entity-table align-middle">
                        <thead>
                            <tr>
                                <th>Supplier</th>
                                <th class="text-end">POs</th>
                                <th class="text-end">Total</th>
                                <th class="text-end">Paid</th>
                                <th class="text-end">Outstanding</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var row in Model.PayableSupplierRows)
                        {
                            <tr>
                                <td>@row.PartyName</td>
                                <td class="text-end">@row.DocumentCount</td>
                                <td class="text-end">@row.TotalAmount.ToString("N2")</td>
                                <td class="text-end">@row.PaidAmount.ToString("N2")</td>
                                <td class="text-end fw-semibold">@row.BalanceAmount.ToString("N2")</td>
                            </tr>
                        }
                        @if (!Model.PayableSupplierRows.Any())
                        {
                            <tr><td colspan="5" class="table-empty">No outstanding supplier balances found.</td></tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .financial-donut-shell {
        display: grid;
        grid-template-columns: minmax(0, 180px) minmax(0, 1fr);
        gap: 24px;
        align-items: center;
        min-height: 220px;
    }

    .financial-donut {
        --pct: 0;
        --fill: #2563eb;
        --rest: #dbeafe;
        width: 180px;
        aspect-ratio: 1;
        border-radius: 50%;
        background: conic-gradient(var(--fill) 0 calc(var(--pct) * 1%), var(--rest) calc(var(--pct) * 1%) 100%);
        display: grid;
        place-items: center;
        margin-inline: auto;
        position: relative;
    }

    .financial-donut::after {
        content: "";
        position: absolute;
        inset: 18px;
        border-radius: 50%;
        background: #fff;
    }

    .financial-donut-center {
        position: relative;
        z-index: 1;
        display: grid;
        gap: 4px;
        text-align: center;
    }

    .financial-donut-center strong {
        font-size: 28px;
        line-height: 1;
        color: #0f172a;
    }

    .financial-donut-center span {
        font-size: 13px;
        color: #64748b;
    }

    .financial-donut-legend {
        display: grid;
        gap: 12px;
    }

    .financial-legend-row {
        display: grid;
        grid-template-columns: auto 1fr auto;
        gap: 10px;
        align-items: center;
    }

    .financial-legend-dot {
        width: 12px;
        height: 12px;
        border-radius: 999px;
    }

    .financial-legend-dot.collected { background: #2563eb; }
    .financial-legend-dot.outstanding { background: #dbeafe; }
    .financial-legend-dot.paid { background: #16a34a; }
    .financial-legend-dot.unpaid { background: #dcfce7; }

    @@media (max-width: 992px) {
        .financial-donut-shell {
            grid-template-columns: 1fr;
        }
    }
</style>
