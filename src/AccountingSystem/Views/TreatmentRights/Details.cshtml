@model BizCore.Models.Entities.TreatmentRight

@{
    ViewData["Title"] = "รายละเอียดสิทธิการรักษา";
}

<div class="page-header">
    <div>
        <div class="page-eyebrow">Master Data</div>
        <h1 class="page-title">รายละเอียดสิทธิการรักษา</h1>
    </div>
    <div class="page-actions">
        <a asp-action="Edit" asp-route-id="@Model.TreatmentRightId" class="btn btn-primary">แก้ไข</a>
        <a asp-action="Index" class="btn btn-outline-secondary">กลับ</a>
    </div>
</div>

<div class="card content-card">
    <div class="card-body">
        <div class="form-shell">
            <div class="form-section quotation-header-section">
                <div class="form-section-title">ข้อมูลสิทธิการรักษา</div>
                <div class="row g-2 quotation-header-grid">
                    <div class="col-lg-3 col-md-6">
                        <div class="detail-label">รหัสสิทธิการรักษา</div>
                        <div class="form-control readonly-detail">@Model.TreatmentRightCode</div>
                    </div>
                    <div class="col-lg-6 col-md-6">
                        <div class="detail-label">ชื่อสิทธิการรักษา</div>
                        <div class="form-control readonly-detail">@Model.TreatmentRightName</div>
                    </div>
                    <div class="col-lg-3 col-md-6">
                        <div class="detail-label">สถานะ</div>
                        <div class="form-control readonly-detail">@(Model.IsActive ? "ใช้งานอยู่" : "ไม่ใช้งาน")</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
