@model BizCore.Models.Entities.ReceiptHeader
@{
    Layout = null;
    var companyName = ViewData["PrintCompanyName"] as string ?? "BizCore Co., Ltd.";
    var companyAddress = ViewData["PrintCompanyAddress"] as string ?? "-";
    var companyTaxId = ViewData["PrintCompanyTaxId"] as string ?? "-";
    var companyPhone = ViewData["PrintCompanyPhone"] as string ?? "-";
    var companyEmail = ViewData["PrintCompanyEmail"] as string ?? "-";
    var payment = Model.PaymentHeader;
    var allocations = payment?.PaymentAllocations.OrderBy(x => x.InvoiceHeader!.InvoiceDate).ThenBy(x => x.InvoiceHeader!.InvoiceNo)
        ?? Enumerable.Empty<BizCore.Models.Entities.PaymentAllocation>();
    var allocationList = allocations.ToList();
    var hasAllocations = allocationList.Any();
    var appliedAmount = allocationList.Sum(x => x.AppliedAmount);
    var invoiceTotal = allocationList.Sum(x => x.InvoiceHeader?.TotalAmount ?? 0m);
    var invoiceVatTotal = allocationList.Sum(x => x.InvoiceHeader?.VatAmount ?? 0m);
    var invoiceSubtotal = invoiceTotal - invoiceVatTotal;
    var remainingBalance = allocationList.Sum(x => x.InvoiceHeader?.BalanceAmount ?? 0m);
    var totalAmountText = BizCore.Utilities.ThaiBahtTextConverter.ToText(Model.TotalReceivedAmount);
    var hasRemark = !string.IsNullOrWhiteSpace(Model.Remark);
    var printCopies = new[]
    {
        "ต้นฉบับ",
        "สำเนา"
    };
}
<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Receipt @Model.ReceiptNo</title>
    <style>
        @@page { size: A4; margin: 14mm; }
        * { box-sizing: border-box; }
        body {
            margin: 0;
            font-family: "Segoe UI", Tahoma, sans-serif;
            color: #111827;
            background: #e5e7eb;
            font-size: 11.5px;
            line-height: 1.35;
        }
        .print-page {
            min-height: 100vh;
            padding: 24px;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 24px;
        }
        .print-shell {
            width: 210mm;
            min-height: 297mm;
            display: flex;
            flex-direction: column;
            background: #fff;
            padding: 14mm;
            box-shadow: 0 16px 40px rgba(15, 23, 42, 0.14);
        }
        .print-copy {
            position: relative;
        }
        .copy-badge {
            margin: 0 0 6px;
            color: #374151;
            font-size: 15px;
            font-weight: 700;
        }
        .screen-actions {
            display: flex;
            justify-content: flex-end;
            width: 210mm;
        }
        .screen-actions button {
            border: 1px solid #cbd5e1;
            background: #fff;
            color: #111827;
            border-radius: 6px;
            padding: 6px 10px;
            font: inherit;
            cursor: pointer;
            box-shadow: 0 1px 2px rgba(15, 23, 42, 0.08);
        }
        .print-header {
            display: flex;
            justify-content: space-between;
            gap: 24px;
            padding-bottom: 14px;
            border-bottom: 2px solid #1d4ed8;
        }
        .company-block { max-width: 58%; }
        .company-name {
            margin: 0 0 6px;
            font-size: 20px;
            font-weight: 700;
            letter-spacing: 0.02em;
            color: #0f172a;
        }
        .company-line,
        .meta-label,
        .section-label,
        .summary-label,
        .signature-label {
            color: #374151;
        }
        .company-meta-grid {
            display: grid;
            gap: 3px;
            margin-top: 8px;
        }
        .company-line {
            color: #111827;
            white-space: pre-line;
        }
        .document-block {
            min-width: 300px;
            text-align: right;
        }
        .document-title-th {
            margin: 0;
            font-size: 24px;
            font-weight: 700;
            color: #1d4ed8;
        }
        .document-title-en {
            margin: 2px 0 12px;
            font-size: 15px;
            font-weight: 600;
            color: #1f2937;
            letter-spacing: 0.04em;
        }
        .document-meta {
            width: 100%;
            border-collapse: collapse;
        }
        .document-meta td {
            padding: 2px 0 2px 16px;
            vertical-align: top;
            color: #111827;
        }
        .document-meta td:first-child {
            white-space: nowrap;
        }
        .meta-value-nowrap {
            white-space: nowrap;
        }
        .print-section { margin-top: 16px; }
        .party-section {
            padding: 0 0 10px;
            border-bottom: 1px solid #d1d5db;
        }
        .party-grid {
            display: grid;
            grid-template-columns: minmax(0, 1.3fr) minmax(0, 0.7fr);
            gap: 8px 20px;
        }
        .party-name {
            font-size: 14px;
            font-weight: 700;
            margin-top: 1px;
            color: #111827;
        }
        .party-value,
        .signature-date {
            white-space: pre-wrap;
            color: #111827;
        }
        .line-table {
            width: 100%;
            border-collapse: collapse;
            table-layout: fixed;
        }
        .line-table th, .line-table td {
            border: 1px solid #d1d5db;
            padding: 7px 8px;
            vertical-align: top;
        }
        .line-table th {
            background: #e0ecff;
            color: #1e3a8a;
            font-weight: 700;
            text-align: center;
            font-size: 11px;
        }
        .bi-label-th,
        .bi-label-en {
            display: block;
            line-height: 1.2;
            white-space: nowrap;
        }
        .bi-label-en {
            margin-top: 2px;
            font-size: 10px;
            font-weight: 600;
        }
        .col-no { width: 42px; text-align: center; }
        .col-description { width: auto; word-break: break-word; }
        .col-qty { width: 76px; text-align: right; }
        .col-price { width: 100px; text-align: right; }
        .col-amount { width: 110px; text-align: right; }
        .invoice-row td {
            background: #f8fbff;
            color: #1e3a8a;
            font-weight: 700;
        }
        .item-code {
            display: block;
            color: #4b5563;
            font-size: 10.5px;
            margin-top: 2px;
        }
        .summary-wrap {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 28px;
            margin-top: 14px;
        }
        .amount-text {
            flex: 1 1 auto;
            padding-right: 18px;
            font-size: 12px;
            font-weight: 600;
            color: #1f2937;
        }
        .summary-table {
            min-width: 300px;
            border-collapse: collapse;
        }
        .summary-table td {
            padding: 4px 0 4px 18px;
        }
        .summary-table td:first-child {
            text-align: left;
        }
        .summary-table td:last-child {
            text-align: right;
            min-width: 120px;
            color: #111827;
        }
        .summary-total td {
            padding-top: 8px;
            border-top: 2px solid #1d4ed8;
            font-weight: 700;
            font-size: 14px;
            color: #0f172a;
        }
        .workflow-note {
            margin-top: 16px;
            padding: 12px 14px;
            border: 1px solid #d1d5db;
            border-radius: 8px;
            color: #374151;
            background: #f8fafc;
        }
        .remark-box {
            white-space: pre-wrap;
            color: #374151;
        }
        .signature-grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 28px;
            margin-top: auto;
            padding-top: 28px;
        }
        .signature-box { text-align: center; color: #111827; }
        .signature-line {
            margin: 44px auto 8px;
            width: 88%;
            border-bottom: 1px solid #111827;
        }
        @@media print {
            body {
                -webkit-print-color-adjust: exact;
                print-color-adjust: exact;
                background: #fff;
            }
            .print-page {
                min-height: auto;
                padding: 0;
                display: block;
            }
            .print-shell {
                width: 100%;
                min-height: calc(297mm - 28mm);
                padding: 0;
                box-shadow: none;
            }
            .print-copy.page-break {
                break-after: page;
                page-break-after: always;
            }
            .screen-actions { display: none; }
        }
    </style>
</head>
<body>
    <div class="print-page">
        <div class="screen-actions">
            <button type="button" onclick="window.print()">Print</button>
        </div>
        @for (var copyIndex = 0; copyIndex < printCopies.Length; copyIndex++)
        {
            var copyClass = copyIndex < printCopies.Length - 1 ? "print-shell print-copy page-break" : "print-shell print-copy";
        <div class="@copyClass">
            <header class="print-header">
                <div class="company-block">
                    <h1 class="company-name">@companyName</h1>
                    <div class="company-meta-grid">
                        <div class="company-line">@companyAddress</div>
                        <div class="company-line">เลขประจำตัวผู้เสียภาษี / Tax ID: @companyTaxId</div>
                        <div class="company-line">โทรศัพท์ / Tel: @companyPhone</div>
                        @if (!string.IsNullOrWhiteSpace(companyEmail))
                        {
                            <div class="company-line">Email: @companyEmail</div>
                        }
                    </div>
                </div>
                <div class="document-block">
                    <div class="copy-badge">@printCopies[copyIndex]</div>
                    <h2 class="document-title-th">ใบเสร็จรับเงิน</h2>
                    <div class="document-title-en">Receipt</div>
                    <table class="document-meta">
                        <tr><td class="meta-label">เลขที่เอกสาร / Doc No.</td><td class="meta-value-nowrap">@Model.ReceiptNo</td></tr>
                        <tr><td class="meta-label">วันที่เอกสาร / Date</td><td>@Model.ReceiptDate.ToString("dd/MM/yyyy")</td></tr>
                        <tr><td class="meta-label">เลขที่รับชำระ / Payment No.</td><td>@(payment?.PaymentNo ?? "-")</td></tr>
                        <tr><td class="meta-label">เลขที่อ้างอิง / Reference No.</td><td>@(string.IsNullOrWhiteSpace(payment?.ReferenceNo) ? "-" : payment!.ReferenceNo)</td></tr>
                        <tr><td class="meta-label">สาขา / Branch</td><td>@(Model.Branch?.BranchName ?? "-")</td></tr>
                    </table>
                </div>
            </header>

            <section class="print-section party-section">
                <div class="party-grid">
                    <div>
                        <div class="section-label">ลูกค้า / Customer</div>
                        <div class="party-name">@Model.Customer?.CustomerName</div>
                    </div>
                    <div>
                        <div class="section-label">เลขประจำตัวผู้เสียภาษี / Tax ID</div>
                        <div class="party-value">@(string.IsNullOrWhiteSpace(Model.Customer?.TaxId) ? "-" : Model.Customer!.TaxId)</div>
                    </div>
                    <div style="grid-column: 1 / -1;">
                        <div class="section-label">ที่อยู่ / Address</div>
                        <div class="party-value">@(string.IsNullOrWhiteSpace(Model.Customer?.Address) ? "-" : Model.Customer!.Address)</div>
                    </div>
                </div>
            </section>

            @if (hasAllocations)
            {
                <section class="print-section">
                    <table class="line-table">
                        <thead>
                            <tr>
                                <th class="col-no"><span class="bi-label-th">ลำดับ</span><span class="bi-label-en">No.</span></th>
                                <th class="col-description"><span class="bi-label-th">รายการ</span><span class="bi-label-en">Description</span></th>
                                <th class="col-qty"><span class="bi-label-th">จำนวน</span><span class="bi-label-en">Qty</span></th>
                                <th class="col-price"><span class="bi-label-th">ราคาต่อหน่วย</span><span class="bi-label-en">Unit Price</span></th>
                                <th class="col-amount"><span class="bi-label-th">จำนวนเงิน</span><span class="bi-label-en">Amount</span></th>
                            </tr>
                        </thead>
                        <tbody>
                        @{
                            var rowNo = 1;
                        }
                        @foreach (var allocation in allocationList)
                        {
                            var invoice = allocation.InvoiceHeader;
                            if (invoice is null)
                            {
                                continue;
                            }

                            <tr class="invoice-row">
                                <td colspan="5">ใบแจ้งหนี้ / Invoice: @invoice.InvoiceNo (@invoice.InvoiceDate.ToString("dd/MM/yyyy"))</td>
                            </tr>
                            foreach (var line in invoice.InvoiceDetails.OrderBy(x => x.LineNumber))
                            {
                                <tr>
                                    <td class="col-no">@rowNo</td>
                                    <td class="col-description">
                                        @(line.Item?.ItemName ?? "-")
                                        <span class="item-code">@line.Item?.ItemCode</span>
                                    </td>
                                    <td class="col-qty">@line.Qty.ToString("N2")</td>
                                    <td class="col-price">@line.UnitPrice.ToString("N2")</td>
                                    <td class="col-amount">@line.LineTotal.ToString("N2")</td>
                                </tr>
                                rowNo++;
                            }
                        }
                        </tbody>
                    </table>

                    <div class="summary-wrap">
                        <div class="amount-text">@totalAmountText</div>
                        <table class="summary-table">
                            <tr><td class="summary-label">ยอดก่อนภาษี / Subtotal</td><td>@invoiceSubtotal.ToString("N2")</td></tr>
                            <tr><td class="summary-label">ภาษีมูลค่าเพิ่ม / VAT</td><td>@invoiceVatTotal.ToString("N2")</td></tr>
                            <tr class="summary-total"><td>ยอดรวมทั้งสิ้น / Total Amount</td><td>@invoiceTotal.ToString("N2")</td></tr>
                        </table>
                    </div>
                </section>

            }
            else
            {
                <section class="print-section">
                    <table class="line-table">
                        <thead>
                            <tr>
                                <th class="col-description"><span class="bi-label-th">รายละเอียด</span><span class="bi-label-en">Description</span></th>
                                <th class="col-amount"><span class="bi-label-th">จำนวนเงิน</span><span class="bi-label-en">Amount</span></th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td class="col-description">รับชำระเงินโดยไม่มีการอ้างอิงใบแจ้งหนี้ / Standalone payment without invoice allocation</td>
                                <td class="col-amount">@Model.TotalReceivedAmount.ToString("N2")</td>
                            </tr>
                        </tbody>
                    </table>

                    <div class="summary-wrap">
                        <div class="amount-text">@totalAmountText</div>
                        <table class="summary-table">
                            <tr><td class="summary-label">ยอดรับชำระ / Payment Amount</td><td>@Model.TotalReceivedAmount.ToString("N2")</td></tr>
                            <tr><td class="summary-label">จัดสรรให้ใบแจ้งหนี้ / Applied Amount</td><td>@appliedAmount.ToString("N2")</td></tr>
                            <tr class="summary-total"><td>เงินรับลอย / Unapplied Amount</td><td>@Math.Max(Model.TotalReceivedAmount - appliedAmount, 0m).ToString("N2")</td></tr>
                        </table>
                    </div>
                </section>

                <section class="workflow-note">
                    This receipt was issued from a standalone payment with no invoice allocations.
                </section>
            }

            @if (hasRemark)
            {
                <section class="print-section">
                    <div class="remark-box">@Model.Remark</div>
                </section>
            }

            <section class="signature-grid">
                <div class="signature-box">
                    <div class="signature-label">ผู้รับเงิน / Received By</div>
                    <div class="signature-line"></div>
                    <div>............................................................</div>
                    <div class="signature-date">วันที่ / Date ........ / ........ / ........</div>
                </div>
                <div class="signature-box">
                    <div class="signature-label">ผู้มีอำนาจลงนาม / Authorized Signature</div>
                    <div class="signature-line"></div>
                    <div>............................................................</div>
                    <div class="signature-date">วันที่ / Date ........ / ........ / ........</div>
                </div>
            </section>
        </div>
        }
    </div>
    <script>
        window.addEventListener("load", () => {
            window.print();
        });
    </script>
</body>
</html>
