@model IEnumerable<BizCore.Models.Entities.ReceiptHeader>

@{
    ViewData["Title"] = "Receipts";
}

<div class="page-header">
    <div>
        <div class="page-eyebrow">AR Module</div>
        <h1 class="page-title">Receipts</h1>
        <p class="page-subtitle">Issued receipts created automatically from posted customer payments.</p>
    </div>
</div>

<div class="card content-card table-card">
    <div class="table-card-header">
        <div>
            <h2 class="section-title">Receipt Register</h2>
            <p class="section-subtitle">Receipts are read-only after issue in this phase.</p>
        </div>
        <div class="table-meta">@Model.Count() record(s)</div>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table entity-table align-middle">
                <thead>
                    <tr>
                        <th>Receipt No.</th>
                        <th>Receipt Date</th>
                        <th>Customer</th>
                        <th>Total Received</th>
                        <th>Status</th>
                        <th class="text-end">Action</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.Any())
                {
                    @foreach (var receipt in Model)
                    {
                        <tr>
                            <td><span class="code-chip">@receipt.ReceiptNo</span></td>
                            <td>@receipt.ReceiptDate.ToString("dd MMM yyyy")</td>
                            <td class="fw-semibold">@receipt.Customer?.CustomerName</td>
                            <td>@receipt.TotalReceivedAmount.ToString("N2")</td>
                            <td><span class="status-pill active">@receipt.Status</span></td>
                            <td class="text-end">
                                <a asp-action="Details" asp-route-id="@receipt.ReceiptId" class="btn btn-sm btn-outline-secondary">View</a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="6" class="table-empty">No receipts yet. Posting a payment will create the first receipt automatically.</td></tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
