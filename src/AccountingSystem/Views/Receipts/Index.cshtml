@model BizCore.Models.ViewModels.PaginatedList<BizCore.Models.Entities.ReceiptHeader>

@{
    ViewData["Title"] = "Receipts";
    var search = ViewData["Search"] as string;
    var status = ViewData["Status"] as string;
    var dateFrom = ViewData["DateFrom"] as string;
    var dateTo = ViewData["DateTo"] as string;
}

<div class="page-header">
    <div>
        <div class="page-eyebrow">AR Module</div>
        <h1 class="page-title">Receipts</h1>
        <p class="page-subtitle">Issued receipts created automatically from posted customer payments.</p>
    </div>
</div>

<div class="card content-card table-card">
    <div class="table-card-header">
        <div>
            <h2 class="section-title">Receipt Register</h2>
            <p class="section-subtitle">Receipts are read-only after issue in this phase.</p>
        </div>
        <div class="table-meta">@Model.TotalCount record(s)</div>
    </div>
    <div class="card-body">
        <form method="get" class="list-filter-bar">
            <div class="list-filter-field grow">
                <label class="form-label" for="search">Search</label>
                <input id="search" name="search" value="@search" class="form-control" placeholder="Receipt no., payment no., reference, or customer" />
            </div>
            <div class="list-filter-field">
                <label class="form-label" for="status">Status</label>
                <select id="status" name="status" class="form-select">
                    <option value="">All</option>
                    <option value="Issued" selected="@(status == "Issued")">Issued</option>
                    <option value="Cancelled" selected="@(status == "Cancelled")">Cancelled</option>
                </select>
            </div>
            <div class="list-filter-field">
                <label class="form-label" for="dateFrom">From</label>
                <input id="dateFrom" name="dateFrom" value="@dateFrom" type="date" class="form-control" />
            </div>
            <div class="list-filter-field">
                <label class="form-label" for="dateTo">To</label>
                <input id="dateTo" name="dateTo" value="@dateTo" type="date" class="form-control" />
            </div>
            <div class="list-filter-actions">
                <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
                <button type="submit" class="btn btn-primary">Search</button>
            </div>
        </form>
        <div class="table-responsive">
            <table class="table entity-table align-middle">
                <thead>
                    <tr>
                        <th>Receipt No.</th>
                        <th>Receipt Date</th>
                        <th>Customer</th>
                        <th>Total Received</th>
                        <th>Status</th>
                        <th class="text-end">Action</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.Any())
                {
                    @foreach (var receipt in Model)
                    {
                        var canCancel = receipt.Status == "Issued";
                        <tr>
                            <td><span class="code-chip">@receipt.ReceiptNo</span></td>
                            <td>@receipt.ReceiptDate.ToString("dd MMM yyyy")</td>
                            <td class="fw-semibold">@receipt.Customer?.CustomerName</td>
                            <td>@receipt.TotalReceivedAmount.ToString("N2")</td>
                            <td><span class="status-pill active">@receipt.Status</span></td>
                            <td class="text-end">
                                <div class="table-actions">
                                    <a asp-action="Details" asp-route-id="@receipt.ReceiptId" class="btn btn-sm btn-outline-secondary">View</a>
                                    <button type="button" class="btn btn-sm btn-outline-secondary" onclick="window.open('@Url.Action("Print", new { id = receipt.ReceiptId })', '_blank', 'noopener');">Print</button>
                                    @if (canCancel)
                                    {
                                        <form asp-action="Cancel" asp-route-id="@receipt.ReceiptId" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Cancel this receipt? Payment and invoice balances will not change.');">Cancel</button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="6" class="table-empty">No receipts yet. Posting a payment will create the first receipt automatically.</td></tr>
                }
                </tbody>
            </table>
        </div>
        <partial name="_Pager" model="Model.Pagination" />
    </div>
</div>
