@model BizCore.Models.ViewModels.PaginatedList<BizCore.Models.Entities.ReceiptHeader>

@{
    ViewData["Title"] = "ใบเสร็จรับเงิน";
    var search = ViewData["Search"] as string;
    var status = ViewData["Status"] as string;
    var dateFrom = ViewData["DateFrom"] as string;
    var dateTo = ViewData["DateTo"] as string;
}

<div class="page-header">
    <div>
        <div class="page-eyebrow">ลูกหนี้การค้า</div>
        <h1 class="page-title">ใบเสร็จรับเงิน</h1>
        </div>
</div>

<div class="card content-card table-card">
    <div class="table-card-header">
        <div>
            <h2 class="section-title">รายการใบเสร็จรับเงิน</h2>
            </div>
        <div class="table-meta">@Model.TotalCount รายการ</div>
    </div>
    <div class="card-body">
        <form method="get" class="list-filter-bar">
            <div class="list-filter-field grow">
                <label class="form-label" for="search">ค้นหา</label>
                <input id="search" name="search" value="@search" class="form-control" placeholder="เลขที่ใบเสร็จ, เลขที่รับชำระ, เลขอ้างอิง หรือลูกค้า" />
            </div>
            <div class="list-filter-field">
                <label class="form-label" for="status">สถานะ</label>
                <select id="status" name="status" class="form-select">
                    <option value="">ทั้งหมด</option>
                    <option value="Issued" selected="@(status == "Issued")">ออกเอกสารแล้ว</option>
                    <option value="Cancelled" selected="@(status == "Cancelled")">ยกเลิกแล้ว</option>
                </select>
            </div>
            <div class="list-filter-field">
                <label class="form-label" for="dateFrom">จากวันที่</label>
                <input id="dateFrom" name="dateFrom" value="@dateFrom" type="date" class="form-control" />
            </div>
            <div class="list-filter-field">
                <label class="form-label" for="dateTo">ถึงวันที่</label>
                <input id="dateTo" name="dateTo" value="@dateTo" type="date" class="form-control" />
            </div>
            <div class="list-filter-actions">
                <a asp-action="Index" class="btn btn-outline-secondary">ล้างค่า</a>
                <button type="submit" class="btn btn-primary">ค้นหา</button>
            </div>
        </form>
        <div class="table-responsive">
            <table class="table entity-table align-middle">
                <thead>
                    <tr>
                        <th>เลขที่ใบเสร็จ</th>
                        <th>วันที่ใบเสร็จ</th>
                        <th>ลูกค้า</th>
                        <th>ยอดรับชำระ</th>
                        <th>สถานะ</th>
                        <th class="text-end">การทำงาน</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.Any())
                {
                    @foreach (var receipt in Model)
                    {
                        <tr>
                            <td><span class="code-chip">@receipt.ReceiptNo</span></td>
                            <td>@receipt.ReceiptDate.ToString("dd MMM yyyy")</td>
                            <td class="fw-semibold">@receipt.Customer?.CustomerName</td>
                            <td>@receipt.TotalReceivedAmount.ToString("N2")</td>
                            <td><span class="status-pill active">@receipt.Status</span></td>
                            <td class="text-end">
                                <div class="table-actions">
                                    <a asp-action="Details" asp-route-id="@receipt.ReceiptId" class="btn btn-sm btn-outline-secondary">ดูรายละเอียด</a>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="6" class="table-empty">ยังไม่มีใบเสร็จรับเงิน เมื่อบันทึกรายการรับชำระแล้ว ระบบจะสร้างใบเสร็จใบแรกให้อัตโนมัติ</td></tr>
                }
                </tbody>
            </table>
        </div>
        <partial name="_Pager" model="Model.Pagination" />
    </div>
</div>
