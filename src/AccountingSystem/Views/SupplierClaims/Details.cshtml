@model BizCore.Models.Entities.SerialClaimLog

@{
    ViewData["Title"] = "รายละเอียดเคลมผู้ขาย";
    var dateValue = DateTime.Today.ToString("yyyy-MM-dd");
    var canMarkSent = Model.ClaimStatus == "Open";
    var markSentBlockedReason = canMarkSent ? string.Empty : "บันทึกส่งได้เฉพาะเคลมผู้ขายสถานะเปิดเคลม";
    var canReceiveResult = Model.ClaimStatus == "Open" || Model.ClaimStatus == "Sent";
    var receiveBlockedReason = canReceiveResult ? string.Empty : "รับผลจากผู้ขายได้เฉพาะเคลมผู้ขายสถานะเปิดเคลมหรือส่งแล้ว";
    var canClose = Model.ClaimStatus == "Returned" || Model.ClaimStatus == "Replaced" || Model.ClaimStatus == "Rejected";
    var closeBlockedReason = canClose ? string.Empty : "ปิดเคลมได้หลังจากบันทึกผลจากผู้ขายแล้วเท่านั้น";
    var workflowReasons = new[] { markSentBlockedReason, closeBlockedReason }
        .Where(x => !string.IsNullOrWhiteSpace(x))
        .Distinct()
        .ToList();
}

@if (TempData["ClaimNotice"] is string notice && !string.IsNullOrWhiteSpace(notice))
{
    @await Html.PartialAsync("_Notice", notice)
}

<div class="page-header">
    <div>
        <div class="page-eyebrow">โมดูลรับประกันผู้ขาย</div>
        <h1 class="page-title">รายละเอียดเคลมผู้ขาย</h1>
        <p class="page-subtitle">ติดตามการซ่อม การเปลี่ยนสินค้า การปฏิเสธ และการปิดงานของ Serial ที่ส่งเคลมผู้ขาย</p>
    </div>
    <div class="page-actions">
        <a asp-action="Index" class="btn btn-outline-secondary">กลับ</a>
        @if (canMarkSent)
        {
            <form asp-action="MarkSent" asp-route-id="@Model.SerialClaimLogId" method="post" class="d-inline-flex align-items-center gap-2 confirm-popover-form">
                @Html.AntiForgeryToken()
                <input type="date" name="sentDate" value="@dateValue" class="form-control form-control-sm" title="วันที่ส่ง" />
                <div class="confirm-popover-shell">
                    <button type="button" class="btn btn-outline-primary js-confirm-popover-toggle" data-confirm-target="markSentSupplierClaimConfirm_@Model.SerialClaimLogId" aria-expanded="false">บันทึกส่ง</button>
                    <div class="confirm-popover" id="markSentSupplierClaimConfirm_@Model.SerialClaimLogId" hidden>
                        <div class="confirm-popover-title">บันทึกว่าได้ส่งเคลมผู้ขายนี้แล้วหรือไม่?</div>
                        <div class="confirm-popover-text">ระบบจะเปลี่ยนสถานะเคลมเป็นส่งไปยังผู้ขายแล้ว</div>
                        <div class="confirm-popover-actions">
                            <button type="submit" class="btn btn-sm btn-outline-primary">ยืนยัน</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary js-confirm-popover-cancel">ปิด</button>
                        </div>
                    </div>
                </div>
            </form>
        }
        else
        {
            <button type="button" class="btn btn-outline-secondary" disabled title="@markSentBlockedReason">บันทึกส่ง</button>
        }
        @if (canClose)
        {
            <form asp-action="Close" asp-route-id="@Model.SerialClaimLogId" method="post" class="d-inline-flex align-items-center gap-2 confirm-popover-form">
                @Html.AntiForgeryToken()
                <input type="date" name="closedDate" value="@dateValue" class="form-control form-control-sm" title="วันที่ปิดเคลม" />
                <div class="confirm-popover-shell">
                    <button type="button" class="btn btn-primary js-confirm-popover-toggle" data-confirm-target="closeSupplierClaimConfirm_@Model.SerialClaimLogId" aria-expanded="false">ปิดเคลม</button>
                    <div class="confirm-popover" id="closeSupplierClaimConfirm_@Model.SerialClaimLogId" hidden>
                        <div class="confirm-popover-title">ปิดเคลมผู้ขายนี้หรือไม่?</div>
                        <div class="confirm-popover-text">ระบบจะปิดเคลมผู้ขายหลังจากบันทึกผลเรียบร้อยแล้ว</div>
                        <div class="confirm-popover-actions">
                            <button type="submit" class="btn btn-sm btn-outline-primary">ยืนยัน</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary js-confirm-popover-cancel">ปิด</button>
                        </div>
                    </div>
                </div>
            </form>
        }
        else
        {
            <button type="button" class="btn btn-outline-secondary" disabled title="@closeBlockedReason">ปิดเคลม</button>
        }
    </div>
</div>

@if (workflowReasons.Any())
{
    <div class="workflow-info mb-3">
        @foreach (var reason in workflowReasons)
        {
            <div>@reason</div>
        }
    </div>
}

<div class="card content-card mb-3">
    <div class="card-body form-shell">
        <div class="form-section">
            <div class="form-section-title">ข้อมูลเคลม</div>
            <div class="detail-grid">
                <div class="detail-item"><span class="detail-label">วันที่เคลม</span><p class="detail-value">@Model.ClaimDate.ToString("dd MMM yyyy")</p></div>
                <div class="detail-item"><span class="detail-label">สถานะเคลม</span><p class="detail-value">@(Model.ClaimStatus == "Open" ? "เปิดเคลม" : Model.ClaimStatus == "Sent" ? "ส่งแล้ว" : Model.ClaimStatus == "Returned" ? "รับของเดิมกลับแล้ว" : Model.ClaimStatus == "Replaced" ? "ได้รับของทดแทน" : Model.ClaimStatus == "Rejected" ? "ปฏิเสธเคลม" : Model.ClaimStatus == "Closed" ? "ปิดเคลม" : Model.ClaimStatus)</p></div>
                <div class="detail-item"><span class="detail-label">ผลลัพธ์</span><p class="detail-value">@(string.IsNullOrWhiteSpace(Model.ResultType) ? "-" : Model.ResultType)</p></div>
                <div class="detail-item">
                    <span class="detail-label">เคลมลูกค้า</span>
                    <p class="detail-value">
                        @if (Model.CustomerClaimHeader is not null)
                        {
                            <a asp-controller="CustomerClaims" asp-action="Details" asp-route-id="@Model.CustomerClaimHeader.CustomerClaimId">@Model.CustomerClaimHeader.CustomerClaimNo</a>
                        }
                        else
                        {
                            <span>-</span>
                        }
                    </p>
                </div>
                <div class="detail-item"><span class="detail-label">วันที่สร้าง</span><p class="detail-value">@Model.CreatedDate.ToLocalTime().ToString("dd MMM yyyy HH:mm")</p></div>
                <div class="detail-item"><span class="detail-label">วันที่ส่ง</span><p class="detail-value">@(Model.SentDate?.ToLocalTime().ToString("dd MMM yyyy HH:mm") ?? "-")</p></div>
                <div class="detail-item"><span class="detail-label">วันที่รับผล</span><p class="detail-value">@(Model.ReceivedDate?.ToLocalTime().ToString("dd MMM yyyy HH:mm") ?? "-")</p></div>
                <div class="detail-item"><span class="detail-label">วันที่ปิดเคลม</span><p class="detail-value">@(Model.ClosedDate?.ToLocalTime().ToString("dd MMM yyyy HH:mm") ?? "-")</p></div>
            </div>
        </div>

        <div class="form-section">
            <div class="form-section-title">ผู้ขาย</div>
            <div class="quotation-info-card">
                <div class="quotation-info-card-title">ข้อมูลผู้ขาย</div>
                <div class="quotation-info-grid">
                    <div class="quotation-info-field">
                        <span class="quotation-info-label">ชื่อผู้ขาย</span>
                        <span class="quotation-info-value">@Model.Supplier?.SupplierName</span>
                    </div>
                    <div class="quotation-info-field">
                        <span class="quotation-info-label">รหัสผู้ขาย</span>
                        <span class="quotation-info-value">@(Model.Supplier?.SupplierCode ?? "-")</span>
                    </div>
                </div>
                <div class="quotation-info-grid">
                    <div class="quotation-info-field">
                        <span class="quotation-info-label">โทรศัพท์</span>
                        <span class="quotation-info-value">@(string.IsNullOrWhiteSpace(Model.Supplier?.PhoneNumber) ? "-" : Model.Supplier!.PhoneNumber)</span>
                    </div>
                    <div class="quotation-info-field">
                        <span class="quotation-info-label">อีเมล</span>
                        <span class="quotation-info-value">@(string.IsNullOrWhiteSpace(Model.Supplier?.Email) ? "-" : Model.Supplier!.Email)</span>
                    </div>
                </div>
                <div class="quotation-info-field">
                    <span class="quotation-info-label">ที่อยู่</span>
                    <span class="quotation-info-value">@(string.IsNullOrWhiteSpace(Model.Supplier?.Address) ? "-" : Model.Supplier!.Address)</span>
                </div>
            </div>
        </div>

        <div class="form-section">
            <div class="form-section-title">Serial / สินค้า</div>
            <div class="quotation-info-card">
                <div class="quotation-info-card-title">ข้อมูล Serial / สินค้า</div>
                <div class="quotation-info-grid">
                    <div class="quotation-info-field">
                        <span class="quotation-info-label">หมายเลข Serial</span>
                        <span class="quotation-info-value">@Model.SerialNumber?.SerialNo</span>
                    </div>
                    <div class="quotation-info-field">
                        <span class="quotation-info-label">สถานะ Serial ปัจจุบัน</span>
                        <span class="quotation-info-value">@Model.SerialNumber?.Status</span>
                    </div>
                </div>
                <div class="quotation-info-grid">
                    <div class="quotation-info-field">
                        <span class="quotation-info-label">สินค้า</span>
                        <span class="quotation-info-value">@Model.SerialNumber?.Item?.ItemCode - @Model.SerialNumber?.Item?.ItemName</span>
                    </div>
                    <div class="quotation-info-field">
                        <span class="quotation-info-label">Part Number</span>
                        <span class="quotation-info-value">@(string.IsNullOrWhiteSpace(Model.SerialNumber?.Item?.PartNumber) ? "-" : Model.SerialNumber.Item.PartNumber)</span>
                    </div>
                </div>
                <div class="quotation-info-field">
                    <span class="quotation-info-label">ประกันผู้ขาย</span>
                    <span class="quotation-info-value">@(Model.SerialNumber?.SupplierWarrantyStartDate?.ToString("dd MMM yyyy") ?? "-") ถึง @(Model.SerialNumber?.SupplierWarrantyEndDate?.ToString("dd MMM yyyy") ?? "-")</span>
                </div>
            </div>
        </div>

        <div class="form-section">
            <div class="form-section-title">อาการ / หมายเหตุ</div>
            <div class="detail-grid">
                <div class="detail-item"><span class="detail-label">อาการ/ปัญหา</span><p class="detail-value quote-notes">@(string.IsNullOrWhiteSpace(Model.ProblemDescription) ? "-" : Model.ProblemDescription)</p></div>
                <div class="detail-item"><span class="detail-label">หมายเหตุ</span><p class="detail-value quote-notes">@(string.IsNullOrWhiteSpace(Model.Remark) ? "-" : Model.Remark)</p></div>
            </div>
        </div>

        <div class="form-section">
            <div class="form-section-title">Supplier Handling</div>
            <div class="quotation-party-grid">
                <div class="quotation-party-column">
                    <div class="quotation-info-card">
                        <div class="quotation-info-card-title">Receive Repaired Original</div>
                        <div class="quotation-info-field mb-2">
                            <span class="quotation-info-label">Result</span>
                            <span class="quotation-info-value">Receive the same serial back from supplier after repair.</span>
                        </div>
                        <form asp-action="ReceiveRepairedOriginal" asp-route-id="@Model.SerialClaimLogId" method="post" class="confirm-popover-form">
                            @Html.AntiForgeryToken()
                            <label class="quotation-info-label" for="repairedReceivedDate">Received Date</label>
                            <input id="repairedReceivedDate" name="receivedDate" type="date" value="@dateValue" class="form-control mb-2" disabled="@(!canReceiveResult)" />
                            <label class="quotation-info-label" for="repairedRemark">Remark</label>
                            <textarea id="repairedRemark" name="remark" class="form-control mb-2" rows="2" disabled="@(!canReceiveResult)"></textarea>
                            <div class="confirm-popover-shell">
                                <button type="button" class="btn btn-outline-primary js-confirm-popover-toggle" disabled="@(!canReceiveResult)" title="@receiveBlockedReason" data-confirm-target="receiveRepairedSupplierClaimConfirm_@Model.SerialClaimLogId" aria-expanded="false">Receive Repaired Original</button>
                                <div class="confirm-popover" id="receiveRepairedSupplierClaimConfirm_@Model.SerialClaimLogId" hidden>
                                    <div class="confirm-popover-title">Receive repaired original serial?</div>
                                    <div class="confirm-popover-text">This will record the original serial as returned from the supplier.</div>
                                    <div class="confirm-popover-actions">
                                        <button type="submit" class="btn btn-sm btn-outline-primary">Confirm</button>
                                        <button type="button" class="btn btn-sm btn-outline-secondary js-confirm-popover-cancel">Cancel</button>
                                    </div>
                                </div>
                            </div>
                        </form>
                        @if (!string.IsNullOrWhiteSpace(receiveBlockedReason))
                        {
                            <div class="form-text">@receiveBlockedReason</div>
                        }
                    </div>
                </div>
                <div class="quotation-party-column">
                    <div class="quotation-info-card">
                        <div class="quotation-info-card-title">Receive Replacement From Supplier</div>
                        @if (Model.SupplierReplacementSerialNumber is not null)
                        {
                            <div class="quotation-info-grid">
                                <div class="quotation-info-field">
                                    <span class="quotation-info-label">Replacement Serial</span>
                                    <span class="quotation-info-value">@Model.SupplierReplacementSerialNumber.SerialNo</span>
                                </div>
                                <div class="quotation-info-field">
                                    <span class="quotation-info-label">Status</span>
                                    <span class="quotation-info-value">@Model.SupplierReplacementSerialNumber.Status</span>
                                </div>
                            </div>
                        }
                        else
                        {
                            <form asp-action="ReceiveReplacement" asp-route-id="@Model.SerialClaimLogId" method="post" class="row g-2 confirm-popover-form">
                                @Html.AntiForgeryToken()
                                <div class="col-12">
                                    <label class="quotation-info-label" for="replacementSerialNo">Replacement Serial No.</label>
                                    <input id="replacementSerialNo" name="replacementSerialNo" class="form-control" disabled="@(!canReceiveResult)" />
                                </div>
                                <div class="col-12">
                                    <label class="quotation-info-label" for="replacementReceivedDate">Received Date</label>
                                    <input id="replacementReceivedDate" name="receivedDate" type="date" value="@dateValue" class="form-control" disabled="@(!canReceiveResult)" />
                                </div>
                                <div class="col-md-6">
                                    <label class="quotation-info-label" for="supplierWarrantyStartDate">Supplier Warranty Start</label>
                                    <input id="supplierWarrantyStartDate" name="supplierWarrantyStartDate" type="date" class="form-control" disabled="@(!canReceiveResult)" />
                                </div>
                                <div class="col-md-6">
                                    <label class="quotation-info-label" for="supplierWarrantyEndDate">Supplier Warranty End</label>
                                    <input id="supplierWarrantyEndDate" name="supplierWarrantyEndDate" type="date" class="form-control" disabled="@(!canReceiveResult)" />
                                </div>
                                <div class="col-12">
                                    <label class="quotation-info-label" for="replacementRemark">Remark</label>
                                    <textarea id="replacementRemark" name="remark" class="form-control" rows="2" disabled="@(!canReceiveResult)"></textarea>
                                </div>
                                <div class="col-12">
                                    <div class="confirm-popover-shell">
                                        <button type="button" class="btn btn-outline-primary js-confirm-popover-toggle" disabled="@(!canReceiveResult)" title="@receiveBlockedReason" data-confirm-target="receiveReplacementSupplierClaimConfirm_@Model.SerialClaimLogId" aria-expanded="false">Receive Replacement</button>
                                        <div class="confirm-popover" id="receiveReplacementSupplierClaimConfirm_@Model.SerialClaimLogId" hidden>
                                            <div class="confirm-popover-title">Receive replacement serial?</div>
                                            <div class="confirm-popover-text">This will bring the replacement serial into stock and link it to the supplier claim result.</div>
                                            <div class="confirm-popover-actions">
                                                <button type="submit" class="btn btn-sm btn-outline-primary">Confirm</button>
                                                <button type="button" class="btn btn-sm btn-outline-secondary js-confirm-popover-cancel">Cancel</button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>
                            @if (!string.IsNullOrWhiteSpace(receiveBlockedReason))
                            {
                                <div class="form-text">@receiveBlockedReason</div>
                            }
                        }
                    </div>
                </div>
            </div>
            <div class="quotation-info-card mt-3">
                <div class="quotation-info-card-title">Supplier Rejects Claim</div>
                <form asp-action="SupplierRejected" asp-route-id="@Model.SerialClaimLogId" method="post" class="row g-2 align-items-end confirm-popover-form">
                    @Html.AntiForgeryToken()
                    <div class="col-auto">
                        <label class="quotation-info-label" for="rejectedDate">Rejected Date</label>
                        <input id="rejectedDate" name="rejectedDate" type="date" value="@dateValue" class="form-control" disabled="@(!canReceiveResult)" />
                    </div>
                    <div class="col">
                        <label class="quotation-info-label" for="rejectRemark">Reject Remark</label>
                        <input id="rejectRemark" name="remark" class="form-control" disabled="@(!canReceiveResult)" />
                    </div>
                    <div class="col-auto">
                        <div class="confirm-popover-shell">
                            <button type="button" class="btn btn-outline-danger js-confirm-popover-toggle" disabled="@(!canReceiveResult)" title="@receiveBlockedReason" data-confirm-target="supplierRejectedClaimConfirm_@Model.SerialClaimLogId" aria-expanded="false">Supplier Rejected</button>
                            <div class="confirm-popover" id="supplierRejectedClaimConfirm_@Model.SerialClaimLogId" hidden>
                                <div class="confirm-popover-title">Mark supplier claim as rejected?</div>
                                <div class="confirm-popover-text">This will record the claim as rejected and keep the original serial in defective status.</div>
                                <div class="confirm-popover-actions">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Confirm</button>
                                    <button type="button" class="btn btn-sm btn-outline-secondary js-confirm-popover-cancel">Cancel</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </form>
                @if (!string.IsNullOrWhiteSpace(receiveBlockedReason))
                {
                    <div class="form-text">@receiveBlockedReason</div>
                }
            </div>
        </div>
    </div>
</div>
