@model BizCore.Models.ViewModels.SupplierClaimFormViewModel

@{
    ViewData["Title"] = "สร้างเคลมผู้ขาย";
}

<div class="page-header">
    <div>
        <div class="page-eyebrow">โมดูลรับประกันผู้ขาย</div>
        <h1 class="page-title">สร้างเคลมผู้ขาย</h1>
        </div>
    <div class="page-actions">
        <a asp-action="Index" class="btn btn-outline-secondary">กลับไปรายการเคลม</a>
    </div>
</div>

<div class="card content-card">
    <div class="card-body">
        <form asp-action="Create" method="post">
            <partial name="_Form" model="Model" />
            <div class="form-actions mt-3">
                <span class="table-meta">เมื่อบันทึก ระบบจะสร้างประวัติการเคลมผู้ขายและเปลี่ยนสถานะ Serial เป็น `ClaimedToSupplier`</span>
                <div class="page-actions">
                    <a asp-action="Index" class="btn btn-outline-secondary">ยกเลิก</a>
                    @if (Model.IsClaimBlocked)
                    {
                        <button type="submit" class="btn btn-primary px-4" disabled>บันทึกเคลม</button>
                    }
                    else
                    {
                        <button type="submit" class="btn btn-primary px-4">บันทึกเคลม</button>
                    }
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

