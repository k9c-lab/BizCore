@model BizCore.Models.ViewModels.PaginatedList<BizCore.Models.Entities.SerialClaimLog>

@{
    ViewData["Title"] = "Supplier Claims";
    var search = ViewData["Search"] as string;
    var status = ViewData["Status"] as string;
    var dateFrom = ViewData["DateFrom"] as string;
    var dateTo = ViewData["DateTo"] as string;
}

<div class="page-header">
    <div>
        <div class="page-eyebrow">Supplier Claim Module</div>
        <h1 class="page-title">Supplier Claims</h1>
        <p class="page-subtitle">Track simple serial-based supplier claim logs. Start a new claim from Serial Inquiry or Stock Inquiry.</p>
    </div>
</div>

<div class="card content-card table-card">
    <div class="table-card-header">
        <div>
            <h2 class="section-title">Claim Register</h2>
            <p class="section-subtitle">Each record is a direct claim log from one selected serial.</p>
        </div>
        <div class="table-meta">@Model.TotalCount record(s)</div>
    </div>
    <div class="card-body">
        <form method="get" class="list-filter-bar">
            <div class="list-filter-field grow">
                <label class="form-label" for="search">Search</label>
                <input id="search" name="search" value="@search" class="form-control" placeholder="Serial no., item, part number, supplier, problem, or remark" />
            </div>
            <div class="list-filter-field">
                <label class="form-label" for="status">Claim Status</label>
                <select id="status" name="status" class="form-select">
                    <option value="">All</option>
                    <option value="Open" selected="@(status == "Open")">Open</option>
                    <option value="Sent" selected="@(status == "Sent")">Sent</option>
                    <option value="Returned" selected="@(status == "Returned")">Returned</option>
                    <option value="Rejected" selected="@(status == "Rejected")">Rejected</option>
                    <option value="Closed" selected="@(status == "Closed")">Closed</option>
                </select>
            </div>
            <div class="list-filter-field">
                <label class="form-label" for="dateFrom">From</label>
                <input id="dateFrom" name="dateFrom" value="@dateFrom" type="date" class="form-control" />
            </div>
            <div class="list-filter-field">
                <label class="form-label" for="dateTo">To</label>
                <input id="dateTo" name="dateTo" value="@dateTo" type="date" class="form-control" />
            </div>
            <div class="list-filter-actions">
                <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
                <button type="submit" class="btn btn-primary">Search</button>
            </div>
        </form>
        <div class="table-responsive">
            <table class="table entity-table align-middle">
                <thead>
                    <tr>
                        <th>Claim Date</th>
                        <th>Serial No.</th>
                        <th>Item</th>
                        <th>Supplier</th>
                        <th>Claim Status</th>
                        <th>Serial Status</th>
                        <th class="text-end">Action</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.Any())
                {
                    @foreach (var claim in Model)
                    {
                        <tr>
                            <td>@claim.ClaimDate.ToString("dd MMM yyyy")</td>
                            <td><span class="code-chip">@claim.SerialNumber?.SerialNo</span></td>
                            <td class="fw-semibold">@claim.SerialNumber?.Item?.ItemName</td>
                            <td class="fw-semibold">@claim.Supplier?.SupplierName</td>
                            <td><span class="status-pill active">@claim.ClaimStatus</span></td>
                            <td>@claim.SerialNumber?.Status</td>
                            <td class="text-end">
                                <a asp-action="Details" asp-route-id="@claim.SerialClaimLogId" class="btn btn-sm btn-outline-secondary">View</a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="7" class="table-empty">No supplier claims yet. Start from an eligible serial under supplier warranty.</td></tr>
                }
                </tbody>
            </table>
        </div>
        <partial name="_Pager" model="Model.Pagination" />
    </div>
</div>
