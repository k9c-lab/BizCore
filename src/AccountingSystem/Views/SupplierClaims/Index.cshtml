@model BizCore.Models.ViewModels.PaginatedList<BizCore.Models.Entities.SerialClaimLog>

@{
    ViewData["Title"] = "เคลมผู้ขาย";
    var search = ViewData["Search"] as string;
    var status = ViewData["Status"] as string;
    var dateFrom = ViewData["DateFrom"] as string;
    var dateTo = ViewData["DateTo"] as string;
}

<div class="page-header">
    <div>
        <div class="page-eyebrow">โมดูลรับประกันผู้ขาย</div>
        <h1 class="page-title">เคลมผู้ขาย</h1>
        </div>
</div>

<div class="card content-card table-card">
    <div class="table-card-header">
        <div>
            <h2 class="section-title">รายการเคลมผู้ขาย</h2>
            </div>
        <div class="table-meta">@Model.TotalCount รายการ</div>
    </div>
    <div class="card-body">
        <form method="get" class="list-filter-bar">
            <div class="list-filter-field grow">
                <label class="form-label" for="search">ค้นหา</label>
                <input id="search" name="search" value="@search" class="form-control" placeholder="Serial, สินค้า, Part Number, ผู้ขาย, อาการ หรือหมายเหตุ" />
            </div>
            <div class="list-filter-field">
                <label class="form-label" for="status">สถานะเคลม</label>
                <select id="status" name="status" class="form-select">
                    <option value="">ทั้งหมด</option>
                    <option value="Open" selected="@(status == "Open")">เปิดเคลม</option>
                    <option value="Sent" selected="@(status == "Sent")">ส่งแล้ว</option>
                    <option value="Returned" selected="@(status == "Returned")">รับของเดิมกลับแล้ว</option>
                    <option value="Replaced" selected="@(status == "Replaced")">ได้รับของทดแทน</option>
                    <option value="Rejected" selected="@(status == "Rejected")">ปฏิเสธเคลม</option>
                    <option value="Closed" selected="@(status == "Closed")">ปิดเคลม</option>
                </select>
            </div>
            <div class="list-filter-field">
                <label class="form-label" for="dateFrom">ตั้งแต่วันที่</label>
                <input id="dateFrom" name="dateFrom" value="@dateFrom" type="date" class="form-control" />
            </div>
            <div class="list-filter-field">
                <label class="form-label" for="dateTo">ถึงวันที่</label>
                <input id="dateTo" name="dateTo" value="@dateTo" type="date" class="form-control" />
            </div>
            <div class="list-filter-actions">
                <a asp-action="Index" class="btn btn-outline-secondary">ล้างค่า</a>
                <button type="submit" class="btn btn-primary">ค้นหา</button>
            </div>
        </form>
        <div class="table-responsive">
            <table class="table entity-table align-middle">
                <thead>
                    <tr>
                        <th>วันที่เคลม</th>
                        <th>Serial</th>
                        <th>สินค้า</th>
                        <th>ผู้ขาย</th>
                        <th>สถานะเคลม</th>
                        <th>สถานะ Serial</th>
                        <th class="text-end">การทำงาน</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.Any())
                {
                    @foreach (var claim in Model)
                    {
                        <tr>
                            <td>@claim.ClaimDate.ToString("dd MMM yyyy")</td>
                            <td><span class="code-chip">@claim.SerialNumber?.SerialNo</span></td>
                            <td class="fw-semibold">@claim.SerialNumber?.Item?.ItemName</td>
                            <td class="fw-semibold">@claim.Supplier?.SupplierName</td>
                            <td><span class="status-pill active">@(claim.ClaimStatus == "Open" ? "เปิดเคลม" : claim.ClaimStatus == "Sent" ? "ส่งแล้ว" : claim.ClaimStatus == "Returned" ? "รับของเดิมกลับแล้ว" : claim.ClaimStatus == "Replaced" ? "ได้รับของทดแทน" : claim.ClaimStatus == "Rejected" ? "ปฏิเสธเคลม" : claim.ClaimStatus == "Closed" ? "ปิดเคลม" : claim.ClaimStatus)</span></td>
                            <td>@claim.SerialNumber?.Status</td>
                            <td class="text-end">
                                <a asp-action="Details" asp-route-id="@claim.SerialClaimLogId" class="btn btn-sm btn-outline-secondary">ดูรายละเอียด</a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="7" class="table-empty">ยังไม่มีข้อมูลเคลมผู้ขาย เริ่มต้นจาก Serial ที่ยังอยู่ในประกันผู้ขาย</td></tr>
                }
                </tbody>
            </table>
        </div>
        <partial name="_Pager" model="Model.Pagination" />
    </div>
</div>

