@model BizCore.Models.ViewModels.PaginatedList<BizCore.Models.Entities.StockIssueHeader>

@{
    ViewData["Title"] = "เบิกสต็อก";
    var search = ViewData["Search"] as string;
    var status = ViewData["Status"] as string;
    var issueType = ViewData["IssueType"] as string;
    var dateFrom = ViewData["DateFrom"] as string;
    var dateTo = ViewData["DateTo"] as string;
}

<div class="page-header">
    <div>
        <div class="page-eyebrow">โมดูลคลังสินค้า</div>
        <h1 class="page-title">เบิกสต็อก</h1>
        </div>
    <div class="page-actions">
        <a asp-action="Create" class="btn btn-primary px-4">สร้างใบเบิก</a>
    </div>
</div>

@if (TempData["StockIssueNotice"] is string notice && !string.IsNullOrWhiteSpace(notice))
{
    @await Html.PartialAsync("_Notice", notice)
}

<div class="card content-card table-card">
    <div class="table-card-header">
        <div>
            <h2 class="section-title">รายการใบเบิก</h2>
            </div>
        <div class="table-meta">@Model.TotalCount รายการ</div>
    </div>
    <div class="card-body">
        <form method="get" class="list-filter-bar">
            <div class="list-filter-field grow">
                <label class="form-label" for="search">ค้นหา</label>
                <input id="search" name="search" value="@search" class="form-control" placeholder="เลขที่ใบเบิก, สาขา, สินค้า, วัตถุประสงค์ หรือหมายเหตุ" />
            </div>
            <div class="list-filter-field">
                <label class="form-label" for="status">สถานะ</label>
                <select id="status" name="status" class="form-select">
                    <option value="">ทั้งหมด</option>
                    <option value="Draft" selected="@(status == "Draft")">ฉบับร่าง</option>
                    <option value="Posted" selected="@(status == "Posted")">ลงรายการแล้ว</option>
                    <option value="Cancelled" selected="@(status == "Cancelled")">ยกเลิกแล้ว</option>
                </select>
            </div>
            <div class="list-filter-field">
                <label class="form-label" for="issueType">ประเภท</label>
                <select id="issueType" name="issueType" class="form-select">
                    <option value="">ทั้งหมด</option>
                    <option value="InternalUse" selected="@(issueType == "InternalUse")">ใช้ภายใน</option>
                    <option value="Damaged" selected="@(issueType == "Damaged")">ชำรุด</option>
                    <option value="Demo" selected="@(issueType == "Demo")">สาธิต</option>
                    <option value="Adjustment" selected="@(issueType == "Adjustment")">ปรับปรุง</option>
                    <option value="Other" selected="@(issueType == "Other")">อื่น ๆ</option>
                </select>
            </div>
            <div class="list-filter-field">
                <label class="form-label" for="dateFrom">ตั้งแต่วันที่</label>
                <input id="dateFrom" name="dateFrom" value="@dateFrom" type="date" class="form-control" />
            </div>
            <div class="list-filter-field">
                <label class="form-label" for="dateTo">ถึงวันที่</label>
                <input id="dateTo" name="dateTo" value="@dateTo" type="date" class="form-control" />
            </div>
            <div class="list-filter-actions">
                <a asp-action="Index" class="btn btn-outline-secondary">ล้างค่า</a>
                <button type="submit" class="btn btn-primary">ค้นหา</button>
            </div>
        </form>

        <div class="table-responsive">
            <table class="table entity-table align-middle">
                <thead>
                    <tr>
                        <th>เลขที่ใบเบิก</th>
                        <th>วันที่</th>
                        <th>สาขา</th>
                        <th>ประเภท</th>
                        <th>จำนวนบรรทัด</th>
                        <th>จำนวนรวม</th>
                        <th>สถานะ</th>
                        <th class="text-end">การทำงาน</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.Any())
                {
                    @foreach (var issue in Model)
                    {
                        var canPost = issue.Status == "Draft" && issue.StockIssueDetails.Any();
                        var postBlockedReason = issue.Status == "Draft"
                            ? "ยังลงรายการไม่ได้ เพราะยังไม่มีรายการเบิก"
                            : $"ลงรายการได้เฉพาะใบเบิกสถานะฉบับร่าง สถานะปัจจุบันคือ {issue.Status}.";
                        <tr>
                            <td><span class="code-chip">@issue.IssueNo</span></td>
                            <td>@issue.IssueDate.ToString("dd MMM yyyy")</td>
                            <td>@(issue.Branch?.BranchName ?? "-")</td>
                            <td>@(issue.IssueType == "InternalUse" ? "ใช้ภายใน" : issue.IssueType == "Damaged" ? "ชำรุด" : issue.IssueType == "Demo" ? "สาธิต" : issue.IssueType == "Adjustment" ? "ปรับปรุง" : issue.IssueType == "Other" ? "อื่น ๆ" : issue.IssueType)</td>
                            <td>@issue.StockIssueDetails.Count</td>
                            <td>@issue.StockIssueDetails.Sum(x => x.Qty).ToString("N2")</td>
                            <td><span class="status-pill active">@(issue.Status == "Draft" ? "ฉบับร่าง" : issue.Status == "Posted" ? "ลงรายการแล้ว" : issue.Status == "Cancelled" ? "ยกเลิกแล้ว" : issue.Status)</span></td>
                            <td class="text-end">
                                <div class="table-actions">
                                    <a asp-action="Details" asp-route-id="@issue.StockIssueId" class="btn btn-sm btn-outline-secondary">ดูรายละเอียด</a>
                                    @if (canPost)
                                    {
                                        <form asp-action="Post" asp-route-id="@issue.StockIssueId" method="post" class="d-inline confirm-popover-form">
                                            @Html.AntiForgeryToken()
                                            <div class="confirm-popover-shell">
                                                <button type="button"
                                                        class="btn btn-sm btn-outline-primary js-confirm-popover-toggle"
                                                        data-confirm-target="postStockIssueConfirm_@issue.StockIssueId"
                                                        aria-expanded="false">
                                                    ลงรายการ
                                                </button>
                                                <div class="confirm-popover" id="postStockIssueConfirm_@issue.StockIssueId" hidden>
                                                    <div class="confirm-popover-title">ลงรายการใบเบิกสต็อกนี้หรือไม่?</div>
                                                    <div class="confirm-popover-text">ระบบจะตัดสต็อกจากสาขาที่เลือกและปิดเอกสารใบเบิกนี้</div>
                                                    <div class="confirm-popover-actions">
                                                        <button type="submit" class="btn btn-sm btn-outline-primary">ยืนยัน</button>
                                                        <button type="button" class="btn btn-sm btn-outline-secondary js-confirm-popover-cancel">ปิด</button>
                                                    </div>
                                                </div>
                                            </div>
                                        </form>
                                    }
                                    else
                                    {
                                        <button type="button" class="btn btn-sm btn-outline-secondary" disabled title="@postBlockedReason">ลงรายการ</button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="8" class="table-empty">ยังไม่มีข้อมูลใบเบิกสต็อก</td></tr>
                }
                </tbody>
            </table>
        </div>
        <partial name="_Pager" model="Model.Pagination" />
    </div>
</div>

