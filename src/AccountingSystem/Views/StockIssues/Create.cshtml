@model BizCore.Models.ViewModels.StockIssueFormViewModel

@{
    ViewData["Title"] = Model.StockIssueId.HasValue ? "แก้ไขใบเบิกสต็อก" : "สร้างใบเบิกสต็อก";
    var formAction = Model.StockIssueId.HasValue ? "Edit" : "Create";
    var itemOptions = Model.ItemLookup
        .Select(x => new { x.ItemId, x.DisplayText, x.ItemCode, x.ItemName, x.PartNumber, x.IsSerialControlled })
        .ToList();
}

<div class="page-header">
    <div>
        <div class="page-eyebrow">โมดูลคลังสินค้า</div>
        <h1 class="page-title">@ViewData["Title"]</h1>
        </div>
    <div class="page-actions">
        @if (Model.StockIssueId.HasValue)
        {
            <form asp-action="Post" asp-route-id="@Model.StockIssueId.Value" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-success">ลงรายการใบเบิก</button>
            </form>
            <a asp-action="Details" asp-route-id="@Model.StockIssueId.Value" class="btn btn-outline-secondary">กลับไปหน้ารายละเอียด</a>
        }
        else
        {
            <a asp-action="Index" class="btn btn-outline-secondary">กลับไปรายการใบเบิก</a>
        }
    </div>
</div>

<div class="card content-card">
    <div class="card-body">
        <form action="@Url.Action(formAction, Model.StockIssueId.HasValue ? new { id = Model.StockIssueId.Value } : null)" method="post">
            @Html.AntiForgeryToken()
            <input asp-for="StockIssueId" type="hidden" />
            <input asp-for="Status" type="hidden" />

            <div asp-validation-summary="All" class="form-alert"></div>

            <div class="form-shell">
                <div class="form-section quotation-header-section">
                    <div class="form-section-title">ข้อมูลหัวเอกสาร</div>
                    <div class="row g-3 quotation-header-grid">
                        <div class="col-lg-3 col-md-6">
                            <label asp-for="IssueNo" class="form-label"></label>
                            <input asp-for="IssueNo" class="form-control" readonly />
                            <span asp-validation-for="IssueNo" class="text-danger"></span>
                        </div>
                        <div class="col-lg-3 col-md-6">
                            <label asp-for="IssueDate" class="form-label"></label>
                            <input asp-for="IssueDate" type="date" class="form-control" />
                            <span asp-validation-for="IssueDate" class="text-danger"></span>
                        </div>
                        <div class="col-lg-3 col-md-6">
                            <label asp-for="BranchId" class="form-label"></label>
                            @if (Model.CanAccessAllBranches)
                            {
                                <select asp-for="BranchId" asp-items="Model.BranchOptions" class="form-select">
                                    <option value="">เลือกสาขา</option>
                                </select>
                            }
                            else
                            {
                                <input type="hidden" asp-for="BranchId" />
                                <div class="form-control readonly-detail">@Model.BranchName</div>
                            }
                            <span asp-validation-for="BranchId" class="text-danger"></span>
                        </div>
                        <div class="col-lg-3 col-md-6">
                            <label asp-for="IssueType" class="form-label"></label>
                            <select asp-for="IssueType" asp-items="Model.IssueTypeOptions" class="form-select"></select>
                            <span asp-validation-for="IssueType" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Purpose" class="form-label"></label>
                            <input asp-for="Purpose" class="form-control" maxlength="500" />
                            <span asp-validation-for="Purpose" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Remark" class="form-label"></label>
                            <input asp-for="Remark" class="form-control" maxlength="500" />
                            <span asp-validation-for="Remark" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="form-section">
                    <div class="d-flex justify-content-between align-items-center gap-2 mb-3 flex-wrap">
                        <div>
                            <div class="form-section-title mb-1">รายการเบิก</div>
                            <div class="table-meta">สำหรับสินค้าที่ควบคุม Serial ให้เลือก Serial ที่พร้อมใช้จากสาขาที่เลือก</div>
                        </div>
                        <button type="button" class="btn btn-outline-primary btn-sm" id="addIssueLine">เพิ่มรายการ</button>
                    </div>

                    <div class="table-responsive">
                        <table class="table entity-table quote-editor-table align-middle" id="issueLinesTable">
                            <thead>
                                <tr>
                                    <th style="width: 5%;">#</th>
                                    <th style="width: 31%;">สินค้า</th>
                                    <th style="width: 13%;">จำนวน</th>
                                    <th style="width: 31%;">หมายเลข Serial</th>
                                    <th style="width: 20%;">หมายเหตุ</th>
                                </tr>
                            </thead>
                            <tbody>
                            @for (var i = 0; i < Model.Details.Count; i++)
                            {
                                <tr>
                                    <td class="line-number">@(i + 1)</td>
                                    <td>
                                        <input type="hidden" asp-for="Details[i].StockIssueDetailId" />
                                        <input type="hidden" asp-for="Details[i].LineNumber" value="@(i + 1)" />
                                        <select asp-for="Details[i].ItemId" class="form-select issue-item-select">
                                            <option value="">เลือกสินค้า</option>
                                            @foreach (var item in Model.ItemLookup)
                                            {
                                                <option value="@item.ItemId" selected="@(Model.Details[i].ItemId == item.ItemId)">@item.DisplayText</option>
                                            }
                                        </select>
                                        <div class="table-meta issue-stock-hint">เลือกสินค้าเพื่อดูสต็อกของสาขา</div>
                                        <span asp-validation-for="Details[i].ItemId" class="text-danger"></span>
                                    </td>
                                    <td>
                                        <input asp-for="Details[i].Qty" class="form-control text-end" type="number" step="0.01" min="0" />
                                        <span asp-validation-for="Details[i].Qty" class="text-danger"></span>
                                    </td>
                                    <td>
                                        <textarea asp-for="Details[i].SerialEntryText" class="form-control serial-entry d-none" rows="2"></textarea>
                                        <div class="serial-picker-panel">
                                            <div class="d-flex gap-2 align-items-center mb-2 flex-wrap">
                                                <button type="button" class="btn btn-sm btn-outline-secondary load-serials-btn">โหลด Serial</button>
                                                <span class="table-meta serial-picker-status">เลือกสินค้าและสาขาก่อน</span>
                                            </div>
                                            <div class="serial-picker-list"></div>
                                        </div>
                                        <span asp-validation-for="Details[i].SerialEntryText" class="text-danger"></span>
                                    </td>
                                    <td>
                                        <input asp-for="Details[i].Remark" class="form-control" maxlength="500" />
                                        <span asp-validation-for="Details[i].Remark" class="text-danger"></span>
                                    </td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="form-actions">
                    <button type="submit" name="command" value="SaveDraft" class="btn btn-outline-primary">บันทึกฉบับร่าง</button>
                    <button type="submit" name="command" value="Post" class="btn btn-success">ลงรายการใบเบิก</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">ยกเลิก</a>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const stockIssueItems = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(itemOptions));
        const buildItemOptions = () => ['<option value="">เลือกสินค้า</option>']
            .concat(stockIssueItems.map(item => `<option value="${item.ItemId}">${item.DisplayText}</option>`))
            .join('');
        const renumberIssueLines = () => {
            document.querySelectorAll('#issueLinesTable tbody tr').forEach((row, index) => {
                row.querySelector('.line-number').textContent = index + 1;
                row.querySelectorAll('input, select, textarea').forEach((field) => {
                    field.name = field.name.replace(/Details\[\d+\]/, `Details[${index}]`);
                    field.id = field.id.replace(/Details_\d+__/, `Details_${index}__`);
                });
                const lineInput = row.querySelector(`input[name="Details[${index}].LineNumber"]`);
                if (lineInput) {
                    lineInput.value = index + 1;
                }
            });
        };
        document.getElementById('addIssueLine')?.addEventListener('click', () => {
            const tbody = document.querySelector('#issueLinesTable tbody');
            const index = tbody.querySelectorAll('tr').length;
            const row = document.createElement('tr');
            row.innerHTML = `
                <td class="line-number">${index + 1}</td>
                <td>
                    <input type="hidden" name="Details[${index}].StockIssueDetailId" />
                    <input type="hidden" name="Details[${index}].LineNumber" value="${index + 1}" />
                    <select name="Details[${index}].ItemId" class="form-select issue-item-select">${buildItemOptions()}</select>
                    <div class="table-meta issue-stock-hint">เลือกสินค้าเพื่อดูสต็อกของสาขา</div>
                </td>
                <td><input name="Details[${index}].Qty" class="form-control text-end" type="number" step="0.01" min="0" value="0" /></td>
                <td>
                    <textarea name="Details[${index}].SerialEntryText" class="form-control serial-entry d-none" rows="2"></textarea>
                    <div class="serial-picker-panel">
                        <div class="d-flex gap-2 align-items-center mb-2 flex-wrap">
                            <button type="button" class="btn btn-sm btn-outline-secondary load-serials-btn">โหลด Serial</button>
                            <span class="table-meta serial-picker-status">เลือกสินค้าและสาขาก่อน</span>
                        </div>
                        <div class="serial-picker-list"></div>
                    </div>
                </td>
                <td><input name="Details[${index}].Remark" class="form-control" maxlength="500" /></td>`;
            tbody.appendChild(row);
            renumberIssueLines();
        });

        const getSelectedItem = (row) => {
            const itemId = Number(row.querySelector('.issue-item-select')?.value || 0);
            return stockIssueItems.find(item => Number(item.ItemId) === itemId);
        };
        const getBranchId = () => document.getElementById('BranchId')?.value || document.querySelector('input[name="BranchId"]')?.value || '';
        const loadStockForRow = async (row) => {
            const item = getSelectedItem(row);
            const branchId = getBranchId();
            const hint = row.querySelector('.issue-stock-hint');
            if (!hint) return;
            if (!item) {
                hint.textContent = 'เลือกสินค้าเพื่อดูสต็อกของสาขา';
                return;
            }
            if (!branchId) {
                hint.textContent = 'เลือกสาขาเพื่อดูสต็อก';
                return;
            }
            hint.textContent = 'กำลังโหลดสต็อกของสาขา...';
            const response = await fetch(`@Url.Action("AvailableStock", "StockIssues")?itemId=${item.ItemId}&branchId=${branchId}`);
            if (!response.ok) {
                hint.textContent = 'ไม่สามารถโหลดสต็อกของสาขาได้';
                return;
            }
            const data = await response.json();
            const qty = Number(data.qtyOnHand ?? data.QtyOnHand ?? 0);
            hint.textContent = `สต็อกของสาขา: ${qty.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
        };
        const loadStockForAllRows = () => document.querySelectorAll('#issueLinesTable tbody tr').forEach(row => loadStockForRow(row));
        const getSelectedSerials = (textarea) => (textarea.value || '').split(/\r?\n|,/).map(value => value.trim()).filter(value => value.length > 0);
        const syncSerialTextarea = (row) => {
            const textarea = row.querySelector('.serial-entry');
            const selected = Array.from(row.querySelectorAll('.serial-picker-check:checked')).map(input => input.value);
            textarea.value = selected.join('\n');
            const qtyInput = row.querySelector('input[name$=".Qty"]');
            const item = getSelectedItem(row);
            if (item?.IsSerialControlled && selected.length > 0 && qtyInput) {
                qtyInput.value = selected.length;
            }
        };
        const renderSerialList = (row, serials) => {
            const list = row.querySelector('.serial-picker-list');
            const status = row.querySelector('.serial-picker-status');
            const textarea = row.querySelector('.serial-entry');
            const selected = new Set(getSelectedSerials(textarea));
            if (!serials.length) {
                list.innerHTML = '<div class="table-meta">ไม่พบ Serial ที่พร้อมใช้ในสาขาที่เลือก</div>';
                status.textContent = 'มี Serial พร้อมใช้ 0 รายการ';
                return;
            }
            list.innerHTML = serials.map(serial => {
                const serialNo = serial.serialNo || serial.SerialNo;
                const isChecked = selected.has(serialNo);
                return `<label class="form-check transfer-serial-choice">
                    <input class="form-check-input serial-picker-check" type="checkbox" value="${serialNo}" ${isChecked ? 'checked' : ''} />
                    <span class="form-check-label">${serialNo}</span>
                </label>`;
            }).join('');
            status.textContent = `มี Serial พร้อมใช้ ${serials.length} รายการ`;
        };
        const loadSerialsForRow = async (row) => {
            const item = getSelectedItem(row);
            const branchId = getBranchId();
            const status = row.querySelector('.serial-picker-status');
            const list = row.querySelector('.serial-picker-list');
            if (!item?.IsSerialControlled) {
                status.textContent = item ? 'สินค้าที่เลือกไม่ได้ควบคุม Serial' : 'กรุณาเลือกสินค้าที่ควบคุม Serial';
                list.innerHTML = '';
                row.querySelector('.serial-entry').value = '';
                return;
            }
            if (!branchId) {
                status.textContent = 'กรุณาเลือกสาขาก่อน';
                list.innerHTML = '';
                return;
            }
            status.textContent = 'กำลังโหลด Serial...';
            const response = await fetch(`@Url.Action("AvailableSerials", "StockIssues")?itemId=${item.ItemId}&branchId=${branchId}`);
            if (!response.ok) {
                status.textContent = 'ไม่สามารถโหลด Serial ของสาขานี้ได้';
                list.innerHTML = '';
                return;
            }
            renderSerialList(row, await response.json());
        };
        document.addEventListener('click', (event) => {
            if (event.target.classList.contains('load-serials-btn')) {
                loadSerialsForRow(event.target.closest('tr'));
            }
        });
        document.addEventListener('change', (event) => {
            if (event.target.classList.contains('serial-picker-check')) {
                syncSerialTextarea(event.target.closest('tr'));
            }
            if (event.target.classList.contains('issue-item-select')) {
                const row = event.target.closest('tr');
                loadStockForRow(row);
                row.querySelector('.serial-picker-list').innerHTML = '';
                row.querySelector('.serial-picker-status').textContent = 'โหลด Serial หลังจากเลือกสินค้าแล้ว';
                row.querySelector('.serial-entry').value = '';
            }
            if (event.target.id === 'BranchId') {
                document.querySelectorAll('#issueLinesTable tbody tr').forEach(row => {
                    loadStockForRow(row);
                    row.querySelector('.serial-picker-list').innerHTML = '';
                    row.querySelector('.serial-picker-status').textContent = 'กรุณาโหลด Serial ใหม่หลังเปลี่ยนสาขา';
                    row.querySelector('.serial-entry').value = '';
                });
            }
        });
        loadStockForAllRows();
    </script>
}

