@model BizCore.Models.ViewModels.PaymentFormViewModel

@{
    ViewData["Title"] = "สร้างรายการรับชำระ";
}

<div class="page-header">
    <div>
        <div class="page-eyebrow">งานลูกหนี้</div>
        <h1 class="page-title">สร้างรายการรับชำระ</h1>
        <p class="page-subtitle">
            @(Model.BillingNoteId.HasValue
                ? $"รับชำระจากใบวางบิล {Model.BillingNoteNo} และกระจายยอดไปยังใบแจ้งหนี้ภายใต้ใบวางบิลนี้"
                : "รับชำระตามลูกค้าและจัดสรรยอดไปยังใบแจ้งหนี้ที่ยังมียอดคงเหลือ")
        </p>
    </div>
    <div class="page-actions">
        <button type="submit" form="paymentForm" name="submitAction" value="draft" class="btn btn-outline-primary js-payment-submit-button">บันทึกฉบับร่าง</button>
        <button type="submit" form="paymentForm" name="submitAction" value="post" class="btn btn-primary px-4 js-payment-submit-button">บันทึกรับชำระ</button>
        <a asp-action="Index" class="btn btn-outline-secondary">กลับไปรายการรับชำระ</a>
    </div>
</div>

<div class="card content-card">
    <div class="card-body">
        <form asp-action="Create" method="post" id="paymentForm">
            <partial name="_Form" model="Model" />
            <div class="form-actions mt-3">
                <span class="table-meta">
                    @(Model.BillingNoteId.HasValue
                        ? "เมื่อบันทึกรายการ ระบบจะลงรับชำระให้ใบวางบิลนี้ และลดคงเหลือของใบแจ้งหนี้ต้นทางตามจำนวนที่จัดสรร"
                        : "เมื่อบันทึกรายการ ระบบจะลงรับชำระทันที โดยสามารถจัดสรรทั้งหมด บางส่วน หรือปล่อยเป็นยอดยังไม่จัดสรรได้")
                </span>
                <div class="page-actions">
                    <span class="table-meta text-danger" id="postPaymentReason"></span>
                    <a asp-action="Index" class="btn btn-outline-secondary">กลับไปรายการรับชำระ</a>
                    <button type="submit" name="submitAction" value="draft" class="btn btn-outline-primary js-payment-submit-button">บันทึกฉบับร่าง</button>
                    <button type="submit" name="submitAction" value="post" class="btn btn-primary px-4 js-payment-submit-button">บันทึกรับชำระ</button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <partial name="_PaymentEditorScripts" model="Model" />
}
