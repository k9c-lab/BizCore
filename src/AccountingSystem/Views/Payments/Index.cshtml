@model BizCore.Models.ViewModels.PaginatedList<BizCore.Models.Entities.PaymentHeader>

@{
    ViewData["Title"] = "รับชำระเงิน";
    var search = ViewData["Search"] as string;
    var status = ViewData["Status"] as string;
    var dateFrom = ViewData["DateFrom"] as string;
    var dateTo = ViewData["DateTo"] as string;
}

<div class="page-header">
    <div>
        <div class="page-eyebrow">ลูกหนี้การค้า</div>
        <h1 class="page-title">รับชำระเงิน</h1>
        <p class="page-subtitle">รองรับทั้งการรับชำระตามใบแจ้งหนี้ปกติ และการรับชำระผ่านใบวางบิล</p>
    </div>
    <div class="page-actions">
        <a asp-action="Create" class="btn btn-primary px-4">สร้างรายการรับชำระ</a>
    </div>
</div>

<div class="card content-card table-card">
    <div class="table-card-header">
        <div>
            <h2 class="section-title">รายการรับชำระเงิน</h2>
        </div>
        <div class="table-meta">@Model.TotalCount รายการ</div>
    </div>
    <div class="card-body">
        <form method="get" class="list-filter-bar">
            <div class="list-filter-field grow">
                <label class="form-label" for="search">ค้นหา</label>
                <input id="search" name="search" value="@search" class="form-control" placeholder="เลขที่รับชำระ, เลขอ้างอิง, ลูกค้า, ใบวางบิล หรือเลขที่ใบเสร็จ" />
            </div>
            <div class="list-filter-field">
                <label class="form-label" for="status">สถานะ</label>
                <select id="status" name="status" class="form-select">
                    <option value="">ทั้งหมด</option>
                    <option value="Draft" selected="@(status == "Draft")">ฉบับร่าง</option>
                    <option value="Posted" selected="@(status == "Posted")">บันทึกแล้ว</option>
                    <option value="Cancelled" selected="@(status == "Cancelled")">ยกเลิกแล้ว</option>
                </select>
            </div>
            <div class="list-filter-field">
                <label class="form-label" for="dateFrom">จากวันที่</label>
                <input id="dateFrom" name="dateFrom" value="@dateFrom" type="date" class="form-control" />
            </div>
            <div class="list-filter-field">
                <label class="form-label" for="dateTo">ถึงวันที่</label>
                <input id="dateTo" name="dateTo" value="@dateTo" type="date" class="form-control" />
            </div>
            <div class="list-filter-actions">
                <a asp-action="Index" class="btn btn-outline-secondary">ล้างค่า</a>
                <button type="submit" class="btn btn-primary">ค้นหา</button>
            </div>
        </form>
        <div class="table-responsive">
            <table class="table entity-table align-middle">
                <thead>
                    <tr>
                        <th>เลขที่รับชำระ</th>
                        <th>วันที่รับชำระ</th>
                        <th>ลูกค้า</th>
                        <th>ใบวางบิล</th>
                        <th>จำนวนเงิน</th>
                        <th>สถานะ</th>
                        <th>ใบเสร็จ</th>
                        <th class="text-end">การทำงาน</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.Any())
                {
                    @foreach (var payment in Model)
                    {
                        <tr>
                            <td><span class="code-chip">@payment.PaymentNo</span></td>
                            <td>@payment.PaymentDate.ToString("dd MMM yyyy")</td>
                            <td class="fw-semibold">@payment.Customer?.CustomerName</td>
                            <td>
                                @if (payment.BillingNoteHeader is not null)
                                {
                                    <a asp-controller="BillingNotes" asp-action="Details" asp-route-id="@payment.BillingNoteHeader.BillingNoteId" class="code-chip">@payment.BillingNoteHeader.BillingNoteNo</a>
                                }
                                else
                                {
                                    <span>-</span>
                                }
                            </td>
                            <td>@payment.Amount.ToString("N2")</td>
                            <td><span class="status-pill active">@payment.Status</span></td>
                            <td>
                                @if (payment.ReceiptHeader is not null)
                                {
                                    <a asp-controller="Receipts" asp-action="Details" asp-route-id="@payment.ReceiptHeader.ReceiptId" class="code-chip">@payment.ReceiptHeader.ReceiptNo</a>
                                }
                                else
                                {
                                    <span>-</span>
                                }
                            </td>
                            <td class="text-end">
                                <div class="table-actions">
                                    <a asp-action="Details" asp-route-id="@payment.PaymentId" class="btn btn-sm btn-outline-secondary">ดูรายละเอียด</a>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="8" class="table-empty">ยังไม่มีรายการรับชำระ เริ่มจากเลือกลูกค้าและจัดสรรยอดชำระให้ใบแจ้งหนี้ค้างรับได้เลย</td></tr>
                }
                </tbody>
            </table>
        </div>
        <partial name="_Pager" model="Model.Pagination" />
    </div>
</div>
