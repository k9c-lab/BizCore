@model BizCore.Models.ViewModels.PaginatedList<BizCore.Models.Entities.PaymentHeader>

@{
    ViewData["Title"] = "Payments";
    var search = ViewData["Search"] as string;
    var status = ViewData["Status"] as string;
    var dateFrom = ViewData["DateFrom"] as string;
    var dateTo = ViewData["DateTo"] as string;
}

<div class="page-header">
    <div>
        <div class="page-eyebrow">AR Module</div>
        <h1 class="page-title">Payments</h1>
        <p class="page-subtitle">Post customer payments, allocate them to open invoices, and issue one receipt per payment.</p>
    </div>
    <div class="page-actions">
        <a asp-action="Create" class="btn btn-primary px-4">New Payment</a>
    </div>
</div>

<div class="card content-card table-card">
    <div class="table-card-header">
        <div>
            <h2 class="section-title">Payment Register</h2>
            <p class="section-subtitle">Receipt cancellation reversal and AP stay out of scope for now.</p>
        </div>
        <div class="table-meta">@Model.TotalCount record(s)</div>
    </div>
    <div class="card-body">
        <form method="get" class="list-filter-bar">
            <div class="list-filter-field grow">
                <label class="form-label" for="search">Search</label>
                <input id="search" name="search" value="@search" class="form-control" placeholder="Payment no., reference, customer, or receipt no." />
            </div>
            <div class="list-filter-field">
                <label class="form-label" for="status">Status</label>
                <select id="status" name="status" class="form-select">
                    <option value="">All</option>
                    <option value="Draft" selected="@(status == "Draft")">Draft</option>
                    <option value="Posted" selected="@(status == "Posted")">Posted</option>
                    <option value="Cancelled" selected="@(status == "Cancelled")">Cancelled</option>
                </select>
            </div>
            <div class="list-filter-field">
                <label class="form-label" for="dateFrom">From</label>
                <input id="dateFrom" name="dateFrom" value="@dateFrom" type="date" class="form-control" />
            </div>
            <div class="list-filter-field">
                <label class="form-label" for="dateTo">To</label>
                <input id="dateTo" name="dateTo" value="@dateTo" type="date" class="form-control" />
            </div>
            <div class="list-filter-actions">
                <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
                <button type="submit" class="btn btn-primary">Search</button>
            </div>
        </form>
        <div class="table-responsive">
            <table class="table entity-table align-middle">
                <thead>
                    <tr>
                        <th>Payment No.</th>
                        <th>Payment Date</th>
                        <th>Customer</th>
                        <th>Amount</th>
                        <th>Status</th>
                        <th>Receipt</th>
                        <th class="text-end">Action</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.Any())
                {
                    @foreach (var payment in Model)
                    {
                        var canGenerateReceipt = payment.Status == "Posted" && payment.ReceiptHeader is null;
                        var canCancel = payment.Status == "Posted" && payment.ReceiptHeader?.Status != "Issued";
                        <tr>
                            <td><span class="code-chip">@payment.PaymentNo</span></td>
                            <td>@payment.PaymentDate.ToString("dd MMM yyyy")</td>
                            <td class="fw-semibold">@payment.Customer?.CustomerName</td>
                            <td>@payment.Amount.ToString("N2")</td>
                            <td><span class="status-pill active">@payment.Status</span></td>
                            <td>
                                @if (payment.ReceiptHeader is not null)
                                {
                                    <a asp-controller="Receipts" asp-action="Details" asp-route-id="@payment.ReceiptHeader.ReceiptId" class="code-chip">@payment.ReceiptHeader.ReceiptNo</a>
                                }
                                else
                                {
                                    <span>-</span>
                                }
                            </td>
                            <td class="text-end">
                                <div class="table-actions">
                                    <a asp-action="Details" asp-route-id="@payment.PaymentId" class="btn btn-sm btn-outline-secondary">View</a>
                                    @if (canGenerateReceipt)
                                    {
                                        <form asp-action="GenerateReceipt" asp-route-id="@payment.PaymentId" method="post" class="d-inline confirm-popover-form">
                                            @Html.AntiForgeryToken()
                                            <div class="confirm-popover-shell">
                                                <button type="button"
                                                        class="btn btn-sm btn-primary js-confirm-popover-toggle"
                                                        data-confirm-target="generateReceiptPaymentConfirm_@payment.PaymentId"
                                                        aria-expanded="false">
                                                    Generate Receipt
                                                </button>
                                                <div class="confirm-popover" id="generateReceiptPaymentConfirm_@payment.PaymentId" hidden>
                                                    <div class="confirm-popover-title">Generate receipt for this payment?</div>
                                                    <div class="confirm-popover-text">This will create one receipt linked to this posted payment.</div>
                                                    <div class="confirm-popover-actions">
                                                        <button type="submit" class="btn btn-sm btn-outline-primary">Confirm</button>
                                                        <button type="button" class="btn btn-sm btn-outline-secondary js-confirm-popover-cancel">Cancel</button>
                                                    </div>
                                                </div>
                                            </div>
                                        </form>
                                    }
                                    @if (canCancel)
                                    {
                                        <form asp-action="Cancel" asp-route-id="@payment.PaymentId" method="post" class="d-inline confirm-popover-form">
                                            @Html.AntiForgeryToken()
                                            <div class="confirm-popover-shell">
                                                <button type="button"
                                                        class="btn btn-sm btn-outline-danger js-confirm-popover-toggle"
                                                        data-confirm-target="cancelPaymentConfirm_@payment.PaymentId"
                                                        aria-expanded="false">
                                                    Cancel
                                                </button>
                                                <div class="confirm-popover" id="cancelPaymentConfirm_@payment.PaymentId" hidden>
                                                    <div class="confirm-popover-title">Cancel this payment?</div>
                                                    <div class="confirm-popover-text">This will cancel the payment and reverse any invoice allocations linked to it.</div>
                                                    <div class="confirm-popover-actions">
                                                        <button type="submit" class="btn btn-sm btn-outline-danger">Confirm</button>
                                                        <button type="button" class="btn btn-sm btn-outline-secondary js-confirm-popover-cancel">Cancel</button>
                                                    </div>
                                                </div>
                                            </div>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="7" class="table-empty">No payments yet. Start by selecting a customer and allocating payment to open invoices.</td></tr>
                }
                </tbody>
            </table>
        </div>
        <partial name="_Pager" model="Model.Pagination" />
    </div>
</div>
