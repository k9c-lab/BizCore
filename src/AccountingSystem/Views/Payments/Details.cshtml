@model BizCore.Models.Entities.PaymentHeader

@{
    ViewData["Title"] = "Payment Details";
}

<div class="page-header">
    <div>
        <div class="page-eyebrow">AR Module</div>
        <h1 class="page-title">Payment Details</h1>
        <p class="page-subtitle">Review posted payment information, invoice allocations, and the issued receipt.</p>
    </div>
    <div class="page-actions">
        <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
        @if (Model.ReceiptHeader is not null)
        {
            <a asp-controller="Receipts" asp-action="Details" asp-route-id="@Model.ReceiptHeader.ReceiptId" class="btn btn-primary">View Receipt</a>
        }
    </div>
</div>

<div class="card content-card mb-3">
    <div class="card-body">
        <div class="detail-grid">
            <div class="detail-item"><span class="detail-label">Payment No.</span><p class="detail-value">@Model.PaymentNo</p></div>
            <div class="detail-item"><span class="detail-label">Payment Date</span><p class="detail-value">@Model.PaymentDate.ToString("dd MMM yyyy")</p></div>
            <div class="detail-item"><span class="detail-label">Customer</span><p class="detail-value">@Model.Customer?.CustomerName</p></div>
            <div class="detail-item"><span class="detail-label">Payment Method</span><p class="detail-value">@Model.PaymentMethod</p></div>
            <div class="detail-item"><span class="detail-label">Reference No.</span><p class="detail-value">@(string.IsNullOrWhiteSpace(Model.ReferenceNo) ? "-" : Model.ReferenceNo)</p></div>
            <div class="detail-item"><span class="detail-label">Status</span><p class="detail-value">@Model.Status</p></div>
            <div class="detail-item"><span class="detail-label">Remark</span><p class="detail-value quote-notes">@(string.IsNullOrWhiteSpace(Model.Remark) ? "-" : Model.Remark)</p></div>
            <div class="detail-item"><span class="detail-label">Receipt</span><p class="detail-value">@(Model.ReceiptHeader?.ReceiptNo ?? "-")</p></div>
        </div>
    </div>
</div>

<div class="card content-card table-card mb-3">
    <div class="table-card-header">
        <div>
            <h2 class="section-title">Payment Allocation</h2>
            <p class="section-subtitle">Each allocation updates invoice paid amount, balance amount, and status.</p>
        </div>
        <div class="table-meta">@Model.PaymentAllocations.Count allocation(s)</div>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table entity-table align-middle">
                <thead>
                    <tr>
                        <th>Invoice No.</th>
                        <th>Invoice Date</th>
                        <th>Total</th>
                        <th>Updated Status</th>
                        <th class="text-end">Applied Amount</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var allocation in Model.PaymentAllocations.OrderBy(x => x.InvoiceHeader!.InvoiceDate).ThenBy(x => x.InvoiceHeader!.InvoiceNo))
                {
                    <tr>
                        <td><span class="code-chip">@allocation.InvoiceHeader?.InvoiceNo</span></td>
                        <td>@allocation.InvoiceHeader?.InvoiceDate.ToString("dd MMM yyyy")</td>
                        <td>@allocation.InvoiceHeader?.TotalAmount.ToString("N2")</td>
                        <td>@allocation.InvoiceHeader?.Status</td>
                        <td class="text-end">@allocation.AppliedAmount.ToString("N2")</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="quote-summary-grid">
    <div class="quote-summary-card">
        <span class="quote-summary-label">Payment Amount</span>
        <p class="quote-summary-value">@Model.Amount.ToString("N2")</p>
    </div>
    <div class="quote-summary-card">
        <span class="quote-summary-label">Applied</span>
        <p class="quote-summary-value">@Model.PaymentAllocations.Sum(x => x.AppliedAmount).ToString("N2")</p>
    </div>
    <div class="quote-summary-card">
        <span class="quote-summary-label">Unapplied</span>
        <p class="quote-summary-value">@Math.Max(Model.Amount - Model.PaymentAllocations.Sum(x => x.AppliedAmount), 0m).ToString("N2")</p>
    </div>
</div>
