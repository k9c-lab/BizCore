@model BizCore.Models.Entities.PaymentHeader

@{
    ViewData["Title"] = "รายละเอียดการรับชำระ";
    var isDraft = Model.Status == "Draft";
    var appliedAmount = Model.PaymentAllocations.Sum(x => x.AppliedAmount);
    var unappliedAmount = Math.Max(Model.Amount - appliedAmount, 0m);
    var hasAllocations = Model.PaymentAllocations.Any();
    var canGenerateReceipt = Model.Status == "Posted" && Model.ReceiptHeader is null;
    var generateReceiptBlockedReason = canGenerateReceipt
        ? string.Empty
        : Model.Status != "Posted"
            ? $"ออกใบเสร็จได้เฉพาะรายการรับชำระที่บันทึกแล้ว สถานะปัจจุบันคือ {Model.Status}"
            : "ไม่สามารถออกใบเสร็จได้ เพราะรายการนี้มีใบเสร็จแล้ว";
    var canCancel = Model.Status == "Posted" && Model.ReceiptHeader?.Status != "Issued";
    var cancelBlockedReason = canCancel
        ? string.Empty
        : Model.Status != "Posted"
            ? $"ยกเลิกรายการรับชำระได้เฉพาะรายการที่บันทึกแล้ว สถานะปัจจุบันคือ {Model.Status}"
            : "ไม่สามารถยกเลิกรายการรับชำระได้ เพราะมีใบเสร็จแล้ว กรุณายกเลิกใบเสร็จก่อน";
}

@if (TempData["PaymentNotice"] is string notice && !string.IsNullOrWhiteSpace(notice))
{
    @await Html.PartialAsync("_Notice", notice)
}

<div class="page-header">
    <div>
        <div class="page-eyebrow">ลูกหนี้การค้า</div>
        <h1 class="page-title">รายละเอียดการรับชำระ</h1>
        <p class="page-subtitle">@(isDraft
            ? "ตรวจสอบฉบับร่างการรับชำระก่อนบันทึกจริง โดยฉบับร่างยังไม่กระทบยอดใบแจ้งหนี้หรือใบวางบิล"
            : "ตรวจสอบข้อมูลการรับชำระ การจัดสรรไปยังใบแจ้งหนี้ และใบเสร็จที่ออกแล้ว")</p>
    </div>
    <div class="page-actions">
        @if (isDraft)
        {
            <a asp-action="Edit" asp-route-id="@Model.PaymentId" class="btn btn-outline-primary">แก้ไขฉบับร่าง</a>
            <form asp-action="PostDraft" asp-route-id="@Model.PaymentId" method="post" class="d-inline confirm-popover-form">
                @Html.AntiForgeryToken()
                <div class="confirm-popover-shell">
                    <button type="button"
                            class="btn btn-primary js-confirm-popover-toggle"
                            data-confirm-target="postDraftPaymentDetailsConfirm_@Model.PaymentId"
                            aria-expanded="false">
                        บันทึกรับชำระ
                    </button>
                    <div class="confirm-popover" id="postDraftPaymentDetailsConfirm_@Model.PaymentId" hidden>
                        <div class="confirm-popover-title">บันทึกรับชำระจากฉบับร่างนี้หรือไม่?</div>
                        <div class="confirm-popover-text">เมื่อยืนยันแล้ว ระบบจะตัดชำระใบแจ้งหนี้และอัปเดตยอดคงเหลือของเอกสารต้นทางทันที</div>
                        <div class="confirm-popover-actions">
                            <button type="submit" class="btn btn-sm btn-outline-primary">ยืนยัน</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary js-confirm-popover-cancel">ยกเลิก</button>
                        </div>
                    </div>
                </div>
            </form>
        }
        @if (Model.ReceiptHeader is not null)
        {
            <a asp-controller="Receipts" asp-action="Details" asp-route-id="@Model.ReceiptHeader.ReceiptId" class="btn btn-primary">ดูใบเสร็จ</a>
        }
        @if (canGenerateReceipt)
        {
            <form asp-action="GenerateReceipt" asp-route-id="@Model.PaymentId" method="post" class="d-inline confirm-popover-form">
                @Html.AntiForgeryToken()
                <div class="confirm-popover-shell">
                    <button type="button"
                            class="btn btn-primary js-confirm-popover-toggle"
                            data-confirm-target="generateReceiptPaymentDetailsConfirm_@Model.PaymentId"
                            aria-expanded="false">
                        ออกใบเสร็จ
                    </button>
                    <div class="confirm-popover" id="generateReceiptPaymentDetailsConfirm_@Model.PaymentId" hidden>
                        <div class="confirm-popover-title">ออกใบเสร็จสำหรับรายการรับชำระนี้หรือไม่?</div>
                        <div class="confirm-popover-text">ระบบจะสร้างใบเสร็จ 1 ใบที่เชื่อมกับรายการรับชำระนี้</div>
                        <div class="confirm-popover-actions">
                            <button type="submit" class="btn btn-sm btn-outline-primary">ยืนยัน</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary js-confirm-popover-cancel">ยกเลิก</button>
                        </div>
                    </div>
                </div>
            </form>
        }
        else if (!isDraft)
        {
            <button type="button" class="btn btn-outline-secondary" disabled title="@generateReceiptBlockedReason">ออกใบเสร็จ</button>
        }
        @if (canCancel)
        {
            <form asp-action="Cancel" asp-route-id="@Model.PaymentId" method="post" class="d-inline confirm-popover-form">
                @Html.AntiForgeryToken()
                <div class="confirm-popover-shell">
                    <button type="button"
                            class="btn btn-outline-danger js-confirm-popover-toggle"
                            data-confirm-target="cancelPaymentDetailsConfirm_@Model.PaymentId"
                            aria-expanded="false">
                        ยกเลิกรายการรับชำระ
                    </button>
                    <div class="confirm-popover" id="cancelPaymentDetailsConfirm_@Model.PaymentId" hidden>
                        <div class="confirm-popover-title">ยกเลิกรายการรับชำระนี้หรือไม่?</div>
                        <div class="confirm-popover-text">ระบบจะยกเลิกรายการรับชำระ และย้อนการตัดชำระที่ผูกกับใบแจ้งหนี้ทั้งหมด</div>
                        <div class="mt-2">
                            <label for="cancelPaymentReason" class="form-label">เหตุผลการยกเลิก</label>
                            <textarea id="cancelPaymentReason" name="cancelReason" class="form-control" rows="3" placeholder="ระบุเหตุผลการยกเลิก" required></textarea>
                        </div>
                        <div class="confirm-popover-actions">
                            <button type="submit" class="btn btn-sm btn-outline-danger">ยืนยัน</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary js-confirm-popover-cancel">ยกเลิก</button>
                        </div>
                    </div>
                </div>
            </form>
        }
        else if (!isDraft)
        {
            <button type="button" class="btn btn-outline-secondary" disabled title="@cancelBlockedReason">ยกเลิกรายการรับชำระ</button>
        }
        <a asp-action="Index" class="btn btn-outline-secondary">กลับไปรายการรับชำระ</a>
    </div>
</div>

@if (isDraft || !canGenerateReceipt || !canCancel)
{
    <div class="workflow-info mb-3">
        @if (isDraft)
        {
            <div>ฉบับร่างจะยังไม่ตัดชำระใบแจ้งหนี้หรือใบวางบิลจนกว่าจะกดบันทึกรับชำระ</div>
        }
        @if (!canGenerateReceipt)
        {
            <div>@generateReceiptBlockedReason</div>
        }
        @if (!canCancel)
        {
            <div>@cancelBlockedReason</div>
        }
    </div>
}

<div class="card content-card">
    <div class="card-body">
        <div class="form-shell">
            <div class="form-section quotation-header-section">
                <div class="form-section-title">ข้อมูลหัวเอกสาร</div>
                <div class="row g-2 quotation-header-grid">
                    <div class="col-lg-3 col-md-6">
                        <div class="detail-label">เลขที่รับชำระ</div>
                        <div class="form-control readonly-detail">@Model.PaymentNo</div>
                    </div>
                    <div class="col-lg-3 col-md-6">
                        <div class="detail-label">วันที่รับชำระ</div>
                        <div class="form-control readonly-detail">@Model.PaymentDate.ToString("dd MMM yyyy")</div>
                    </div>
                    <div class="col-lg-3 col-md-6">
                        <div class="detail-label">เลขอ้างอิง</div>
                        <div class="form-control readonly-detail">@(string.IsNullOrWhiteSpace(Model.ReferenceNo) ? "-" : Model.ReferenceNo)</div>
                    </div>
                    <div class="col-lg-3 col-md-6">
                        <div class="detail-label">สถานะ</div>
                        <div class="form-control readonly-detail">@Model.Status</div>
                    </div>
                    <div class="col-12">
                        <div class="detail-label">หมายเหตุ</div>
                        <div class="form-control readonly-detail readonly-detail-multiline">@(string.IsNullOrWhiteSpace(Model.Remark) ? "-" : Model.Remark)</div>
                    </div>
                </div>
            </div>

            <div class="quotation-party-grid">
                <div class="quotation-party-column">
                    <div class="quotation-info-card">
                        <div class="quotation-info-card-title">ข้อมูลลูกค้า</div>
                        <div class="quotation-info-grid">
                            <div class="quotation-info-field">
                                <span class="quotation-info-label">รหัสลูกค้า</span>
                                <span class="quotation-info-value">@(string.IsNullOrWhiteSpace(Model.Customer?.CustomerCode) ? "-" : Model.Customer!.CustomerCode)</span>
                            </div>
                            <div class="quotation-info-field">
                                <span class="quotation-info-label">ชื่อลูกค้า</span>
                                <span class="quotation-info-value">@Model.Customer?.CustomerName</span>
                            </div>
                        </div>
                        <div class="quotation-info-grid">
                            <div class="quotation-info-field">
                                <span class="quotation-info-label">เลขประจำตัวผู้เสียภาษี</span>
                                <span class="quotation-info-value">@(string.IsNullOrWhiteSpace(Model.Customer?.TaxId) ? "-" : Model.Customer!.TaxId)</span>
                            </div>
                            <div class="quotation-info-field">
                                <span class="quotation-info-label">โทรศัพท์</span>
                                <span class="quotation-info-value">@(string.IsNullOrWhiteSpace(Model.Customer?.PhoneNumber) ? "-" : Model.Customer!.PhoneNumber)</span>
                            </div>
                        </div>
                        <div class="quotation-info-field">
                            <span class="quotation-info-label">ที่อยู่</span>
                            <span class="quotation-info-value">@(string.IsNullOrWhiteSpace(Model.Customer?.Address) ? "-" : Model.Customer!.Address)</span>
                        </div>
                    </div>
                </div>

                <div class="quotation-party-column">
                    <div class="quotation-info-card">
                        <div class="quotation-info-card-title">ข้อมูลการชำระเงิน</div>
                        <div class="quotation-info-grid">
                            <div class="quotation-info-field">
                                <span class="quotation-info-label">วิธีชำระเงิน</span>
                                <span class="quotation-info-value">@Model.PaymentMethod</span>
                            </div>
                            <div class="quotation-info-field">
                                <span class="quotation-info-label">ใบเสร็จ</span>
                                <span class="quotation-info-value">@(Model.ReceiptHeader?.ReceiptNo ?? "-")</span>
                            </div>
                        </div>
                        <div class="quotation-info-grid">
                            <div class="quotation-info-field">
                                <span class="quotation-info-label">บันทึกเมื่อ</span>
                                <span class="quotation-info-value">@(Model.PostedDate?.ToString("dd MMM yyyy HH:mm") ?? "-")</span>
                            </div>
                            <div class="quotation-info-field">
                                <span class="quotation-info-label">การจัดสรร</span>
                                <span class="quotation-info-value">@(hasAllocations ? $"{Model.PaymentAllocations.Count} ใบแจ้งหนี้" : "ยังไม่จัดสรรเข้ากับใบแจ้งหนี้")</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="form-section">
                <div class="table-card-header px-0 pt-0">
                    <div>
                        <h2 class="section-title">การจัดสรรให้ใบแจ้งหนี้</h2>
                        <p class="section-subtitle">ทุกการจัดสรรจะกระทบยอดชำระ ยอดคงเหลือ และสถานะของใบแจ้งหนี้ โดยสามารถบันทึกแบบยังไม่จัดสรรได้เช่นกัน</p>
                    </div>
                    <div class="table-meta">@Model.PaymentAllocations.Count รายการ</div>
                </div>
                @if (hasAllocations)
                {
                    <div class="table-responsive">
                        <table class="table entity-table align-middle">
                            <thead>
                                <tr>
                                    <th>เลขที่ใบแจ้งหนี้</th>
                                    <th>วันที่เอกสาร</th>
                                    <th>ยอดรวม</th>
                                    <th>สถานะหลังรับชำระ</th>
                                    <th class="text-end">ยอดที่ตัดชำระ</th>
                                </tr>
                            </thead>
                            <tbody>
                            @foreach (var allocation in Model.PaymentAllocations.OrderBy(x => x.InvoiceHeader!.InvoiceDate).ThenBy(x => x.InvoiceHeader!.InvoiceNo))
                            {
                                <tr>
                                    <td><span class="code-chip">@allocation.InvoiceHeader?.InvoiceNo</span></td>
                                    <td>@allocation.InvoiceHeader?.InvoiceDate.ToString("dd MMM yyyy")</td>
                                    <td>@allocation.InvoiceHeader?.TotalAmount.ToString("N2")</td>
                                    <td><span class="status-pill active">@allocation.InvoiceHeader?.Status</span></td>
                                    <td class="text-end">@allocation.AppliedAmount.ToString("N2")</td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="workflow-info">รายการรับชำระนี้ถูกบันทึกโดยยังไม่จัดสรรเข้ากับใบแจ้งหนี้ ยอดทั้งหมดจึงยังเป็นยอดคงเหลือที่ไม่ถูกตัดชำระ</div>
                }
            </div>

            <div class="quotation-summary-wrap">
                <div class="quotation-summary-stack">
                    <div class="quotation-summary-row total">
                        <span class="quotation-summary-name">จำนวนเงินรับชำระ</span>
                        <span class="quotation-summary-amount">@Model.Amount.ToString("N2")</span>
                    </div>
                    <div class="quotation-summary-row">
                        <span class="quotation-summary-name">ตัดชำระแล้ว</span>
                        <span class="quotation-summary-amount">@appliedAmount.ToString("N2")</span>
                    </div>
                    <div class="quotation-summary-row">
                        <span class="quotation-summary-name">ยังไม่ตัดชำระ</span>
                        <span class="quotation-summary-amount">@unappliedAmount.ToString("N2")</span>
                    </div>
                </div>
            </div>

            <div class="form-section document-history-section">
                <div class="form-section-title">ประวัติเอกสาร</div>
                <div class="document-history-list">
                    <div class="document-history-row">
                        <span class="document-history-label">สร้างโดย</span>
                        <span class="document-history-value">@(Model.CreatedByUser?.DisplayName ?? "-")</span>
                        <span class="document-history-meta">@Model.CreatedDate.ToString("dd MMM yyyy HH:mm")</span>
                    </div>
                    <div class="document-history-row">
                        <span class="document-history-label">แก้ไขล่าสุด</span>
                        <span class="document-history-value">@(Model.UpdatedByUser?.DisplayName ?? "-")</span>
                        <span class="document-history-meta">@(Model.UpdatedDate?.ToString("dd MMM yyyy HH:mm") ?? "-")</span>
                    </div>
                    <div class="document-history-row">
                        <span class="document-history-label">บันทึกโดย</span>
                        <span class="document-history-value">@(Model.PostedByUser?.DisplayName ?? "-")</span>
                        <span class="document-history-meta">@(Model.PostedDate?.ToString("dd MMM yyyy HH:mm") ?? "-")</span>
                    </div>
                    <div class="document-history-row">
                        <span class="document-history-label">ยกเลิกโดย</span>
                        <span class="document-history-value">@(Model.CancelledByUser?.DisplayName ?? "-")</span>
                        <span class="document-history-meta">@(Model.CancelledDate?.ToString("dd MMM yyyy HH:mm") ?? "-")</span>
                    </div>
                    @if (Model.Status == "Cancelled")
                    {
                        <div class="document-history-reason">
                            <span class="document-history-label">เหตุผลที่ยกเลิก</span>
                            <span class="document-history-value">@(string.IsNullOrWhiteSpace(Model.CancelReason) ? "-" : Model.CancelReason)</span>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
