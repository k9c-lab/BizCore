@model BizCore.Models.Entities.PaymentHeader

@{
    ViewData["Title"] = "Payment Details";
    var appliedAmount = Model.PaymentAllocations.Sum(x => x.AppliedAmount);
    var canGenerateReceipt = Model.Status == "Posted" && Model.ReceiptHeader is null;
    var generateReceiptBlockedReason = canGenerateReceipt
        ? string.Empty
        : Model.Status != "Posted"
            ? $"Generate Receipt is available only for Posted payments. Current status is {Model.Status}."
            : "Generate Receipt is blocked because this payment already has a receipt.";
    var canCancel = Model.Status == "Posted" && Model.ReceiptHeader?.Status != "Issued";
    var cancelBlockedReason = canCancel
        ? string.Empty
        : Model.Status != "Posted"
            ? $"Cancel Payment is available only for Posted payments. Current status is {Model.Status}."
            : "Cannot cancel payment because receipt already exists. Cancel receipt first.";
}

@if (TempData["PaymentNotice"] is string notice && !string.IsNullOrWhiteSpace(notice))
{
    <div class="workflow-info mb-3">@notice</div>
}

<div class="page-header">
    <div>
        <div class="page-eyebrow">AR Module</div>
        <h1 class="page-title">Payment Details</h1>
        <p class="page-subtitle">Review posted payment information, invoice allocations, and the issued receipt.</p>
    </div>
    <div class="page-actions">
        @if (Model.ReceiptHeader is not null)
        {
            <a asp-controller="Receipts" asp-action="Details" asp-route-id="@Model.ReceiptHeader.ReceiptId" class="btn btn-primary">View Receipt</a>
        }
        @if (canGenerateReceipt)
        {
            <form asp-action="GenerateReceipt" asp-route-id="@Model.PaymentId" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-primary">Generate Receipt</button>
            </form>
        }
        else
        {
            <button type="button" class="btn btn-outline-secondary" disabled title="@generateReceiptBlockedReason">Generate Receipt</button>
        }
        @if (canCancel)
        {
            <form asp-action="Cancel" asp-route-id="@Model.PaymentId" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-danger" onclick="return confirm('Cancel this payment and reverse invoice allocations?');">Cancel Payment</button>
            </form>
        }
        else
        {
            <button type="button" class="btn btn-outline-secondary" disabled title="@cancelBlockedReason">Cancel Payment</button>
        }
        <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
    </div>
</div>

@if (!canGenerateReceipt || !canCancel)
{
    <div class="workflow-info mb-3">
        @if (!canGenerateReceipt)
        {
            <div>@generateReceiptBlockedReason</div>
        }
        @if (!canCancel)
        {
            <div>@cancelBlockedReason</div>
        }
    </div>
}

<div class="card content-card">
    <div class="card-body">
        <div class="form-shell">
            <div class="form-section quotation-header-section">
                <div class="form-section-title">Payment Header</div>
                <div class="row g-2 quotation-header-grid">
                    <div class="col-lg-3 col-md-6">
                        <div class="detail-label">Payment No.</div>
                        <div class="form-control readonly-detail">@Model.PaymentNo</div>
                    </div>
                    <div class="col-lg-3 col-md-6">
                        <div class="detail-label">Payment Date</div>
                        <div class="form-control readonly-detail">@Model.PaymentDate.ToString("dd MMM yyyy")</div>
                    </div>
                    <div class="col-lg-3 col-md-6">
                        <div class="detail-label">Reference No.</div>
                        <div class="form-control readonly-detail">@(string.IsNullOrWhiteSpace(Model.ReferenceNo) ? "-" : Model.ReferenceNo)</div>
                    </div>
                    <div class="col-lg-3 col-md-6">
                        <div class="detail-label">Status</div>
                        <div class="form-control readonly-detail">@Model.Status</div>
                    </div>
                    <div class="col-12">
                        <div class="detail-label">Remark</div>
                        <div class="form-control readonly-detail readonly-detail-multiline">@(string.IsNullOrWhiteSpace(Model.Remark) ? "-" : Model.Remark)</div>
                    </div>
                </div>
            </div>

            <div class="quotation-party-grid">
                <div class="quotation-party-column">
                    <div class="quotation-info-card">
                        <div class="quotation-info-card-title">Customer Information</div>
                        <div class="quotation-info-grid">
                            <div class="quotation-info-field">
                                <span class="quotation-info-label">Customer Code</span>
                                <span class="quotation-info-value">@(string.IsNullOrWhiteSpace(Model.Customer?.CustomerCode) ? "-" : Model.Customer!.CustomerCode)</span>
                            </div>
                            <div class="quotation-info-field">
                                <span class="quotation-info-label">Customer Name</span>
                                <span class="quotation-info-value">@Model.Customer?.CustomerName</span>
                            </div>
                        </div>
                        <div class="quotation-info-grid">
                            <div class="quotation-info-field">
                                <span class="quotation-info-label">Tax ID</span>
                                <span class="quotation-info-value">@(string.IsNullOrWhiteSpace(Model.Customer?.TaxId) ? "-" : Model.Customer!.TaxId)</span>
                            </div>
                            <div class="quotation-info-field">
                                <span class="quotation-info-label">Phone</span>
                                <span class="quotation-info-value">@(string.IsNullOrWhiteSpace(Model.Customer?.PhoneNumber) ? "-" : Model.Customer!.PhoneNumber)</span>
                            </div>
                        </div>
                        <div class="quotation-info-field">
                            <span class="quotation-info-label">Address</span>
                            <span class="quotation-info-value">@(string.IsNullOrWhiteSpace(Model.Customer?.Address) ? "-" : Model.Customer!.Address)</span>
                        </div>
                    </div>
                </div>

                <div class="quotation-party-column">
                    <div class="quotation-info-card">
                        <div class="quotation-info-card-title">Payment Information</div>
                        <div class="quotation-info-grid">
                            <div class="quotation-info-field">
                                <span class="quotation-info-label">Payment Method</span>
                                <span class="quotation-info-value">@Model.PaymentMethod</span>
                            </div>
                            <div class="quotation-info-field">
                                <span class="quotation-info-label">Receipt</span>
                                <span class="quotation-info-value">@(Model.ReceiptHeader?.ReceiptNo ?? "-")</span>
                            </div>
                        </div>
                        <div class="quotation-info-grid">
                            <div class="quotation-info-field">
                                <span class="quotation-info-label">Posted</span>
                                <span class="quotation-info-value">@(Model.PostedDate?.ToString("dd MMM yyyy HH:mm") ?? "-")</span>
                            </div>
                            <div class="quotation-info-field">
                                <span class="quotation-info-label">Allocations</span>
                                <span class="quotation-info-value">@Model.PaymentAllocations.Count invoice(s)</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="form-section">
                <div class="table-card-header px-0 pt-0">
                    <div>
                        <h2 class="section-title">Invoice Allocation</h2>
                        <p class="section-subtitle">Each allocation updates invoice paid amount, balance amount, and status.</p>
                    </div>
                    <div class="table-meta">@Model.PaymentAllocations.Count allocation(s)</div>
                </div>
                <div class="table-responsive">
                    <table class="table entity-table align-middle">
                        <thead>
                            <tr>
                                <th>Invoice No.</th>
                                <th>Invoice Date</th>
                                <th>Total</th>
                                <th>Updated Status</th>
                                <th class="text-end">Applied Amount</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var allocation in Model.PaymentAllocations.OrderBy(x => x.InvoiceHeader!.InvoiceDate).ThenBy(x => x.InvoiceHeader!.InvoiceNo))
                        {
                            <tr>
                                <td><span class="code-chip">@allocation.InvoiceHeader?.InvoiceNo</span></td>
                                <td>@allocation.InvoiceHeader?.InvoiceDate.ToString("dd MMM yyyy")</td>
                                <td>@allocation.InvoiceHeader?.TotalAmount.ToString("N2")</td>
                                <td><span class="status-pill active">@allocation.InvoiceHeader?.Status</span></td>
                                <td class="text-end">@allocation.AppliedAmount.ToString("N2")</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="quotation-summary-wrap">
                <div class="quotation-summary-stack">
                    <div class="quotation-summary-row total">
                        <span class="quotation-summary-name">Payment Amount</span>
                        <span class="quotation-summary-amount">@Model.Amount.ToString("N2")</span>
                    </div>
                    <div class="quotation-summary-row">
                        <span class="quotation-summary-name">Applied</span>
                        <span class="quotation-summary-amount">@appliedAmount.ToString("N2")</span>
                    </div>
                    <div class="quotation-summary-row">
                        <span class="quotation-summary-name">Unapplied</span>
                        <span class="quotation-summary-amount">@Math.Max(Model.Amount - appliedAmount, 0m).ToString("N2")</span>
                    </div>
                </div>
            </div>

            <div class="form-section document-history-section">
                <div class="form-section-title">Document History</div>
                <div class="document-history-list">
                    <div class="document-history-row">
                        <span class="document-history-label">Created</span>
                        <span class="document-history-value">@(Model.CreatedByUser?.DisplayName ?? "-")</span>
                        <span class="document-history-meta">@Model.CreatedDate.ToString("dd MMM yyyy HH:mm")</span>
                    </div>
                    <div class="document-history-row">
                        <span class="document-history-label">Updated</span>
                        <span class="document-history-value">@(Model.UpdatedByUser?.DisplayName ?? "-")</span>
                        <span class="document-history-meta">@(Model.UpdatedDate?.ToString("dd MMM yyyy HH:mm") ?? "-")</span>
                    </div>
                    <div class="document-history-row">
                        <span class="document-history-label">Posted</span>
                        <span class="document-history-value">@(Model.PostedByUser?.DisplayName ?? "-")</span>
                        <span class="document-history-meta">@(Model.PostedDate?.ToString("dd MMM yyyy HH:mm") ?? "-")</span>
                    </div>
                    <div class="document-history-row">
                        <span class="document-history-label">Cancelled</span>
                        <span class="document-history-value">@(Model.CancelledByUser?.DisplayName ?? "-")</span>
                        <span class="document-history-meta">@(Model.CancelledDate?.ToString("dd MMM yyyy HH:mm") ?? "-")</span>
                    </div>
                    @if (Model.Status == "Cancelled")
                    {
                        <div class="document-history-reason">
                            <span class="document-history-label">Cancel Reason</span>
                            <span class="document-history-value">@(string.IsNullOrWhiteSpace(Model.CancelReason) ? "-" : Model.CancelReason)</span>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
