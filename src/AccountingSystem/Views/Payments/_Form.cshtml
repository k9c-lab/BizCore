@model BizCore.Models.ViewModels.PaymentFormViewModel

<div asp-validation-summary="All" class="form-alert"></div>
<input asp-for="BranchId" type="hidden" />

<div class="form-shell">
    <div class="form-section quotation-header-section">
        <div class="form-section-title">Payment Header</div>
        <div class="row g-2 quotation-header-grid">
            <div class="col-lg-3 col-md-6">
                <label asp-for="PaymentNo" class="form-label"></label>
                <input asp-for="PaymentNo" class="form-control" readonly />
                <div class="form-text">Auto-generated monthly payment number.</div>
                <span asp-validation-for="PaymentNo" class="text-danger"></span>
            </div>
            <div class="col-lg-3 col-md-6">
                <label asp-for="PaymentDate" class="form-label"></label>
                <input asp-for="PaymentDate" class="form-control" />
                <span asp-validation-for="PaymentDate" class="text-danger"></span>
            </div>
            <div class="col-lg-3 col-md-6">
                <label asp-for="ReferenceNo" class="form-label"></label>
                <input asp-for="ReferenceNo" class="form-control" />
                <span asp-validation-for="ReferenceNo" class="text-danger"></span>
            </div>
            <div class="col-lg-3 col-md-6">
                <label class="form-label">Status</label>
                <div class="form-control readonly-detail">Draft to Posted</div>
            </div>
            <div class="col-lg-3 col-md-6">
                <label asp-for="BranchId" class="form-label"></label>
                <div class="form-control readonly-detail">@Model.BranchName</div>
            </div>
            <div class="col-12">
                <label asp-for="Remark" class="form-label"></label>
                <textarea asp-for="Remark" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Remark" class="text-danger"></span>
            </div>
        </div>
    </div>

    <div class="quotation-party-grid">
        <div class="quotation-party-column">
            <div class="quotation-info-card">
                <div class="quotation-info-card-title">Customer Information</div>
                <div class="mb-2">
                    <label asp-for="CustomerId" class="form-label"></label>
                    <input asp-for="CustomerId" type="hidden" id="paymentCustomerId" />
                    <div class="search-dropdown">
                        <input type="text"
                               class="form-control"
                               id="paymentCustomerSearch"
                               placeholder="Search customer code, name, or tax ID"
                               autocomplete="off" />
                        <div id="paymentCustomerResults" class="search-dropdown-menu" style="display:none;"></div>
                    </div>
                    <span asp-validation-for="CustomerId" class="text-danger"></span>
                </div>
                <div class="quotation-info-grid">
                    <div class="quotation-info-field">
                        <span class="quotation-info-label">Customer Name</span>
                        <span class="quotation-info-value" id="paymentCustomerName">-</span>
                    </div>
                    <div class="quotation-info-field">
                        <span class="quotation-info-label">Tax ID</span>
                        <span class="quotation-info-value" id="paymentCustomerTaxId">-</span>
                    </div>
                </div>
                <div class="quotation-info-grid">
                    <div class="quotation-info-field">
                        <span class="quotation-info-label">Phone</span>
                        <span class="quotation-info-value" id="paymentCustomerPhone">-</span>
                    </div>
                    <div class="quotation-info-field">
                        <span class="quotation-info-label">Email</span>
                        <span class="quotation-info-value" id="paymentCustomerEmail">-</span>
                    </div>
                </div>
                <div class="quotation-info-field">
                    <span class="quotation-info-label">Billing Address</span>
                    <span class="quotation-info-value" id="paymentCustomerBillingAddress">-</span>
                </div>
                <div class="table-meta mt-2"><span id="visibleInvoiceCount">0</span> open invoice(s)</div>
            </div>
        </div>

        <div class="quotation-party-column">
            <div class="quotation-info-card">
                <div class="quotation-info-card-title">Payment Information</div>
                <div class="row g-2">
                    <div class="col-md-6">
                        <label asp-for="PaymentMethod" class="form-label"></label>
                        <select asp-for="PaymentMethod" asp-items="Model.PaymentMethodOptions" class="form-select"></select>
                        <span asp-validation-for="PaymentMethod" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Amount" class="form-label"></label>
                        <input asp-for="Amount" class="form-control" />
                        <span asp-validation-for="Amount" class="text-danger"></span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="form-section">
        <div class="table-card-header px-0 pt-0">
            <div>
                <h2 class="section-title">Invoice Allocation</h2>
                <p class="section-subtitle">Only open invoices of the selected customer can receive allocation.</p>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table entity-table align-middle">
                <thead>
                    <tr>
                        <th>Invoice No.</th>
                        <th>Invoice Date</th>
                        <th>Total</th>
                        <th>Paid</th>
                        <th>Balance</th>
                        <th>Status</th>
                        <th>Applied Amount</th>
                    </tr>
                </thead>
                <tbody id="paymentAllocationBody">
                @for (var i = 0; i < Model.Allocations.Count; i++)
                {
                    <tr class="payment-allocation-row" data-customer-id="@Model.Allocations[i].CustomerId" data-balance="@Model.Allocations[i].BalanceAmount.ToString("0.##")">
                        <td>
                            <input type="hidden" name="Allocations[@i].InvoiceId" value="@Model.Allocations[i].InvoiceId" />
                            <input type="hidden" name="Allocations[@i].CustomerId" value="@Model.Allocations[i].CustomerId" />
                            <input type="hidden" name="Allocations[@i].CustomerName" value="@Model.Allocations[i].CustomerName" />
                            <input type="hidden" name="Allocations[@i].InvoiceNo" value="@Model.Allocations[i].InvoiceNo" />
                            <input type="hidden" name="Allocations[@i].InvoiceDate" value="@Model.Allocations[i].InvoiceDate.ToString("yyyy-MM-dd")" />
                            <input type="hidden" name="Allocations[@i].TotalAmount" value="@Model.Allocations[i].TotalAmount.ToString("0.##")" />
                            <input type="hidden" name="Allocations[@i].PaidAmount" value="@Model.Allocations[i].PaidAmount.ToString("0.##")" />
                            <input type="hidden" name="Allocations[@i].BalanceAmount" value="@Model.Allocations[i].BalanceAmount.ToString("0.##")" />
                            <input type="hidden" name="Allocations[@i].Status" value="@Model.Allocations[i].Status" />
                            <span class="code-chip">@Model.Allocations[i].InvoiceNo</span>
                        </td>
                        <td>@Model.Allocations[i].InvoiceDate.ToString("dd MMM yyyy")</td>
                        <td>@Model.Allocations[i].TotalAmount.ToString("N2")</td>
                        <td>@Model.Allocations[i].PaidAmount.ToString("N2")</td>
                        <td class="js-balance">@Model.Allocations[i].BalanceAmount.ToString("N2")</td>
                        <td><span class="status-pill active">@Model.Allocations[i].Status</span></td>
                        <td>
                            <input type="number" step="0.01" min="0" max="@Model.Allocations[i].BalanceAmount.ToString("0.##")" name="Allocations[@i].AppliedAmount" value="@Model.Allocations[i].AppliedAmount.ToString("0.##")" class="form-control js-applied-amount" />
                            <span class="text-danger field-validation-valid" data-valmsg-for="Allocations[@i].AppliedAmount" data-valmsg-replace="true"></span>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
        <span asp-validation-for="Allocations" class="text-danger"></span>
    </div>

    <div class="quotation-summary-wrap">
        <div class="quotation-summary-stack">
            <div class="quotation-summary-row total">
                <span class="quotation-summary-name">Payment Amount</span>
                <span class="quotation-summary-amount" id="paymentAmountSummary">@Model.Amount.ToString("N2")</span>
            </div>
            <div class="quotation-summary-row">
                <span class="quotation-summary-name">Allocated Amount</span>
                <span class="quotation-summary-amount" id="paymentAppliedSummary">@Model.TotalAppliedAmount.ToString("N2")</span>
            </div>
            <div class="quotation-summary-row">
                <span class="quotation-summary-name">Remaining Amount</span>
                <span class="quotation-summary-amount" id="paymentUnappliedSummary">@Model.UnappliedAmount.ToString("N2")</span>
            </div>
        </div>
    </div>
</div>

<script type="application/json" id="paymentCustomerLookupData">@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.CustomerLookup))</script>
