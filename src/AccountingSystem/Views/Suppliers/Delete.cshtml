@model BizCore.Models.Entities.Supplier

@{
    ViewData["Title"] = "ลบผู้ขาย";
}

<div class="page-header">
    <div>
        <div class="page-eyebrow">ข้อมูลผู้ขาย</div>
        <h1 class="page-title">ลบผู้ขาย</h1>
        <p class="page-subtitle">โปรดยืนยันก่อนลบผู้ขายรายการนี้ออกจากข้อมูลหลัก</p>
    </div>
</div>

<div class="card content-card danger-card">
    <div class="card-body">
        <div class="danger-banner">
            การกระทำนี้จะลบ <strong>@Model.SupplierName</strong> ออกจากข้อมูลผู้ขาย ให้ดำเนินการต่อเมื่อมั่นใจว่าไม่ต้องใช้งานแล้วเท่านั้น
        </div>
        <div class="detail-grid">
            <div class="detail-item"><span class="detail-label">รหัส</span><p class="detail-value">@Model.SupplierCode</p></div>
            <div class="detail-item"><span class="detail-label">อีเมล</span><p class="detail-value">@(string.IsNullOrWhiteSpace(Model.Email) ? "-" : Model.Email)</p></div>
        </div>
        <form asp-action="Delete" method="post" class="form-actions mt-4">
            <input type="hidden" asp-for="SupplierId" />
            <a asp-action="Index" class="btn btn-outline-secondary">ยกเลิก</a>
            <button type="submit" class="btn btn-danger px-4">ลบผู้ขาย</button>
        </form>
    </div>
</div>
