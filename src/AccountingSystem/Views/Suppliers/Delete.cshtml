@model BizCore.Models.Entities.Supplier

@{
    ViewData["Title"] = "Delete Supplier";
}

<div class="page-header">
    <div>
        <div class="page-eyebrow">Supplier Record</div>
        <h1 class="page-title">Delete Supplier</h1>
        <p class="page-subtitle">Confirm deletion before removing this supplier from the master data list.</p>
    </div>
</div>

<div class="card content-card danger-card">
    <div class="card-body">
        <div class="danger-banner">
            This action removes <strong>@Model.SupplierName</strong> from supplier master data. Make sure the record is no longer needed.
        </div>
        <div class="detail-grid">
            <div class="detail-item"><span class="detail-label">Code</span><p class="detail-value">@Model.SupplierCode</p></div>
            <div class="detail-item"><span class="detail-label">Email</span><p class="detail-value">@(string.IsNullOrWhiteSpace(Model.Email) ? "-" : Model.Email)</p></div>
        </div>
        <form asp-action="Delete" method="post" class="form-actions mt-4">
            <input type="hidden" asp-for="SupplierId" />
            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            <button type="submit" class="btn btn-danger px-4">Delete Supplier</button>
        </form>
    </div>
</div>
