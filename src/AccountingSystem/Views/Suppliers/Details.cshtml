@model BizCore.Models.Entities.Supplier

@{
    ViewData["Title"] = "Supplier Details";
}

<div class="page-header">
    <div>
        <div class="page-eyebrow">Master Data</div>
        <h1 class="page-title">Supplier Details</h1>
        <p class="page-subtitle">Review supplier profile, purchasing setting, and contact information.</p>
    </div>
    <div class="page-actions">
        <a asp-action="Edit" asp-route-id="@Model.SupplierId" class="btn btn-primary">Edit Supplier</a>
        <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
    </div>
</div>

<div class="card content-card">
    <div class="card-body">
        <div class="form-shell">
            <div class="form-section quotation-header-section">
                <div class="form-section-title">Supplier Profile</div>
                <div class="row g-2 quotation-header-grid">
                    <div class="col-lg-3 col-md-6">
                        <div class="detail-label">Supplier Code</div>
                        <div class="form-control readonly-detail">@Model.SupplierCode</div>
                    </div>
                    <div class="col-lg-5 col-md-6">
                        <div class="detail-label">Supplier Name</div>
                        <div class="form-control readonly-detail">@Model.SupplierName</div>
                    </div>
                    <div class="col-lg-2 col-md-6">
                        <div class="detail-label">Status</div>
                        <div class="form-control readonly-detail">@(Model.IsActive ? "Active" : "Inactive")</div>
                    </div>
                    <div class="col-lg-2 col-md-6">
                        <div class="detail-label">Credit Limit</div>
                        <div class="form-control readonly-detail">@Model.CreditLimit.ToString("N2")</div>
                    </div>
                    <div class="col-lg-4 col-md-6">
                        <div class="detail-label">Tax ID</div>
                        <div class="form-control readonly-detail">@(string.IsNullOrWhiteSpace(Model.TaxId) ? "-" : Model.TaxId)</div>
                    </div>
                </div>
            </div>

            <div class="quotation-party-grid">
                <div class="quotation-party-column">
                    <div class="quotation-info-card">
                        <div class="quotation-info-card-title">Contact Information</div>
                        <div class="quotation-info-grid">
                            <div class="quotation-info-field">
                                <span class="quotation-info-label">Phone</span>
                                <span class="quotation-info-value">@(string.IsNullOrWhiteSpace(Model.PhoneNumber) ? "-" : Model.PhoneNumber)</span>
                            </div>
                            <div class="quotation-info-field">
                                <span class="quotation-info-label">Email</span>
                                <span class="quotation-info-value">@(string.IsNullOrWhiteSpace(Model.Email) ? "-" : Model.Email)</span>
                            </div>
                        </div>
                        <div class="quotation-info-field">
                            <span class="quotation-info-label">Address</span>
                            <span class="quotation-info-value">@(string.IsNullOrWhiteSpace(Model.Address) ? "-" : Model.Address)</span>
                        </div>
                    </div>
                </div>

                <div class="quotation-party-column">
                    <div class="quotation-info-card">
                        <div class="quotation-info-card-title">Purchasing Usage</div>
                        <div class="quotation-info-grid">
                            <div class="quotation-info-field">
                                <span class="quotation-info-label">Purchase Orders</span>
                                <span class="quotation-info-value">Uses supplier code, tax ID, and supplier address.</span>
                            </div>
                            <div class="quotation-info-field">
                                <span class="quotation-info-label">Availability</span>
                                <span class="quotation-info-value">@(Model.IsActive ? "Selectable in documents" : "Hidden from normal selection")</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

