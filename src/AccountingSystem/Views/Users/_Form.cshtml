@model BizCore.Models.ViewModels.UserFormViewModel

<div asp-validation-summary="All" class="form-alert"></div>

<div class="form-section quotation-header-section">
    <div class="form-section-title">Account Information</div>
    <div class="user-form-grid">
        <div class="user-form-field">
            <label asp-for="Username" class="form-label"></label>
            <input asp-for="Username" class="form-control" autocomplete="off" />
            <span asp-validation-for="Username" class="text-danger"></span>
        </div>
        <div class="user-form-field">
            <label asp-for="DisplayName" class="form-label"></label>
            <input asp-for="DisplayName" class="form-control" />
            <span asp-validation-for="DisplayName" class="text-danger"></span>
        </div>
        <div class="user-form-field">
            <label asp-for="Email" class="form-label"></label>
            <input asp-for="Email" class="form-control" />
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>
    </div>

    <div class="user-access-grid">
        <div class="user-form-field user-role-status-field">
            <label asp-for="Role" class="form-label"></label>
            <div class="quotation-expiry-group user-role-status-group">
                <select asp-for="Role" asp-items="Model.RoleOptions" class="form-select"></select>
                <label class="quotation-inline-check" asp-for="IsActive">
                    <input asp-for="IsActive" class="form-check-input" />
                    <span>Active</span>
                </label>
            </div>
            <span asp-validation-for="Role" class="text-danger"></span>
        </div>
        <div class="user-form-field">
            <label asp-for="BranchId" class="form-label"></label>
            <select asp-for="BranchId" asp-items="Model.BranchOptions" class="form-select"></select>
            <span asp-validation-for="BranchId" class="text-danger"></span>
        </div>
        <div class="user-form-field">
            <label class="form-label">Branch Access</label>
            <label class="quotation-inline-check d-flex align-items-center gap-2 mt-2" asp-for="CanAccessAllBranches">
                <input asp-for="CanAccessAllBranches" class="form-check-input" id="CanAccessAllBranches" />
                <span>Access all branches</span>
            </label>
            <div class="form-text">Use for admin or cross-branch supervisors.</div>
        </div>
    </div>
</div>

<script>
    (() => {
        const role = document.getElementById("Role");
        const allBranches = document.getElementById("CanAccessAllBranches");
        const syncBranchAdminAccess = () => {
            if (!role || !allBranches) return;
            if (role.value === "BranchAdmin") {
                allBranches.checked = false;
                allBranches.disabled = true;
            } else {
                allBranches.disabled = false;
            }
        };

        role?.addEventListener("change", syncBranchAdminAccess);
        syncBranchAdminAccess();
    })();
</script>

@if (!Model.IsEdit)
{
    <div class="form-section">
        <div class="form-section-title">Initial Password</div>
        <div class="row g-3">
            <div class="col-lg-4 col-md-6">
                <label asp-for="Password" class="form-label"></label>
                <input asp-for="Password" class="form-control" autocomplete="new-password" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>
            <div class="col-lg-4 col-md-6">
                <label asp-for="ConfirmPassword" class="form-label"></label>
                <input asp-for="ConfirmPassword" class="form-control" autocomplete="new-password" />
                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
            </div>
        </div>
    </div>
}
