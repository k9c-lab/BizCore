@model BizCore.Models.ViewModels.UserFormViewModel

@{
    ViewData["Title"] = "Edit User";
}

<div class="page-header">
    <div>
        <div class="page-eyebrow">Administration</div>
        <h1 class="page-title">Edit User</h1>
        <p class="page-subtitle">Update account details, role, and access status.</p>
    </div>
    <div class="page-actions">
        <a asp-action="Details" asp-route-id="@Model.UserId" class="btn btn-outline-secondary">Back</a>
    </div>
</div>

<div class="card content-card">
    <div class="card-body">
        <form asp-action="Edit" asp-route-id="@Model.UserId" method="post" class="form-shell">
            <input type="hidden" asp-for="UserId" />
            <partial name="_Form" model="Model" />
            <div class="workflow-info">
                Use Reset Password when the password needs to change.
            </div>
            <div class="form-actions">
                <button type="submit" class="btn btn-primary">Save User</button>
                <a asp-action="Details" asp-route-id="@Model.UserId" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

