@model BizCore.Models.ViewModels.UserFormViewModel

@{
    ViewData["Title"] = "Create User";
}

<div class="page-header">
    <div>
        <div class="page-eyebrow">Administration</div>
        <h1 class="page-title">Create User</h1>
        <p class="page-subtitle">Create a new login account and assign module access.</p>
    </div>
    <div class="page-actions">
        <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
    </div>
</div>

<div class="card content-card">
    <div class="card-body">
        <form asp-action="Create" method="post" class="form-shell">
            <partial name="_Form" model="Model" />
            <div class="form-actions">
                <button type="submit" class="btn btn-primary">Save User</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

