@model BizCore.Models.ViewModels.StockInquiryPageViewModel

@{
    ViewData["Title"] = "สอบถามสต็อก";
}

<div class="page-header">
    <div>
        <div class="page-eyebrow">สอบถามข้อมูลคลังสินค้า</div>
        <h1 class="page-title">สอบถามสต็อก</h1>
        </div>
</div>

<div class="card content-card table-card">
    <div class="table-card-header">
        <div>
            <h2 class="section-title">ยอดคงเหลือสต็อก</h2>
            </div>
        <div class="table-meta">@Model.Pagination.TotalCount รายการ</div>
    </div>
    <div class="card-body">
        <form method="get" class="list-filter-bar">
            <div class="list-filter-field grow">
                <label for="search" class="form-label">ค้นหา</label>
                <input id="search" name="search" value="@Model.Search" class="form-control" placeholder="รหัส, ชื่อ, Part Number, ประเภท หรือหน่วยนับ" />
            </div>
            <div class="list-filter-field">
                <label for="itemType" class="form-label">ประเภท</label>
                <select id="itemType" name="itemType" class="form-select">
                    <option value="">ทั้งหมด</option>
                    <option value="Product" selected="@(Model.ItemType == "Product")">สินค้า</option>
                    <option value="Service" selected="@(Model.ItemType == "Service")">บริการ</option>
                    <option value="Spare Part" selected="@(Model.ItemType == "Spare Part")">อะไหล่</option>
                </select>
            </div>
            <div class="list-filter-field">
                <label for="status" class="form-label">สถานะ</label>
                <select id="status" name="status" class="form-select">
                    <option value="">ทั้งหมด</option>
                    <option value="Active" selected="@(Model.Status == "Active")">ใช้งาน</option>
                    <option value="Inactive" selected="@(Model.Status == "Inactive")">ไม่ใช้งาน</option>
                </select>
            </div>
            @if (Model.CanAccessAllBranches)
            {
                <div class="list-filter-field">
                    <label for="branchId" class="form-label">สาขา</label>
                    <select id="branchId" name="branchId" asp-items="Model.BranchOptions" class="form-select"></select>
                </div>
            }
            <div class="list-filter-actions">
                <a asp-action="Index" class="btn btn-outline-secondary">ล้างค่า</a>
                <button type="submit" class="btn btn-primary">ค้นหา</button>
            </div>
        </form>
        <div class="table-responsive">
            <table class="table entity-table align-middle">
                <thead>
                    <tr>
                        <th>รหัสสินค้า</th>
                        <th>ชื่อสินค้า</th>
                        <th>Part Number</th>
                        <th>ประเภท</th>
                        <th>หน่วยนับ</th>
                        <th>สาขา</th>
                        <th>สต็อกคงเหลือ</th>
                        <th>ติดตามสต็อก</th>
                        <th>ควบคุม Serial</th>
                        <th>สถานะ</th>
                        <th class="text-end">การทำงาน</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.Results.Any())
                {
                    @foreach (var item in Model.Results)
                    {
                        <tr>
                            <td><span class="code-chip">@item.ItemCode</span></td>
                            <td class="fw-semibold">@item.ItemName</td>
                            <td>@item.PartNumber</td>
                            <td>@item.ItemType</td>
                            <td>@item.Unit</td>
                            <td>@item.BranchName</td>
                            <td>@item.CurrentStock.ToString("N2")</td>
                            <td>@(item.TrackStock ? "ใช่" : "ไม่ใช่")</td>
                            <td>@(item.IsSerialControlled ? "ใช่" : "ไม่ใช่")</td>
                            <td><span class="status-pill @(item.IsActive ? "active" : "inactive")">@(item.IsActive ? "ใช้งาน" : "ไม่ใช้งาน")</span></td>
                            <td class="text-end">
                                <div class="table-actions">
                                    <a asp-controller="StockLedger" asp-action="Index" asp-route-itemId="@item.ItemId" asp-route-branchId="@Model.BranchId" class="btn btn-sm btn-outline-primary">สมุดสต็อก</a>
                                    @if (item.IsSerialControlled)
                                    {
                                        <a asp-action="Serials" asp-route-itemId="@item.ItemId" asp-route-branchId="@Model.BranchId" class="btn btn-sm btn-outline-secondary">Serial</a>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="11" class="table-empty">ไม่พบข้อมูลสต็อกตามเงื่อนไขที่ค้นหา</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
        <partial name="_Pager" model="Model.Pagination" />
    </div>
</div>

