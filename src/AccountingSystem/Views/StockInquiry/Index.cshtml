@model BizCore.Models.ViewModels.StockInquiryPageViewModel

@{
    ViewData["Title"] = "Stock Inquiry";
}

<div class="page-header">
    <div>
        <div class="page-eyebrow">Inventory Inquiry</div>
        <h1 class="page-title">Stock Inquiry</h1>
        <p class="page-subtitle">Read-only stock visibility from the current item master and stock balance data.</p>
    </div>
</div>

<div class="card content-card mb-3">
    <div class="card-body">
        <form method="get" class="form-shell">
            <div class="form-section">
                <div class="form-section-title">Search Filters</div>
                <div class="row g-3">
                    <div class="col-md-4">
                        <label for="itemCode" class="form-label">Item Code</label>
                        <input id="itemCode" name="itemCode" value="@Model.ItemCode" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label for="itemName" class="form-label">Item Name</label>
                        <input id="itemName" name="itemName" value="@Model.ItemName" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label for="partNumber" class="form-label">Part Number</label>
                        <input id="partNumber" name="partNumber" value="@Model.PartNumber" class="form-control" />
                    </div>
                </div>
                <div class="form-actions mt-3">
                    <span class="table-meta">Inquiry only. Editing remains in the item master screen.</span>
                    <div class="page-actions">
                        <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
                        <button type="submit" class="btn btn-primary">Search</button>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="card content-card table-card">
    <div class="table-card-header">
        <div>
            <h2 class="section-title">Stock Balances</h2>
            <p class="section-subtitle">Current item-level stock and control flags.</p>
        </div>
        <div class="table-meta">@Model.Results.Count record(s)</div>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table entity-table align-middle">
                <thead>
                    <tr>
                        <th>Item Code</th>
                        <th>Item Name</th>
                        <th>Part Number</th>
                        <th>Current Stock</th>
                        <th>Track Stock</th>
                        <th>Is Serial Controlled</th>
                        <th class="text-end">Action</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.Results.Any())
                {
                    @foreach (var item in Model.Results)
                    {
                        <tr>
                            <td><span class="code-chip">@item.ItemCode</span></td>
                            <td class="fw-semibold">@item.ItemName</td>
                            <td>@item.PartNumber</td>
                            <td>@item.CurrentStock.ToString("N2")</td>
                            <td>@(item.TrackStock ? "Yes" : "No")</td>
                            <td>@(item.IsSerialControlled ? "Yes" : "No")</td>
                            <td class="text-end">
                                @if (item.IsSerialControlled)
                                {
                                    <a asp-action="Serials" asp-route-itemId="@item.ItemId" class="btn btn-sm btn-outline-primary">View Serials</a>
                                }
                                else
                                {
                                    <span class="table-meta">-</span>
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="table-empty">No stock records matched the current search.</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
