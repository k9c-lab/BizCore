@model BizCore.Models.ViewModels.StockInquiryPageViewModel

@{
    ViewData["Title"] = "Stock Inquiry";
}

<div class="page-header">
    <div>
        <div class="page-eyebrow">Inventory Inquiry</div>
        <h1 class="page-title">Stock Inquiry</h1>
        <p class="page-subtitle">Read-only stock visibility for @Model.BranchName.</p>
    </div>
</div>

<div class="card content-card table-card">
    <div class="table-card-header">
        <div>
            <h2 class="section-title">Stock Balances</h2>
            <p class="section-subtitle">Current item-level stock and control flags.</p>
        </div>
        <div class="table-meta">@Model.Pagination.TotalCount record(s)</div>
    </div>
    <div class="card-body">
        <form method="get" class="list-filter-bar">
            <div class="list-filter-field grow">
                <label for="search" class="form-label">Search</label>
                <input id="search" name="search" value="@Model.Search" class="form-control" placeholder="Code, name, part number, type, or unit" />
            </div>
            <div class="list-filter-field">
                <label for="itemType" class="form-label">Type</label>
                <select id="itemType" name="itemType" class="form-select">
                    <option value="">All</option>
                    <option value="Product" selected="@(Model.ItemType == "Product")">Product</option>
                    <option value="Service" selected="@(Model.ItemType == "Service")">Service</option>
                    <option value="Spare Part" selected="@(Model.ItemType == "Spare Part")">Spare Part</option>
                </select>
            </div>
            <div class="list-filter-field">
                <label for="status" class="form-label">Status</label>
                <select id="status" name="status" class="form-select">
                    <option value="">All</option>
                    <option value="Active" selected="@(Model.Status == "Active")">Active</option>
                    <option value="Inactive" selected="@(Model.Status == "Inactive")">Inactive</option>
                </select>
            </div>
            @if (Model.CanAccessAllBranches)
            {
                <div class="list-filter-field">
                    <label for="branchId" class="form-label">Branch</label>
                    <select id="branchId" name="branchId" asp-items="Model.BranchOptions" class="form-select"></select>
                </div>
            }
            <div class="list-filter-actions">
                <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
                <button type="submit" class="btn btn-primary">Search</button>
            </div>
        </form>
        <div class="table-responsive">
            <table class="table entity-table align-middle">
                <thead>
                    <tr>
                        <th>Item Code</th>
                        <th>Item Name</th>
                        <th>Part Number</th>
                        <th>Type</th>
                        <th>Unit</th>
                        <th>Branch</th>
                        <th>Current Stock</th>
                        <th>Track Stock</th>
                        <th>Is Serial Controlled</th>
                        <th>Status</th>
                        <th class="text-end">Action</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.Results.Any())
                {
                    @foreach (var item in Model.Results)
                    {
                        <tr>
                            <td><span class="code-chip">@item.ItemCode</span></td>
                            <td class="fw-semibold">@item.ItemName</td>
                            <td>@item.PartNumber</td>
                            <td>@item.ItemType</td>
                            <td>@item.Unit</td>
                            <td>@item.BranchName</td>
                            <td>@item.CurrentStock.ToString("N2")</td>
                            <td>@(item.TrackStock ? "Yes" : "No")</td>
                            <td>@(item.IsSerialControlled ? "Yes" : "No")</td>
                            <td><span class="status-pill @(item.IsActive ? "active" : "inactive")">@(item.IsActive ? "Active" : "Inactive")</span></td>
                            <td class="text-end">
                                <div class="table-actions">
                                    <a asp-controller="StockLedger" asp-action="Index" asp-route-itemId="@item.ItemId" asp-route-branchId="@Model.BranchId" class="btn btn-sm btn-outline-primary">Ledger</a>
                                    @if (item.IsSerialControlled)
                                    {
                                        <a asp-action="Serials" asp-route-itemId="@item.ItemId" asp-route-branchId="@Model.BranchId" class="btn btn-sm btn-outline-secondary">Serials</a>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="11" class="table-empty">No stock records matched the current search.</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
        <partial name="_Pager" model="Model.Pagination" />
    </div>
</div>
