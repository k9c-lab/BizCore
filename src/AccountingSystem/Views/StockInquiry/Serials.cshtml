@model BizCore.Models.ViewModels.StockInquirySerialsPageViewModel

@{
    ViewData["Title"] = "Item Serials";
}

<div class="page-header">
    <div>
        <div class="page-eyebrow">Inventory Inquiry</div>
        <h1 class="page-title">Item Serials</h1>
        <p class="page-subtitle">Read-only serial listing for the selected serial-controlled item.</p>
    </div>
    <div class="page-actions">
        <a asp-action="Index" class="btn btn-outline-secondary">Back to Stock Inquiry</a>
    </div>
</div>

<div class="card content-card mb-3">
    <div class="card-body">
        <div class="detail-grid">
            <div class="detail-item"><span class="detail-label">Item Code</span><p class="detail-value">@Model.ItemCode</p></div>
            <div class="detail-item"><span class="detail-label">Item Name</span><p class="detail-value">@Model.ItemName</p></div>
            <div class="detail-item"><span class="detail-label">Part Number</span><p class="detail-value">@Model.PartNumber</p></div>
            <div class="detail-item"><span class="detail-label">Current Stock</span><p class="detail-value">@Model.CurrentStock.ToString("N2")</p></div>
        </div>
    </div>
</div>

<div class="card content-card table-card">
    <div class="table-card-header">
        <div>
            <h2 class="section-title">Serial List</h2>
            <p class="section-subtitle">Serial records for the selected item.</p>
        </div>
        <div class="table-meta">@Model.Pagination.TotalCount record(s)</div>
    </div>
    <div class="card-body">
        <form method="get" asp-action="Serials" asp-route-itemId="@Model.ItemId" class="list-filter-bar">
            <div class="list-filter-field grow">
                <label for="search" class="form-label">Search</label>
                <input id="search" name="search" value="@Model.Search" class="form-control" placeholder="Serial, status, supplier, customer, or invoice" />
            </div>
            <div class="list-filter-field">
                <label for="status" class="form-label">Status</label>
                <select id="status" name="status" class="form-select">
                    <option value="">All</option>
                    <option value="InStock" selected="@(Model.Status == "InStock")">In Stock</option>
                    <option value="Sold" selected="@(Model.Status == "Sold")">Sold</option>
                    <option value="ClaimedToSupplier" selected="@(Model.Status == "ClaimedToSupplier")">Claimed To Supplier</option>
                    <option value="Available" selected="@(Model.Status == "Available")">Available</option>
                </select>
            </div>
            <div class="list-filter-actions">
                <a asp-action="Serials" asp-route-itemId="@Model.ItemId" class="btn btn-outline-secondary">Clear</a>
                <button type="submit" class="btn btn-primary">Search</button>
            </div>
        </form>
        @if (Model.Results.Any())
        {
            <div class="inquiry-card-list">
                @foreach (var serial in Model.Results)
                {
                    var isWarrantyExpired = !serial.SupplierWarrantyEndDate.HasValue || serial.SupplierWarrantyEndDate.Value.Date < DateTime.Today;
                    <article class="inquiry-card inquiry-card-compact">
                        <div class="inquiry-card-top">
                            <div class="inquiry-card-title-group">
                                <span class="code-chip">@serial.SerialNo</span>
                                <div>
                                    <h3 class="inquiry-card-title">@Model.ItemName</h3>
                                    <p class="inquiry-card-subtitle">@Model.ItemCode | @Model.PartNumber</p>
                                </div>
                            </div>
                            <div class="page-actions">
                                <span class="status-pill active">@serial.Status</span>
                                @if (isWarrantyExpired)
                                {
                                    <span class="status-pill inactive">Warranty Expired</span>
                                    <button type="button" class="btn btn-sm btn-outline-secondary" disabled>Claim</button>
                                }
                                else
                                {
                                    <a asp-controller="SupplierClaims" asp-action="Create" asp-route-serialId="@serial.SerialId" class="btn btn-sm btn-outline-primary">Claim</a>
                                }
                            </div>
                        </div>

                        <div class="inquiry-card-grid">
                            <div class="inquiry-card-field">
                                <span class="inquiry-card-label">Supplier</span>
                                <span class="inquiry-card-value">@serial.SupplierName</span>
                            </div>
                            <div class="inquiry-card-field">
                                <span class="inquiry-card-label">Customer</span>
                                <span class="inquiry-card-value">@serial.CurrentCustomerName</span>
                            </div>
                            <div class="inquiry-card-field">
                                <span class="inquiry-card-label">Supplier Warranty</span>
                                <span class="inquiry-card-value">@(serial.SupplierWarrantyStartDate?.ToString("dd MMM yyyy") ?? "-") to @(serial.SupplierWarrantyEndDate?.ToString("dd MMM yyyy") ?? "-")</span>
                            </div>
                            <div class="inquiry-card-field">
                                <span class="inquiry-card-label">Invoice Code</span>
                                <span class="inquiry-card-value">@serial.InvoiceCode</span>
                            </div>
                            <div class="inquiry-card-field">
                                <span class="inquiry-card-label">Customer Warranty</span>
                                <span class="inquiry-card-value">@(serial.CustomerWarrantyStartDate?.ToString("dd MMM yyyy") ?? "-") to @(serial.CustomerWarrantyEndDate?.ToString("dd MMM yyyy") ?? "-")</span>
                            </div>
                        </div>
                    </article>
                }
            </div>
        }
        else
        {
            <div class="table-empty">No serial records matched the current search for this item.</div>
        }
        <partial name="_Pager" model="Model.Pagination" />
    </div>
</div>
