@model BizCore.Models.Entities.Salesperson

@{
    ViewData["Title"] = "Delete Salesperson";
}

<div class="page-header">
    <div>
        <div class="page-eyebrow">Sales Team</div>
        <h1 class="page-title">Delete Salesperson</h1>
        <p class="page-subtitle">Confirm deletion before removing this salesperson from the team master list.</p>
    </div>
</div>

<div class="card content-card danger-card">
    <div class="card-body">
        <div class="danger-banner">
            This action removes <strong>@Model.SalespersonName</strong> from the sales team master data.
        </div>
        <div class="detail-grid">
            <div class="detail-item"><span class="detail-label">Code</span><p class="detail-value">@Model.SalespersonCode</p></div>
            <div class="detail-item"><span class="detail-label">Email</span><p class="detail-value">@(string.IsNullOrWhiteSpace(Model.Email) ? "-" : Model.Email)</p></div>
        </div>
        <form asp-action="Delete" method="post" class="form-actions mt-4">
            <input type="hidden" asp-for="SalespersonId" />
            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            <button type="submit" class="btn btn-danger px-4">Delete Salesperson</button>
        </form>
    </div>
</div>
