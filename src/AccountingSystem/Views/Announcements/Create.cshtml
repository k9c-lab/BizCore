@model BizCore.Models.Entities.Announcement

@{
    ViewData["Title"] = "Create Announcement";
}

<div class="page-header">
    <div>
        <div class="page-eyebrow">Overview Module</div>
        <h1 class="page-title">Create Announcement</h1>
        <p class="page-subtitle">Write a notice for the welcome page and control when it should be visible.</p>
    </div>
    <div class="page-actions">
        <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
    </div>
</div>

<div class="card content-card">
    <div class="card-body">
        <form asp-action="Create" method="post" class="form-shell">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="All" class="form-alert"></div>
            @await Html.PartialAsync("_Form", Model)
            <div class="form-actions">
                <button type="submit" class="btn btn-primary">Save Announcement</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
