@inject IUserPermissionService PermissionService
@model BizCore.Models.Entities.PurchaseRequestHeader

@{
    ViewData["Title"] = "รายละเอียดใบขอซื้อ";
    var linkedPOs = Model.PurchaseOrderHeaders
        .Concat(Model.PurchaseRequestDetails
            .SelectMany(x => x.PurchaseOrderAllocationSources)
            .Select(x => x.PurchaseOrderAllocation?.PurchaseOrderDetail?.PurchaseOrderHeader)
            .Where(x => x is not null)!)
        .GroupBy(x => x!.PurchaseOrderId)
        .Select(x => x.First()!)
        .OrderByDescending(x => x.PurchaseOrderId)
        .ToList();
    var hasPO = linkedPOs.Any();
    var linkedPO = linkedPOs.FirstOrDefault();
    var canViewPOCreate = PermissionService.HasPermission(User, "PO.Create");
    var canEditPermission = PermissionService.HasPermission(User, "PR.Edit");
    var canSubmitPermission = PermissionService.HasPermission(User, "PR.Submit");
    var canApprovePermission = PermissionService.HasPermission(User, "PR.Approve");
    var canRejectPermission = PermissionService.HasPermission(User, "PR.Reject");
    var canCancelPermission = PermissionService.HasPermission(User, "PR.Cancel");
    var canEdit = canEditPermission && (Model.Status is "Draft" or "Rejected");
    var editBlockedReason = canEdit
        ? string.Empty
        : !canEditPermission
            ? "คุณไม่มีสิทธิ์แก้ไขใบขอซื้อ"
            : $"แก้ไขได้เฉพาะใบขอซื้อสถานะ Draft หรือ Rejected เท่านั้น สถานะปัจจุบันคือ {Model.Status}";
    var canSubmit = canSubmitPermission && (Model.Status is "Draft" or "Rejected") && Model.PurchaseRequestDetails.Any();
    var submitBlockedReason = canSubmit
        ? string.Empty
        : !canSubmitPermission
            ? "คุณไม่มีสิทธิ์ส่งอนุมัติใบขอซื้อ"
            : Model.Status is not ("Draft" or "Rejected")
                ? $"ส่งอนุมัติได้เฉพาะใบขอซื้อสถานะ Draft หรือ Rejected เท่านั้น สถานะปัจจุบันคือ {Model.Status}"
                : "ยังส่งอนุมัติไม่ได้ เพราะยังไม่มีรายการสินค้า";
    var canApprove = canApprovePermission && Model.Status == "Submitted";
    var approveBlockedReason = canApprove
        ? string.Empty
        : !canApprovePermission
            ? "คุณไม่มีสิทธิ์อนุมัติใบขอซื้อ"
            : Model.Status != "Submitted"
                ? $"อนุมัติได้เฉพาะใบขอซื้อสถานะ Submitted เท่านั้น สถานะปัจจุบันคือ {Model.Status}"
                : "ยังอนุมัติไม่ได้";
    var canReject = canRejectPermission && Model.Status == "Submitted";
    var rejectBlockedReason = canReject
        ? string.Empty
        : !canRejectPermission
            ? "คุณไม่มีสิทธิ์ตีกลับใบขอซื้อ"
            : Model.Status != "Submitted"
                ? $"ตีกลับได้เฉพาะใบขอซื้อสถานะ Submitted เท่านั้น สถานะปัจจุบันคือ {Model.Status}"
                : "ยังตีกลับไม่ได้";
    var canCreatePO = canViewPOCreate && Model.Status == "Approved" && !hasPO;
    var createPOBlockedReason = canCreatePO
        ? string.Empty
        : hasPO
            ? "สร้างใบสั่งซื้อไม่ได้ เพราะใบขอซื้อนี้ถูกนำไปสร้างใบสั่งซื้อแล้ว"
            : Model.Status != "Approved"
                ? "จะสร้างใบสั่งซื้อได้หลังจากใบขอซื้อได้รับการอนุมัติแล้ว"
                : "คุณไม่มีสิทธิ์สร้างใบสั่งซื้อจากใบขอซื้อนี้";
    var canCancel = canCancelPermission && (Model.Status == "Draft" || Model.Status == "Submitted" || Model.Status == "Approved" || Model.Status == "Rejected") && !hasPO;
    var cancelBlockedReason = canCancel
        ? string.Empty
        : !canCancelPermission
            ? "คุณไม่มีสิทธิ์ยกเลิกใบขอซื้อ"
            : hasPO
                ? "ยังยกเลิกไม่ได้ เพราะมีการสร้างใบสั่งซื้อจากใบขอซื้อนี้แล้ว"
                : Model.Status == "Cancelled"
                    ? "ใบขอซื้อที่ยกเลิกแล้วไม่สามารถแก้ไขต่อได้"
                    : $"ยกเลิกได้เฉพาะใบขอซื้อสถานะ Draft, Submitted, Approved หรือ Rejected เท่านั้น สถานะปัจจุบันคือ {Model.Status}";
}

@if (TempData["PurchaseRequestNotice"] is string notice && !string.IsNullOrWhiteSpace(notice))
{
    @await Html.PartialAsync("_Notice", notice)
}

<div class="page-header">
    <div>
        <div class="page-eyebrow">งานจัดซื้อ</div>
        <h1 class="page-title">รายละเอียดใบขอซื้อ</h1>
        <p class="page-subtitle">ใช้หน้านี้เป็นจุดหลักสำหรับตรวจสอบ ส่งอนุมัติ อนุมัติ ตีกลับ สร้างใบสั่งซื้อ และยกเลิกเอกสาร</p>
    </div>
    <div class="page-actions justify-content-end">
        @if (canEdit)
        {
            <a asp-action="Edit" asp-route-id="@Model.PurchaseRequestId" class="btn btn-outline-primary">แก้ไขฉบับร่าง</a>
        }
        else
        {
            <button type="button" class="btn btn-outline-secondary" disabled title="@editBlockedReason">แก้ไขฉบับร่าง</button>
        }
        @if (canSubmit)
        {
            <form asp-action="Submit" asp-route-id="@Model.PurchaseRequestId" method="post" class="d-inline confirm-popover-form">
                @Html.AntiForgeryToken()
                <div class="confirm-popover-shell">
                    <button type="button" class="btn btn-primary js-confirm-popover-toggle" data-confirm-target="submitPrDetailsConfirm_@Model.PurchaseRequestId" aria-expanded="false">ส่งอนุมัติ</button>
                    <div class="confirm-popover" id="submitPrDetailsConfirm_@Model.PurchaseRequestId" hidden>
                        <div class="confirm-popover-title">ส่งใบขอซื้อนี้เข้าอนุมัติใช่หรือไม่?</div>
                        <div class="confirm-popover-text">เมื่อยืนยันแล้ว เอกสารจะเข้าสู่กระบวนการอนุมัติ และจะไม่ควรแก้ไขต่อจนกว่าจะถูกตีกลับ</div>
                        <div class="confirm-popover-actions">
                            <button type="submit" class="btn btn-sm btn-outline-primary">ยืนยัน</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary js-confirm-popover-cancel">ยกเลิก</button>
                        </div>
                    </div>
                </div>
            </form>
        }
        else
        {
            <button type="button" class="btn btn-outline-secondary" disabled title="@submitBlockedReason">ส่งอนุมัติ</button>
        }
        @if (canApprove)
        {
            <form asp-action="Approve" asp-route-id="@Model.PurchaseRequestId" method="post" class="d-inline confirm-popover-form">
                @Html.AntiForgeryToken()
                <div class="confirm-popover-shell">
                    <button type="button" class="btn btn-primary js-confirm-popover-toggle" data-confirm-target="approvePrDetailsConfirm_@Model.PurchaseRequestId" aria-expanded="false">อนุมัติ</button>
                    <div class="confirm-popover" id="approvePrDetailsConfirm_@Model.PurchaseRequestId" hidden>
                        <div class="confirm-popover-title">อนุมัติใบขอซื้อนี้ใช่หรือไม่?</div>
                        <div class="confirm-popover-text">เมื่ออนุมัติแล้ว จะสามารถนำใบขอซื้อนี้ไปสร้างใบสั่งซื้อได้</div>
                        <div class="confirm-popover-actions">
                            <button type="submit" class="btn btn-sm btn-outline-primary">ยืนยัน</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary js-confirm-popover-cancel">ยกเลิก</button>
                        </div>
                    </div>
                </div>
            </form>
        }
        else
        {
            <button type="button" class="btn btn-outline-secondary" disabled title="@approveBlockedReason">อนุมัติ</button>
        }
        @if (canReject)
        {
            <form asp-action="Reject" asp-route-id="@Model.PurchaseRequestId" method="post" class="d-inline confirm-popover-form">
                @Html.AntiForgeryToken()
                <div class="confirm-popover-shell">
                    <button type="button" class="btn btn-outline-danger js-confirm-popover-toggle" data-confirm-target="rejectPrDetailsConfirm_@Model.PurchaseRequestId" aria-expanded="false">ตีกลับ</button>
                    <div class="confirm-popover" id="rejectPrDetailsConfirm_@Model.PurchaseRequestId" hidden>
                        <div class="confirm-popover-title">ตีกลับใบขอซื้อนี้ใช่หรือไม่?</div>
                        <div class="confirm-popover-text">กรุณาระบุเหตุผล เพื่อให้ผู้ขอซื้อกลับไปแก้ไขได้ถูกต้อง</div>
                        <div class="confirm-popover-field">
                            <label class="confirm-popover-label" for="rejectPrDetailsReason_@Model.PurchaseRequestId">เหตุผลที่ตีกลับ</label>
                            <textarea id="rejectPrDetailsReason_@Model.PurchaseRequestId" name="rejectReason" class="form-control" rows="3" placeholder="ระบุเหตุผลที่ตีกลับ" required></textarea>
                        </div>
                        <div class="confirm-popover-actions">
                            <button type="submit" class="btn btn-sm btn-outline-danger">ยืนยัน</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary js-confirm-popover-cancel">ยกเลิก</button>
                        </div>
                    </div>
                </div>
            </form>
        }
        else
        {
            <button type="button" class="btn btn-outline-secondary" disabled title="@rejectBlockedReason">ตีกลับ</button>
        }
        @if (canCreatePO)
        {
            <a asp-controller="PurchaseOrders" asp-action="Create" asp-route-purchaseRequestId="@Model.PurchaseRequestId" class="btn btn-success">สร้างใบสั่งซื้อ</a>
        }
        else if (linkedPO is not null)
        {
            <a asp-controller="PurchaseOrders" asp-action="Details" asp-route-id="@linkedPO.PurchaseOrderId" class="btn btn-outline-success">ดูใบสั่งซื้อ</a>
        }
        else
        {
            <button type="button" class="btn btn-outline-secondary" disabled title="@createPOBlockedReason">สร้างใบสั่งซื้อ</button>
        }
        <a asp-action="Print" asp-route-id="@Model.PurchaseRequestId" class="btn btn-outline-secondary" target="_blank">พิมพ์</a>
        @if (canCancel)
        {
            <form asp-action="Cancel" asp-route-id="@Model.PurchaseRequestId" method="post" class="d-inline confirm-popover-form">
                @Html.AntiForgeryToken()
                <div class="confirm-popover-shell">
                    <button type="button" class="btn btn-outline-danger js-confirm-popover-toggle" data-confirm-target="cancelPrDetailsConfirm_@Model.PurchaseRequestId" aria-expanded="false">ยกเลิกใบขอซื้อ</button>
                    <div class="confirm-popover" id="cancelPrDetailsConfirm_@Model.PurchaseRequestId" hidden>
                        <div class="confirm-popover-title">ยกเลิกใบขอซื้อนี้ใช่หรือไม่?</div>
                        <div class="confirm-popover-text">การยกเลิกจะปิดเอกสารนี้ และต้องระบุเหตุผลการยกเลิกเพื่อใช้เป็นประวัติอ้างอิง</div>
                        <div class="confirm-popover-field">
                            <label class="confirm-popover-label" for="cancelPrDetailsReason_@Model.PurchaseRequestId">เหตุผลที่ยกเลิก</label>
                            <textarea id="cancelPrDetailsReason_@Model.PurchaseRequestId" name="cancelReason" class="form-control" rows="3" placeholder="ระบุเหตุผลที่ยกเลิก" required></textarea>
                        </div>
                        <div class="confirm-popover-actions">
                            <button type="submit" class="btn btn-sm btn-outline-danger">ยืนยัน</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary js-confirm-popover-cancel">ยกเลิก</button>
                        </div>
                    </div>
                </div>
            </form>
        }
        else
        {
            <button type="button" class="btn btn-outline-secondary" disabled title="@cancelBlockedReason">ยกเลิกใบขอซื้อ</button>
        }
        <a asp-action="Index" class="btn btn-outline-secondary">กลับไปรายการใบขอซื้อ</a>
    </div>
</div>

<div class="card content-card">
    <div class="card-body">
        <div class="form-shell">
            <div class="form-section quotation-header-section">
                <div class="form-section-title">ข้อมูลหัวเอกสาร</div>
                <div class="row g-2 quotation-header-grid">
                    <div class="col-lg-3 col-md-6">
                        <div class="detail-label">เลขที่ใบขอซื้อ</div>
                        <div class="form-control readonly-detail">@Model.PRNo</div>
                    </div>
                    <div class="col-lg-3 col-md-6">
                        <div class="detail-label">วันที่ขอซื้อ</div>
                        <div class="form-control readonly-detail">@Model.RequestDate.ToString("dd/MM/yyyy")</div>
                    </div>
                    <div class="col-lg-3 col-md-6">
                        <div class="detail-label">วันที่ต้องการใช้</div>
                        <div class="form-control readonly-detail">@(Model.RequiredDate?.ToString("dd/MM/yyyy") ?? "-")</div>
                    </div>
                    <div class="col-lg-3 col-md-6">
                        <div class="detail-label">สถานะ</div>
                        <div class="readonly-detail-status">@await Html.PartialAsync("_StatusPill", Model.Status)</div>
                    </div>
                    <div class="col-md-6">
                        <div class="detail-label">สาขา</div>
                        <div class="form-control readonly-detail">@(Model.Branch?.BranchName ?? "-")</div>
                    </div>
                    <div class="col-md-6">
                        <div class="detail-label">ใบสั่งซื้อที่เชื่อมโยง</div>
                        <div class="form-control readonly-detail">
                            @if (linkedPO is null)
                            {
                                <span>-</span>
                            }
                            else
                            {
                                <a asp-controller="PurchaseOrders" asp-action="Details" asp-route-id="@linkedPO.PurchaseOrderId">@linkedPO.PONo</a>
                            }
                        </div>
                    </div>
                    <div class="col-12">
                        <div class="detail-label">วัตถุประสงค์</div>
                        <div class="form-control readonly-detail readonly-detail-multiline">@(string.IsNullOrWhiteSpace(Model.Purpose) ? "-" : Model.Purpose)</div>
                    </div>
                    <div class="col-12">
                        <div class="detail-label">หมายเหตุ</div>
                        <div class="form-control readonly-detail readonly-detail-multiline">@(string.IsNullOrWhiteSpace(Model.Remark) ? "-" : Model.Remark)</div>
                    </div>
                </div>
            </div>

            <div class="form-section">
                <div class="d-flex justify-content-between align-items-center gap-2 mb-3 flex-wrap">
                    <div>
                        <div class="form-section-title mb-1">รายการสินค้าที่ขอซื้อ</div>
                        <div class="table-meta">@Model.PurchaseRequestDetails.Count รายการ</div>
                    </div>
                </div>

                <div class="table-responsive">
                    <table class="table entity-table quote-editor-table align-middle">
                        <thead>
                            <tr>
                                <th style="width: 6%;">#</th>
                                <th>สินค้า</th>
                                <th style="width: 16%;">จำนวนที่ขอซื้อ</th>
                                <th style="width: 30%;">หมายเหตุ</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var line in Model.PurchaseRequestDetails.OrderBy(x => x.LineNumber))
                        {
                            <tr>
                                <td>@line.LineNumber</td>
                                <td>
                                    <div class="fw-semibold">@line.Item?.ItemCode - @line.Item?.ItemName</div>
                                    <div class="table-meta">Part No.: @(string.IsNullOrWhiteSpace(line.Item?.PartNumber) ? "-" : line.Item!.PartNumber)</div>
                                </td>
                                <td>@line.RequestedQty.ToString("N2")</td>
                                <td>@(string.IsNullOrWhiteSpace(line.Remark) ? "-" : line.Remark)</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="form-section document-history-section">
                <div class="form-section-title">ประวัติเอกสาร</div>
                <div class="document-history-list">
                    <div class="document-history-row">
                        <span class="document-history-label">สร้างโดย</span>
                        <span class="document-history-value">@(Model.CreatedByUser?.DisplayName ?? "-")</span>
                        <span class="document-history-meta">@Model.CreatedDate.ToString("dd/MM/yyyy HH:mm")</span>
                    </div>
                    <div class="document-history-row">
                        <span class="document-history-label">แก้ไขล่าสุด</span>
                        <span class="document-history-value">@(Model.UpdatedByUser?.DisplayName ?? "-")</span>
                        <span class="document-history-meta">@(Model.UpdatedDate?.ToString("dd/MM/yyyy HH:mm") ?? "-")</span>
                    </div>
                    <div class="document-history-row">
                        <span class="document-history-label">ส่งอนุมัติโดย</span>
                        <span class="document-history-value">@(Model.SubmittedByUser?.DisplayName ?? "-")</span>
                        <span class="document-history-meta">@(Model.SubmittedDate?.ToString("dd/MM/yyyy HH:mm") ?? "-")</span>
                    </div>
                    <div class="document-history-row">
                        <span class="document-history-label">อนุมัติโดย</span>
                        <span class="document-history-value">@(Model.ApprovedByUser?.DisplayName ?? "-")</span>
                        <span class="document-history-meta">@(Model.ApprovedDate?.ToString("dd/MM/yyyy HH:mm") ?? "-")</span>
                    </div>
                    <div class="document-history-row">
                        <span class="document-history-label">ตีกลับโดย</span>
                        <span class="document-history-value">@(Model.RejectedByUser?.DisplayName ?? "-")</span>
                        <span class="document-history-meta">@(Model.RejectedDate?.ToString("dd/MM/yyyy HH:mm") ?? "-")</span>
                    </div>
                    <div class="document-history-row">
                        <span class="document-history-label">ยกเลิกโดย</span>
                        <span class="document-history-value">@(Model.CancelledByUser?.DisplayName ?? "-")</span>
                        <span class="document-history-meta">@(Model.CancelledDate?.ToString("dd/MM/yyyy HH:mm") ?? "-")</span>
                    </div>
                </div>
                @if (Model.Status == "Cancelled")
                {
                    <div class="document-history-reason">
                        <span class="document-history-label">เหตุผลที่ยกเลิก</span>
                        <span class="document-history-value">@(string.IsNullOrWhiteSpace(Model.CancelReason) ? "-" : Model.CancelReason)</span>
                    </div>
                }
                @if (Model.Status == "Rejected")
                {
                    <div class="document-history-reason">
                        <span class="document-history-label">เหตุผลที่ตีกลับ</span>
                        <span class="document-history-value">@(string.IsNullOrWhiteSpace(Model.RejectReason) ? "-" : Model.RejectReason)</span>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
