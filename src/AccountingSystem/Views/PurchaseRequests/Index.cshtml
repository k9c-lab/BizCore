@inject IUserPermissionService PermissionService
@model BizCore.Models.ViewModels.PaginatedList<BizCore.Models.Entities.PurchaseRequestHeader>

@{
    ViewData["Title"] = "ใบขอซื้อ";
    var search = ViewData["Search"] as string;
    var status = ViewData["Status"] as string;
    var dateFrom = ViewData["DateFrom"] as string;
    var dateTo = ViewData["DateTo"] as string;
    var canCreatePR = PermissionService.HasPermission(User, "PR.Create");
    var canCreatePOPermission = PermissionService.HasPermission(User, "PO.Create");
}

<div class="page-header">
    <div>
        <div class="page-eyebrow">งานจัดซื้อ</div>
        <h1 class="page-title">ใบขอซื้อ</h1>
        <p class="page-subtitle">ติดตามคำขอซื้อของแต่ละสาขา โดยใช้หน้ารายละเอียดเป็นจุดหลักสำหรับส่งอนุมัติ อนุมัติ ตีกลับ และยกเลิกเอกสาร</p>
    </div>
    <div class="page-actions">
        @if (canCreatePOPermission)
        {
            <form asp-controller="PurchaseOrders" asp-action="Create" method="get" id="createPOFromPRsForm" class="d-inline"></form>
            <button type="submit" form="createPOFromPRsForm" class="btn btn-outline-success">สร้างใบสั่งซื้อจากรายการที่เลือก</button>
        }
        @if (canCreatePR)
        {
            <a asp-action="Create" class="btn btn-primary px-4">สร้างใบขอซื้อ</a>
        }
    </div>
</div>

@if (TempData["PurchaseRequestNotice"] is string notice && !string.IsNullOrWhiteSpace(notice))
{
    @await Html.PartialAsync("_Notice", notice)
}

<div class="card content-card table-card">
    <div class="table-card-header">
        <div>
            <h2 class="section-title">รายการใบขอซื้อ</h2>
        </div>
        <div class="table-meta">@Model.TotalCount รายการ</div>
    </div>
    <div class="card-body">
        <form method="get" class="list-filter-bar">
            <div class="list-filter-field grow">
                <label class="form-label" for="search">ค้นหา</label>
                <input id="search" name="search" value="@search" class="form-control" placeholder="เลขที่ใบขอซื้อ สาขา สินค้า วัตถุประสงค์ หรือหมายเหตุ" />
            </div>
            <div class="list-filter-field">
                <label class="form-label" for="status">สถานะ</label>
                <select id="status" name="status" class="form-select">
                    <option value="">ทั้งหมด</option>
                    <option value="Draft" selected="@(status == "Draft")">Draft</option>
                    <option value="Submitted" selected="@(status == "Submitted")">Submitted</option>
                    <option value="Approved" selected="@(status == "Approved")">Approved</option>
                    <option value="Rejected" selected="@(status == "Rejected")">Rejected</option>
                    <option value="ConvertedToPO" selected="@(status == "ConvertedToPO")">Converted To PO</option>
                    <option value="Cancelled" selected="@(status == "Cancelled")">Cancelled</option>
                </select>
            </div>
            <div class="list-filter-field">
                <label class="form-label" for="dateFrom">จากวันที่</label>
                <input id="dateFrom" name="dateFrom" value="@dateFrom" type="date" class="form-control" />
            </div>
            <div class="list-filter-field">
                <label class="form-label" for="dateTo">ถึงวันที่</label>
                <input id="dateTo" name="dateTo" value="@dateTo" type="date" class="form-control" />
            </div>
            <div class="list-filter-actions">
                <a asp-action="Index" class="btn btn-outline-secondary">ล้างตัวกรอง</a>
                <button type="submit" class="btn btn-primary">ค้นหา</button>
            </div>
        </form>

        <div class="table-responsive">
            <table class="table entity-table align-middle">
                <thead>
                    <tr>
                        @if (canCreatePOPermission)
                        {
                            <th style="width: 42px;">เลือก</th>
                        }
                        <th>เลขที่ใบขอซื้อ</th>
                        <th>วันที่</th>
                        <th>สาขา</th>
                        <th>จำนวนรายการ</th>
                        <th>จำนวนรวม</th>
                        <th>สถานะ</th>
                        <th class="text-end">การทำงาน</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.Any())
                {
                    @foreach (var pr in Model)
                    {
                        var hasPO = pr.PurchaseOrderHeaders.Any() ||
                            pr.PurchaseRequestDetails.Any(d => d.PurchaseOrderAllocationSources.Any());
                        var canCreatePO = canCreatePOPermission && pr.Status == "Approved" && !hasPO;
                        var createPOBlockedReason = hasPO
                            ? "สร้างใบสั่งซื้อไม่ได้ เพราะใบขอซื้อนี้ถูกนำไปสร้างใบสั่งซื้อแล้ว"
                            : pr.Status == "Approved"
                                ? "คุณไม่มีสิทธิ์สร้างใบสั่งซื้อจากใบขอซื้อนี้"
                                : "จะสร้างใบสั่งซื้อได้หลังจากใบขอซื้อได้รับการอนุมัติแล้ว";
                        <tr>
                            @if (canCreatePOPermission)
                            {
                                <td>
                                    <input type="checkbox"
                                           class="form-check-input"
                                           form="createPOFromPRsForm"
                                           name="purchaseRequestIds"
                                           value="@pr.PurchaseRequestId"
                                           disabled="@(!canCreatePO)"
                                           title="@(canCreatePO ? "เลือกใบขอซื้อนี้เพื่อนำไปสร้างใบสั่งซื้อ" : createPOBlockedReason)" />
                                </td>
                            }
                            <td><span class="code-chip">@pr.PRNo</span></td>
                            <td>@pr.RequestDate.ToString("dd/MM/yyyy")</td>
                            <td>@(pr.Branch?.BranchName ?? "-")</td>
                            <td>@pr.PurchaseRequestDetails.Count</td>
                            <td>@pr.PurchaseRequestDetails.Sum(x => x.RequestedQty).ToString("N2")</td>
                            <td>@await Html.PartialAsync("_StatusPill", pr.Status)</td>
                            <td class="text-end">
                                <div class="table-actions">
                                    <a asp-action="Details" asp-route-id="@pr.PurchaseRequestId" class="btn btn-sm btn-outline-secondary">รายละเอียด</a>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="@(canCreatePOPermission ? 8 : 7)" class="table-empty">ยังไม่มีรายการใบขอซื้อ</td></tr>
                }
                </tbody>
            </table>
        </div>
        <partial name="_Pager" model="Model.Pagination" />
    </div>
</div>
