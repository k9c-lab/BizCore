@model BizCore.Models.ViewModels.PurchaseRequestFormViewModel

@{
    ViewData["Title"] = "แก้ไขใบขอซื้อ";
}

<div class="page-header">
    <div>
        <div class="page-eyebrow">งานจัดซื้อ</div>
        <h1 class="page-title">แก้ไขใบขอซื้อ</h1>
        <p class="page-subtitle">แก้ไขได้เฉพาะใบขอซื้อสถานะ Draft หรือ Rejected เท่านั้น</p>
    </div>
    <div class="page-actions">
        <button type="submit" form="purchaseRequestForm" class="btn btn-primary px-4">บันทึกฉบับร่าง</button>
        <a asp-action="Details" asp-route-id="@Model.PurchaseRequestId" class="btn btn-outline-secondary">กลับไปรายละเอียดใบขอซื้อ</a>
    </div>
</div>

<div class="card content-card">
    <div class="card-body">
        <form asp-action="Edit" asp-route-id="@Model.PurchaseRequestId" method="post" id="purchaseRequestForm">
            <partial name="_Form" model="Model" />
            <div class="form-actions mt-3">
                <span class="table-meta">หลังบันทึกแล้ว ให้กลับไปส่งอนุมัติหรือดำเนินการต่อจากหน้ารายละเอียดเอกสาร</span>
                <div class="page-actions">
                    <a asp-action="Details" asp-route-id="@Model.PurchaseRequestId" class="btn btn-outline-secondary">กลับไปรายละเอียดใบขอซื้อ</a>
                    <button type="submit" class="btn btn-primary px-4">บันทึกฉบับร่าง</button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <partial name="_FormScripts" />
}
