@model BizCore.Models.ViewModels.PaginatedList<BizCore.Models.Entities.StockTransferHeader>

@{
    ViewData["Title"] = "Stock Transfers";
    var search = ViewData["Search"] as string;
    var status = ViewData["Status"] as string;
    var dateFrom = ViewData["DateFrom"] as string;
    var dateTo = ViewData["DateTo"] as string;
}

<div class="page-header">
    <div>
        <div class="page-eyebrow">Inventory Module</div>
        <h1 class="page-title">Stock Transfers</h1>
        <p class="page-subtitle">Move stock and serial numbers between branches with branch balance tracking.</p>
    </div>
    <div class="page-actions">
        <a asp-action="Create" class="btn btn-primary px-4">New Transfer</a>
    </div>
</div>

@if (TempData["StockTransferNotice"] is string notice && !string.IsNullOrWhiteSpace(notice))
{
    <div class="workflow-info mb-3">@notice</div>
}

<div class="card content-card table-card">
    <div class="table-card-header">
        <div>
            <h2 class="section-title">Transfer Register</h2>
            <p class="section-subtitle">Track branch-to-branch inventory movement.</p>
        </div>
        <div class="table-meta">@Model.TotalCount records</div>
    </div>
    <div class="card-body">
        <form method="get" class="list-filter-bar">
            <div class="list-filter-field grow">
                <label class="form-label" for="search">Search</label>
                <input id="search" name="search" value="@search" class="form-control" placeholder="Transfer no., branch, item, or remark" />
            </div>
            <div class="list-filter-field">
                <label class="form-label" for="status">Status</label>
                <select id="status" name="status" class="form-select">
                    <option value="">All</option>
                    <option value="Draft" selected="@(status == "Draft")">Draft</option>
                    <option value="Posted" selected="@(status == "Posted")">Posted</option>
                    <option value="Cancelled" selected="@(status == "Cancelled")">Cancelled</option>
                </select>
            </div>
            <div class="list-filter-field">
                <label class="form-label" for="dateFrom">From</label>
                <input id="dateFrom" name="dateFrom" value="@dateFrom" type="date" class="form-control" />
            </div>
            <div class="list-filter-field">
                <label class="form-label" for="dateTo">To</label>
                <input id="dateTo" name="dateTo" value="@dateTo" type="date" class="form-control" />
            </div>
            <div class="list-filter-actions">
                <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
                <button type="submit" class="btn btn-primary">Search</button>
            </div>
        </form>

        <div class="table-responsive">
            <table class="table entity-table align-middle">
                <thead>
                    <tr>
                        <th>Transfer No.</th>
                        <th>Date</th>
                        <th>From</th>
                        <th>To</th>
                        <th>Lines</th>
                        <th>Qty</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.Any())
                {
                    @foreach (var transfer in Model)
                    {
                        var canPost = transfer.Status == "Draft" && transfer.StockTransferDetails.Any();
                        var postBlockedReason = transfer.Status == "Draft"
                            ? "Post is blocked because no transfer lines exist."
                            : $"Post is available only for Draft stock transfers. Current status is {transfer.Status}.";
                        <tr>
                            <td><span class="code-chip">@transfer.TransferNo</span></td>
                            <td>@transfer.TransferDate.ToString("dd MMM yyyy")</td>
                            <td>@(transfer.FromBranch?.BranchName ?? "-")</td>
                            <td>@(transfer.ToBranch?.BranchName ?? "-")</td>
                            <td>@transfer.StockTransferDetails.Count</td>
                            <td>@transfer.StockTransferDetails.Sum(x => x.Qty).ToString("N2")</td>
                            <td><span class="status-pill active">@transfer.Status</span></td>
                            <td class="text-end">
                                <div class="table-actions">
                                    <a asp-action="Details" asp-route-id="@transfer.StockTransferId" class="btn btn-sm btn-outline-secondary">View</a>
                                    @if (canPost)
                                    {
                                        <form asp-action="Post" asp-route-id="@transfer.StockTransferId" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-primary">Post</button>
                                        </form>
                                    }
                                    else
                                    {
                                        <button type="button" class="btn btn-sm btn-outline-secondary" disabled title="@postBlockedReason">Post</button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="8" class="table-empty">No stock transfers yet.</td></tr>
                }
                </tbody>
            </table>
        </div>
        <partial name="_Pager" model="Model.Pagination" />
    </div>
</div>
