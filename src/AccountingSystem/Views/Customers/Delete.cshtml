@model BizCore.Models.Entities.Customer

@{
    ViewData["Title"] = "ลบลูกค้า";
}

<div class="page-header">
    <div>
        <div class="page-eyebrow">ข้อมูลลูกค้า</div>
        <h1 class="page-title">ลบลูกค้า</h1>
        <p class="page-subtitle">โปรดยืนยันให้แน่ใจก่อนลบลูกค้ารายการนี้ออกจากข้อมูลหลัก</p>
    </div>
</div>

<div class="card content-card danger-card">
    <div class="card-body">
        <div class="danger-banner">
            การกระทำนี้จะลบ <strong>@Model.CustomerName</strong> ออกจากข้อมูลลูกค้า ให้ดำเนินการต่อเมื่อมั่นใจว่าไม่ต้องใช้งานแล้วเท่านั้น
        </div>
        <div class="detail-grid">
            <div class="detail-item"><span class="detail-label">รหัส</span><p class="detail-value">@Model.CustomerCode</p></div>
            <div class="detail-item"><span class="detail-label">อีเมล</span><p class="detail-value">@(string.IsNullOrWhiteSpace(Model.Email) ? "-" : Model.Email)</p></div>
        </div>
        <form asp-action="Delete" method="post" class="form-actions mt-4">
            <input type="hidden" asp-for="CustomerId" />
            <a asp-action="Index" class="btn btn-outline-secondary">ยกเลิก</a>
            <button type="submit" class="btn btn-danger px-4">ลบลูกค้า</button>
        </form>
    </div>
</div>
