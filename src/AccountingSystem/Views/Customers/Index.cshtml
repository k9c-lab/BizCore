@model BizCore.Models.ViewModels.PaginatedList<BizCore.Models.Entities.Customer>

@{
    ViewData["Title"] = "ลูกค้า";
    var search = ViewData["Search"] as string;
    var status = ViewData["Status"] as string;
}

<div class="page-header">
    <div>
        <div class="page-eyebrow">ข้อมูลหลัก</div>
        <h1 class="page-title">ลูกค้า</h1>
        </div>
    <div class="page-actions">
        <a asp-action="Create" class="btn btn-primary px-4">เพิ่มลูกค้า</a>
    </div>
</div>

<div class="card content-card table-card">
    <div class="table-card-header">
        <div>
            <h2 class="section-title">รายการลูกค้า</h2>
            </div>
        <div class="table-meta">@Model.TotalCount รายการ</div>
    </div>
    <div class="card-body">
        <form method="get" class="list-filter-bar">
            <div class="list-filter-field grow">
                <label class="form-label" for="search">ค้นหา</label>
                <input id="search" name="search" value="@search" class="form-control" placeholder="รหัส, ชื่อ, เลขประจำตัวผู้เสียภาษี, โทรศัพท์ หรืออีเมล" />
            </div>
            <div class="list-filter-field">
                <label class="form-label" for="status">สถานะ</label>
                <select id="status" name="status" class="form-select">
                    <option value="">ทั้งหมด</option>
                    <option value="Active" selected="@(status == "Active")">ใช้งาน</option>
                    <option value="Inactive" selected="@(status == "Inactive")">ไม่ใช้งาน</option>
                </select>
            </div>
            <div class="list-filter-actions">
                <a asp-action="Index" class="btn btn-outline-secondary">ล้างค่า</a>
                <button type="submit" class="btn btn-primary">ค้นหา</button>
            </div>
        </form>
        <div class="table-responsive">
            <table class="table entity-table align-middle">
                <thead>
                    <tr>
                        <th>รหัสลูกค้า</th>
                        <th>ชื่อลูกค้า</th>
                        <th>โทรศัพท์</th>
                        <th>วงเงินเครดิต</th>
                        <th>สถานะ</th>
                        <th class="text-end">การทำงาน</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.Any())
                {
                @foreach (var item in Model)
                {
                    <tr>
                        <td><span class="code-chip">@item.CustomerCode</span></td>
                        <td class="fw-semibold">@item.CustomerName</td>
                        <td>@(string.IsNullOrWhiteSpace(item.PhoneNumber) ? "-" : item.PhoneNumber)</td>
                        <td>@item.CreditLimit.ToString("N2")</td>
                        <td><span class="status-pill @(item.IsActive ? "active" : "inactive")">@(item.IsActive ? "ใช้งาน" : "ไม่ใช้งาน")</span></td>
                        <td class="text-end">
                            <div class="table-actions">
                                <a asp-action="Details" asp-route-id="@item.CustomerId" class="btn btn-sm btn-outline-secondary">รายละเอียด</a>
                                <a asp-action="Edit" asp-route-id="@item.CustomerId" class="btn btn-sm btn-outline-primary">แก้ไข</a>
                                <a asp-action="Delete" asp-route-id="@item.CustomerId" class="btn btn-sm btn-outline-danger">ลบ</a>
                            </div>
                        </td>
                    </tr>
                }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="table-empty">ยังไม่มีข้อมูลลูกค้า เริ่มเพิ่มลูกค้ารายแรกเพื่อใช้งานงานขายได้เลย</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
        <partial name="_Pager" model="Model.Pagination" />
    </div>
</div>

