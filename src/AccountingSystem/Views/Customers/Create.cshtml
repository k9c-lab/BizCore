@model BizCore.Models.Entities.Customer

@{
    ViewData["Title"] = "เพิ่มลูกค้า";
}

<div class="page-header">
    <div>
        <div class="page-eyebrow">ข้อมูลหลัก</div>
        <h1 class="page-title">เพิ่มลูกค้า</h1>
        </div>
    <div class="page-actions">
        <button type="submit" form="customerForm" class="btn btn-primary px-4">บันทึกลูกค้า</button>
        <a asp-action="Index" class="btn btn-outline-secondary">กลับไปรายการ</a>
    </div>
</div>

<div class="card content-card">
    <div class="card-body">
        <form asp-action="Create" method="post" id="customerForm">
            <partial name="_Form" model="Model" />
            <div class="form-actions mt-3">
                <span class="table-meta">หากมีข้อความ validation กรุณาแก้ไขข้อมูลก่อนบันทึก</span>
                <div class="page-actions">
                    <a asp-action="Index" class="btn btn-outline-secondary">ยกเลิก</a>
                    <button type="submit" class="btn btn-primary px-4">บันทึกลูกค้า</button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

