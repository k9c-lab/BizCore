@model BizCore.Models.Entities.Customer

@{
    ViewData["Title"] = "แก้ไขลูกค้า";
}

<div class="page-header">
    <div>
        <div class="page-eyebrow">ข้อมูลหลัก</div>
        <h1 class="page-title">แก้ไขลูกค้า</h1>
        </div>
    <div class="page-actions">
        <a asp-action="Details" asp-route-id="@Model.CustomerId" class="btn btn-outline-secondary">ดูรายละเอียด</a>
    </div>
</div>

<div class="card content-card">
    <div class="card-body">
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="CustomerId" />
            <partial name="_Form" model="Model" />
            <div class="form-actions">
                <span class="table-meta">ระบบตรวจสอบข้อมูลในแต่ละช่องระหว่างแก้ไขเหมือนเดิม</span>
                <div class="page-actions">
                    <a asp-action="Index" class="btn btn-outline-secondary">กลับ</a>
                    <button type="submit" class="btn btn-primary px-4">บันทึกการเปลี่ยนแปลง</button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

