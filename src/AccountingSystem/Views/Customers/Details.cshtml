@model BizCore.Models.Entities.Customer

@{
    ViewData["Title"] = "รายละเอียดลูกค้า";
}

<div class="page-header">
    <div>
        <div class="page-eyebrow">ข้อมูลหลัก</div>
        <h1 class="page-title">รายละเอียดลูกค้า</h1>
        <p class="page-subtitle">ตรวจสอบข้อมูลลูกค้า วงเงินเครดิต และข้อมูลติดต่อ</p>
    </div>
    <div class="page-actions">
        <a asp-action="Edit" asp-route-id="@Model.CustomerId" class="btn btn-primary">แก้ไขลูกค้า</a>
        <a asp-action="Index" class="btn btn-outline-secondary">กลับ</a>
    </div>
</div>

<div class="card content-card">
    <div class="card-body">
        <div class="form-shell">
            <div class="form-section quotation-header-section">
                <div class="form-section-title">ข้อมูลลูกค้า</div>
                <div class="row g-2 quotation-header-grid">
                    <div class="col-lg-3 col-md-6">
                        <div class="detail-label">รหัสลูกค้า</div>
                        <div class="form-control readonly-detail">@Model.CustomerCode</div>
                    </div>
                    <div class="col-lg-5 col-md-6">
                        <div class="detail-label">ชื่อลูกค้า</div>
                        <div class="form-control readonly-detail">@Model.CustomerName</div>
                    </div>
                    <div class="col-lg-2 col-md-6">
                        <div class="detail-label">สถานะ</div>
                        <div class="form-control readonly-detail">@(Model.IsActive ? "ใช้งาน" : "ไม่ใช้งาน")</div>
                    </div>
                    <div class="col-lg-2 col-md-6">
                        <div class="detail-label">วงเงินเครดิต</div>
                        <div class="form-control readonly-detail">@Model.CreditLimit.ToString("N2")</div>
                    </div>
                    <div class="col-lg-4 col-md-6">
                        <div class="detail-label">เลขประจำตัวผู้เสียภาษี</div>
                        <div class="form-control readonly-detail">@(string.IsNullOrWhiteSpace(Model.TaxId) ? "-" : Model.TaxId)</div>
                    </div>
                </div>
            </div>

            <div class="quotation-party-grid">
                <div class="quotation-party-column">
                    <div class="quotation-info-card">
                        <div class="quotation-info-card-title">ข้อมูลติดต่อ</div>
                        <div class="quotation-info-grid">
                            <div class="quotation-info-field">
                                <span class="quotation-info-label">โทรศัพท์</span>
                                <span class="quotation-info-value">@(string.IsNullOrWhiteSpace(Model.PhoneNumber) ? "-" : Model.PhoneNumber)</span>
                            </div>
                            <div class="quotation-info-field">
                                <span class="quotation-info-label">อีเมล</span>
                                <span class="quotation-info-value">@(string.IsNullOrWhiteSpace(Model.Email) ? "-" : Model.Email)</span>
                            </div>
                        </div>
                        <div class="quotation-info-field">
                            <span class="quotation-info-label">ที่อยู่</span>
                            <span class="quotation-info-value">@(string.IsNullOrWhiteSpace(Model.Address) ? "-" : Model.Address)</span>
                        </div>
                    </div>
                </div>

                <div class="quotation-party-column">
                    <div class="quotation-info-card">
                        <div class="quotation-info-card-title">การใช้งานในงานขาย</div>
                        <div class="quotation-info-grid">
                            <div class="quotation-info-field">
                                <span class="quotation-info-label">ใบแจ้งหนี้ / ใบเสร็จ</span>
                                <span class="quotation-info-value">ใช้รหัสลูกค้า เลขประจำตัวผู้เสียภาษี และที่อยู่วางบิล</span>
                            </div>
                            <div class="quotation-info-field">
                                <span class="quotation-info-label">การใช้งาน</span>
                                <span class="quotation-info-value">@(Model.IsActive ? "เลือกใช้ในเอกสารได้" : "ซ่อนจากการเลือกใช้งานปกติ")</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
