@model BizCore.Models.Entities.Customer
@{
    var codeReadOnly = (bool?)ViewData["CodeReadOnly"] == true;
}

<div asp-validation-summary="ModelOnly" class="form-alert"></div>

<div class="form-shell">
    <div class="form-section quotation-header-section">
        <div class="form-section-title">Customer Profile</div>
        <div class="row g-2 quotation-header-grid">
            <div class="col-lg-3 col-md-6">
                <label asp-for="CustomerCode" class="form-label"></label>
                <input asp-for="CustomerCode" class="form-control" readonly="@codeReadOnly" />
                @if (codeReadOnly)
                {
                    <div class="form-text">Auto-generated code in CUS-0001 format.</div>
                }
                <span asp-validation-for="CustomerCode" class="text-danger"></span>
            </div>
            <div class="col-lg-5 col-md-6">
                <label asp-for="CustomerName" class="form-label"></label>
                <input asp-for="CustomerName" class="form-control" />
                <span asp-validation-for="CustomerName" class="text-danger"></span>
            </div>
            <div class="col-lg-4 col-md-6">
                <label asp-for="CreditLimit" class="form-label"></label>
                <input asp-for="CreditLimit" class="form-control" />
                <div class="form-text">Set the customer credit ceiling used in sales operations.</div>
                <span asp-validation-for="CreditLimit" class="text-danger"></span>
            </div>
            <div class="col-lg-4 col-md-6">
                <label asp-for="TaxId" class="form-label"></label>
                <div class="quotation-expiry-group master-status-group">
                    <input asp-for="TaxId" class="form-control" />
                    <label class="quotation-inline-check" asp-for="IsActive">
                        <input asp-for="IsActive" class="form-check-input" />
                        <span>Active</span>
                    </label>
                </div>
                <span asp-validation-for="TaxId" class="text-danger"></span>
            </div>
        </div>
    </div>

    <div class="form-section">
        <div class="form-section-title">Contact Information</div>
        <div class="row g-2 quotation-header-grid">
            <div class="col-lg-4 col-md-6">
                <label asp-for="PhoneNumber" class="form-label"></label>
                <input asp-for="PhoneNumber" class="form-control" />
                <span asp-validation-for="PhoneNumber" class="text-danger"></span>
            </div>
            <div class="col-lg-4 col-md-6">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>
            <div class="col-12">
                <label asp-for="Address" class="form-label"></label>
                <textarea asp-for="Address" class="form-control" rows="3"></textarea>
                <div class="form-text">Use billing or primary contact address for invoices and receipts.</div>
                <span asp-validation-for="Address" class="text-danger"></span>
            </div>
        </div>
    </div>
</div>

