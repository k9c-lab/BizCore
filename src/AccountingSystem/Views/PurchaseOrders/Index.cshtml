@inject IUserPermissionService PermissionService
@model BizCore.Models.ViewModels.PaginatedList<BizCore.Models.Entities.PurchaseOrderHeader>

@{
    ViewData["Title"] = "ใบสั่งซื้อ";
    var search = ViewData["Search"] as string;
    var status = ViewData["Status"] as string;
    var dateFrom = ViewData["DateFrom"] as string;
    var dateTo = ViewData["DateTo"] as string;
    var canCreatePO = PermissionService.HasPermission(User, "PO.Create");
    var canCreatePR = PermissionService.HasPermission(User, "PR.Create");
}

<div class="page-header">
    <div>
        <div class="page-eyebrow">งานจัดซื้อ</div>
        <h1 class="page-title">ใบสั่งซื้อ</h1>
        <p class="page-subtitle">ติดตามใบสั่งซื้อทั้งหมดจากหน้านี้ และไปดำเนินการต่อที่หน้ารายละเอียดเอกสารตาม pattern หลักของระบบ</p>
    </div>
    <div class="page-actions">
        @if (canCreatePO)
        {
            <a asp-action="Create" class="btn btn-primary px-4">สร้างใบสั่งซื้อ</a>
        }
        else if (canCreatePR)
        {
            <a asp-controller="PurchaseRequests" asp-action="Create" class="btn btn-outline-primary px-4">สร้างใบขอซื้อ</a>
        }
    </div>
</div>

@if (TempData["PurchaseOrderNotice"] is string notice && !string.IsNullOrWhiteSpace(notice))
{
    @await Html.PartialAsync("_Notice", notice)
}

<div class="card content-card table-card">
    <div class="table-card-header">
        <div>
            <h2 class="section-title">รายการใบสั่งซื้อ</h2>
        </div>
        <div class="table-meta">@Model.TotalCount รายการ</div>
    </div>
    <div class="card-body">
        <form method="get" class="list-filter-bar">
            <div class="list-filter-field grow">
                <label class="form-label" for="search">ค้นหา</label>
                <input id="search" name="search" value="@search" class="form-control" placeholder="เลขที่ PO, เลขอ้างอิง, ผู้จำหน่าย หรือเลขผู้เสียภาษี" />
            </div>
            <div class="list-filter-field">
                <label class="form-label" for="status">สถานะ</label>
                <select id="status" name="status" class="form-select">
                    <option value="">ทั้งหมด</option>
                    <option value="Draft" selected="@(status == "Draft")">Draft</option>
                    <option value="Submitted" selected="@(status == "Submitted")">Submitted</option>
                    <option value="Approved" selected="@(status == "Approved")">Approved</option>
                    <option value="Rejected" selected="@(status == "Rejected")">Rejected</option>
                    <option value="PartiallyReceived" selected="@(status == "PartiallyReceived")">Partially Received</option>
                    <option value="FullyReceived" selected="@(status == "FullyReceived")">Fully Received</option>
                    <option value="Cancelled" selected="@(status == "Cancelled")">Cancelled</option>
                </select>
            </div>
            <div class="list-filter-field">
                <label class="form-label" for="dateFrom">จากวันที่</label>
                <input id="dateFrom" name="dateFrom" value="@dateFrom" type="date" class="form-control" />
            </div>
            <div class="list-filter-field">
                <label class="form-label" for="dateTo">ถึงวันที่</label>
                <input id="dateTo" name="dateTo" value="@dateTo" type="date" class="form-control" />
            </div>
            <div class="list-filter-actions">
                <a asp-action="Index" class="btn btn-outline-secondary">ล้างตัวกรอง</a>
                <button type="submit" class="btn btn-primary">ค้นหา</button>
            </div>
        </form>

        <div class="table-responsive">
            <table class="table entity-table align-middle">
                <thead>
                    <tr>
                        <th>เลขที่ใบสั่งซื้อ</th>
                        <th>วันที่</th>
                        <th>ผู้จำหน่าย</th>
                        <th>สาขา</th>
                        <th>ยอดรวม</th>
                        <th>การชำระ</th>
                        <th>สถานะ</th>
                        <th class="text-end">การทำงาน</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.Any())
                {
                    @foreach (var po in Model)
                    {
                        var postedSupplierPayments = po.SupplierPayments.Where(x => x.Status == "Posted").ToList();
                        var poPaidAmount = postedSupplierPayments.Sum(x => x.Amount);
                        var poBalanceAmount = Math.Max(po.TotalAmount - poPaidAmount, 0m);
                        var paymentStatus = poPaidAmount <= 0m
                            ? "Unpaid"
                            : poBalanceAmount <= 0m
                                ? "Paid"
                                : "Partially Paid";
                        <tr>
                            <td><span class="code-chip">@po.PONo</span></td>
                            <td>@po.PODate.ToString("dd/MM/yyyy")</td>
                            <td>
                                <div class="fw-semibold">@po.Supplier?.SupplierName</div>
                                <div class="table-meta">เลขผู้เสียภาษี: @(string.IsNullOrWhiteSpace(po.Supplier?.TaxId) ? "-" : po.Supplier!.TaxId)</div>
                            </td>
                            <td>@(po.Branch?.BranchName ?? "-")</td>
                            <td>
                                <div>@po.TotalAmount.ToString("N2")</div>
                                <div class="table-meta">จ่ายแล้ว @poPaidAmount.ToString("N2")</div>
                                <div class="table-meta">คงเหลือ @poBalanceAmount.ToString("N2")</div>
                            </td>
                            <td>@await Html.PartialAsync("_StatusPill", paymentStatus)</td>
                            <td>@await Html.PartialAsync("_StatusPill", po.Status)</td>
                            <td class="text-end">
                                <div class="table-actions">
                                    <a asp-action="Details" asp-route-id="@po.PurchaseOrderId" class="btn btn-sm btn-outline-secondary">รายละเอียด</a>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="8" class="table-empty">ยังไม่มีรายการใบสั่งซื้อ</td></tr>
                }
                </tbody>
            </table>
        </div>
        <partial name="_Pager" model="Model.Pagination" />
    </div>
</div>
