@model BizCore.Models.ViewModels.PaginatedList<BizCore.Models.Entities.PurchaseOrderHeader>

@{
    ViewData["Title"] = "Purchase Orders";
    var search = ViewData["Search"] as string;
    var status = ViewData["Status"] as string;
    var dateFrom = ViewData["DateFrom"] as string;
    var dateTo = ViewData["DateTo"] as string;
    var hasPermissionClaims = User.HasClaim(x => x.Type == "Permission");
    var oldPrOperatorFallback = !hasPermissionClaims && (User.IsInRole("BranchAdmin") || User.IsInRole("Warehouse"));
    var oldCentralAdminFallback = !hasPermissionClaims && User.IsInRole("CentralAdmin");
    var canCreatePO = User.IsInRole("Admin") || User.HasClaim("Permission", "PO.Create") || oldCentralAdminFallback;
    var canCreatePR = User.IsInRole("Admin") || User.HasClaim("Permission", "PR.Create") || oldPrOperatorFallback;
    var canSubmitPO = User.IsInRole("Admin") || User.HasClaim("Permission", "PO.Submit") || oldCentralAdminFallback;
    var canApprovePO = User.IsInRole("Admin") || User.HasClaim("Permission", "PO.Approve");
    var canRejectPO = User.IsInRole("Admin") || User.HasClaim("Permission", "PO.Reject");
    var canCancelPO = User.IsInRole("Admin") || User.HasClaim("Permission", "PO.Cancel") || oldCentralAdminFallback;
    var oldReceivingOperatorFallback = !hasPermissionClaims && (User.IsInRole("BranchAdmin") || User.IsInRole("Warehouse"));
    var canReceiveGoods = User.IsInRole("Admin") || User.HasClaim("Permission", "Receiving.Create") || User.HasClaim("Permission", "PO.Receive") || oldReceivingOperatorFallback;
    var canRecordSupplierPayment = User.IsInRole("Admin") || User.HasClaim("Permission", "SupplierPayment.Create") || oldCentralAdminFallback;
}

<div class="page-header">
    <div>
        <div class="page-eyebrow">Purchasing Module</div>
        <h1 class="page-title">Purchase Orders</h1>
        <p class="page-subtitle">Create supplier purchase orders before receiving and stock-in processing.</p>
    </div>
    <div class="page-actions">
        @if (canCreatePO)
        {
            <a asp-action="Create" class="btn btn-primary px-4">New PO</a>
        }
        else if (canCreatePR)
        {
            <a asp-controller="PurchaseRequests" asp-action="Create" class="btn btn-primary px-4">New PR</a>
        }
    </div>
</div>

@if (TempData["ReceivingNotice"] is string receivingNotice && !string.IsNullOrWhiteSpace(receivingNotice))
{
    @await Html.PartialAsync("_Notice", receivingNotice)
}

<div class="card content-card table-card">
    <div class="table-card-header">
        <div>
            <h2 class="section-title">PO Register</h2>
            <p class="section-subtitle">Track supplier orders and received progress without AP.</p>
        </div>
        <div class="table-meta">@Model.TotalCount records</div>
    </div>
    <div class="card-body">
        <form method="get" class="list-filter-bar">
            <div class="list-filter-field grow">
                <label class="form-label" for="search">Search</label>
                <input id="search" name="search" value="@search" class="form-control" placeholder="PO no., reference, supplier, or tax ID" />
            </div>
            <div class="list-filter-field">
                <label class="form-label" for="status">Status</label>
                <select id="status" name="status" class="form-select">
                    <option value="">All</option>
                    <option value="Draft" selected="@(status == "Draft")">Draft</option>
                    <option value="Submitted" selected="@(status == "Submitted")">Submitted</option>
                    <option value="Approved" selected="@(status == "Approved")">Approved</option>
                    <option value="Rejected" selected="@(status == "Rejected")">Rejected</option>
                    <option value="PartiallyReceived" selected="@(status == "PartiallyReceived")">Partially Received</option>
                    <option value="FullyReceived" selected="@(status == "FullyReceived")">Fully Received</option>
                    <option value="Cancelled" selected="@(status == "Cancelled")">Cancelled</option>
                </select>
            </div>
            <div class="list-filter-field">
                <label class="form-label" for="dateFrom">From</label>
                <input id="dateFrom" name="dateFrom" value="@dateFrom" type="date" class="form-control" />
            </div>
            <div class="list-filter-field">
                <label class="form-label" for="dateTo">To</label>
                <input id="dateTo" name="dateTo" value="@dateTo" type="date" class="form-control" />
            </div>
            <div class="list-filter-actions">
                <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
                <button type="submit" class="btn btn-primary">Search</button>
            </div>
        </form>
        <div class="table-responsive">
            <table class="table entity-table align-middle">
                <thead>
                    <tr>
                        <th>PO No.</th>
                        <th>Date</th>
                        <th>Supplier</th>
                        <th>Branch</th>
                        <th>Total</th>
                        <th>Payment</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.Any())
                {
                    @foreach (var po in Model)
                    {
                        var hasReceiving = po.PurchaseOrderDetails.Any(x => x.ReceivedQty > 0);
                        var hasOpenLines = po.PurchaseOrderDetails.Any(x => x.Qty > x.ReceivedQty);
                        var postedSupplierPayments = po.SupplierPayments.Where(x => x.Status == "Posted").ToList();
                        var poPaidAmount = postedSupplierPayments.Sum(x => x.Amount);
                        var poBalanceAmount = Math.Max(po.TotalAmount - poPaidAmount, 0m);
                        var paymentStatus = poPaidAmount <= 0m
                            ? "Unpaid"
                            : poBalanceAmount <= 0m
                                ? "Paid"
                                : "Partially Paid";
                        var canPay = canRecordSupplierPayment && po.Status is "Approved" or "PartiallyReceived" or "FullyReceived" && poBalanceAmount > 0m;
                        var payBlockedReason = !canRecordSupplierPayment
                            ? "You do not have permission to record supplier payments."
                            : po.Status is not ("Approved" or "PartiallyReceived" or "FullyReceived")
                                ? $"Pay is available only for Approved or received purchase orders. Current status is {po.Status}."
                                : "This purchase order has already been fully paid.";
                        var canSubmit = canSubmitPO && (po.Status is "Draft" or "Rejected") && po.PurchaseOrderDetails.Any();
                        var submitBlockedReason = po.Status is "Draft" or "Rejected"
                            ? canSubmitPO
                                ? "Submit is blocked because no PO lines exist."
                                : "You do not have permission to submit purchase orders."
                            : $"Submit is available only for Draft or Rejected purchase orders. Current status is {po.Status}.";
                        var canApprove = canApprovePO && po.Status == "Submitted";
                        var approveBlockedReason = !canApprovePO
                            ? "You do not have permission to approve purchase orders."
                            : po.Status == "Submitted"
                                ? "Approve is blocked."
                                : $"Approve is available only for Submitted purchase orders. Current status is {po.Status}.";
                        var canReject = canRejectPO && po.Status == "Submitted";
                        var rejectBlockedReason = !canRejectPO
                            ? "You do not have permission to reject purchase orders."
                            : po.Status == "Submitted"
                                ? "Reject is blocked."
                                : $"Reject is available only for Submitted purchase orders. Current status is {po.Status}.";
                        var canCancel = canCancelPO && (po.Status == "Draft" || po.Status == "Submitted" || po.Status == "Approved" || po.Status == "Rejected") && !hasReceiving;
                        var cancelBlockedReason = po.Status == "Cancelled"
                            ? "Cancelled purchase orders are read-only."
                            : hasReceiving || po.Status is "PartiallyReceived" or "FullyReceived"
                                ? "Cancel PO is blocked because receiving already exists."
                                : canCancelPO
                                    ? $"Cancel PO is available only for Draft, Submitted, Approved, or Rejected purchase orders. Current status is {po.Status}."
                                    : "You do not have permission to cancel purchase orders.";
                        var canReceive = canReceiveGoods && (po.Status == "Approved" || po.Status == "PartiallyReceived") && hasOpenLines;
                        var receiveBlockedReason = !canReceiveGoods
                            ? "You do not have permission to receive goods."
                            : po.Status == "Cancelled"
                            ? "Receive Goods is blocked because the PO is cancelled."
                            : po.Status == "FullyReceived" || !hasOpenLines
                                ? "Receive Goods is blocked because the PO is already fully received."
                                : "Receive Goods is available only after PO approval.";
                        <tr>
                            <td><span class="code-chip">@po.PONo</span></td>
                            <td>@po.PODate.ToString("dd MMM yyyy")</td>
                            <td>
                                <div class="fw-semibold">@po.Supplier?.SupplierName</div>
                                <div class="table-meta">Payment: @paymentStatus</div>
                            </td>
                            <td>@(po.Branch?.BranchName ?? "-")</td>
                            <td>
                                <div>@po.TotalAmount.ToString("N2")</div>
                                <div class="table-meta">Paid @poPaidAmount.ToString("N2")</div>
                                <div class="table-meta">Balance @poBalanceAmount.ToString("N2")</div>
                            </td>
                            <td>@await Html.PartialAsync("_StatusPill", paymentStatus)</td>
                            <td>@await Html.PartialAsync("_StatusPill", po.Status)</td>
                            <td class="text-end">
                                <div class="table-actions table-actions-multirow">
                                    <a asp-action="Details" asp-route-id="@po.PurchaseOrderId" class="btn btn-sm btn-outline-secondary">View</a>
                                    <button type="button" class="btn btn-sm btn-outline-secondary" onclick="window.open('@Url.Action("Print", new { id = po.PurchaseOrderId })', '_blank', 'noopener');">Print</button>
                                    @if (canSubmit)
                                    {
                                        <form asp-action="Submit" asp-route-id="@po.PurchaseOrderId" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-primary">Submit</button>
                                        </form>
                                    }
                                    else
                                    {
                                        <button type="button" class="btn btn-sm btn-outline-secondary" disabled title="@submitBlockedReason">Submit</button>
                                    }
                                    @if (canApprove)
                                    {
                                        <form asp-action="Approve" asp-route-id="@po.PurchaseOrderId" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-primary">Approve</button>
                                        </form>
                                    }
                                    else
                                    {
                                        <button type="button" class="btn btn-sm btn-outline-secondary" disabled title="@approveBlockedReason">Approve</button>
                                    }
                                    @if (canReject)
                                    {
                                        <form asp-action="Reject" asp-route-id="@po.PurchaseOrderId" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="rejectReason" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger" onclick="const reason = prompt('Reason for rejecting this purchase order:'); if (reason === null) return false; if (!reason.trim()) { alert('Reject reason is required.'); return false; } this.form.rejectReason.value = reason; return confirm('Reject this purchase order and return it for correction?');">Reject</button>
                                        </form>
                                    }
                                    else
                                    {
                                        <button type="button" class="btn btn-sm btn-outline-secondary" disabled title="@rejectBlockedReason">Reject</button>
                                    }
                                    @if (canReceive)
                                    {
                                        <a asp-controller="Receivings" asp-action="Create" asp-route-purchaseOrderId="@po.PurchaseOrderId" class="btn btn-sm btn-outline-success">Receive</a>
                                    }
                                    else
                                    {
                                        <button type="button" class="btn btn-sm btn-outline-secondary" disabled title="@receiveBlockedReason">Receive</button>
                                    }
                                    @if (canPay)
                                    {
                                        <a asp-controller="SupplierPayments" asp-action="Create" asp-route-purchaseOrderId="@po.PurchaseOrderId" class="btn btn-sm btn-outline-primary">Pay</a>
                                    }
                                    else
                                    {
                                        <button type="button" class="btn btn-sm btn-outline-secondary" disabled title="@payBlockedReason">Pay</button>
                                    }
                                    @if (canCancel)
                                    {
                                        <form asp-action="Cancel" asp-route-id="@po.PurchaseOrderId" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="cancelReason" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger" onclick="const reason = prompt('Reason for cancelling this purchase order (optional):'); if (reason === null) return false; this.form.cancelReason.value = reason; return confirm('Cancel this purchase order?');">Cancel</button>
                                        </form>
                                    }
                                    else
                                    {
                                        <button type="button" class="btn btn-sm btn-outline-secondary" disabled title="@cancelBlockedReason">Cancel</button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="8" class="table-empty">No purchase orders yet. Start with a supplier PO.</td></tr>
                }
                </tbody>
            </table>
        </div>
        <partial name="_Pager" model="Model.Pagination" />
    </div>
</div>
