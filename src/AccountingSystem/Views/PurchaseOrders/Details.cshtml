@model BizCore.Models.Entities.PurchaseOrderHeader

@{
    ViewData["Title"] = "Purchase Order Details";
    var canAccessAllBranches = !User.IsInRole("BranchAdmin") &&
        (User.IsInRole("Admin") || string.Equals(User.FindFirst("CanAccessAllBranches")?.Value, "true", StringComparison.OrdinalIgnoreCase));
    var currentBranchId = int.TryParse(User.FindFirst("BranchId")?.Value, out var parsedBranchId) ? parsedBranchId : (int?)null;
    var hasReceiving = Model.PurchaseOrderDetails.Any(x => x.ReceivedQty > 0);
    var hasOpenLines = Model.PurchaseOrderDetails.Any(x => x.Qty > x.ReceivedQty);
    var openReceivingBranches = Model.PurchaseOrderDetails
        .SelectMany(x => x.PurchaseOrderAllocations)
        .Where(x => x.AllocatedQty > x.ReceivedQty && (canAccessAllBranches || x.BranchId == currentBranchId))
        .GroupBy(x => x.BranchId)
        .Select(x => new
        {
            BranchId = x.Key,
            BranchName = x.First().Branch?.BranchName ?? "Branch",
            RemainingQty = x.Sum(a => a.AllocatedQty - a.ReceivedQty)
        })
        .OrderBy(x => x.BranchName)
        .ToList();
    if (!openReceivingBranches.Any() && hasOpenLines && Model.BranchId.HasValue && (canAccessAllBranches || Model.BranchId == currentBranchId))
    {
        openReceivingBranches.Add(new
        {
            BranchId = Model.BranchId.Value,
            BranchName = Model.Branch?.BranchName ?? "Branch",
            RemainingQty = Model.PurchaseOrderDetails.Sum(x => Math.Max(0m, x.Qty - x.ReceivedQty))
        });
    }
    var canEdit = User.IsInRole("Admin") && Model.Status == "Draft" && !hasReceiving;
    var editBlockedReason = canEdit
        ? string.Empty
        : !User.IsInRole("Admin")
            ? "Only Admin can edit purchase orders."
            : Model.Status == "Cancelled"
            ? "Cancelled purchase orders are read-only."
            : hasReceiving
                ? "Edit PO is blocked because receiving already exists."
                : $"Edit PO is available only for Draft purchase orders. Current status is {Model.Status}.";
    var canApprove = User.IsInRole("Admin") &&
        Model.Status == "Draft" &&
        Model.SupplierId > 0 &&
        Model.PurchaseOrderDetails.Any() &&
        Model.PurchaseOrderDetails.All(x => x.ItemId > 0 && x.Qty > 0 && x.UnitPrice >= 0 && x.DiscountAmount >= 0);
    var approveBlockedReason = canApprove
        ? string.Empty
        : !User.IsInRole("Admin")
            ? "Only Admin can approve purchase orders."
            : Model.Status != "Draft"
            ? $"Approve is available only for Draft purchase orders. Current status is {Model.Status}."
            : !Model.PurchaseOrderDetails.Any()
                ? "Approve is blocked because no PO lines exist."
                : "Approve is blocked because supplier or PO lines are incomplete.";
    var canReceive = (Model.Status == "Approved" || Model.Status == "PartiallyReceived") && openReceivingBranches.Any();
    var receiveBlockedReason = canReceive
        ? string.Empty
        : Model.Status == "Cancelled"
            ? "Receive Goods is blocked because the PO is cancelled."
            : Model.Status == "FullyReceived" || !hasOpenLines
                ? "Receive Goods is blocked because the PO is already fully received."
                : !openReceivingBranches.Any() && hasOpenLines
                    ? "Receive Goods is blocked because this PO has no open allocation for your branch."
                    : "Receive Goods is available only after PO approval.";
    var canCancel = User.IsInRole("Admin") && (Model.Status == "Draft" || Model.Status == "Approved") && !hasReceiving;
    var cancelBlockedReason = canCancel
        ? string.Empty
        : !User.IsInRole("Admin")
            ? "Only Admin can cancel purchase orders."
            : Model.Status == "Cancelled"
            ? "Cancelled purchase orders are read-only."
            : hasReceiving || Model.Status is "PartiallyReceived" or "FullyReceived"
                ? "Cancel PO is blocked because receiving already exists."
                : $"Cancel PO is available only for Draft or Approved purchase orders. Current status is {Model.Status}.";
}

@if (TempData["PurchaseOrderNotice"] is string notice && !string.IsNullOrWhiteSpace(notice))
{
    <div class="workflow-info mb-3">@notice</div>
}

<div class="page-header">
    <div>
        <div class="page-eyebrow">Purchasing Module</div>
        <h1 class="page-title">Purchase Order Details</h1>
        <p class="page-subtitle">Review PO header, supplier, and line quantities before receiving.</p>
    </div>
    <div class="page-actions">
        @if (canEdit)
        {
            <a asp-action="Edit" asp-route-id="@Model.PurchaseOrderId" class="btn btn-primary">Edit PO</a>
        }
        else
        {
            <button type="button" class="btn btn-outline-secondary" disabled title="@editBlockedReason">Edit PO</button>
        }
        @if (canApprove)
        {
            <form asp-action="Approve" asp-route-id="@Model.PurchaseOrderId" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-primary">Approve</button>
            </form>
        }
        else
        {
            <button type="button" class="btn btn-outline-secondary" disabled title="@approveBlockedReason">Approve</button>
        }
        @if (canCancel)
        {
            <form asp-action="Cancel" asp-route-id="@Model.PurchaseOrderId" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <input type="hidden" name="cancelReason" />
                <button type="submit" class="btn btn-outline-danger" onclick="const reason = prompt('Reason for cancelling this purchase order (optional):'); if (reason === null) return false; this.form.cancelReason.value = reason; return confirm('Cancel this purchase order?');">Cancel PO</button>
            </form>
        }
        else
        {
            <button type="button" class="btn btn-outline-secondary" disabled title="@cancelBlockedReason">Cancel PO</button>
        }
        @if (canReceive)
        {
            @foreach (var branch in openReceivingBranches)
            {
                <a asp-controller="Receivings" asp-action="Create" asp-route-purchaseOrderId="@Model.PurchaseOrderId" asp-route-branchId="@branch.BranchId" class="btn btn-success">
                    @(openReceivingBranches.Count == 1 ? "Receive Goods" : $"Receive {branch.BranchName}")
                </a>
            }
        }
        else
        {
            <button type="button" class="btn btn-outline-secondary" disabled title="@receiveBlockedReason">Receive Goods</button>
        }
        <a asp-action="Print" asp-route-id="@Model.PurchaseOrderId" class="btn btn-outline-secondary" target="_blank" rel="noopener">Print</a>
        <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
    </div>
</div>

@if (!canEdit || !canApprove || !canCancel || !canReceive)
{
    <div class="workflow-info mb-3">
        @if (!canEdit)
        {
            <div>@editBlockedReason</div>
        }
        @if (!canApprove)
        {
            <div>@approveBlockedReason</div>
        }
        @if (!canCancel)
        {
            <div>@cancelBlockedReason</div>
        }
        @if (!canReceive)
        {
            <div>@receiveBlockedReason</div>
        }
    </div>
}

<div class="card content-card">
    <div class="card-body">
        <div class="form-shell">
            <div class="form-section quotation-header-section">
                <div class="form-section-title">PO Header</div>
                <div class="row g-2 quotation-header-grid">
                    <div class="col-lg-3 col-md-6">
                        <div class="detail-label">PO No.</div>
                        <div class="form-control readonly-detail">@Model.PONo</div>
                    </div>
                    <div class="col-lg-3 col-md-6">
                        <div class="detail-label">PO Date</div>
                        <div class="form-control readonly-detail">@Model.PODate.ToString("dd MMM yyyy")</div>
                    </div>
                    <div class="col-lg-3 col-md-6">
                        <div class="detail-label">Expected Receive</div>
                        <div class="form-control readonly-detail">@(Model.ExpectedReceiveDate?.ToString("dd MMM yyyy") ?? "-")</div>
                    </div>
                    <div class="col-lg-3 col-md-6">
                        <div class="detail-label">Reference No.</div>
                        <div class="form-control readonly-detail">@(string.IsNullOrWhiteSpace(Model.ReferenceNo) ? "-" : Model.ReferenceNo)</div>
                    </div>
                    <div class="col-md-3">
                        <div class="detail-label">VAT Type</div>
                        <div class="form-control readonly-detail">@Model.VatType</div>
                    </div>
                    <div class="col-md-3">
                        <div class="detail-label">Branch</div>
                        <div class="form-control readonly-detail">@(Model.Branch?.BranchName ?? "-")</div>
                    </div>
                    <div class="col-md-3">
                        <div class="detail-label">Purchase Request</div>
                        <div class="form-control readonly-detail">
                            @if (Model.PurchaseRequestHeader is null)
                            {
                                <span>-</span>
                            }
                            else
                            {
                                <a asp-controller="PurchaseRequests" asp-action="Details" asp-route-id="@Model.PurchaseRequestHeader.PurchaseRequestId">@Model.PurchaseRequestHeader.PRNo</a>
                            }
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="detail-label">Received Lines</div>
                        <div class="form-control readonly-detail">@Model.PurchaseOrderDetails.Count(x => x.ReceivedQty > 0)</div>
                    </div>
                    <div class="col-md-3">
                        <div class="detail-label">Open Lines</div>
                        <div class="form-control readonly-detail">@Model.PurchaseOrderDetails.Count(x => x.Qty > x.ReceivedQty)</div>
                    </div>
                    <div class="col-md-3">
                        <div class="detail-label">Status</div>
                        <div class="form-control readonly-detail">@Model.Status</div>
                    </div>
                    <div class="col-12">
                        <div class="detail-label">Remark</div>
                        <div class="form-control readonly-detail readonly-detail-multiline">@(string.IsNullOrWhiteSpace(Model.Remark) ? "-" : Model.Remark)</div>
                    </div>
                </div>
            </div>

            <div class="quotation-party-grid">
                <div class="quotation-party-column">
                    <div class="quotation-info-card">
                        <div class="quotation-info-card-title">Supplier Information</div>
                        <div class="quotation-info-grid">
                            <div class="quotation-info-field">
                                <span class="quotation-info-label">Supplier Name</span>
                                <span class="quotation-info-value">@Model.Supplier?.SupplierName</span>
                            </div>
                            <div class="quotation-info-field">
                                <span class="quotation-info-label">Tax ID</span>
                                <span class="quotation-info-value">@(string.IsNullOrWhiteSpace(Model.Supplier?.TaxId) ? "-" : Model.Supplier!.TaxId)</span>
                            </div>
                        </div>
                        <div class="quotation-info-grid">
                            <div class="quotation-info-field">
                                <span class="quotation-info-label">Phone</span>
                                <span class="quotation-info-value">@(string.IsNullOrWhiteSpace(Model.Supplier?.PhoneNumber) ? "-" : Model.Supplier!.PhoneNumber)</span>
                            </div>
                            <div class="quotation-info-field">
                                <span class="quotation-info-label">Email</span>
                                <span class="quotation-info-value">@(string.IsNullOrWhiteSpace(Model.Supplier?.Email) ? "-" : Model.Supplier!.Email)</span>
                            </div>
                        </div>
                        <div class="quotation-info-field">
                            <span class="quotation-info-label">Address</span>
                            <span class="quotation-info-value">@(string.IsNullOrWhiteSpace(Model.Supplier?.Address) ? "-" : Model.Supplier!.Address)</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="form-section">
                <div class="d-flex justify-content-between align-items-center gap-2 mb-3 flex-wrap">
                    <div>
                        <div class="form-section-title mb-1">PO Lines</div>
                        <div class="table-meta">@Model.PurchaseOrderDetails.Count line(s). Received quantity is tracked on each purchase line.</div>
                    </div>
                </div>

                <div class="table-responsive">
                    <table class="table entity-table quote-editor-table align-middle">
                        <thead>
                            <tr>
                                <th style="width: 6%;">#</th>
                                <th>Item</th>
                                <th style="width: 10%;">Qty</th>
                                <th style="width: 10%;">Received</th>
                                <th style="width: 10%;">Remaining</th>
                                <th style="width: 12%;">Unit Price</th>
                                <th style="width: 10%;">Discount</th>
                                <th style="width: 12%;">Line Total</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var line in Model.PurchaseOrderDetails.OrderBy(x => x.LineNumber))
                        {
                            <tr>
                                <td>@line.LineNumber</td>
                                <td>
                                    <div class="fw-semibold">@line.Item?.ItemCode - @line.Item?.ItemName</div>
                                    <div class="table-meta">Part No.: @(string.IsNullOrWhiteSpace(line.Item?.PartNumber) ? "-" : line.Item!.PartNumber)</div>
                                </td>
                                <td>@line.Qty.ToString("N2")</td>
                                <td>@line.ReceivedQty.ToString("N2")</td>
                                <td>@((line.Qty - line.ReceivedQty).ToString("N2"))</td>
                                <td>@line.UnitPrice.ToString("N2")</td>
                                <td>@line.DiscountAmount.ToString("N2")</td>
                                <td>@line.LineTotal.ToString("N2")</td>
                            </tr>
                            @if (line.PurchaseOrderAllocations.Any())
                            {
                                <tr>
                                    <td></td>
                                    <td colspan="7">
                                        <div class="table-meta mb-1">Delivery Allocation</div>
                                        <div class="d-flex flex-wrap gap-2">
                                            @foreach (var allocation in line.PurchaseOrderAllocations.OrderBy(x => x.Branch?.BranchCode))
                                            {
                                                <span class="badge-soft">
                                                    @(allocation.Branch?.BranchName ?? "-"):
                                                    @allocation.AllocatedQty.ToString("N2")
                                                    received @allocation.ReceivedQty.ToString("N2")
                                                </span>
                                                @if (allocation.PurchaseOrderAllocationSources.Any())
                                                {
                                                    <span class="table-meta">
                                                        Source PR:
                                                        @string.Join(", ", allocation.PurchaseOrderAllocationSources
                                                            .OrderBy(x => x.PurchaseRequestDetail?.PurchaseRequestHeader?.PRNo)
                                                            .Select(x => $"{x.PurchaseRequestDetail?.PurchaseRequestHeader?.PRNo ?? "-"} {x.SourceQty:N2}"))
                                                    </span>
                                                }
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        </tbody>
                    </table>
                </div>

                <div class="quotation-summary-wrap">
                    <div class="quotation-summary-stack">
                        <div class="quotation-summary-row">
                            <span class="quotation-summary-name">Subtotal</span>
                            <span class="quotation-summary-amount">@Model.Subtotal.ToString("N2")</span>
                        </div>
                        <div class="quotation-summary-row">
                            <span class="quotation-summary-name">Discount</span>
                            <span class="quotation-summary-amount">@Model.DiscountAmount.ToString("N2")</span>
                        </div>
                        <div class="quotation-summary-row">
                            <span class="quotation-summary-name">VAT</span>
                            <span class="quotation-summary-amount">@Model.VatAmount.ToString("N2")</span>
                        </div>
                        <div class="quotation-summary-row total">
                            <span class="quotation-summary-name">Total</span>
                            <span class="quotation-summary-amount">@Model.TotalAmount.ToString("N2")</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="form-section document-history-section">
                <div class="form-section-title">Document History</div>
                <div class="document-history-list">
                    <div class="document-history-row">
                        <span class="document-history-label">Created</span>
                        <span class="document-history-value">@(Model.CreatedByUser?.DisplayName ?? "-")</span>
                        <span class="document-history-meta">@Model.CreatedDate.ToString("dd MMM yyyy HH:mm")</span>
                    </div>
                    <div class="document-history-row">
                        <span class="document-history-label">Updated</span>
                        <span class="document-history-value">@(Model.UpdatedByUser?.DisplayName ?? "-")</span>
                        <span class="document-history-meta">@(Model.UpdatedDate?.ToString("dd MMM yyyy HH:mm") ?? "-")</span>
                    </div>
                    <div class="document-history-row">
                        <span class="document-history-label">Approved</span>
                        <span class="document-history-value">@(Model.ApprovedByUser?.DisplayName ?? "-")</span>
                        <span class="document-history-meta">@(Model.ApprovedDate?.ToString("dd MMM yyyy HH:mm") ?? "-")</span>
                    </div>
                    <div class="document-history-row">
                        <span class="document-history-label">Cancelled</span>
                        <span class="document-history-value">@(Model.CancelledByUser?.DisplayName ?? "-")</span>
                        <span class="document-history-meta">@(Model.CancelledDate?.ToString("dd MMM yyyy HH:mm") ?? "-")</span>
                    </div>
                </div>
                @if (Model.Status == "Cancelled")
                {
                    <div class="document-history-reason">
                        <span class="document-history-label">Cancel Reason</span>
                        <span class="document-history-value">@(string.IsNullOrWhiteSpace(Model.CancelReason) ? "-" : Model.CancelReason)</span>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
