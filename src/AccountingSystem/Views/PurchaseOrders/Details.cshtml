@inject IUserPermissionService PermissionService
@model BizCore.Models.Entities.PurchaseOrderHeader

@{
    ViewData["Title"] = "รายละเอียดใบสั่งซื้อ";
    var canAccessAllBranches = !User.IsInRole("BranchAdmin") &&
        (User.IsInRole("Admin") || string.Equals(User.FindFirst("CanAccessAllBranches")?.Value, "true", StringComparison.OrdinalIgnoreCase));
    var currentBranchId = int.TryParse(User.FindFirst("BranchId")?.Value, out var parsedBranchId) ? parsedBranchId : (int?)null;

    var hasReceiving = Model.PurchaseOrderDetails.Any(x => x.ReceivedQty > 0);
    var hasOpenLines = Model.PurchaseOrderDetails.Any(x => x.Qty > x.ReceivedQty);

    var canEditPermission = PermissionService.HasPermission(User, "PO.Edit");
    var canSubmitPermission = PermissionService.HasPermission(User, "PO.Submit");
    var canApprovePermission = PermissionService.HasPermission(User, "PO.Approve");
    var canRejectPermission = PermissionService.HasPermission(User, "PO.Reject");
    var canCancelPermission = PermissionService.HasPermission(User, "PO.Cancel");
    var canReceivePermission = PermissionService.HasPermission(User, "Receiving.Create") || PermissionService.HasPermission(User, "PO.Receive");
    var canSupplierPaymentPermission = PermissionService.HasPermission(User, "SupplierPayment.Create");

    var openReceivingBranches = Model.PurchaseOrderDetails
        .SelectMany(x => x.PurchaseOrderAllocations)
        .Where(x => x.AllocatedQty > x.ReceivedQty && (canAccessAllBranches || x.BranchId == currentBranchId))
        .GroupBy(x => x.BranchId)
        .Select(x => new
        {
            BranchId = x.Key,
            BranchName = x.First().Branch?.BranchName ?? "สาขา",
            RemainingQty = x.Sum(a => a.AllocatedQty - a.ReceivedQty)
        })
        .OrderBy(x => x.BranchName)
        .ToList();

    if (!openReceivingBranches.Any() && hasOpenLines && Model.BranchId.HasValue && (canAccessAllBranches || Model.BranchId == currentBranchId))
    {
        openReceivingBranches.Add(new
        {
            BranchId = Model.BranchId.Value,
            BranchName = Model.Branch?.BranchName ?? "สาขา",
            RemainingQty = Model.PurchaseOrderDetails.Sum(x => Math.Max(0m, x.Qty - x.ReceivedQty))
        });
    }

    var canEdit = canEditPermission && (Model.Status is "Draft" or "Rejected") && !hasReceiving;
    var editBlockedReason = canEdit
        ? string.Empty
        : !canEditPermission
            ? "คุณไม่มีสิทธิ์แก้ไขใบสั่งซื้อ"
            : Model.Status == "Cancelled"
                ? "ใบสั่งซื้อที่ยกเลิกแล้วไม่สามารถแก้ไขต่อได้"
                : hasReceiving
                    ? "ยังแก้ไขใบสั่งซื้อไม่ได้ เพราะมีการรับสินค้าแล้ว"
                    : $"แก้ไขได้เฉพาะใบสั่งซื้อสถานะ Draft หรือ Rejected เท่านั้น สถานะปัจจุบันคือ {Model.Status}";

    var canSubmit = canSubmitPermission &&
        (Model.Status is "Draft" or "Rejected") &&
        Model.SupplierId > 0 &&
        Model.PurchaseOrderDetails.Any() &&
        Model.PurchaseOrderDetails.All(x => x.ItemId > 0 && x.Qty > 0 && x.UnitPrice >= 0);
    var submitBlockedReason = canSubmit
        ? string.Empty
        : !canSubmitPermission
            ? "คุณไม่มีสิทธิ์ส่งอนุมัติใบสั่งซื้อ"
            : Model.Status is not ("Draft" or "Rejected")
                ? $"ส่งอนุมัติได้เฉพาะใบสั่งซื้อสถานะ Draft หรือ Rejected เท่านั้น สถานะปัจจุบันคือ {Model.Status}"
                : !Model.PurchaseOrderDetails.Any()
                    ? "ยังส่งอนุมัติไม่ได้ เพราะยังไม่มีรายการสินค้า"
                    : "ยังส่งอนุมัติไม่ได้ เพราะข้อมูลผู้จำหน่ายหรือรายการสินค้าไม่ครบถ้วน";

    var canApprove = canApprovePermission && Model.Status == "Submitted";
    var approveBlockedReason = canApprove
        ? string.Empty
        : !canApprovePermission
            ? "คุณไม่มีสิทธิ์อนุมัติใบสั่งซื้อ"
            : $"อนุมัติได้เฉพาะใบสั่งซื้อสถานะ Submitted เท่านั้น สถานะปัจจุบันคือ {Model.Status}";

    var canReject = canRejectPermission && Model.Status == "Submitted";
    var rejectBlockedReason = canReject
        ? string.Empty
        : !canRejectPermission
            ? "คุณไม่มีสิทธิ์ตีกลับใบสั่งซื้อ"
            : $"ตีกลับได้เฉพาะใบสั่งซื้อสถานะ Submitted เท่านั้น สถานะปัจจุบันคือ {Model.Status}";

    var canReceive = canReceivePermission && (Model.Status == "Approved" || Model.Status == "PartiallyReceived") && openReceivingBranches.Any();
    var receiveBlockedReason = canReceive
        ? string.Empty
        : !canReceivePermission
            ? "คุณไม่มีสิทธิ์รับสินค้า"
            : Model.Status == "Cancelled"
                ? "ยังรับสินค้าไม่ได้ เพราะใบสั่งซื้อนี้ถูกยกเลิกแล้ว"
                : Model.Status == "FullyReceived" || !hasOpenLines
                    ? "ยังรับสินค้าไม่ได้ เพราะรับสินค้าครบแล้ว"
                    : !openReceivingBranches.Any() && hasOpenLines
                        ? "ยังรับสินค้าไม่ได้ เพราะไม่มี allocation คงเหลือสำหรับสาขาที่คุณใช้งานอยู่"
                        : "รับสินค้าได้หลังจากใบสั่งซื้อได้รับการอนุมัติแล้วเท่านั้น";

    var canCancel = canCancelPermission && (Model.Status == "Draft" || Model.Status == "Submitted" || Model.Status == "Approved" || Model.Status == "Rejected") && !hasReceiving;
    var cancelBlockedReason = canCancel
        ? string.Empty
        : !canCancelPermission
            ? "คุณไม่มีสิทธิ์ยกเลิกใบสั่งซื้อ"
            : Model.Status == "Cancelled"
                ? "ใบสั่งซื้อที่ยกเลิกแล้วไม่สามารถแก้ไขต่อได้"
                : hasReceiving || Model.Status is "PartiallyReceived" or "FullyReceived"
                    ? "ยังยกเลิกใบสั่งซื้อไม่ได้ เพราะมีการรับสินค้าแล้ว"
                    : $"ยกเลิกได้เฉพาะใบสั่งซื้อสถานะ Draft, Submitted, Approved หรือ Rejected เท่านั้น สถานะปัจจุบันคือ {Model.Status}";

    var postedSupplierPayments = Model.SupplierPayments
        .Where(x => x.Status == "Posted")
        .OrderByDescending(x => x.PaymentDate)
        .ThenByDescending(x => x.SupplierPaymentId)
        .ToList();
    var poPaidAmount = postedSupplierPayments.Sum(x => x.Amount);
    var poBalanceAmount = Math.Max(Model.TotalAmount - poPaidAmount, 0m);
    var paymentStatus = poPaidAmount <= 0m ? "Unpaid" : poBalanceAmount <= 0m ? "Paid" : "Partially Paid";
    var poSummary = BizCore.Utilities.VatModeHelper.ComputeSummaryBreakdown(Model.Subtotal, Model.DiscountAmount, Model.VatType);

    var canRecordPayment = canSupplierPaymentPermission &&
        Model.Status is "Approved" or "PartiallyReceived" or "FullyReceived" &&
        poBalanceAmount > 0m;
    var supplierPaymentBlockedReason = canRecordPayment
        ? string.Empty
        : !canSupplierPaymentPermission
            ? "คุณไม่มีสิทธิ์บันทึกการชำระเงินให้ผู้จำหน่าย"
            : Model.Status is not ("Approved" or "PartiallyReceived" or "FullyReceived")
                ? $"บันทึกการชำระเงินได้เฉพาะใบสั่งซื้อที่อนุมัติแล้วหรือมีการรับสินค้าแล้วเท่านั้น สถานะปัจจุบันคือ {Model.Status}"
                : "ใบสั่งซื้อนี้ชำระครบแล้ว";
}

@if (TempData["PurchaseOrderNotice"] is string notice && !string.IsNullOrWhiteSpace(notice))
{
    @await Html.PartialAsync("_Notice", notice)
}

<div class="page-header">
    <div>
        <div class="page-eyebrow">งานจัดซื้อ</div>
        <h1 class="page-title">รายละเอียดใบสั่งซื้อ</h1>
        <p class="page-subtitle">ใช้หน้านี้เป็นจุดหลักสำหรับตรวจสอบ แก้ไข ส่งอนุมัติ อนุมัติ ตีกลับ รับสินค้า บันทึกการชำระเงิน และพิมพ์เอกสาร</p>
    </div>
    <div class="page-actions justify-content-end">
        @if (canEdit)
        {
            <a asp-action="Edit" asp-route-id="@Model.PurchaseOrderId" class="btn btn-outline-primary">แก้ไขฉบับร่าง</a>
        }
        else
        {
            <button type="button" class="btn btn-outline-secondary" disabled title="@editBlockedReason">แก้ไขฉบับร่าง</button>
        }

        @if (canSubmit)
        {
            <form asp-action="Submit" asp-route-id="@Model.PurchaseOrderId" method="post" class="d-inline confirm-popover-form">
                @Html.AntiForgeryToken()
                <div class="confirm-popover-shell">
                    <button type="button" class="btn btn-primary js-confirm-popover-toggle" data-confirm-target="submitPoDetailsConfirm_@Model.PurchaseOrderId" aria-expanded="false">ส่งอนุมัติ</button>
                    <div class="confirm-popover" id="submitPoDetailsConfirm_@Model.PurchaseOrderId" hidden>
                        <div class="confirm-popover-title">ส่งใบสั่งซื้อนี้เข้าอนุมัติใช่หรือไม่?</div>
                        <div class="confirm-popover-text">เมื่อยืนยันแล้ว เอกสารจะเข้าสู่ขั้นตอนอนุมัติ และควรกลับมาแก้ไขเฉพาะกรณีที่ถูกตีกลับ</div>
                        <div class="confirm-popover-actions">
                            <button type="submit" class="btn btn-sm btn-outline-primary">ยืนยัน</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary js-confirm-popover-cancel">ยกเลิก</button>
                        </div>
                    </div>
                </div>
            </form>
        }
        else
        {
            <button type="button" class="btn btn-outline-secondary" disabled title="@submitBlockedReason">ส่งอนุมัติ</button>
        }

        @if (canApprove)
        {
            <form asp-action="Approve" asp-route-id="@Model.PurchaseOrderId" method="post" class="d-inline confirm-popover-form">
                @Html.AntiForgeryToken()
                <div class="confirm-popover-shell">
                    <button type="button" class="btn btn-primary js-confirm-popover-toggle" data-confirm-target="approvePoDetailsConfirm_@Model.PurchaseOrderId" aria-expanded="false">อนุมัติ</button>
                    <div class="confirm-popover" id="approvePoDetailsConfirm_@Model.PurchaseOrderId" hidden>
                        <div class="confirm-popover-title">อนุมัติใบสั่งซื้อนี้ใช่หรือไม่?</div>
                        <div class="confirm-popover-text">เมื่ออนุมัติแล้ว จะสามารถนำใบสั่งซื้อนี้ไปใช้ในขั้นตอนรับสินค้าได้</div>
                        <div class="confirm-popover-actions">
                            <button type="submit" class="btn btn-sm btn-outline-primary">ยืนยัน</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary js-confirm-popover-cancel">ยกเลิก</button>
                        </div>
                    </div>
                </div>
            </form>
        }
        else
        {
            <button type="button" class="btn btn-outline-secondary" disabled title="@approveBlockedReason">อนุมัติ</button>
        }

        @if (canReject)
        {
            <form asp-action="Reject" asp-route-id="@Model.PurchaseOrderId" method="post" class="d-inline confirm-popover-form">
                @Html.AntiForgeryToken()
                <div class="confirm-popover-shell">
                    <button type="button" class="btn btn-outline-danger js-confirm-popover-toggle" data-confirm-target="rejectPoDetailsConfirm_@Model.PurchaseOrderId" aria-expanded="false">ตีกลับ</button>
                    <div class="confirm-popover" id="rejectPoDetailsConfirm_@Model.PurchaseOrderId" hidden>
                        <div class="confirm-popover-title">ตีกลับใบสั่งซื้อนี้ใช่หรือไม่?</div>
                        <div class="confirm-popover-text">กรุณาระบุเหตุผล เพื่อให้ผู้จัดทำกลับไปแก้ไขได้ถูกต้อง</div>
                        <div class="confirm-popover-field">
                            <label class="confirm-popover-label" for="rejectPoDetailsReason_@Model.PurchaseOrderId">เหตุผลที่ตีกลับ</label>
                            <textarea id="rejectPoDetailsReason_@Model.PurchaseOrderId" name="rejectReason" class="form-control" rows="3" placeholder="ระบุเหตุผลที่ตีกลับ" required></textarea>
                        </div>
                        <div class="confirm-popover-actions">
                            <button type="submit" class="btn btn-sm btn-outline-danger">ยืนยัน</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary js-confirm-popover-cancel">ยกเลิก</button>
                        </div>
                    </div>
                </div>
            </form>
        }
        else
        {
            <button type="button" class="btn btn-outline-secondary" disabled title="@rejectBlockedReason">ตีกลับ</button>
        }

        @if (canReceive)
        {
            @foreach (var branch in openReceivingBranches)
            {
                <a asp-controller="Receivings" asp-action="Create" asp-route-purchaseOrderId="@Model.PurchaseOrderId" asp-route-branchId="@branch.BranchId" class="btn btn-success">
                    @(openReceivingBranches.Count == 1 ? "รับสินค้า" : $"รับสินค้า {branch.BranchName}")
                </a>
            }
        }
        else
        {
            <button type="button" class="btn btn-outline-secondary" disabled title="@receiveBlockedReason">รับสินค้า</button>
        }

        @if (canRecordPayment)
        {
            <a asp-controller="SupplierPayments" asp-action="Create" asp-route-purchaseOrderId="@Model.PurchaseOrderId" class="btn btn-outline-primary">บันทึกการชำระเงิน</a>
        }
        else
        {
            <button type="button" class="btn btn-outline-secondary" disabled title="@supplierPaymentBlockedReason">บันทึกการชำระเงิน</button>
        }

        <a asp-action="Print" asp-route-id="@Model.PurchaseOrderId" class="btn btn-outline-secondary" target="_blank">พิมพ์</a>

        @if (canCancel)
        {
            <form asp-action="Cancel" asp-route-id="@Model.PurchaseOrderId" method="post" class="d-inline confirm-popover-form">
                @Html.AntiForgeryToken()
                <div class="confirm-popover-shell">
                    <button type="button" class="btn btn-outline-danger js-confirm-popover-toggle" data-confirm-target="cancelPoDetailsConfirm_@Model.PurchaseOrderId" aria-expanded="false">ยกเลิกใบสั่งซื้อ</button>
                    <div class="confirm-popover" id="cancelPoDetailsConfirm_@Model.PurchaseOrderId" hidden>
                        <div class="confirm-popover-title">ยกเลิกใบสั่งซื้อนี้ใช่หรือไม่?</div>
                        <div class="confirm-popover-text">การยกเลิกจะปิดเอกสารนี้ และต้องระบุเหตุผลไว้เพื่อใช้อ้างอิงย้อนหลัง</div>
                        <div class="confirm-popover-field">
                            <label class="confirm-popover-label" for="cancelPoDetailsReason_@Model.PurchaseOrderId">เหตุผลที่ยกเลิก</label>
                            <textarea id="cancelPoDetailsReason_@Model.PurchaseOrderId" name="cancelReason" class="form-control" rows="3" placeholder="ระบุเหตุผลที่ยกเลิก" required></textarea>
                        </div>
                        <div class="confirm-popover-actions">
                            <button type="submit" class="btn btn-sm btn-outline-danger">ยืนยัน</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary js-confirm-popover-cancel">ยกเลิก</button>
                        </div>
                    </div>
                </div>
            </form>
        }
        else
        {
            <button type="button" class="btn btn-outline-secondary" disabled title="@cancelBlockedReason">ยกเลิกใบสั่งซื้อ</button>
        }

        <a asp-action="Index" class="btn btn-outline-secondary">กลับไปรายการใบสั่งซื้อ</a>
    </div>
</div>

<div class="card content-card">
    <div class="card-body">
        <div class="form-shell">
            <div class="form-section quotation-header-section">
                <div class="form-section-title">ข้อมูลหัวเอกสาร</div>
                <div class="row g-2 quotation-header-grid">
                    <div class="col-lg-3 col-md-6">
                        <div class="detail-label">เลขที่ใบสั่งซื้อ</div>
                        <div class="form-control readonly-detail">@Model.PONo</div>
                    </div>
                    <div class="col-lg-3 col-md-6">
                        <div class="detail-label">วันที่ใบสั่งซื้อ</div>
                        <div class="form-control readonly-detail">@Model.PODate.ToString("dd/MM/yyyy")</div>
                    </div>
                    <div class="col-lg-3 col-md-6">
                        <div class="detail-label">กำหนดรับสินค้า</div>
                        <div class="form-control readonly-detail">@(Model.ExpectedReceiveDate?.ToString("dd/MM/yyyy") ?? "-")</div>
                    </div>
                    <div class="col-lg-3 col-md-6">
                        <div class="detail-label">เลขที่อ้างอิง</div>
                        <div class="form-control readonly-detail">@(string.IsNullOrWhiteSpace(Model.ReferenceNo) ? "-" : Model.ReferenceNo)</div>
                    </div>
                    <div class="col-md-3">
                        <div class="detail-label">ประเภทภาษี</div>
                        <div class="form-control readonly-detail">@BizCore.Utilities.VatModeHelper.GetDisplayLabel(Model.VatType)</div>
                    </div>
                    <div class="col-md-3">
                        <div class="detail-label">สาขา</div>
                        <div class="form-control readonly-detail">@(Model.Branch?.BranchName ?? "-")</div>
                    </div>
                    <div class="col-md-3">
                        <div class="detail-label">ใบขอซื้อที่เชื่อมโยง</div>
                        <div class="form-control readonly-detail">
                            @if (Model.PurchaseRequestHeader is null)
                            {
                                <span>-</span>
                            }
                            else
                            {
                                <a asp-controller="PurchaseRequests" asp-action="Details" asp-route-id="@Model.PurchaseRequestHeader.PurchaseRequestId">@Model.PurchaseRequestHeader.PRNo</a>
                            }
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="detail-label">สถานะ</div>
                        <div class="readonly-detail-status">@await Html.PartialAsync("_StatusPill", Model.Status)</div>
                    </div>
                    <div class="col-md-3">
                        <div class="detail-label">รายการที่รับแล้ว</div>
                        <div class="form-control readonly-detail">@Model.PurchaseOrderDetails.Count(x => x.ReceivedQty > 0)</div>
                    </div>
                    <div class="col-md-3">
                        <div class="detail-label">รายการคงเหลือ</div>
                        <div class="form-control readonly-detail">@Model.PurchaseOrderDetails.Count(x => x.Qty > x.ReceivedQty)</div>
                    </div>
                    <div class="col-12">
                        <div class="detail-label">หมายเหตุ</div>
                        <div class="form-control readonly-detail readonly-detail-multiline">@(string.IsNullOrWhiteSpace(Model.Remark) ? "-" : Model.Remark)</div>
                    </div>
                </div>
            </div>

            <div class="quotation-party-grid">
                <div class="quotation-party-column">
                    <div class="quotation-info-card">
                        <div class="quotation-info-card-title">ข้อมูลผู้จำหน่าย</div>
                        <div class="quotation-info-grid">
                            <div class="quotation-info-field">
                                <span class="quotation-info-label">ชื่อผู้จำหน่าย</span>
                                <span class="quotation-info-value">@(Model.Supplier?.SupplierName ?? "-")</span>
                            </div>
                            <div class="quotation-info-field">
                                <span class="quotation-info-label">เลขผู้เสียภาษี</span>
                                <span class="quotation-info-value">@(string.IsNullOrWhiteSpace(Model.Supplier?.TaxId) ? "-" : Model.Supplier!.TaxId)</span>
                            </div>
                        </div>
                        <div class="quotation-info-grid">
                            <div class="quotation-info-field">
                                <span class="quotation-info-label">โทรศัพท์</span>
                                <span class="quotation-info-value">@(string.IsNullOrWhiteSpace(Model.Supplier?.PhoneNumber) ? "-" : Model.Supplier!.PhoneNumber)</span>
                            </div>
                            <div class="quotation-info-field">
                                <span class="quotation-info-label">อีเมล</span>
                                <span class="quotation-info-value">@(string.IsNullOrWhiteSpace(Model.Supplier?.Email) ? "-" : Model.Supplier!.Email)</span>
                            </div>
                        </div>
                        <div class="quotation-info-field">
                            <span class="quotation-info-label">ที่อยู่</span>
                            <span class="quotation-info-value">@(string.IsNullOrWhiteSpace(Model.Supplier?.Address) ? "-" : Model.Supplier!.Address)</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="quote-summary-grid mb-3">
                <div class="quote-summary-card">
                    <span class="quote-summary-label">ยอดใบสั่งซื้อ</span>
                    <p class="quote-summary-value">@Model.TotalAmount.ToString("N2")</p>
                </div>
                <div class="quote-summary-card">
                    <span class="quote-summary-label">ชำระแล้ว</span>
                    <p class="quote-summary-value">@poPaidAmount.ToString("N2")</p>
                </div>
                <div class="quote-summary-card">
                    <span class="quote-summary-label">ค้างชำระ</span>
                    <p class="quote-summary-value">@poBalanceAmount.ToString("N2")</p>
                </div>
                <div class="quote-summary-card">
                    <span class="quote-summary-label">สถานะการชำระ</span>
                    <p class="quote-summary-value">@await Html.PartialAsync("_StatusPill", paymentStatus)</p>
                </div>
            </div>

            <div class="form-section">
                <div class="d-flex justify-content-between align-items-center gap-2 mb-3 flex-wrap">
                    <div>
                        <div class="form-section-title mb-1">รายการสินค้า</div>
                        <div class="table-meta">@Model.PurchaseOrderDetails.Count รายการ และติดตามจำนวนที่รับสินค้าแล้วในแต่ละรายการ</div>
                    </div>
                </div>

                <div class="table-responsive">
                    <table class="table entity-table quote-editor-table align-middle">
                        <thead>
                            <tr>
                                <th style="width: 6%;">#</th>
                                <th>สินค้า</th>
                                <th style="width: 10%;">จำนวน</th>
                                <th style="width: 10%;">รับแล้ว</th>
                                <th style="width: 10%;">คงเหลือ</th>
                                <th style="width: 12%;">ราคาต่อหน่วย</th>
                                <th style="width: 12%;">รวมเงิน</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var line in Model.PurchaseOrderDetails.OrderBy(x => x.LineNumber))
                        {
                            <tr>
                                <td>@line.LineNumber</td>
                                <td>
                                    <div class="fw-semibold">@line.Item?.ItemCode - @line.Item?.ItemName</div>
                                    <div class="table-meta">Part No.: @(string.IsNullOrWhiteSpace(line.Item?.PartNumber) ? "-" : line.Item!.PartNumber)</div>
                                </td>
                                <td>@line.Qty.ToString("N2")</td>
                                <td>@line.ReceivedQty.ToString("N2")</td>
                                <td>@((line.Qty - line.ReceivedQty).ToString("N2"))</td>
                                <td>@line.UnitPrice.ToString("N2")</td>
                                <td>@line.LineTotal.ToString("N2")</td>
                            </tr>
                            @if (line.PurchaseOrderAllocations.Any())
                            {
                                <tr>
                                    <td></td>
                                    <td colspan="6">
                                        <div class="table-meta mb-1">การกระจายรับสินค้าตามสาขา</div>
                                        <div class="d-flex flex-wrap gap-2">
                                            @foreach (var allocation in line.PurchaseOrderAllocations.OrderBy(x => x.Branch?.BranchCode))
                                            {
                                                <span class="badge-soft">
                                                    @(allocation.Branch?.BranchName ?? "-"):
                                                    @allocation.AllocatedQty.ToString("N2")
                                                    รับแล้ว @allocation.ReceivedQty.ToString("N2")
                                                </span>
                                                @if (allocation.PurchaseOrderAllocationSources.Any())
                                                {
                                                    <span class="table-meta">
                                                        Source PR:
                                                        @string.Join(", ", allocation.PurchaseOrderAllocationSources
                                                            .OrderBy(x => x.PurchaseRequestDetail?.PurchaseRequestHeader?.PRNo)
                                                            .Select(x => $"{x.PurchaseRequestDetail?.PurchaseRequestHeader?.PRNo ?? "-"} {x.SourceQty:N2}"))
                                                    </span>
                                                }
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        </tbody>
                    </table>
                </div>

                <div class="quotation-summary-wrap">
                    <div class="quotation-summary-stack">
                        <div class="quotation-summary-row">
                            <span class="quotation-summary-name">ยอดก่อนภาษี</span>
                            <span class="quotation-summary-amount">@poSummary.SubtotalBeforeVat.ToString("N2")</span>
                        </div>
                        <div class="quotation-summary-row">
                            <span class="quotation-summary-name">ส่วนลด</span>
                            <span class="quotation-summary-amount">@poSummary.DiscountBeforeVat.ToString("N2")</span>
                        </div>
                        <div class="quotation-summary-row">
                            <span class="quotation-summary-name">VAT</span>
                            <span class="quotation-summary-amount">@Model.VatAmount.ToString("N2")</span>
                        </div>
                        <div class="quotation-summary-row total">
                            <span class="quotation-summary-name">ยอดรวมทั้งสิ้น</span>
                            <span class="quotation-summary-amount">@Model.TotalAmount.ToString("N2")</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="form-section document-history-section">
                <div class="form-section-title">ประวัติเอกสาร</div>
                <div class="document-history-list">
                    <div class="document-history-row">
                        <span class="document-history-label">สร้างโดย</span>
                        <span class="document-history-value">@(Model.CreatedByUser?.DisplayName ?? "-")</span>
                        <span class="document-history-meta">@Model.CreatedDate.ToString("dd/MM/yyyy HH:mm")</span>
                    </div>
                    <div class="document-history-row">
                        <span class="document-history-label">แก้ไขล่าสุด</span>
                        <span class="document-history-value">@(Model.UpdatedByUser?.DisplayName ?? "-")</span>
                        <span class="document-history-meta">@(Model.UpdatedDate?.ToString("dd/MM/yyyy HH:mm") ?? "-")</span>
                    </div>
                    <div class="document-history-row">
                        <span class="document-history-label">อนุมัติโดย</span>
                        <span class="document-history-value">@(Model.ApprovedByUser?.DisplayName ?? "-")</span>
                        <span class="document-history-meta">@(Model.ApprovedDate?.ToString("dd/MM/yyyy HH:mm") ?? "-")</span>
                    </div>
                    <div class="document-history-row">
                        <span class="document-history-label">ตีกลับโดย</span>
                        <span class="document-history-value">@(Model.RejectedByUser?.DisplayName ?? "-")</span>
                        <span class="document-history-meta">@(Model.RejectedDate?.ToString("dd/MM/yyyy HH:mm") ?? "-")</span>
                    </div>
                    <div class="document-history-row">
                        <span class="document-history-label">ยกเลิกโดย</span>
                        <span class="document-history-value">@(Model.CancelledByUser?.DisplayName ?? "-")</span>
                        <span class="document-history-meta">@(Model.CancelledDate?.ToString("dd/MM/yyyy HH:mm") ?? "-")</span>
                    </div>
                </div>
                @if (Model.Status == "Cancelled")
                {
                    <div class="document-history-reason">
                        <span class="document-history-label">เหตุผลที่ยกเลิก</span>
                        <span class="document-history-value">@(string.IsNullOrWhiteSpace(Model.CancelReason) ? "-" : Model.CancelReason)</span>
                    </div>
                }
                @if (Model.Status == "Rejected")
                {
                    <div class="document-history-reason">
                        <span class="document-history-label">เหตุผลที่ตีกลับ</span>
                        <span class="document-history-value">@(string.IsNullOrWhiteSpace(Model.RejectReason) ? "-" : Model.RejectReason)</span>
                    </div>
                }
            </div>

            <div class="form-section">
                <div class="d-flex justify-content-between align-items-center gap-2 mb-3 flex-wrap">
                    <div>
                        <div class="form-section-title mb-1">การชำระเงินให้ผู้จำหน่าย</div>
                        <div class="table-meta">ติดตามการชำระเงินที่ผูกกับใบสั่งซื้อนี้</div>
                    </div>
                    <div class="table-meta">@postedSupplierPayments.Count รายการที่โพสต์แล้ว</div>
                </div>

                <div class="table-responsive">
                    <table class="table entity-table align-middle">
                        <thead>
                            <tr>
                                <th>เลขที่เอกสาร</th>
                                <th>วันที่</th>
                                <th>วิธีชำระ</th>
                                <th>เลขอ้างอิง</th>
                                <th class="text-end">จำนวนเงิน</th>
                                <th>สถานะ</th>
                                <th class="text-end">การทำงาน</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var payment in Model.SupplierPayments.OrderByDescending(x => x.PaymentDate).ThenByDescending(x => x.SupplierPaymentId))
                        {
                            <tr>
                                <td><span class="code-chip">@payment.PaymentNo</span></td>
                                <td>@payment.PaymentDate.ToString("dd/MM/yyyy")</td>
                                <td>@payment.PaymentMethod</td>
                                <td>@(string.IsNullOrWhiteSpace(payment.ReferenceNo) ? "-" : payment.ReferenceNo)</td>
                                <td class="text-end">@payment.Amount.ToString("N2")</td>
                                <td>@await Html.PartialAsync("_StatusPill", payment.Status)</td>
                                <td class="text-end">
                                    <a asp-controller="SupplierPayments" asp-action="Details" asp-route-id="@payment.SupplierPaymentId" class="btn btn-sm btn-outline-secondary">รายละเอียด</a>
                                </td>
                            </tr>
                        }
                        @if (!Model.SupplierPayments.Any())
                        {
                            <tr><td colspan="7" class="table-empty">ยังไม่มีรายการชำระเงินให้ผู้จำหน่าย</td></tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
