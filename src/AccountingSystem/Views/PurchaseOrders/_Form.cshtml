@model BizCore.Models.ViewModels.PurchaseOrderFormViewModel
@{
    var selectedSupplier = Model.SupplierLookup.FirstOrDefault(x => x.SupplierId == Model.SupplierId);
    var branchOptions = Model.BranchOptions.ToList();
}

<div asp-validation-summary="All" class="form-alert"></div>
<input asp-for="Status" type="hidden" />
<input asp-for="PurchaseRequestId" type="hidden" />
@for (var sourceIndex = 0; sourceIndex < Model.PurchaseRequestIds.Count; sourceIndex++)
{
    <input type="hidden" name="PurchaseRequestIds[@sourceIndex]" value="@Model.PurchaseRequestIds[sourceIndex]" />
}

<div class="form-shell">
    <div class="form-section">
        <div class="form-section-title">PO Header</div>
        <div class="row g-3">
            @if (!string.IsNullOrWhiteSpace(Model.PurchaseRequestNo))
            {
                <div class="col-12">
                    <div class="workflow-info">
                        Creating PO from Purchase Request source(s) <strong>@Model.PurchaseRequestNo</strong>. Delivery allocation and source PR quantities were copied from the selected PR lines.
                    </div>
                </div>
            }
            <div class="col-md-3">
                <label asp-for="PONo" class="form-label"></label>
                <input asp-for="PONo" class="form-control" readonly />
                <div class="form-text">Auto-generated monthly PO number.</div>
            </div>
            <div class="col-md-3">
                <label asp-for="PODate" class="form-label"></label>
                <input asp-for="PODate" class="form-control" />
                <span asp-validation-for="PODate" class="text-danger"></span>
            </div>
            <div class="col-md-3">
                <label asp-for="ExpectedReceiveDate" class="form-label"></label>
                <input asp-for="ExpectedReceiveDate" class="form-control" />
                <span asp-validation-for="ExpectedReceiveDate" class="text-danger"></span>
            </div>
            <div class="col-md-3">
                <label asp-for="ReferenceNo" class="form-label"></label>
                <input asp-for="ReferenceNo" class="form-control" />
                <span asp-validation-for="ReferenceNo" class="text-danger"></span>
            </div>
            <div class="col-md-3">
                <label asp-for="VatType" class="form-label"></label>
                <select asp-for="VatType" asp-items="Model.VatTypeOptions" class="form-select" id="poVatType"></select>
                <span asp-validation-for="VatType" class="text-danger"></span>
            </div>
            <div class="col-md-3">
                <label asp-for="BranchId" class="form-label"></label>
                @if (Model.CanAccessAllBranches)
                {
                    <select asp-for="BranchId" asp-items="Model.BranchOptions" class="form-select">
                        <option value="">Select branch</option>
                    </select>
                }
                else
                {
                    <input type="hidden" asp-for="BranchId" />
                    <div class="form-control readonly-detail">@Model.BranchName</div>
                }
                <span asp-validation-for="BranchId" class="text-danger"></span>
                <span asp-validation-for="PurchaseRequestId" class="text-danger"></span>
            </div>
            <div class="col-12">
                <label asp-for="Remark" class="form-label"></label>
                <textarea asp-for="Remark" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Remark" class="text-danger"></span>
            </div>
        </div>
    </div>

    <div class="quotation-party-grid">
        <div class="quotation-party-column">
            <div class="quotation-info-card">
                <div class="quotation-info-card-title">Supplier Information</div>
                <label asp-for="SupplierId" class="form-label"></label>
                <input asp-for="SupplierId" type="hidden" id="SupplierId" />
                <div class="search-dropdown">
                    <input type="text"
                           id="poSupplierSearch"
                           class="form-control"
                           value="@(selectedSupplier is null ? string.Empty : $"{selectedSupplier.SupplierCode} - {selectedSupplier.SupplierName}")"
                           placeholder="Search supplier code, name, or tax ID"
                           autocomplete="off" />
                    <div id="poSupplierResults" class="search-dropdown-menu" style="display:none;"></div>
                </div>
                <span asp-validation-for="SupplierId" class="text-danger"></span>

                <div class="quotation-info-grid mt-3">
                    <div class="quotation-info-field">
                        <span class="quotation-info-label">Supplier Name</span>
                        <span class="quotation-info-value" id="poSupplierName">@(selectedSupplier?.SupplierName ?? "-")</span>
                    </div>
                    <div class="quotation-info-field">
                        <span class="quotation-info-label">Tax ID</span>
                        <span class="quotation-info-value" id="poSupplierTaxId">@(string.IsNullOrWhiteSpace(selectedSupplier?.TaxId) ? "-" : selectedSupplier.TaxId)</span>
                    </div>
                </div>
                <div class="quotation-info-grid">
                    <div class="quotation-info-field">
                        <span class="quotation-info-label">Phone</span>
                        <span class="quotation-info-value" id="poSupplierPhone">@(string.IsNullOrWhiteSpace(selectedSupplier?.Phone) ? "-" : selectedSupplier.Phone)</span>
                    </div>
                    <div class="quotation-info-field">
                        <span class="quotation-info-label">Email</span>
                        <span class="quotation-info-value" id="poSupplierEmail">@(string.IsNullOrWhiteSpace(selectedSupplier?.Email) ? "-" : selectedSupplier.Email)</span>
                    </div>
                </div>
                <div class="quotation-info-field">
                    <span class="quotation-info-label">Address</span>
                    <span class="quotation-info-value" id="poSupplierAddress">@(string.IsNullOrWhiteSpace(selectedSupplier?.Address) ? "-" : selectedSupplier.Address)</span>
                </div>
            </div>
        </div>

        <div class="quotation-party-column">
            <div class="quotation-info-card">
                <div class="quotation-info-card-title">Workflow</div>
                <div class="quotation-info-grid">
                    <div class="quotation-info-field">
                        <span class="quotation-info-label">Current Status</span>
                        <span class="quotation-info-value">@await Html.PartialAsync("_StatusPill", Model.Status)</span>
                    </div>
                    <div class="quotation-info-field">
                        <span class="quotation-info-label">Save Action</span>
                        <span class="quotation-info-value">Save Draft</span>
                    </div>
                </div>
                <div class="table-meta">Submit, approval, rejection, cancellation, and receiving are handled from the PO details screen.</div>
            </div>
        </div>
    </div>

    <div class="form-section">
        <div class="d-flex justify-content-between align-items-center gap-2 mb-3 flex-wrap">
            <div>
                <div class="form-section-title mb-1">PO Lines</div>
                <div class="table-meta">Supplier order lines using existing item master data.</div>
            </div>
            <button type="button" class="btn btn-outline-primary btn-sm" id="addPOLine">Add Line</button>
        </div>
        <div class="table-responsive po-lines-editor-wrap">
            <table class="table entity-table quote-editor-table" id="poLinesTable">
                <thead>
                    <tr>
                        <th style="width: 18%;">Item</th>
                        <th style="width: 8%;">Is Serial</th>
                        <th style="width: 8%;">Qty</th>
                        <th style="width: 9%;">Received</th>
                        <th style="width: 10%;">Unit Price</th>
                        <th style="width: 10%;">Discount</th>
                        <th style="width: 10%;">Line Total</th>
                        <th style="width: 22%;">Delivery Allocation</th>
                        <th style="width: 9%;">Remark</th>
                        <th style="width: 6%;" class="text-end">Action</th>
                    </tr>
                </thead>
                <tbody id="poLineBody">
                @for (var i = 0; i < Model.Details.Count; i++)
                {
                    var selectedItem = Model.ItemLookup.FirstOrDefault(x => x.ItemId == Model.Details[i].ItemId);
                    <tr class="po-line-row">
                        <td>
                            <input type="hidden" name="Details[@i].PurchaseOrderDetailId" value="@Model.Details[i].PurchaseOrderDetailId" />
                            <input type="hidden" class="js-line-number" name="Details[@i].LineNumber" value="@(i + 1)" />
                            <input type="hidden" name="Details[@i].ItemId" id="Details_@(i)__ItemId" value="@Model.Details[i].ItemId" class="js-item-id" />
                            <div class="search-dropdown">
                                <input type="text"
                                       class="form-control js-item-search"
                                       value="@(selectedItem is null ? string.Empty : $"{selectedItem.ItemCode} - {selectedItem.ItemName}")"
                                       placeholder="Search item code, name, or part no."
                                       autocomplete="off" />
                                <div id="poItemResults_@i" class="search-dropdown-menu js-item-results" style="display:none;"></div>
                            </div>
                            <div class="table-meta js-item-meta">@(selectedItem is null ? "Select item from master data." : $"Part No.: {(string.IsNullOrWhiteSpace(selectedItem.PartNumber) ? "-" : selectedItem.PartNumber)}")</div>
                            <span class="text-danger field-validation-valid" data-valmsg-for="Details[@i].ItemId" data-valmsg-replace="true"></span>
                        </td>
                        <td>
                            <span class="js-serial-flag badge-soft">
                                @(selectedItem?.IsSerialControlled == true ? "Yes" : "No")
                            </span>
                        </td>
                        <td>
                            <input type="number" step="0.01" min="0.01" name="Details[@i].Qty" id="Details_@(i)__Qty" value="@Model.Details[i].Qty.ToString("0.##")" class="form-control js-line-qty" />
                            <span class="text-danger field-validation-valid" data-valmsg-for="Details[@i].Qty" data-valmsg-replace="true"></span>
                        </td>
                        <td>
                            <input type="number" step="0.01" name="Details[@i].ReceivedQty" id="Details_@(i)__ReceivedQty" value="@Model.Details[i].ReceivedQty.ToString("0.##")" class="form-control" readonly />
                        </td>
                        <td>
                            <input type="number" step="0.01" min="0" name="Details[@i].UnitPrice" id="Details_@(i)__UnitPrice" value="@Model.Details[i].UnitPrice.ToString("0.##")" class="form-control js-line-price" />
                            <span class="text-danger field-validation-valid" data-valmsg-for="Details[@i].UnitPrice" data-valmsg-replace="true"></span>
                        </td>
                        <td>
                            <input type="number" step="0.01" min="0" name="Details[@i].DiscountAmount" id="Details_@(i)__DiscountAmount" value="@Model.Details[i].DiscountAmount.ToString("0.##")" class="form-control js-line-discount" />
                            <span class="text-danger field-validation-valid" data-valmsg-for="Details[@i].DiscountAmount" data-valmsg-replace="true"></span>
                        </td>
                        <td>
                            <input type="number" step="0.01" name="Details[@i].LineTotal" id="Details_@(i)__LineTotal" value="@Model.Details[i].LineTotal.ToString("0.##")" class="form-control js-line-total" readonly />
                        </td>
                        <td>
                            @{
                                var allocations = Model.Details[i].Allocations.Any()
                                    ? Model.Details[i].Allocations
                                    : new List<BizCore.Models.ViewModels.PurchaseOrderAllocationEditorViewModel>
                                    {
                                        new() { BranchId = Model.BranchId, AllocatedQty = Model.Details[i].Qty }
                                    };
                            }
                            <div class="js-allocation-list">
                                @for (var j = 0; j < allocations.Count; j++)
                                {
                                    <div class="po-allocation-row js-allocation-row">
                                        <input type="hidden" name="Details[@i].Allocations[@j].PurchaseOrderAllocationId" value="@allocations[j].PurchaseOrderAllocationId" />
                                        <input type="hidden" name="Details[@i].Allocations[@j].ReceivedQty" value="@allocations[j].ReceivedQty.ToString("0.##")" />
                                        @for (var s = 0; s < allocations[j].Sources.Count; s++)
                                        {
                                            <input type="hidden" name="Details[@i].Allocations[@j].Sources[@s].PurchaseOrderAllocationSourceId" value="@allocations[j].Sources[s].PurchaseOrderAllocationSourceId" />
                                            <input type="hidden" name="Details[@i].Allocations[@j].Sources[@s].PurchaseRequestDetailId" value="@allocations[j].Sources[s].PurchaseRequestDetailId" />
                                            <input type="hidden" name="Details[@i].Allocations[@j].Sources[@s].PurchaseRequestId" value="@allocations[j].Sources[s].PurchaseRequestId" />
                                            <input type="hidden" name="Details[@i].Allocations[@j].Sources[@s].PurchaseRequestNo" value="@allocations[j].Sources[s].PurchaseRequestNo" />
                                            <input type="hidden" name="Details[@i].Allocations[@j].Sources[@s].SourceQty" value="@allocations[j].Sources[s].SourceQty.ToString("0.##")" />
                                        }
                                        <select name="Details[@i].Allocations[@j].BranchId" class="form-select form-select-sm js-allocation-branch">
                                            <option value="">Branch</option>
                                            @foreach (var branch in branchOptions)
                                            {
                                                <option value="@branch.Value" selected="@(branch.Value == allocations[j].BranchId?.ToString())">@branch.Text</option>
                                            }
                                        </select>
                                        <input type="number" step="0.01" min="0" name="Details[@i].Allocations[@j].AllocatedQty" value="@allocations[j].AllocatedQty.ToString("0.##")" class="form-control form-control-sm js-allocation-qty" />
                                        <button type="button" class="btn btn-sm btn-outline-secondary js-remove-allocation" title="Remove branch allocation">-</button>
                                    </div>
                                    @if (allocations[j].Sources.Any())
                                    {
                                        <div class="table-meta mb-1">
                                            Source PR:
                                            @string.Join(", ", allocations[j].Sources.Select(x => $"{x.PurchaseRequestNo} {x.SourceQty:N2}"))
                                        </div>
                                    }
                                }
                            </div>
                            <button type="button" class="btn btn-sm btn-outline-primary mt-1 js-add-allocation">Add Branch</button>
                            <span class="text-danger field-validation-valid" data-valmsg-for="Details[@i].Allocations" data-valmsg-replace="true"></span>
                        </td>
                        <td>
                            <input type="text" name="Details[@i].Remark" id="Details_@(i)__Remark" value="@Model.Details[i].Remark" class="form-control" />
                        </td>
                        <td class="text-end">
                            <button type="button" class="btn btn-sm btn-outline-danger js-remove-line">Remove</button>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
        <span class="text-danger field-validation-valid" data-valmsg-for="Details" data-valmsg-replace="true"></span>
    </div>

    <div class="quotation-summary-wrap">
        <div class="quotation-summary-stack">
            <div class="quotation-summary-row">
                <span class="quotation-summary-name">Subtotal</span>
                <span class="quotation-summary-amount" id="poSubtotal">@Model.Subtotal.ToString("N2")</span>
            </div>
            <div class="quotation-summary-row">
                <span class="quotation-summary-name">Discount</span>
                <span class="quotation-summary-amount">@Model.DiscountAmount.ToString("N2")</span>
            </div>
            <div class="quotation-summary-row">
                <span class="quotation-summary-name">VAT</span>
                <span class="quotation-summary-amount" id="poVatDisplay">@Model.VatAmount.ToString("N2")</span>
                <input asp-for="VatAmount" type="hidden" id="poVatAmount" />
            </div>
            <div class="quotation-summary-row total">
                <span class="quotation-summary-name">Total</span>
                <span class="quotation-summary-amount" id="poTotal">@Model.TotalAmount.ToString("N2")</span>
            </div>
        </div>
    </div>
</div>

<script type="application/json" id="poSupplierLookupData">@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.SupplierLookup))</script>
<script type="application/json" id="poItemLookupData">@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ItemLookup))</script>
<script type="application/json" id="poBranchOptionsData">@Html.Raw(System.Text.Json.JsonSerializer.Serialize(branchOptions.Select(x => new { x.Value, x.Text })))</script>
