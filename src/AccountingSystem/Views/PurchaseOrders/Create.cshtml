@model BizCore.Models.ViewModels.PurchaseOrderFormViewModel

@{
    ViewData["Title"] = "Create Purchase Order";
}

<div class="page-header">
    <div>
        <div class="page-eyebrow">Purchasing Module</div>
        <h1 class="page-title">Create Purchase Order</h1>
        <p class="page-subtitle">Create supplier purchase orders before receiving and stock update processing.</p>
    </div>
    <div class="page-actions">
        <a asp-action="Index" class="btn btn-outline-secondary">Back to POs</a>
    </div>
</div>

<div class="card content-card">
    <div class="card-body">
        <form asp-action="Create" method="post">
            <partial name="_Form" model="Model" />
            <div class="form-actions mt-3">
                <span class="table-meta">AP is intentionally not implemented yet.</span>
                <div class="page-actions">
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    <button type="submit" class="btn btn-primary px-4">Save Draft</button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <partial name="_FormScripts" />
}
