@model BizCore.Models.ViewModels.PurchaseOrderFormViewModel

@{
    ViewData["Title"] = "Edit Purchase Order";
}

<div class="page-header">
    <div>
        <div class="page-eyebrow">Purchasing Module</div>
        <h1 class="page-title">Edit Purchase Order</h1>
        <p class="page-subtitle">Adjust PO header and lines before receiving is posted.</p>
    </div>
    <div class="page-actions">
        <a asp-action="Details" asp-route-id="@Model.PurchaseOrderId" class="btn btn-outline-secondary">View PO</a>
    </div>
</div>

<div class="card content-card">
    <div class="card-body">
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="PurchaseOrderId" />
            <partial name="_Form" model="Model" />
            <div class="form-actions mt-3">
                <span class="table-meta">If receiving already exists, editing PO lines will be blocked.</span>
                <div class="page-actions">
                    <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
                    <button type="submit" class="btn btn-primary px-4">Save Changes</button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (() => {
            const itemLookup = JSON.parse(document.getElementById("poItemLookupData").textContent);
            const itemMap = Object.fromEntries(itemLookup.map(item => [String(item.ItemId), item]));
            const lineBody = document.getElementById("poLineBody");
            const addButton = document.getElementById("addPOLine");
            const vatInput = document.getElementById("poVatAmount");
            const vatTypeSelect = document.getElementById("poVatType");

            const buildItemOptions = selectedValue => {
                const selectedKey = selectedValue ? String(selectedValue) : "";
                const options = ['<option value="">Select item</option>'];
                itemLookup.forEach(item => {
                    const selected = selectedKey === String(item.ItemId) ? ' selected="selected"' : "";
                    options.push(`<option value="${item.ItemId}"${selected}>${item.DisplayText}</option>`);
                });
                return options.join("");
            };

            const createRow = index => {
                const row = document.createElement("tr");
                row.className = "po-line-row";
                row.innerHTML = `
                    <td>
                        <input type="hidden" name="Details[${index}].PurchaseOrderDetailId" value="" />
                        <input type="hidden" class="js-line-number" name="Details[${index}].LineNumber" value="${index + 1}" />
                        <select name="Details[${index}].ItemId" id="Details_${index}__ItemId" class="form-select js-item-select">
                            ${buildItemOptions("")}
                        </select>
                        <span class="text-danger field-validation-valid" data-valmsg-for="Details[${index}].ItemId" data-valmsg-replace="true"></span>
                    </td>
                    <td><span class="js-serial-flag badge-soft">No</span></td>
                    <td>
                        <input type="number" step="0.01" min="0.01" name="Details[${index}].Qty" id="Details_${index}__Qty" value="1" class="form-control js-line-qty" />
                        <span class="text-danger field-validation-valid" data-valmsg-for="Details[${index}].Qty" data-valmsg-replace="true"></span>
                    </td>
                    <td><input type="number" step="0.01" name="Details[${index}].ReceivedQty" id="Details_${index}__ReceivedQty" value="0" class="form-control" readonly /></td>
                    <td>
                        <input type="number" step="0.01" min="0" name="Details[${index}].UnitPrice" id="Details_${index}__UnitPrice" value="0" class="form-control js-line-price" />
                        <span class="text-danger field-validation-valid" data-valmsg-for="Details[${index}].UnitPrice" data-valmsg-replace="true"></span>
                    </td>
                    <td>
                        <input type="number" step="0.01" min="0" name="Details[${index}].DiscountAmount" id="Details_${index}__DiscountAmount" value="0" class="form-control js-line-discount" />
                        <span class="text-danger field-validation-valid" data-valmsg-for="Details[${index}].DiscountAmount" data-valmsg-replace="true"></span>
                    </td>
                    <td><input type="number" step="0.01" name="Details[${index}].LineTotal" id="Details_${index}__LineTotal" value="0" class="form-control js-line-total" readonly /></td>
                    <td><input type="text" name="Details[${index}].Remark" id="Details_${index}__Remark" class="form-control" /></td>
                    <td class="text-end"><button type="button" class="btn btn-sm btn-outline-danger js-remove-line">Remove</button></td>`;
                return row;
            };

            const reindexRows = () => {
                [...lineBody.querySelectorAll(".po-line-row")].forEach((row, index) => {
                    row.querySelectorAll("input, select, span[data-valmsg-for]").forEach(element => {
                        if (element.name) element.name = element.name.replace(/Details\[\d+\]/g, `Details[${index}]`);
                        if (element.id) element.id = element.id.replace(/Details_\d+__/g, `Details_${index}__`);
                        const field = element.getAttribute("data-valmsg-for");
                        if (field) element.setAttribute("data-valmsg-for", field.replace(/Details\[\d+\]/g, `Details[${index}]`));
                    });
                    row.querySelector(".js-line-number").value = String(index + 1);
                });
            };

            const updateLine = (row, syncItemPrice) => {
                const itemSelect = row.querySelector(".js-item-select");
                const qty = parseFloat(row.querySelector(".js-line-qty").value || "0");
                const priceInput = row.querySelector(".js-line-price");
                const discountInput = row.querySelector(".js-line-discount");
                const totalInput = row.querySelector(".js-line-total");
                const serialFlag = row.querySelector(".js-serial-flag");
                const item = itemMap[itemSelect.value];

                if (item && syncItemPrice && !parseFloat(priceInput.value)) {
                    priceInput.value = item.UnitPrice;
                }

                if (serialFlag) {
                    serialFlag.textContent = item?.IsSerialControlled ? "Yes" : "No";
                }

                const price = parseFloat(priceInput.value || "0");
                const discount = parseFloat(discountInput.value || "0");
                totalInput.value = Math.max((qty * price) - discount, 0).toFixed(2);
            };

            const updateSummary = () => {
                let subtotal = 0;
                let discount = 0;
                lineBody.querySelectorAll(".po-line-row").forEach(row => {
                    const qty = parseFloat(row.querySelector(".js-line-qty").value || "0");
                    const price = parseFloat(row.querySelector(".js-line-price").value || "0");
                    const disc = parseFloat(row.querySelector(".js-line-discount").value || "0");
                    subtotal += qty * price;
                    discount += disc;
                });

                const taxableAmount = subtotal - discount;
                const vat = vatTypeSelect.value === "VAT" ? taxableAmount * 0.07 : 0;
                vatInput.value = vat.toFixed(2);
                document.getElementById("poSubtotal").textContent = subtotal.toFixed(2);
                document.getElementById("poVatDisplay").textContent = vat.toFixed(2);
                document.getElementById("poTotal").textContent = (taxableAmount + vat).toFixed(2);
            };

            lineBody.addEventListener("input", event => {
                const row = event.target.closest(".po-line-row");
                if (!row) return;
                updateLine(row, false);
                updateSummary();
            });

            lineBody.addEventListener("change", event => {
                const row = event.target.closest(".po-line-row");
                if (!row) return;
                updateLine(row, event.target.classList.contains("js-item-select"));
                updateSummary();
            });

            lineBody.addEventListener("click", event => {
                if (!event.target.classList.contains("js-remove-line")) return;
                if (lineBody.querySelectorAll(".po-line-row").length === 1) return;
                event.target.closest(".po-line-row").remove();
                reindexRows();
                updateSummary();
            });

            addButton.addEventListener("click", () => {
                lineBody.appendChild(createRow(lineBody.querySelectorAll(".po-line-row").length));
            });

            vatTypeSelect.addEventListener("change", updateSummary);
            lineBody.querySelectorAll(".po-line-row").forEach(row => updateLine(row, false));
            updateSummary();
        })();
    </script>
}
