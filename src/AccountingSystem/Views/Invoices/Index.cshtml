@model BizCore.Models.ViewModels.PaginatedList<BizCore.Models.Entities.InvoiceHeader>

@{
    ViewData["Title"] = "ใบแจ้งหนี้";
    var search = ViewData["Search"] as string;
    var status = ViewData["Status"] as string;
    var dateFrom = ViewData["DateFrom"] as string;
    var dateTo = ViewData["DateTo"] as string;
}

<div class="page-header">
    <div>
        <div class="page-eyebrow">งานขาย</div>
        <h1 class="page-title">ใบแจ้งหนี้</h1>
    </div>
    <div class="page-actions">
        <a asp-action="Create" class="btn btn-primary px-4">สร้างใบแจ้งหนี้</a>
    </div>
</div>

<div class="card content-card table-card">
    <div class="table-card-header">
        <div>
            <h2 class="section-title">รายการใบแจ้งหนี้</h2>
        </div>
        <div class="table-meta">@Model.TotalCount รายการ</div>
    </div>
    <div class="card-body">
        <form method="get" class="list-filter-bar">
            <div class="list-filter-field grow">
                <label class="form-label" for="search">ค้นหา</label>
                <input id="search" name="search" value="@search" class="form-control" placeholder="เลขที่ใบแจ้งหนี้, ลูกค้า, คนไข้, HN หรือพนักงานขาย" />
            </div>
            <div class="list-filter-field">
                <label class="form-label" for="status">สถานะ</label>
                <select id="status" name="status" class="form-select">
                    <option value="">ทั้งหมด</option>
                    <option value="Draft" selected="@(status == "Draft")">ฉบับร่าง</option>
                    <option value="Issued" selected="@(status == "Issued")">ออกเอกสารแล้ว</option>
                    <option value="PartiallyPaid" selected="@(status == "PartiallyPaid")">ชำระบางส่วน</option>
                    <option value="Paid" selected="@(status == "Paid")">ชำระครบแล้ว</option>
                    <option value="Cancelled" selected="@(status == "Cancelled")">ยกเลิกแล้ว</option>
                </select>
            </div>
            <div class="list-filter-field">
                <label class="form-label" for="dateFrom">จากวันที่</label>
                <input id="dateFrom" name="dateFrom" value="@dateFrom" type="date" class="form-control" />
            </div>
            <div class="list-filter-field">
                <label class="form-label" for="dateTo">ถึงวันที่</label>
                <input id="dateTo" name="dateTo" value="@dateTo" type="date" class="form-control" />
            </div>
            <div class="list-filter-actions">
                <a asp-action="Index" class="btn btn-outline-secondary">ล้างค่า</a>
                <button type="submit" class="btn btn-primary">ค้นหา</button>
            </div>
        </form>
        <div class="table-responsive">
            <table class="table entity-table align-middle">
                <thead>
                    <tr>
                        <th>เลขที่ใบแจ้งหนี้</th>
                        <th>วันที่เอกสาร</th>
                        <th>ลูกค้า</th>
                        <th>สาขา</th>
                        <th>ยอดรวม</th>
                        <th>ใบวางบิล</th>
                        <th>สถานะ</th>
                        <th class="text-end">การทำงาน</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.Any())
                {
                    @foreach (var invoice in Model)
                    {
                        var linkedBillingNote = invoice.BillingNoteInvoices
                            .Select(x => x.BillingNoteHeader)
                            .FirstOrDefault(x => x != null);
                        <tr>
                            <td><span class="code-chip">@invoice.InvoiceNo</span></td>
                            <td>@invoice.InvoiceDate.ToString("dd/M/yyyy")</td>
                            <td class="fw-semibold">@invoice.Customer?.CustomerName</td>
                            <td>@(invoice.Branch?.BranchName ?? "-")</td>
                            <td>@invoice.TotalAmount.ToString("N2")</td>
                            <td>
                                @if (linkedBillingNote is not null)
                                {
                                    <div>@await Html.PartialAsync("_StatusPill", linkedBillingNote.Status)</div>
                                    <div class="table-meta">
                                        <a asp-controller="BillingNotes" asp-action="Details" asp-route-id="@linkedBillingNote.BillingNoteId">
                                            @linkedBillingNote.BillingNoteNo
                                        </a>
                                    </div>
                                }
                                else
                                {
                                    <span class="table-meta">ยังไม่ทำใบวางบิล</span>
                                }
                            </td>
                            <td>
                                <div>@await Html.PartialAsync("_StatusPill", invoice.Status)</div>
                                <div class="table-meta">ชำระแล้ว @invoice.PaidAmount.ToString("N2") / @invoice.TotalAmount.ToString("N2")</div>
                            </td>
                            <td class="text-end">
                                <div class="table-actions">
                                    <a asp-action="Details" asp-route-id="@invoice.InvoiceId" class="btn btn-sm btn-outline-secondary">ดูรายละเอียด</a>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="8" class="table-empty">ยังไม่มีใบแจ้งหนี้ เริ่มสร้างเอกสารแรกจากข้อมูลลูกค้าและสินค้าได้เลย</td></tr>
                }
                </tbody>
            </table>
        </div>
        <partial name="_Pager" model="Model.Pagination" />
    </div>
</div>
