@model BizCore.Models.ViewModels.PaginatedList<BizCore.Models.Entities.InvoiceHeader>

@{
    ViewData["Title"] = "Invoices";
    var search = ViewData["Search"] as string;
    var status = ViewData["Status"] as string;
    var dateFrom = ViewData["DateFrom"] as string;
    var dateTo = ViewData["DateTo"] as string;
}

<div class="page-header">
    <div>
        <div class="page-eyebrow">Sales Module</div>
        <h1 class="page-title">Invoices</h1>
        <p class="page-subtitle">Direct sales invoices with stock deduction and serial issue on save.</p>
    </div>
    <div class="page-actions">
        <a asp-action="Create" class="btn btn-primary px-4">New Invoice</a>
    </div>
</div>

<div class="card content-card table-card">
    <div class="table-card-header">
        <div>
            <h2 class="section-title">Invoice Register</h2>
            <p class="section-subtitle">Direct invoices can be paid through the Payment module. Draft and unpaid issued invoices can be cancelled safely.</p>
        </div>
        <div class="table-meta">@Model.TotalCount record(s)</div>
    </div>
    <div class="card-body">
        <form method="get" class="list-filter-bar">
            <div class="list-filter-field grow">
                <label class="form-label" for="search">Search</label>
                <input id="search" name="search" value="@search" class="form-control" placeholder="Invoice no., quotation no., reference, customer, or salesperson" />
            </div>
            <div class="list-filter-field">
                <label class="form-label" for="status">Status</label>
                <select id="status" name="status" class="form-select">
                    <option value="">All</option>
                    <option value="Draft" selected="@(status == "Draft")">Draft</option>
                    <option value="Issued" selected="@(status == "Issued")">Issued</option>
                    <option value="PartiallyPaid" selected="@(status == "PartiallyPaid")">Partially Paid</option>
                    <option value="Paid" selected="@(status == "Paid")">Paid</option>
                    <option value="Cancelled" selected="@(status == "Cancelled")">Cancelled</option>
                </select>
            </div>
            <div class="list-filter-field">
                <label class="form-label" for="dateFrom">From</label>
                <input id="dateFrom" name="dateFrom" value="@dateFrom" type="date" class="form-control" />
            </div>
            <div class="list-filter-field">
                <label class="form-label" for="dateTo">To</label>
                <input id="dateTo" name="dateTo" value="@dateTo" type="date" class="form-control" />
            </div>
            <div class="list-filter-actions">
                <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
                <button type="submit" class="btn btn-primary">Search</button>
            </div>
        </form>
        <div class="table-responsive">
            <table class="table entity-table align-middle">
                <thead>
                    <tr>
                        <th>Invoice No.</th>
                        <th>Quotation No.</th>
                        <th>Reference No.</th>
                        <th>Invoice Date</th>
                        <th>Customer</th>
                        <th>Branch</th>
                        <th>Total Amount</th>
                        <th>Status</th>
                        <th class="text-end">Action</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.Any())
                {
                    @foreach (var invoice in Model)
                    {
                        var canReceivePayment = invoice.BalanceAmount > 0 &&
                            (invoice.Status == "Issued" || invoice.Status == "PartiallyPaid");
                        <tr>
                            <td><span class="code-chip">@invoice.InvoiceNo</span></td>
                            <td>@(string.IsNullOrWhiteSpace(invoice.Quotation?.QuotationNumber) ? "-" : invoice.Quotation!.QuotationNumber)</td>
                            <td>@(string.IsNullOrWhiteSpace(invoice.ReferenceNo) ? "-" : invoice.ReferenceNo)</td>
                            <td>@invoice.InvoiceDate.ToString("dd MMM yyyy")</td>
                            <td class="fw-semibold">@invoice.Customer?.CustomerName</td>
                            <td>@(invoice.Branch?.BranchName ?? "-")</td>
                            <td>@invoice.TotalAmount.ToString("N2")</td>
                            <td><span class="status-pill active">@invoice.Status</span></td>
                            <td class="text-end">
                                <div class="table-actions">
                                    <a asp-action="Details" asp-route-id="@invoice.InvoiceId" class="btn btn-sm btn-outline-secondary">View</a>
                                    @if (canReceivePayment)
                                    {
                                        <a asp-controller="Payments" asp-action="Create" asp-route-customerId="@invoice.CustomerId" asp-route-invoiceId="@invoice.InvoiceId" class="btn btn-sm btn-outline-success">Receive Payment</a>
                                    }
                                    @if (invoice.Status == "Draft")
                                    {
                                        <a asp-action="Edit" asp-route-id="@invoice.InvoiceId" class="btn btn-sm btn-outline-primary">Edit</a>
                                        <form asp-action="Issue" asp-route-id="@invoice.InvoiceId" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-primary">Issue</button>
                                        </form>
                                    }
                                    @if ((invoice.Status == "Draft" || invoice.Status == "Issued") && invoice.PaidAmount <= 0 && !invoice.PaymentAllocations.Any())
                                    {
                                        <form asp-action="Cancel" asp-route-id="@invoice.InvoiceId" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger">Cancel</button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="9" class="table-empty">No invoices yet. Create the first direct invoice from customer and item master data.</td></tr>
                }
                </tbody>
            </table>
        </div>
        <partial name="_Pager" model="Model.Pagination" />
    </div>
</div>
