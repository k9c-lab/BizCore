@model BizCore.Models.ViewModels.InvoiceFormViewModel

@{
    ViewData["Title"] = "Edit Invoice";
}

<div class="page-header">
    <div>
        <div class="page-eyebrow">Sales Module</div>
        <h1 class="page-title">Edit Invoice</h1>
        <p class="page-subtitle">Only draft invoices can be edited. Issued and cancelled invoices remain read-only.</p>
    </div>
    <div class="page-actions">
        <a asp-action="Details" asp-route-id="@Model.InvoiceId" class="btn btn-outline-secondary">View Invoice</a>
    </div>
</div>

@if (TempData["InvoiceNotice"] is string notice && !string.IsNullOrWhiteSpace(notice))
{
    @await Html.PartialAsync("_Notice", notice)
}

<div class="card content-card">
    <div class="card-body">
        <form asp-action="Edit" asp-route-id="@Model.InvoiceId" method="post">
            <div asp-validation-summary="All" class="form-alert"></div>
            <input asp-for="InvoiceId" type="hidden" />
            <input asp-for="QuotationId" type="hidden" />

            <div class="form-shell">
                <div class="form-section quotation-header-section">
                    <div class="form-section-title">Invoice Header</div>
                    <div class="row g-2 quotation-header-grid">
                        <div class="col-lg-3 col-md-6">
                            <label asp-for="InvoiceNo" class="form-label"></label>
                            <input asp-for="InvoiceNo" class="form-control" readonly />
                            <span asp-validation-for="InvoiceNo" class="text-danger"></span>
                        </div>
                        <div class="col-lg-3 col-md-6">
                            <label asp-for="InvoiceDate" class="form-label"></label>
                            <input asp-for="InvoiceDate" class="form-control" />
                            <span asp-validation-for="InvoiceDate" class="text-danger"></span>
                        </div>
                        <div class="col-lg-3 col-md-6">
                            <label asp-for="ReferenceNo" class="form-label"></label>
                            <input asp-for="ReferenceNo" class="form-control" />
                            <span asp-validation-for="ReferenceNo" class="text-danger"></span>
                        </div>
                        <div class="col-lg-3 col-md-6">
                            <label asp-for="QuotationNo" class="form-label"></label>
                            <input asp-for="QuotationNo" class="form-control" readonly />
                        </div>
                        <div class="col-md-3">
                            <label asp-for="CustomerId" class="form-label"></label>
                            <input asp-for="CustomerId" type="hidden" id="CustomerId" />
                            <div class="search-dropdown">
                                <input type="text"
                                       class="form-control"
                                       id="invoiceCustomerSearch"
                                       placeholder="Search customer code, name, or tax ID"
                                       autocomplete="off" />
                                <div id="invoiceCustomerResults" class="search-dropdown-menu" style="display:none;"></div>
                            </div>
                            <span asp-validation-for="CustomerId" class="text-danger"></span>
                        </div>
                        <div class="col-md-3">
                            <label asp-for="SalespersonId" class="form-label"></label>
                            <select asp-for="SalespersonId" asp-items="Model.SalespersonOptions" class="form-select">
                                <option value="">Select salesperson</option>
                            </select>
                            <span asp-validation-for="SalespersonId" class="text-danger"></span>
                        </div>
                        <div class="col-md-2">
                            <label asp-for="DiscountMode" class="form-label"></label>
                            <select asp-for="DiscountMode" asp-items="Model.DiscountModeOptions" class="form-select"></select>
                            <span asp-validation-for="DiscountMode" class="text-danger"></span>
                        </div>
                        <div class="col-md-2">
                            <label asp-for="VatType" class="form-label"></label>
                            <select asp-for="VatType" asp-items="Model.VatTypeOptions" class="form-select"></select>
                            <span asp-validation-for="VatType" class="text-danger"></span>
                        </div>
                        <div class="col-md-2">
                            <label asp-for="HeaderDiscountAmount" class="form-label"></label>
                            <input asp-for="HeaderDiscountAmount" class="form-control" />
                            <span asp-validation-for="HeaderDiscountAmount" class="text-danger"></span>
                        </div>
                        <div class="col-12">
                            <label asp-for="Remark" class="form-label"></label>
                            <textarea asp-for="Remark" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="Remark" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="quotation-party-grid">
                    <div class="quotation-party-column">
                        <div class="quotation-info-card">
                            <div class="quotation-info-card-title">Customer Information</div>
                            <div class="quotation-info-grid">
                                <div class="quotation-info-field">
                                    <span class="quotation-info-label">Customer Name</span>
                                    <span class="quotation-info-value" id="invoiceCustomerName">-</span>
                                </div>
                                <div class="quotation-info-field">
                                    <span class="quotation-info-label">Tax ID</span>
                                    <span class="quotation-info-value" id="invoiceCustomerTaxId">-</span>
                                </div>
                            </div>
                            <div class="quotation-info-grid">
                                <div class="quotation-info-field">
                                    <span class="quotation-info-label">Phone</span>
                                    <span class="quotation-info-value" id="invoiceCustomerPhone">-</span>
                                </div>
                                <div class="quotation-info-field">
                                    <span class="quotation-info-label">Email</span>
                                    <span class="quotation-info-value" id="invoiceCustomerEmail">-</span>
                                </div>
                            </div>
                            <div class="quotation-info-field">
                                <span class="quotation-info-label">Billing Address</span>
                                <span class="quotation-info-value" id="invoiceCustomerBillingAddress">-</span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="form-section">
                    <div class="form-section-title mb-1">Invoice Lines</div>
                    <div class="table-meta mb-3">Draft edit updates existing lines only. Select serials here, then issue the invoice when ready.</div>
                    <div class="table-responsive">
                        <table class="table entity-table quote-editor-table align-middle">
                            <thead>
                                <tr>
                                    <th style="width: 28%;">Item</th>
                                    <th style="width: 10%;">Qty</th>
                                    <th style="width: 12%;">Unit Price</th>
                                    <th style="width: 12%;">Discount</th>
                                    <th>Description / Remark</th>
                                </tr>
                            </thead>
                            <tbody>
                            @for (var i = 0; i < Model.Details.Count; i++)
                            {
                                var availableSerials = Model.SerialLookup
                                    .Where(x => x.ItemId == Model.Details[i].ItemId)
                                    .OrderBy(x => x.SerialNo)
                                    .ToList();
                                var showSerialSection = Model.Details[i].IsSerialControlled &&
                                    string.Equals(Model.Details[i].ItemType, "Product", StringComparison.OrdinalIgnoreCase);
                                <tr>
                                    <td>
                                        <input type="hidden" name="Details[@i].InvoiceDetailId" value="@Model.Details[i].InvoiceDetailId" />
                                        <input type="hidden" name="Details[@i].LineNumber" value="@(i + 1)" />
                                        <input type="hidden" name="Details[@i].ItemId" value="@Model.Details[i].ItemId" />
                                        <input type="hidden" name="Details[@i].ItemCode" value="@Model.Details[i].ItemCode" />
                                        <input type="hidden" name="Details[@i].ItemName" value="@Model.Details[i].ItemName" />
                                        <input type="hidden" name="Details[@i].PartNumber" value="@Model.Details[i].PartNumber" />
                                        <input type="hidden" name="Details[@i].ItemType" value="@Model.Details[i].ItemType" />
                                        <input type="hidden" name="Details[@i].TrackStock" value="@Model.Details[i].TrackStock.ToString().ToLowerInvariant()" />
                                        <input type="hidden" name="Details[@i].IsSerialControlled" value="@Model.Details[i].IsSerialControlled.ToString().ToLowerInvariant()" />
                                        <input type="hidden" name="Details[@i].CurrentStock" value="@Model.Details[i].CurrentStock.ToString("0.##")" />
                                        <input type="hidden" name="Details[@i].LineTotal" value="@Model.Details[i].LineTotal.ToString("0.##")" />
                                        <div class="fw-semibold">@Model.Details[i].ItemCode - @Model.Details[i].ItemName</div>
                                        <div class="table-meta">Part No.: @(string.IsNullOrWhiteSpace(Model.Details[i].PartNumber) ? "-" : Model.Details[i].PartNumber)</div>
                                        <span class="text-danger field-validation-valid" data-valmsg-for="Details[@i].ItemId" data-valmsg-replace="true"></span>
                                    </td>
                                    <td>
                                        <input type="number" step="0.01" min="0.01" name="Details[@i].Qty" value="@Model.Details[i].Qty.ToString("0.##")" class="form-control" />
                                        <span class="text-danger field-validation-valid" data-valmsg-for="Details[@i].Qty" data-valmsg-replace="true"></span>
                                    </td>
                                    <td>
                                        <input type="number" step="0.01" min="0" name="Details[@i].UnitPrice" value="@Model.Details[i].UnitPrice.ToString("0.##")" class="form-control" />
                                        <span class="text-danger field-validation-valid" data-valmsg-for="Details[@i].UnitPrice" data-valmsg-replace="true"></span>
                                    </td>
                                    <td>
                                        <input type="number" step="0.01" min="0" name="Details[@i].DiscountAmount" value="@Model.Details[i].DiscountAmount.ToString("0.##")" class="form-control" />
                                        <span class="text-danger field-validation-valid" data-valmsg-for="Details[@i].DiscountAmount" data-valmsg-replace="true"></span>
                                    </td>
                                    <td>
                                        <textarea name="Details[@i].Remark" class="form-control" rows="3">@Model.Details[i].Remark</textarea>
                                        <span class="text-danger field-validation-valid" data-valmsg-for="Details[@i].Remark" data-valmsg-replace="true"></span>
                                    </td>
                                </tr>
                                @if (showSerialSection)
                                {
                                    <tr class="invoice-line-row invoice-line-detail">
                                        <td colspan="5">
                                            <div class="invoice-line-detail-shell">
                                                <div class="invoice-line-detail-block">
                                                    <div class="detail-label">Serial Numbers</div>
                                                    @if (availableSerials.Any())
                                                    {
                                                        <div class="serial-checkbox-list js-serial-limit-group" data-max="@((int)Model.Details[i].Qty)">
                                                            @foreach (var serial in availableSerials)
                                                            {
                                                                var isChecked = Model.Details[i].SelectedSerialIds.Contains(serial.SerialId);
                                                                <label class="serial-checkbox-item">
                                                                    <input type="checkbox"
                                                                           class="form-check-input"
                                                                           name="Details[@i].SelectedSerialIds"
                                                                           value="@serial.SerialId"
                                                                           checked="@isChecked" />
                                                                    <span>@serial.DisplayText</span>
                                                                </label>
                                                            }
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        <div class="detail-value">No InStock serials available for this item.</div>
                                                    }
                                                    <span class="text-danger field-validation-valid" data-valmsg-for="Details[@i].SelectedSerialIds" data-valmsg-replace="true"></span>
                                                    <div class="text-danger js-serial-count-message" style="display:none;"></div>
                                                    <div class="form-text">Selected serial count must match quantity before issuing.</div>
                                                </div>
                                                <div class="invoice-line-detail-block">
                                                    <div class="detail-label">Warranty</div>
                                                    <div class="invoice-warranty-row">
                                                        <input type="date"
                                                               name="Details[@i].CustomerWarrantyStartDate"
                                                               value="@Model.Details[i].CustomerWarrantyStartDate?.ToString("yyyy-MM-dd")"
                                                               class="form-control" />
                                                        <input type="date"
                                                               name="Details[@i].CustomerWarrantyEndDate"
                                                               value="@Model.Details[i].CustomerWarrantyEndDate?.ToString("yyyy-MM-dd")"
                                                               class="form-control" />
                                                    </div>
                                                    <span class="text-danger field-validation-valid" data-valmsg-for="Details[@i].CustomerWarrantyStartDate" data-valmsg-replace="true"></span>
                                                    <span class="text-danger field-validation-valid" data-valmsg-for="Details[@i].CustomerWarrantyEndDate" data-valmsg-replace="true"></span>
                                                </div>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            </tbody>
                        </table>
                    </div>
                    <span class="text-danger field-validation-valid" data-valmsg-for="Details" data-valmsg-replace="true"></span>
                </div>
            </div>

            <div class="form-actions mt-3">
                <span class="table-meta">Saving keeps this invoice as Draft. Use Issue after serials and warranty are complete.</span>
                <div class="page-actions">
                    <a asp-action="Details" asp-route-id="@Model.InvoiceId" class="btn btn-outline-secondary">Cancel</a>
                    <button type="submit" class="btn btn-primary px-4">Save Draft</button>
                </div>
            </div>
        </form>
    </div>
</div>

<script type="application/json" id="invoiceCustomerLookupData">@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.CustomerLookup))</script>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (() => {
            const customerLookup = JSON.parse(document.getElementById("invoiceCustomerLookupData").textContent);
            const customerMap = Object.fromEntries(customerLookup.map(customer => [String(customer.CustomerId), customer]));
            const customerInput = document.getElementById("CustomerId");
            const customerSearch = document.getElementById("invoiceCustomerSearch");
            const customerResults = document.getElementById("invoiceCustomerResults");

            const getValue = value => value && String(value).trim() ? value : "-";

            const updateCustomerInfo = () => {
                const customer = customerMap[customerInput.value];
                document.getElementById("invoiceCustomerName").textContent = getValue(customer?.CustomerName);
                document.getElementById("invoiceCustomerTaxId").textContent = getValue(customer?.TaxId);
                document.getElementById("invoiceCustomerPhone").textContent = getValue(customer?.Phone);
                document.getElementById("invoiceCustomerEmail").textContent = getValue(customer?.Email);
                document.getElementById("invoiceCustomerBillingAddress").textContent = getValue(customer?.BillingAddress);
            };

            const hideCustomerResults = () => {
                customerResults.style.display = "none";
                customerResults.innerHTML = "";
            };

            const selectCustomer = customer => {
                customerInput.value = customer.CustomerId;
                customerSearch.value = `${customer.CustomerCode || "-"} - ${customer.CustomerName}`;
                customerSearch.dataset.selectedCustomerId = String(customer.CustomerId);
                hideCustomerResults();
                updateCustomerInfo();
            };

            const renderCustomerResults = query => {
                const keyword = (query || "").trim().toLowerCase();
                const matches = customerLookup
                    .filter(customer =>
                        !keyword ||
                        (customer.CustomerCode || "").toLowerCase().includes(keyword) ||
                        customer.CustomerName.toLowerCase().includes(keyword) ||
                        (customer.TaxId || "").toLowerCase().includes(keyword))
                    .slice(0, keyword ? 12 : 20);

                if (matches.length === 0) {
                    customerResults.innerHTML = `<div class="search-dropdown-empty">No matching customers found.</div>`;
                    customerResults.style.display = "";
                    return;
                }

                customerResults.innerHTML = matches
                    .map(customer => `
                        <button type="button" class="search-dropdown-option" data-customer-id="${customer.CustomerId}">
                            <span class="search-dropdown-title">${customer.CustomerCode || "-"} - ${customer.CustomerName}</span>
                            <span class="search-dropdown-meta">Tax ID: ${customer.TaxId || "-"} | ${customer.Phone || "-"}</span>
                        </button>`)
                    .join("");
                customerResults.style.display = "";
            };

            customerSearch.addEventListener("input", () => {
                delete customerSearch.dataset.selectedCustomerId;
                customerInput.value = "";
                updateCustomerInfo();
                renderCustomerResults(customerSearch.value);
            });
            customerSearch.addEventListener("focus", () => renderCustomerResults(customerSearch.value));
            customerResults.addEventListener("click", event => {
                const option = event.target.closest("[data-customer-id]");
                if (!option) {
                    return;
                }
                selectCustomer(customerMap[option.dataset.customerId]);
            });
            customerSearch.addEventListener("blur", () => {
                window.setTimeout(() => {
                    const selectedId = customerSearch.dataset.selectedCustomerId;
                    const exactMatch = customerLookup.find(customer =>
                        `${customer.CustomerCode || "-"} - ${customer.CustomerName}`.toLowerCase() === (customerSearch.value || "").trim().toLowerCase() ||
                        customer.CustomerName.toLowerCase() === (customerSearch.value || "").trim().toLowerCase());

                    if (selectedId && customerMap[selectedId]) {
                        selectCustomer(customerMap[selectedId]);
                    } else if (exactMatch) {
                        selectCustomer(exactMatch);
                    } else if (customerInput.value && customerMap[customerInput.value]) {
                        selectCustomer(customerMap[customerInput.value]);
                    } else {
                        customerSearch.value = "";
                        customerInput.value = "";
                        updateCustomerInfo();
                    }
                    hideCustomerResults();
                }, 120);
            });

            document.querySelectorAll(".js-serial-limit-group").forEach(group => {
                const message = group.closest(".invoice-line-detail-block")?.querySelector(".js-serial-count-message");
                const update = event => {
                    const max = Number(group.dataset.max || 0);
                    const checked = [...group.querySelectorAll("input[type='checkbox']:checked")];
                    if (checked.length > max) {
                        event?.target && (event.target.checked = false);
                    }

                    const nextChecked = [...group.querySelectorAll("input[type='checkbox']:checked")];
                    if (!message) {
                        return;
                    }

                    if (nextChecked.length > max) {
                        message.textContent = `Selected serial count cannot exceed quantity (${max}).`;
                        message.style.display = "";
                    } else {
                        message.textContent = "";
                        message.style.display = "none";
                    }
                };

                group.addEventListener("change", update);
                update();
            });

            if (customerInput.value && customerMap[customerInput.value]) {
                selectCustomer(customerMap[customerInput.value]);
            } else {
                updateCustomerInfo();
            }
        })();
    </script>
}
