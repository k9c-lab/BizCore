@model BizCore.Models.Entities.InvoiceHeader
@{
    Layout = null;
    var companyName = ViewData["PrintCompanyName"] as string ?? "BizCore Co., Ltd.";
    var companyAddress = ViewData["PrintCompanyAddress"] as string ?? "-";
    var companyTaxId = ViewData["PrintCompanyTaxId"] as string ?? "-";
    var companyPhone = ViewData["PrintCompanyPhone"] as string ?? "-";
    var companyEmail = ViewData["PrintCompanyEmail"] as string ?? "-";
    var totalAmountText = BizCore.Utilities.ThaiBahtTextConverter.ToText(Model.TotalAmount);
    var referenceSubtotal = Model.ReferenceLineSubtotal
        ?? Model.InvoiceDetails.Sum(x => (x.QuotedQty > 0 ? x.QuotedQty : x.Qty) * x.UnitPrice);
    var referenceDiscount = Model.ReferenceLineDiscountAmount
        ?? Model.InvoiceDetails.Sum(x => x.DiscountAmount);
    var referenceVat = Model.ReferenceLineVatAmount
        ?? (Model.VatType == "VAT"
            ? Math.Round((referenceSubtotal - referenceDiscount) * 0.07m, 2, MidpointRounding.AwayFromZero)
            : 0m);
    var referenceTotal = Model.ReferenceLineTotalAmount
        ?? (referenceSubtotal - referenceDiscount + referenceVat);
    var referenceNet = referenceSubtotal - referenceDiscount;
    var showsInstallmentBilling = Model.QuotationId.HasValue && Math.Abs(referenceTotal - Model.TotalAmount) > 0.01m;
    var hasRemark = !string.IsNullOrWhiteSpace(Model.Remark);
}
<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Invoice @Model.InvoiceNo</title>
    <style>
        @@page { size: A4; margin: 14mm; }
        * { box-sizing: border-box; }
        body {
            margin: 0;
            font-family: "Segoe UI", Tahoma, sans-serif;
            color: #111827;
            background: #e5e7eb;
            font-size: 11.5px;
            line-height: 1.35;
        }
        .print-page {
            min-height: 100vh;
            padding: 24px;
            display: flex;
            justify-content: center;
            align-items: flex-start;
        }
        .print-shell {
            width: 210mm;
            min-height: 297mm;
            display: flex;
            flex-direction: column;
            background: #fff;
            padding: 14mm;
            box-shadow: 0 16px 40px rgba(15, 23, 42, 0.14);
        }
        .screen-actions {
            display: flex;
            justify-content: flex-end;
            margin: 0 0 14px;
        }
        .screen-actions button {
            border: 1px solid #cbd5e1;
            background: #fff;
            color: #111827;
            border-radius: 6px;
            padding: 6px 10px;
            font: inherit;
            cursor: pointer;
            box-shadow: 0 1px 2px rgba(15, 23, 42, 0.08);
        }
        .print-header {
            display: flex;
            justify-content: space-between;
            gap: 24px;
            padding-bottom: 14px;
            border-bottom: 2px solid #1d4ed8;
        }
        .company-block { max-width: 58%; }
        .company-name {
            margin: 0 0 6px;
            font-size: 20px;
            font-weight: 700;
            letter-spacing: 0.02em;
            color: #0f172a;
        }
        .company-line,
        .meta-label,
        .section-label,
        .summary-label,
        .signature-label {
            color: #374151;
        }
        .company-meta-grid {
            display: grid;
            gap: 3px;
            margin-top: 8px;
        }
        .company-line {
            color: #111827;
            white-space: pre-line;
        }
        .document-block {
            min-width: 300px;
            text-align: right;
        }
        .document-title-th {
            margin: 0;
            font-size: 24px;
            font-weight: 700;
            color: #1d4ed8;
        }
        .document-title-en {
            margin: 2px 0 12px;
            font-size: 15px;
            font-weight: 600;
            color: #1f2937;
            letter-spacing: 0.04em;
        }
        .document-meta {
            width: 100%;
            border-collapse: collapse;
        }
        .document-meta td {
            padding: 2px 0 2px 16px;
            vertical-align: top;
            color: #111827;
        }
        .document-meta td:first-child {
            white-space: nowrap;
        }
        .meta-value-nowrap {
            white-space: nowrap;
        }
        .salesperson-meta {
            margin-top: 12px;
            margin-left: auto;
            width: 100%;
            max-width: 320px;
            border-top: 1px solid #cbd5e1;
            padding-top: 10px;
        }
        .salesperson-row {
            display: flex;
            justify-content: space-between;
            gap: 12px;
            padding: 1px 0;
            color: #111827;
        }
        .salesperson-row .meta-label {
            min-width: 110px;
        }
        .print-section { margin-top: 16px; }
        .party-section {
            padding: 0 0 10px;
            border-bottom: 1px solid #d1d5db;
        }
        .party-grid {
            display: grid;
            grid-template-columns: minmax(0, 1.3fr) minmax(0, 0.7fr);
            gap: 8px 20px;
        }
        .party-name {
            font-size: 14px;
            font-weight: 700;
            margin-top: 1px;
            color: #111827;
        }
        .party-value,
        .remark-value,
        .signature-date {
            white-space: pre-wrap;
            color: #111827;
        }
        .line-table {
            width: 100%;
            border-collapse: collapse;
            table-layout: fixed;
        }
        .line-table th, .line-table td {
            border: 1px solid #d1d5db;
            padding: 7px 8px;
            vertical-align: top;
        }
        .line-table th {
            background: #e0ecff;
            color: #1e3a8a;
            font-weight: 700;
            text-align: center;
            font-size: 11px;
        }
        .bi-label-th,
        .bi-label-en {
            display: block;
            line-height: 1.2;
            white-space: nowrap;
        }
        .bi-label-en {
            margin-top: 2px;
            font-size: 10px;
            font-weight: 600;
        }
        .col-no { width: 48px; text-align: center; }
        .col-description { width: auto; word-break: break-word; }
        .line-description-text {
            white-space: pre-line;
        }
        .line-description-extra {
            margin-top: 4px;
            color: #4b5563;
            white-space: normal;
        }
        .col-qty { width: 70px; text-align: right; }
        .col-price, .col-discount, .col-total { width: 96px; text-align: right; }
        .summary-wrap {
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            gap: 24px;
            margin-top: 14px;
        }
        .amount-text {
            flex: 1 1 auto;
            padding-right: 18px;
            font-size: 12px;
            font-weight: 600;
            color: #1f2937;
        }
        .summary-table {
            min-width: 300px;
            border-collapse: collapse;
        }
        .summary-grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 18px;
            align-items: start;
        }
        .summary-card-title {
            margin: 0 0 6px;
            font-size: 12px;
            font-weight: 700;
            color: #1e3a8a;
        }
        .summary-table td {
            padding: 4px 0 4px 18px;
        }
        .summary-table td:first-child {
            text-align: left;
        }
        .summary-table td:last-child {
            text-align: right;
            min-width: 120px;
            color: #111827;
        }
        .summary-total td {
            padding-top: 8px;
            border-top: 2px solid #1d4ed8;
            font-weight: 700;
            font-size: 14px;
            color: #0f172a;
        }
        .summary-separator td {
            padding: 0;
            height: 8px;
            border-bottom: 1px solid #cbd5e1;
        }
        .remark-box {
            white-space: pre-wrap;
            color: #374151;
        }
        .signature-grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 28px;
            margin-top: auto;
            padding-top: 28px;
        }
        .signature-box { text-align: center; color: #111827; }
        .signature-line {
            margin: 44px auto 8px;
            width: 88%;
            border-bottom: 1px solid #111827;
        }
        @@media print {
            body {
                -webkit-print-color-adjust: exact;
                print-color-adjust: exact;
                background: #fff;
            }
            .print-page {
                min-height: auto;
                padding: 0;
                display: block;
            }
            .print-shell {
                width: 100%;
                min-height: calc(297mm - 28mm);
                padding: 0;
                box-shadow: none;
            }
            .screen-actions { display: none; }
        }
    </style>
</head>
<body>
    <div class="print-page">
        <div class="print-shell">
            <div class="screen-actions">
                <button type="button" onclick="window.print()">Print</button>
            </div>

            <header class="print-header">
                <div class="company-block">
                    <h1 class="company-name">@companyName</h1>
                    <div class="company-meta-grid">
                        <div class="company-line">@companyAddress</div>
                        <div class="company-line">เลขประจำตัวผู้เสียภาษี / Tax ID: @companyTaxId</div>
                        <div class="company-line">โทรศัพท์ / Tel: @companyPhone</div>
                        @if (!string.IsNullOrWhiteSpace(companyEmail))
                        {
                            <div class="company-line">Email: @companyEmail</div>
                        }
                    </div>
                </div>
                <div class="document-block">
                    <h2 class="document-title-th">ใบแจ้งหนี้</h2>
                    <div class="document-title-en">Invoice</div>
                    <table class="document-meta">
                        <tr><td class="meta-label">เลขที่เอกสาร / Doc No.</td><td class="meta-value-nowrap">@Model.InvoiceNo</td></tr>
                        <tr><td class="meta-label">วันที่เอกสาร / Date</td><td>@Model.InvoiceDate.ToString("dd/MM/yyyy")</td></tr>
                        <tr><td class="meta-label">เลขที่ใบเสนอราคา / Quotation No.</td><td>@(string.IsNullOrWhiteSpace(Model.Quotation?.QuotationNumber) ? "-" : Model.Quotation!.QuotationNumber)</td></tr>
                        <tr><td class="meta-label">เลขที่อ้างอิง / Reference No.</td><td>@(string.IsNullOrWhiteSpace(Model.ReferenceNo) ? "-" : Model.ReferenceNo)</td></tr>
                        <tr><td class="meta-label">สาขา / Branch</td><td>@(Model.Branch?.BranchName ?? "-")</td></tr>
                    </table>
                    <div class="salesperson-meta">
                        <div class="salesperson-row"><span class="meta-label">พนักงานขาย / Salesperson</span><span>@(string.IsNullOrWhiteSpace(Model.Salesperson?.SalespersonName) ? "-" : Model.Salesperson!.SalespersonName)</span></div>
                        <div class="salesperson-row"><span class="meta-label">โทรศัพท์ / Tel</span><span>@(string.IsNullOrWhiteSpace(Model.Salesperson?.PhoneNumber) ? "-" : Model.Salesperson!.PhoneNumber)</span></div>
                        <div class="salesperson-row"><span class="meta-label">Email</span><span>@(string.IsNullOrWhiteSpace(Model.Salesperson?.Email) ? "-" : Model.Salesperson!.Email)</span></div>
                    </div>
                </div>
            </header>

            <section class="print-section party-section">
                <div class="party-grid">
                    <div>
                        <div class="section-label">ลูกค้า / Customer</div>
                        <div class="party-name">@Model.Customer?.CustomerName</div>
                    </div>
                    <div>
                        <div class="section-label">เลขประจำตัวผู้เสียภาษี / Tax ID</div>
                        <div class="party-value">@(string.IsNullOrWhiteSpace(Model.Customer?.TaxId) ? "-" : Model.Customer!.TaxId)</div>
                    </div>
                    <div style="grid-column: 1 / -1;">
                        <div class="section-label">ที่อยู่ / Address</div>
                        <div class="party-value">@(string.IsNullOrWhiteSpace(Model.Customer?.Address) ? "-" : Model.Customer!.Address)</div>
                    </div>
                </div>
            </section>

            <section class="print-section">
                <table class="line-table">
                    <thead>
                        <tr>
                            <th class="col-no"><span class="bi-label-th">ลำดับ</span><span class="bi-label-en">No.</span></th>
                            <th class="col-description"><span class="bi-label-th">รายการ</span><span class="bi-label-en">Description</span></th>
                            <th class="col-qty"><span class="bi-label-th">จำนวน</span><span class="bi-label-en">Qty</span></th>
                            <th class="col-price"><span class="bi-label-th">ราคาต่อหน่วย</span><span class="bi-label-en">Unit Price</span></th>
                            <th class="col-discount"><span class="bi-label-th">ส่วนลด</span><span class="bi-label-en">Discount</span></th>
                            <th class="col-total"><span class="bi-label-th">จำนวนเงิน</span><span class="bi-label-en">Amount</span></th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var line in Model.InvoiceDetails.OrderBy(x => x.LineNumber))
                    {
                        var description = string.IsNullOrWhiteSpace(line.Remark)
                            ? $"{line.Item?.ItemCode} - {line.Item?.ItemName}"
                            : line.Remark;
                        var quotedQty = line.QuotedQty > 0 ? line.QuotedQty : line.Qty;
                        var showsActualQty = Math.Abs(quotedQty - line.Qty) > 0.01m;
                        <tr>
                            <td class="col-no">@line.LineNumber</td>
                            <td class="col-description">
                                <div class="line-description-text">@description</div>
                                @if (showsActualQty)
                                {
                                    <div class="line-description-extra">จำนวนออกบิลครั้งนี้ / Qty This Invoice: @line.Qty.ToString("N2")</div>
                                }
                            </td>
                            <td class="col-qty">@quotedQty.ToString("N2")</td>
                            <td class="col-price">@line.UnitPrice.ToString("N2")</td>
                            <td class="col-discount">@line.DiscountAmount.ToString("N2")</td>
                            <td class="col-total">@line.LineTotal.ToString("N2")</td>
                        </tr>
                    }
                    </tbody>
                </table>

                <div class="summary-wrap">
                    <div class="amount-text">@totalAmountText</div>
                    @if (Model.QuotationId.HasValue)
                    {
                        <div class="summary-grid">
                            <div>
                                <div class="summary-card-title">Quotation Reference Summary</div>
                                <table class="summary-table">
                                    <tr><td class="summary-label">ยอดก่อนส่วนลด / Subtotal</td><td>@referenceSubtotal.ToString("N2")</td></tr>
                                    <tr><td class="summary-label">ส่วนลด / Discount</td><td>@referenceDiscount.ToString("N2")</td></tr>
                                    <tr><td class="summary-label">ราคาหลังส่วนลด / Net After Discount</td><td>@referenceNet.ToString("N2")</td></tr>
                                    <tr><td class="summary-label">VAT</td><td>@referenceVat.ToString("N2")</td></tr>
                                    <tr class="summary-separator"><td colspan="2"></td></tr>
                                    <tr class="summary-total"><td>ยอดรวมอ้างอิง / Reference Item Total</td><td>@referenceTotal.ToString("N2")</td></tr>
                                </table>
                            </div>
                            <div>
                                <div class="summary-card-title">Invoice Summary</div>
                                <table class="summary-table">
                                    <tr><td class="summary-label">Amount Due This Invoice</td><td>@Model.TotalAmount.ToString("N2")</td></tr>
                                    <tr><td class="summary-label">VAT</td><td>@Model.VatAmount.ToString("N2")</td></tr>
                                    <tr class="summary-total"><td>Total Amount</td><td>@Model.TotalAmount.ToString("N2")</td></tr>
                                </table>
                            </div>
                        </div>
                    }
                    else
                    {
                        <table class="summary-table">
                            @if (showsInstallmentBilling)
                        {
                            <tr><td class="summary-label">ยอดอ้างอิงตามรายการ / Reference Item Total</td><td>@referenceTotal.ToString("N2")</td></tr>
                            <tr class="summary-separator"><td colspan="2"></td></tr>
                        }
                        <tr><td class="summary-label">ยอดก่อน VAT / Subtotal</td><td>@Model.Subtotal.ToString("N2")</td></tr>
                        <tr><td class="summary-label">ส่วนลด / Discount</td><td>@Model.DiscountAmount.ToString("N2")</td></tr>
                        <tr><td class="summary-label">VAT</td><td>@Model.VatAmount.ToString("N2")</td></tr>
                        <tr class="summary-total"><td>ยอดรวมทั้งสิ้น / Total Amount</td><td>@Model.TotalAmount.ToString("N2")</td></tr>
                        </table>
                    }
                </div>
            </section>

            @if (hasRemark)
            {
                <section class="print-section">
                    <div class="remark-box">@Model.Remark</div>
                </section>
            }

            <section class="signature-grid">
                <div class="signature-box">
                    <div class="signature-label">ผู้รับเอกสาร / Received By</div>
                    <div class="signature-line"></div>
                    <div>............................................................</div>
                    <div class="signature-date">วันที่ / Date ........ / ........ / ........</div>
                </div>
                <div class="signature-box">
                    <div class="signature-label">ผู้มีอำนาจลงนาม / Authorized Signature</div>
                    <div class="signature-line"></div>
                    <div>............................................................</div>
                    <div class="signature-date">วันที่ / Date ........ / ........ / ........</div>
                </div>
            </section>
        </div>
    </div>
    <script>
        window.addEventListener("load", () => {
            window.print();
        });
    </script>
</body>
</html>

