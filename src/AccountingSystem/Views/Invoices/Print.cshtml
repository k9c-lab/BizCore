@model BizCore.Models.Entities.InvoiceHeader
@{
    Layout = null;
    var companyName = ViewData["PrintCompanyName"] as string ?? "BizCore Co., Ltd.";
    var companyAddress = ViewData["PrintCompanyAddress"] as string ?? "-";
    var companyTaxId = ViewData["PrintCompanyTaxId"] as string ?? "-";
    var companyPhone = ViewData["PrintCompanyPhone"] as string ?? "-";
    var companyEmail = ViewData["PrintCompanyEmail"] as string ?? "-";
    var totalAmountText = BizCore.Utilities.ThaiBahtTextConverter.ToText(Model.TotalAmount);
    var quotationAppliedDiscount = Model.Quotation is not null
        ? (string.Equals(Model.Quotation.DiscountMode, "Header", StringComparison.OrdinalIgnoreCase)
            ? Model.Quotation.HeaderDiscountAmount
            : Model.Quotation.DiscountAmount)
        : 0m;
    var referenceSubtotal = Model.QuotationId.HasValue && Model.Quotation is not null
        ? Model.Quotation.Subtotal
        : (Model.ReferenceLineSubtotal ?? Model.InvoiceDetails.Sum(x => (x.QuotedQty > 0 ? x.QuotedQty : x.Qty) * x.UnitPrice));
    var referenceDiscount = Model.QuotationId.HasValue && Model.Quotation is not null
        ? quotationAppliedDiscount
        : (Model.ReferenceLineDiscountAmount ?? Model.InvoiceDetails.Sum(x => x.DiscountAmount));
    var referenceVat = Model.QuotationId.HasValue && Model.Quotation is not null
        ? Model.Quotation.VatAmount
        : (Model.ReferenceLineVatAmount
            ?? BizCore.Utilities.VatModeHelper.ComputeFromDocumentPricing(referenceSubtotal - referenceDiscount, Model.VatType).VatAmount);
    var referenceTotal = Model.QuotationId.HasValue && Model.Quotation is not null
        ? Model.Quotation.TotalAmount
        : (Model.ReferenceLineTotalAmount ?? (referenceSubtotal - referenceDiscount + referenceVat));
    var currentSummary = BizCore.Utilities.VatModeHelper.ComputeSummaryBreakdown(Model.Subtotal, Model.DiscountAmount, Model.VatType);
    var showsInstallmentBilling = Model.QuotationId.HasValue && Math.Abs(referenceTotal - Model.TotalAmount) > 0.01m;
    var hasRemark = !string.IsNullOrWhiteSpace(Model.Remark);
    var hasSalespersonInfo =
        !string.IsNullOrWhiteSpace(Model.Salesperson?.SalespersonName) ||
        !string.IsNullOrWhiteSpace(Model.Salesperson?.PhoneNumber) ||
        !string.IsNullOrWhiteSpace(Model.Salesperson?.Email);
    var hasPatientName = !string.IsNullOrWhiteSpace(Model.PatientFullName);
    var hasPatientHn = !string.IsNullOrWhiteSpace(Model.PatientHn);
    var hasPatientAge = Model.PatientAge.HasValue;
    var hasPatientGender = !string.IsNullOrWhiteSpace(Model.PatientGender);
    var hasTreatmentRight = Model.TreatmentRight is not null;
    var hasPatientWard = !string.IsNullOrWhiteSpace(Model.PatientWard);
    var hasReferringDoctor = Model.ReferringDoctor is not null;
    var hasReadingDoctor = Model.ReadingDoctor is not null;
    var printVariant = ViewData["PrintVariant"] as string ?? "1";
}
<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Invoice @Model.InvoiceNo</title>
    <style>
        @@page { size: A4; margin: 14mm; }
        * { box-sizing: border-box; }
        body {
            margin: 0;
            font-family: "Segoe UI", Tahoma, sans-serif;
            color: #111827;
            background: #e5e7eb;
            font-size: 11.5px;
            line-height: 1.35;
        }
        .print-page {
            min-height: 100vh;
            padding: 24px;
            display: flex;
            justify-content: center;
            align-items: flex-start;
        }
        .print-shell {
            width: 210mm;
            min-height: 297mm;
            display: flex;
            flex-direction: column;
            background: #fff;
            padding: 14mm;
            box-shadow: 0 16px 40px rgba(15, 23, 42, 0.14);
        }
        .screen-actions {
            display: flex;
            justify-content: flex-end;
            margin: 0 0 14px;
        }
        .screen-actions button {
            border: 1px solid #cbd5e1;
            background: #fff;
            color: #111827;
            border-radius: 6px;
            padding: 6px 10px;
            font: inherit;
            cursor: pointer;
            box-shadow: 0 1px 2px rgba(15, 23, 42, 0.08);
        }
        .print-header {
            display: flex;
            justify-content: space-between;
            gap: 24px;
            padding-bottom: 14px;
            border-bottom: 2px solid #1d4ed8;
        }
        .company-block { max-width: 58%; }
        .company-name {
            margin: 0 0 6px;
            font-size: 20px;
            font-weight: 700;
            letter-spacing: 0.02em;
            color: #0f172a;
        }
        .company-line,
        .meta-label,
        .section-label,
        .summary-label,
        .signature-label {
            color: #374151;
        }
        .company-meta-grid {
            display: grid;
            gap: 3px;
            margin-top: 8px;
        }
        .company-line {
            color: #111827;
            white-space: pre-line;
        }
        .document-block {
            min-width: 300px;
            text-align: right;
        }
        .document-title-th {
            margin: 0;
            font-size: 24px;
            font-weight: 700;
            color: #1d4ed8;
        }
        .document-title-en {
            margin: 2px 0 12px;
            font-size: 15px;
            font-weight: 600;
            color: #1f2937;
            letter-spacing: 0.04em;
        }
        .document-meta {
            width: 100%;
            border-collapse: collapse;
        }
        .document-meta td {
            padding: 2px 0 2px 16px;
            vertical-align: top;
            color: #111827;
        }
        .document-meta td:first-child {
            white-space: nowrap;
        }
        .meta-value-nowrap {
            white-space: nowrap;
        }
        .salesperson-meta {
            margin-top: 12px;
            margin-left: auto;
            width: 100%;
            max-width: 320px;
            border-top: 1px solid #cbd5e1;
            padding-top: 10px;
        }
        .salesperson-row {
            display: flex;
            justify-content: space-between;
            gap: 12px;
            padding: 1px 0;
            color: #111827;
        }
        .salesperson-row .meta-label {
            min-width: 110px;
        }
        .print-section { margin-top: 16px; }
        .party-section {
            padding: 0 0 10px;
            border-bottom: 1px solid #d1d5db;
        }
        .party-grid {
            display: grid;
            grid-template-columns: minmax(0, 1.3fr) minmax(0, 0.7fr);
            gap: 8px 20px;
        }
        .patient-grid {
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 6px 16px;
        }
        .patient-name-block {
            grid-column: 1 / span 2;
        }
        .patient-doctor-block {
            grid-column: span 2;
        }
        .party-name {
            font-size: 14px;
            font-weight: 700;
            margin-top: 1px;
            color: #111827;
        }
        .party-value,
        .remark-value,
        .signature-date {
            white-space: pre-wrap;
            color: #111827;
        }
        .patient-value-compact {
            margin-top: 1px;
            line-height: 1.2;
        }
        .line-table {
            width: 100%;
            border-collapse: collapse;
            table-layout: fixed;
        }
        .line-table th, .line-table td {
            border: 1px solid #d1d5db;
            padding: 7px 8px;
            vertical-align: top;
        }
        .line-table th {
            background: #e0ecff;
            color: #1e3a8a;
            font-weight: 700;
            text-align: center;
            font-size: 11px;
        }
        .bi-label-th,
        .bi-label-en {
            display: block;
            line-height: 1.2;
            white-space: nowrap;
        }
        .bi-label-en {
            margin-top: 2px;
            font-size: 10px;
            font-weight: 600;
        }
        .col-no { width: 48px; text-align: center; }
        .col-description { width: auto; word-break: break-word; }
        .line-description-text {
            white-space: pre-line;
        }
        .line-description-extra {
            margin-top: 4px;
            color: #4b5563;
            white-space: normal;
        }
        .col-qty { width: 70px; text-align: right; }
        .col-price, .col-discount, .col-total { width: 96px; text-align: right; }
        .summary-wrap {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 24px;
            margin-top: 14px;
        }
        .amount-text {
            flex: 1 1 auto;
            padding-right: 18px;
            font-size: 12px;
            font-weight: 600;
            color: #1f2937;
        }
        .summary-table {
            min-width: 300px;
            border-collapse: collapse;
        }
        .summary-table td {
            padding: 4px 0 4px 18px;
        }
        .summary-table td:first-child {
            text-align: left;
        }
        .summary-table td:last-child {
            text-align: right;
            min-width: 120px;
            color: #111827;
        }
        .summary-total td {
            padding-top: 8px;
            border-top: 2px solid #1d4ed8;
            font-weight: 700;
            font-size: 14px;
            color: #0f172a;
        }
        .summary-separator td {
            padding: 0;
            height: 8px;
            border-bottom: 1px solid #cbd5e1;
        }
        .remark-box {
            white-space: pre-wrap;
            color: #374151;
        }
        .signature-grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 28px;
            margin-top: auto;
            padding-top: 28px;
        }
        .signature-box { text-align: center; color: #111827; }
        .signature-line {
            margin: 44px auto 8px;
            width: 88%;
            border-bottom: 1px solid #111827;
        }
        .formal-sig-wrap { display: flex; justify-content: flex-end; margin-top: auto; padding-top: 28px; }
        .formal-sig-box { text-align: center; min-width: 260px; color: #111827; }
        .formal-sig-company { font-weight: 700; font-size: 13px; margin-bottom: 4px; }
        .formal-sig-sincerely { font-size: 12px; margin-bottom: 2px; }
        .formal-sig-auth { font-weight: 700; font-size: 12px; letter-spacing: 0.04em; text-transform: uppercase; margin-bottom: 0; }
        .formal-sig-line { margin: 36px auto 8px; width: 88%; border-bottom: 1px solid #111827; }
        .formal-sig-name { font-size: 12px; }
        .formal-sig-title { font-size: 12px; color: #374151; }
        @@media print {
            body {
                -webkit-print-color-adjust: exact;
                print-color-adjust: exact;
                background: #fff;
            }
            .print-page {
                min-height: auto;
                padding: 0;
                display: block;
            }
            .print-shell {
                width: 100%;
                min-height: calc(297mm - 28mm);
                padding: 0;
                box-shadow: none;
            }
            .screen-actions { display: none; }
        }
    </style>
</head>
<body>
    <div class="print-page">
        <div class="print-shell">
            <div class="screen-actions">
                <button type="button" onclick="window.print()">Print</button>
            </div>

            <header class="print-header">
                <div class="company-block">
                    <h1 class="company-name">@companyName</h1>
                    <div class="company-meta-grid">
                        <div class="company-line">@companyAddress</div>
                        <div class="company-line">เลขประจำตัวผู้เสียภาษี / Tax ID: @companyTaxId</div>
                        <div class="company-line">โทรศัพท์ / Tel: @companyPhone</div>
                        @if (!string.IsNullOrWhiteSpace(companyEmail))
                        {
                            <div class="company-line">Email: @companyEmail</div>
                        }
                        @if (hasReadingDoctor && false)
                        {
                            <div class="patient-doctor-block">
                                <div class="section-label">แพทย์อ่านผล / Reading Doctor</div>
                                <div class="party-value patient-value-compact">@Model.ReadingDoctor!.DoctorName</div>
                            </div>
                        }
                    </div>
                </div>
                <div class="document-block">
                    <h2 class="document-title-th">ใบแจ้งหนี้</h2>
                    <div class="document-title-en">Invoice</div>
                    <table class="document-meta">
                        <tr><td class="meta-label">เลขที่เอกสาร / Doc No.</td><td class="meta-value-nowrap">@Model.InvoiceNo</td></tr>
                        <tr><td class="meta-label">วันที่เอกสาร / Date</td><td>@Model.InvoiceDate.ToString("dd/MM/") @(Model.InvoiceDate.Year + 543)</td></tr>
                        <tr><td class="meta-label">เลขที่ใบเสนอราคา / Quotation No.</td><td>@(string.IsNullOrWhiteSpace(Model.Quotation?.QuotationNumber) ? "-" : Model.Quotation!.QuotationNumber)</td></tr>
                        <tr><td class="meta-label">เลขที่อ้างอิง / Reference No.</td><td>@(string.IsNullOrWhiteSpace(Model.ReferenceNo) ? "-" : Model.ReferenceNo)</td></tr>
                        <tr><td class="meta-label">สาขา / Branch</td><td>@(Model.Branch?.BranchName ?? "-")</td></tr>
                    </table>
                    @if (hasSalespersonInfo)
                    {
                        <div class="salesperson-meta">
                            @if (!string.IsNullOrWhiteSpace(Model.Salesperson?.SalespersonName))
                            {
                                <div class="salesperson-row"><span class="meta-label">พนักงานขาย / Salesperson</span><span>@Model.Salesperson!.SalespersonName</span></div>
                            }
                            @if (!string.IsNullOrWhiteSpace(Model.Salesperson?.PhoneNumber))
                            {
                                <div class="salesperson-row"><span class="meta-label">โทรศัพท์ / Tel</span><span>@Model.Salesperson!.PhoneNumber</span></div>
                            }
                            @if (!string.IsNullOrWhiteSpace(Model.Salesperson?.Email))
                            {
                                <div class="salesperson-row"><span class="meta-label">Email</span><span>@Model.Salesperson!.Email</span></div>
                            }
                        </div>
                    }
                </div>
            </header>

            <section class="print-section party-section">
                <div class="party-grid">
                    <div>
                        <div class="section-label">ลูกค้า / Customer</div>
                        <div class="party-name">@Model.Customer?.CustomerName</div>
                    </div>
                    <div>
                        <div class="section-label">เลขประจำตัวผู้เสียภาษี / Tax ID</div>
                        <div class="party-value">@(string.IsNullOrWhiteSpace(Model.Customer?.TaxId) ? "-" : Model.Customer!.TaxId)</div>
                    </div>
                    <div style="grid-column: 1 / -1;">
                        <div class="section-label">ที่อยู่ / Address</div>
                        <div class="party-value">@(string.IsNullOrWhiteSpace(Model.Customer?.Address) ? "-" : Model.Customer!.Address)</div>
                    </div>
                </div>
            </section>

            @if (ViewData["EnablePatientInfo"] as bool? ?? true)
            {
                <section class="print-section party-section">
                    <div class="party-grid patient-grid">
                        @if (hasPatientName)
                        {
                            <div class="patient-name-block">
                                <div class="section-label">ชื่อ-สกุลคนไข้ / Patient Name</div>
                                <div class="party-value patient-value-compact">@Model.PatientFullName</div>
                            </div>
                        }
                        @if (hasPatientHn)
                        {
                            <div>
                                <div class="section-label">HN</div>
                                <div class="party-value patient-value-compact">@Model.PatientHn</div>
                            </div>
                        }
                        @if (hasPatientAge)
                        {
                            <div>
                                <div class="section-label">อายุ / Age</div>
                                <div class="party-value patient-value-compact">@Model.PatientAge</div>
                            </div>
                        }
                        @if (hasPatientGender)
                        {
                            <div>
                                <div class="section-label">เพศ / Gender</div>
                                <div class="party-value patient-value-compact">@Model.PatientGender</div>
                            </div>
                        }
                        @if (hasTreatmentRight)
                        {
                            <div>
                                <div class="section-label">สิทธิการรักษา / Treatment Right</div>
                                <div class="party-value patient-value-compact">@Model.TreatmentRight!.TreatmentRightName</div>
                            </div>
                        }
                        @if (hasPatientWard)
                        {
                            <div>
                                <div class="section-label">Ward</div>
                                <div class="party-value patient-value-compact">@Model.PatientWard</div>
                            </div>
                        }
                        @if (hasReferringDoctor)
                        {
                            <div class="patient-doctor-block">
                                <div class="section-label">แพทย์ส่ง / Referring Doctor</div>
                                <div class="party-value patient-value-compact">@Model.ReferringDoctor!.DoctorName</div>
                            </div>
                        }
                    </div>
                </section>
            }

            <section class="print-section">
                <table class="line-table">
                    <thead>
                        <tr>
                            <th class="col-no"><span class="bi-label-th">ลำดับ</span><span class="bi-label-en">No.</span></th>
                            <th class="col-description"><span class="bi-label-th">รายการ</span><span class="bi-label-en">Description</span></th>
                            <th class="col-qty"><span class="bi-label-th">จำนวน</span><span class="bi-label-en">Qty</span></th>
                            <th class="col-price"><span class="bi-label-th">ราคาต่อหน่วย</span><span class="bi-label-en">Unit Price</span></th>
                            <th class="col-discount"><span class="bi-label-th">ส่วนลด</span><span class="bi-label-en">Discount</span></th>
                            <th class="col-total"><span class="bi-label-th">จำนวนเงิน</span><span class="bi-label-en">Amount</span></th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var line in Model.InvoiceDetails.OrderBy(x => x.LineNumber))
                    {
                        var description = string.IsNullOrWhiteSpace(line.Remark)
                            ? (string.IsNullOrWhiteSpace(line.Item?.ItemName) ? "-" : line.Item!.ItemName)
                            : line.Remark;
                        var quotedQty = line.QuotedQty > 0 ? line.QuotedQty : line.Qty;
                        var showsActualQty = Math.Abs(quotedQty - line.Qty) > 0.01m;
                        <tr>
                            <td class="col-no">@line.LineNumber</td>
                            <td class="col-description">
                                <div class="line-description-text">@description</div>
                                @if (showsActualQty)
                                {
                                    <div class="line-description-extra">จำนวนออกบิลครั้งนี้ / Qty This Invoice: @line.Qty.ToString("N2")</div>
                                }
                            </td>
                            <td class="col-qty">@quotedQty.ToString("N2")</td>
                            <td class="col-price">@line.UnitPrice.ToString("N2")</td>
                            <td class="col-discount">@line.DiscountAmount.ToString("N2")</td>
                            <td class="col-total">@line.LineTotal.ToString("N2")</td>
                        </tr>
                    }
                    </tbody>
                </table>

                <div class="summary-wrap">
                    <div class="amount-text">@totalAmountText</div>
                    <table class="summary-table">
                        @if (showsInstallmentBilling)
                        {
                            <tr><td class="summary-label">ยอดอ้างอิงตามรายการ / Reference Item Total</td><td>@referenceTotal.ToString("N2")</td></tr>
                            <tr class="summary-separator"><td colspan="2"></td></tr>
                        }
                        <tr><td class="summary-label">ยอดก่อน VAT / Subtotal</td><td>@currentSummary.SubtotalBeforeVat.ToString("N2")</td></tr>
                        <tr><td class="summary-label">ส่วนลด / Discount</td><td>@currentSummary.DiscountBeforeVat.ToString("N2")</td></tr>
                        <tr><td class="summary-label">VAT</td><td>@Model.VatAmount.ToString("N2")</td></tr>
                        <tr class="summary-total"><td>ยอดรวมทั้งสิ้น / Total Amount</td><td>@Model.TotalAmount.ToString("N2")</td></tr>
                    </table>
                </div>
            </section>

            @if (hasRemark)
            {
                <section class="print-section">
                    <div class="remark-box">@Model.Remark</div>
                </section>
            }

            @if (printVariant == "2")
            {
                <div class="formal-sig-wrap">
                    <div class="formal-sig-box">
                        <div class="formal-sig-company">Neura Medical Imaging Co., Ltd.</div>
                        <div class="formal-sig-sincerely">Sincerely</div>
                        <div class="formal-sig-auth">Authorised Signature</div>
                        <div class="formal-sig-line"></div>
                        <div class="formal-sig-name">( Phawaran Suwansantisuk )</div>
                        <div class="formal-sig-title">General Manager</div>
                    </div>
                </div>
            }
            else
            {
                <section class="signature-grid">
                    <div class="signature-box">
                        <div class="signature-label">ผู้รับบริการ/ญาติ/พยาบาล / Patient / Relative / Nurse</div>
                        <div class="signature-line"></div>
                        <div>............................................................</div>
                        <div class="signature-date">วันที่ / Date ........ / ........ / ........</div>
                    </div>
                    <div class="signature-box">
                        <div class="signature-label">เจ้าหน้าที่ / Staff</div>
                        <div class="signature-line"></div>
                        <div>............................................................</div>
                        <div class="signature-date">วันที่ / Date ........ / ........ / ........</div>
                    </div>
                </section>
            }
        </div>
    </div>
    <script>
        window.addEventListener("load", () => {
            window.print();
        });
    </script>
</body>
</html>
