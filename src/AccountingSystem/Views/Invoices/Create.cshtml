@model BizCore.Models.ViewModels.InvoiceFormViewModel

@{
    ViewData["Title"] = "Create Invoice";
}

<div class="page-header">
    <div>
        <div class="page-eyebrow">Sales Module</div>
        <h1 class="page-title">Create Invoice</h1>
        <p class="page-subtitle">Create a draft invoice first or issue immediately when stock and serial assignment are ready.</p>
    </div>
    <div class="page-actions">
        <a asp-action="Index" class="btn btn-outline-secondary">Back to Invoices</a>
    </div>
</div>

<div class="card content-card">
    <div class="card-body">
        <form asp-action="Create" method="post" id="invoiceForm">
            <partial name="_Form" model="Model" />
            <div class="form-actions mt-3">
                <span class="table-meta">Save Draft keeps the invoice editable. Issue Invoice posts stock and serial movement immediately.</span>
                <div class="page-actions">
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    <button type="submit" name="submitAction" value="Draft" class="btn btn-outline-primary px-4">Save Draft</button>
                    <button type="submit" name="submitAction" value="Issue" class="btn btn-primary px-4">Issue Invoice</button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <partial name="_InvoiceEditorScripts" />
}
