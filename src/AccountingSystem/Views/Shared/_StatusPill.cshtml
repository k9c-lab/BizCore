@model string

@{
    var status = string.IsNullOrWhiteSpace(Model) ? "-" : Model.Trim();
    var normalized = status.Replace(" ", string.Empty, StringComparison.OrdinalIgnoreCase).ToLowerInvariant();
    var displayStatus = normalized switch
    {
        "draft" => "ฉบับร่าง",
        "unpaid" => "ยังไม่ชำระ",
        "submitted" => "ส่งอนุมัติแล้ว",
        "approved" => "อนุมัติแล้ว",
        "issued" => "ออกเอกสารแล้ว",
        "posted" => "บันทึกแล้ว",
        "paid" => "ชำระแล้ว",
        "fullyinvoiced" => "ออกใบแจ้งหนี้ครบแล้ว",
        "notinvoiced" => "ยังไม่ออกใบแจ้งหนี้",
        "converted" => "แปลงเอกสารแล้ว",
        "convertedtopo" => "แปลงเป็นใบสั่งซื้อแล้ว",
        "partiallypaid" => "ชำระบางส่วน",
        "partiallyinvoiced" => "ออกใบแจ้งหนี้บางส่วน",
        "partiallyreceived" => "รับบางส่วน",
        "fullyreceived" => "รับครบแล้ว",
        "completed" => "เสร็จสมบูรณ์",
        "rejected" => "ไม่อนุมัติ",
        "cancelled" => "ยกเลิกแล้ว",
        "inactive" => "ปิดใช้งาน",
        _ => status
    };
    var toneClass = normalized switch
    {
        "draft" => "status-pill-draft",
        "unpaid" => "status-pill-draft",
        "submitted" => "status-pill-submitted",
        "approved" => "status-pill-approved",
        "issued" => "status-pill-issued",
        "posted" => "status-pill-posted",
        "paid" => "status-pill-paid",
        "fullyinvoiced" => "status-pill-complete",
        "notinvoiced" => "status-pill-draft",
        "converted" => "status-pill-converted",
        "convertedtopo" => "status-pill-converted",
        "partiallypaid" => "status-pill-partial",
        "partiallyinvoiced" => "status-pill-partial",
        "partiallyreceived" => "status-pill-partial",
        "fullyreceived" => "status-pill-complete",
        "completed" => "status-pill-complete",
        "rejected" => "status-pill-rejected",
        "cancelled" => "status-pill-cancelled",
        "inactive" => "status-pill-cancelled",
        _ => "status-pill-default"
    };
}

<span class="status-pill @toneClass">@displayStatus</span>
