@using Microsoft.Extensions.Options
@inject IUserPermissionService PermissionService
@inject IOptions<SiteBrandingSettings> SiteBrandingOptions

@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
    string ActiveLink(string controller) => string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase) ? " active" : string.Empty;
    string ActiveSection(params string[] controllers) => controllers.Any(controller => string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase)) ? " active" : string.Empty;
    string? AriaCurrent(string controller) => string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase) ? "page" : null;
    bool CanUseMenu(string permissionCode) => PermissionService.HasMenuAccess(User, permissionCode);

    var canUseDashboard = CanUseMenu("Dashboard.Menu");
    var canUseFinancialOverview = CanUseMenu("FinancialOverview.Menu");
    var canUseInventoryOverview = CanUseMenu("InventoryOverview.Menu");
    var canUseAnnouncements = CanUseMenu("Announcements.Menu");
    var canUseReports = CanUseMenu("Reports.Menu");
    var showOverviewSection = canUseDashboard || canUseFinancialOverview || canUseInventoryOverview || canUseAnnouncements || canUseReports;
    var canUseSales = CanUseMenu("Sales.Menu");
    var canUseQuotations = CanUseMenu("Sales.Quotations.Menu");
    var canUseInvoices = CanUseMenu("Sales.Invoices.Menu");
    var canUseCashSales = CanUseMenu("Sales.CashSales.Menu");
    var canUseBillingNotes = CanUseMenu("Sales.BillingNotes.Menu");
    var canUsePayments = CanUseMenu("Sales.Payments.Menu");
    var canUseReceipts = CanUseMenu("Sales.Receipts.Menu");
    var showSalesSection = canUseSales || canUseQuotations || canUseInvoices || canUseCashSales || canUseBillingNotes || canUsePayments || canUseReceipts;

    var canUsePurchasing = CanUseMenu("Purchasing.Menu");
    var canUsePurchaseRequests = CanUseMenu("Purchasing.PR.Menu");
    var canUsePurchaseOrders = CanUseMenu("Purchasing.PO.Menu");
    var canViewReceiving = CanUseMenu("Purchasing.Receiving.Menu");
    var canUseSupplierPayments = CanUseMenu("Purchasing.SupplierPayments.Menu");
    var showPurchasingSection = canUsePurchasing || canUsePurchaseRequests || canUsePurchaseOrders || canViewReceiving || canUseSupplierPayments;

    var canUseInventory = CanUseMenu("Inventory.Menu");
    var canUseStockInquiry = CanUseMenu("Inventory.StockInquiry.Menu");
    var canUseSerialInquiry = CanUseMenu("Inventory.SerialInquiry.Menu");
    var canUseStockLedger = CanUseMenu("Inventory.StockLedger.Menu");
    var canUseStockAudit = CanUseMenu("Inventory.StockAudit.Menu");
    var canUseStockTransfers = CanUseMenu("Inventory.StockTransfers.Menu");
    var canUseStockIssues = CanUseMenu("Inventory.StockIssues.Menu");
    var canUseStockAdjustments = CanUseMenu("Inventory.StockAdjustments.Menu");
    var showInventorySection = canUseInventory || canUseStockInquiry || canUseSerialInquiry || canUseStockLedger || canUseStockAudit || canUseStockTransfers || canUseStockIssues || canUseStockAdjustments;

    var canUseWarranty = CanUseMenu("Warranty.Menu");
    var canUseCustomerClaims = CanUseMenu("Warranty.CustomerClaims.Menu");
    var canUseSupplierClaims = CanUseMenu("Warranty.SupplierClaims.Menu");
    var showWarrantySection = canUseWarranty || canUseCustomerClaims || canUseSupplierClaims;

    var canUseMasterData = CanUseMenu("MasterData.Menu");
    var canUseBranches = CanUseMenu("MasterData.Branches.Menu");
    var canUseCustomers = CanUseMenu("MasterData.Customers.Menu");
    var canUseSuppliers = CanUseMenu("MasterData.Suppliers.Menu");
    var canUseSalespersons = CanUseMenu("MasterData.Salespersons.Menu");
    var canUseTreatmentRights = CanUseMenu("MasterData.TreatmentRights.Menu");
    var canUseReferringDoctors = CanUseMenu("MasterData.ReferringDoctors.Menu");
    var canUseReadingDoctors = CanUseMenu("MasterData.ReadingDoctors.Menu");
    var canUseItems = CanUseMenu("MasterData.Items.Menu");
    var canUseUsers = CanUseMenu("MasterData.Users.Menu");
    var canUseRolePermissions = CanUseMenu("MasterData.RolePermissions.Menu");
    var canUsePriceLevels = CanUseMenu("MasterData.PriceLevels.Menu");
    var canUseSettings = CanUseMenu("MasterData.Settings.Menu");
    var showMasterDataSection = canUseMasterData || canUseBranches || canUseCustomers || canUseSuppliers || canUseSalespersons || canUseTreatmentRights || canUseReferringDoctors || canUseReadingDoctors || canUseItems || canUseUsers || canUseRolePermissions || canUsePriceLevels || canUseSettings;
    var branchName = User.FindFirst("CanAccessAllBranches")?.Value == "true" && !User.IsInRole("BranchAdmin")
        ? "All Branches"
        : User.FindFirst("BranchName")?.Value;
    var branding = SiteBrandingOptions.Value ?? new SiteBrandingSettings();
    var siteName = string.IsNullOrWhiteSpace(branding.SiteName) ? "BizCore" : branding.SiteName;
    var siteSubtitle = string.IsNullOrWhiteSpace(branding.SiteSubtitle) ? "BizCore" : branding.SiteSubtitle;
    var environmentLabel = string.IsNullOrWhiteSpace(branding.EnvironmentLabel) ? null : branding.EnvironmentLabel;
}
<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @siteName</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/BizCore.styles.css" asp-append-version="true" />
</head>
<body>
    <div class="app-layout">
        <aside class="app-sidebar">
            <div class="sidebar-brand">
                <a class="sidebar-brand-link" asp-controller="Welcome" asp-action="Index">@siteName</a>
                @if (!string.IsNullOrWhiteSpace(environmentLabel))
                {
                    <div class="site-environment-label">@environmentLabel</div>
                }
                <div class="sidebar-caption">@siteSubtitle</div>
            </div>

            <nav class="sidebar-nav">
                @if (showOverviewSection)
                {
                    <div class="sidebar-section sidebar-section-overview@(ActiveSection("Home", "Reports", "FinancialOverview", "InventoryOverview", "Announcements"))">
                        <div class="sidebar-section-title">ภาพรวม</div>
                        @if (canUseDashboard)
                        {
                            <a class="sidebar-link@(ActiveLink("Home"))" asp-controller="Home" asp-action="Index" aria-current="@AriaCurrent("Home")">แดชบอร์ด</a>
                        }
                        @if (canUseFinancialOverview)
                        {
                            <a class="sidebar-link@(ActiveLink("FinancialOverview"))" asp-controller="FinancialOverview" asp-action="Index" aria-current="@AriaCurrent("FinancialOverview")">ภาพรวมการเงิน</a>
                        }
                        @if (canUseInventoryOverview)
                        {
                            <a class="sidebar-link@(ActiveLink("InventoryOverview"))" asp-controller="InventoryOverview" asp-action="Index" aria-current="@AriaCurrent("InventoryOverview")">ภาพรวมคลังสินค้า</a>
                        }
                        @if (canUseAnnouncements)
                        {
                            <a class="sidebar-link@(ActiveLink("Announcements"))" asp-controller="Announcements" asp-action="Index" aria-current="@AriaCurrent("Announcements")">ประกาศ</a>
                        }
                        @if (canUseReports)
                        {
                            <a class="sidebar-link@(ActiveLink("Reports"))" asp-controller="Reports" asp-action="Index" aria-current="@AriaCurrent("Reports")">รายงาน</a>
                        }
                    </div>
                }

                @if (showSalesSection)
                {
                    <div class="sidebar-section sidebar-section-sales@(ActiveSection("Quotations", "Invoices", "CashSales", "BillingNotes", "Payments", "Receipts"))">
                        <div class="sidebar-section-title">งานขาย</div>
                        @if (canUseQuotations)
                        {
                            <a class="sidebar-link@(ActiveLink("Quotations"))" asp-controller="Quotations" asp-action="Index" aria-current="@AriaCurrent("Quotations")">ใบเสนอราคา</a>
                        }
                        @if (canUseInvoices)
                        {
                            <a class="sidebar-link@(ActiveLink("Invoices"))" asp-controller="Invoices" asp-action="Index" aria-current="@AriaCurrent("Invoices")">ใบแจ้งหนี้</a>
                        }
                        @if (canUseCashSales)
                        {
                            <a class="sidebar-link@(ActiveLink("CashSales"))" asp-controller="CashSales" asp-action="Index" aria-current="@AriaCurrent("CashSales")">ขายบุคคลทั่วไป</a>
                        }
                        @if (canUseBillingNotes)
                        {
                            <a class="sidebar-link@(ActiveLink("BillingNotes"))" asp-controller="BillingNotes" asp-action="Index" aria-current="@AriaCurrent("BillingNotes")">ใบวางบิล</a>
                        }
                        @if (canUsePayments)
                        {
                            <a class="sidebar-link@(ActiveLink("Payments"))" asp-controller="Payments" asp-action="Index" aria-current="@AriaCurrent("Payments")">รับชำระเงิน</a>
                        }
                        @if (canUseReceipts)
                        {
                            <a class="sidebar-link@(ActiveLink("Receipts"))" asp-controller="Receipts" asp-action="Index" aria-current="@AriaCurrent("Receipts")">ใบเสร็จรับเงิน</a>
                        }
                    </div>
                }

                @if (showPurchasingSection)
                {
                    <div class="sidebar-section sidebar-section-purchasing@(ActiveSection("PurchaseRequests", "PurchaseOrders", "Receivings", "SupplierPayments"))">
                        <div class="sidebar-section-title">งานจัดซื้อ</div>
                        @if (canUsePurchaseRequests)
                        {
                            <a class="sidebar-link@(ActiveLink("PurchaseRequests"))" asp-controller="PurchaseRequests" asp-action="Index" aria-current="@AriaCurrent("PurchaseRequests")">ใบขอซื้อ</a>
                        }
                        @if (canUsePurchaseOrders)
                        {
                            <a class="sidebar-link@(ActiveLink("PurchaseOrders"))" asp-controller="PurchaseOrders" asp-action="Index" aria-current="@AriaCurrent("PurchaseOrders")">ใบสั่งซื้อ</a>
                        }
                        @if (canViewReceiving)
                        {
                            <a class="sidebar-link@(ActiveLink("Receivings"))" asp-controller="Receivings" asp-action="Index" aria-current="@AriaCurrent("Receivings")">รับสินค้า</a>
                        }
                        @if (canUseSupplierPayments)
                        {
                            <a class="sidebar-link@(ActiveLink("SupplierPayments"))" asp-controller="SupplierPayments" asp-action="Index" aria-current="@AriaCurrent("SupplierPayments")">ชำระเงินผู้ขาย</a>
                        }
                    </div>
                }

                @if (showInventorySection)
                {
                    <div class="sidebar-section sidebar-section-inventory@(ActiveSection("StockInquiry", "SerialInquiry", "StockLedger", "StockAudit", "StockTransfers", "StockIssues", "StockAdjustments"))">
                        <div class="sidebar-section-title">คลังสินค้า</div>
                        @if (canUseStockInquiry)
                        {
                            <a class="sidebar-link@(ActiveLink("StockInquiry"))" asp-controller="StockInquiry" asp-action="Index" aria-current="@AriaCurrent("StockInquiry")">สอบถามสต็อก</a>
                        }
                        @if (canUseSerialInquiry)
                        {
                            <a class="sidebar-link@(ActiveLink("SerialInquiry"))" asp-controller="SerialInquiry" asp-action="Index" aria-current="@AriaCurrent("SerialInquiry")">สอบถาม Serial</a>
                        }
                        @if (canUseStockLedger)
                        {
                            <a class="sidebar-link@(ActiveLink("StockLedger"))" asp-controller="StockLedger" asp-action="Index" aria-current="@AriaCurrent("StockLedger")">สมุดสต็อก</a>
                        }
                        @if (canUseStockAudit)
                        {
                            <a class="sidebar-link@(ActiveLink("StockAudit"))" asp-controller="StockAudit" asp-action="Index" aria-current="@AriaCurrent("StockAudit")">ตรวจนับสต็อก</a>
                        }
                        @if (canUseStockTransfers)
                        {
                            <a class="sidebar-link@(ActiveLink("StockTransfers"))" asp-controller="StockTransfers" asp-action="Index" aria-current="@AriaCurrent("StockTransfers")">โอนย้ายสต็อก</a>
                        }
                        @if (canUseStockIssues)
                        {
                            <a class="sidebar-link@(ActiveLink("StockIssues"))" asp-controller="StockIssues" asp-action="Index" aria-current="@AriaCurrent("StockIssues")">เบิกสต็อก</a>
                        }
                        @if (canUseStockAdjustments)
                        {
                            <a class="sidebar-link@(ActiveLink("StockAdjustments"))" asp-controller="StockAdjustments" asp-action="Index" aria-current="@AriaCurrent("StockAdjustments")">
                                <span class="sidebar-link-icon" aria-hidden="true">
                                    <svg viewBox="0 0 24 24" fill="none" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                        <line x1="4" y1="21" x2="4" y2="14" /><line x1="4" y1="10" x2="4" y2="3" />
                                        <line x1="12" y1="21" x2="12" y2="12" /><line x1="12" y1="8" x2="12" y2="3" />
                                        <line x1="20" y1="21" x2="20" y2="16" /><line x1="20" y1="12" x2="20" y2="3" />
                                        <line x1="1" y1="14" x2="7" y2="14" /><line x1="9" y1="8" x2="15" y2="8" /><line x1="17" y1="16" x2="23" y2="16" />
                                    </svg>
                                </span>
                                ปรับสต็อก
                            </a>
                        }
                    </div>
                }

                @if (showWarrantySection)
                {
                    <div class="sidebar-section sidebar-section-warranty@(ActiveSection("SupplierClaims", "CustomerClaims"))">
                        <div class="sidebar-section-title">งานเคลม</div>
                        @if (canUseCustomerClaims)
                        {
                            <a class="sidebar-link@(ActiveLink("CustomerClaims"))" asp-controller="CustomerClaims" asp-action="Index" aria-current="@AriaCurrent("CustomerClaims")">เคลมลูกค้า</a>
                        }
                        @if (canUseSupplierClaims)
                        {
                            <a class="sidebar-link@(ActiveLink("SupplierClaims"))" asp-controller="SupplierClaims" asp-action="Index" aria-current="@AriaCurrent("SupplierClaims")">เคลมผู้ขาย</a>
                        }
                    </div>
                }

                @if (showMasterDataSection)
                {
                    <div class="sidebar-section sidebar-section-master@(ActiveSection("Branches", "Customers", "Suppliers", "Salespersons", "TreatmentRights", "ReferringDoctors", "ReadingDoctors", "Items", "Users", "RolePermissions", "PriceLevels", "Settings"))">
                        <div class="sidebar-section-title">ข้อมูลหลัก</div>
                        @if (canUseBranches)
                        {
                            <a class="sidebar-link@(ActiveLink("Branches"))" asp-controller="Branches" asp-action="Index" aria-current="@AriaCurrent("Branches")">สาขา</a>
                        }
                        @if (canUseCustomers)
                        {
                            <a class="sidebar-link@(ActiveLink("Customers"))" asp-controller="Customers" asp-action="Index" aria-current="@AriaCurrent("Customers")">ลูกค้า</a>
                        }
                        @if (canUseSuppliers)
                        {
                            <a class="sidebar-link@(ActiveLink("Suppliers"))" asp-controller="Suppliers" asp-action="Index" aria-current="@AriaCurrent("Suppliers")">ผู้ขาย</a>
                        }
                        @if (canUseSalespersons)
                        {
                            <a class="sidebar-link@(ActiveLink("Salespersons"))" asp-controller="Salespersons" asp-action="Index" aria-current="@AriaCurrent("Salespersons")">พนักงานขาย</a>
                        }
                        @if (canUseTreatmentRights)
                        {
                            <a class="sidebar-link@(ActiveLink("TreatmentRights"))" asp-controller="TreatmentRights" asp-action="Index" aria-current="@AriaCurrent("TreatmentRights")">สิทธิการรักษา</a>
                        }
                        @if (canUseReferringDoctors)
                        {
                            <a class="sidebar-link@(ActiveLink("ReferringDoctors"))" asp-controller="ReferringDoctors" asp-action="Index" aria-current="@AriaCurrent("ReferringDoctors")">แพทย์ส่ง</a>
                        }
                        @if (canUseReadingDoctors)
                        {
                            <a class="sidebar-link@(ActiveLink("ReadingDoctors"))" asp-controller="ReadingDoctors" asp-action="Index" aria-current="@AriaCurrent("ReadingDoctors")">
                                <span class="sidebar-link-icon" aria-hidden="true">
                                    <svg viewBox="0 0 24 24" fill="none" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M2.5 12s3.5-6 9.5-6 9.5 6 9.5 6-3.5 6-9.5 6-9.5-6-9.5-6Z" />
                                        <circle cx="12" cy="12" r="3.2" />
                                    </svg>
                                </span>
                                <span>แพทย์อ่านผล</span>
                            </a>
                        }
                        @if (canUseItems)
                        {
                            <a class="sidebar-link@(ActiveLink("Items"))" asp-controller="Items" asp-action="Index" aria-current="@AriaCurrent("Items")">สินค้าและบริการ</a>
                        }
                        @if (canUseUsers)
                        {
                            <a class="sidebar-link@(ActiveLink("Users"))" asp-controller="Users" asp-action="Index" aria-current="@AriaCurrent("Users")">ผู้ใช้งาน</a>
                        }
                        @if (canUseRolePermissions)
                        {
                            <a class="sidebar-link@(ActiveLink("RolePermissions"))" asp-controller="RolePermissions" asp-action="Index" aria-current="@AriaCurrent("RolePermissions")">สิทธิ์ตามบทบาท</a>
                        }
                        @if (canUsePriceLevels)
                        {
                            <a class="sidebar-link@(ActiveLink("PriceLevels"))" asp-controller="PriceLevels" asp-action="Index" aria-current="@AriaCurrent("PriceLevels")">ระดับราคา</a>
                        }
                        @if (canUseSettings)
                        {
                            <a class="sidebar-link@(ActiveLink("Settings"))" asp-controller="Settings" asp-action="Index" aria-current="@AriaCurrent("Settings")">ตั้งค่า</a>
                        }
                    </div>
                }
            </nav>

            <div class="sidebar-footer">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <div class="sidebar-user">
                        <div class="sidebar-user-name">@User.FindFirst(System.Security.Claims.ClaimTypes.GivenName)?.Value</div>
                        <div class="sidebar-user-role">@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</div>
                        @if (!string.IsNullOrWhiteSpace(branchName))
                        {
                            <div class="sidebar-user-role">@branchName</div>
                        }
                    </div>
                    <a class="sidebar-logout sidebar-account-link" asp-controller="Account" asp-action="Profile">My Profile</a>
                    <form asp-controller="Account" asp-action="Logout" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="sidebar-logout">ออกจากระบบ</button>
                    </form>
                }
                else
                {
                    <div class="sidebar-footer-site">@siteName</div>
                    <span>@siteSubtitle</span>
                }
            </div>
        </aside>

        <div class="app-main">
            <header class="mobile-topbar">
                <a class="sidebar-brand-link" asp-controller="Welcome" asp-action="Index">@siteName</a>
            </header>

            <div class="page-shell">
                <main role="main">
                    @RenderBody()
                </main>
            </div>

        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
