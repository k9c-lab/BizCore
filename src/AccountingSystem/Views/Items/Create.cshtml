@model BizCore.Models.Entities.Item

@{
    ViewData["Title"] = "เพิ่มสินค้า";
}

<div class="page-header">
    <div>
        <div class="page-eyebrow">ข้อมูลหลัก</div>
        <h1 class="page-title">เพิ่มสินค้าและบริการ</h1>
        </div>
    <div class="page-actions">
        <button type="submit" form="itemForm" class="btn btn-primary px-4">บันทึก</button>
        <a asp-action="Index" class="btn btn-outline-secondary">กลับไปรายการ</a>
    </div>
</div>

<div class="card content-card">
    <div class="card-body">
        <div class="workflow-info workflow-info-info mb-3">
            กำหนด <strong>ราคาต่อหน่วย</strong> ของสินค้าได้ที่นี่ โดยระบบจะใช้เป็นราคาขายตั้งต้นในใบเสนอราคาและใบแจ้งหนี้เมื่อใช้งานในโหมดราคาเดียว
        </div>
        <form asp-action="Create" method="post" id="itemForm">
            <partial name="_Form" model="Model" />
            <div class="form-actions mt-3">
                <span class="table-meta">หลังบันทึกแล้ว หากรายการนี้ต้องมีราคาขายหลายแบบ สามารถเข้าไปกำหนดต่อที่ <strong>ราคาขาย</strong></span>
                <div class="page-actions">
                    <a asp-action="Index" class="btn btn-outline-secondary">ยกเลิก</a>
                    <button type="submit" class="btn btn-primary px-4">บันทึก</button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (() => {
            const itemTypeSelect = document.getElementById("ItemType");
            const itemCodeInput = document.getElementById("ItemCode");
            const codeMapElement = document.getElementById("itemNextCodeMapData");
            if (!itemTypeSelect || !itemCodeInput || !codeMapElement) {
                return;
            }

            const nextCodeMap = JSON.parse(codeMapElement.textContent || "{}");
            const updateCodePreview = () => {
                const nextCode = nextCodeMap[itemTypeSelect.value];
                if (nextCode) {
                    itemCodeInput.value = nextCode;
                }
            };

            itemTypeSelect.addEventListener("change", updateCodePreview);
            updateCodePreview();
        })();
    </script>
}
