@model BizCore.Models.Entities.Item
@using Microsoft.AspNetCore.Mvc.Rendering
@using System.Text.Json
@{
    var codeReadOnly = (bool?)ViewData["CodeReadOnly"] == true;
    var itemTypeOptions = ViewData["ItemTypeOptions"] as IEnumerable<SelectListItem> ?? Enumerable.Empty<SelectListItem>();
    var nextItemCodeMap = ViewData["NextItemCodeMap"] as IDictionary<string, string> ?? new Dictionary<string, string>();
}

<div asp-validation-summary="ModelOnly" class="form-alert"></div>

<div class="form-shell">
    <div class="form-section quotation-header-section">
        <div class="form-section-title">Item Profile</div>
        <div class="row g-2 quotation-header-grid">
            <div class="col-lg-3 col-md-6">
                <label asp-for="ItemCode" class="form-label"></label>
                <input asp-for="ItemCode" class="form-control" readonly="@codeReadOnly" id="ItemCode" />
                @if (codeReadOnly)
                {
                    <div class="form-text">Auto-generated by item type: PRD, SRV, or SPP.</div>
                }
                <span asp-validation-for="ItemCode" class="text-danger"></span>
            </div>
            <div class="col-lg-5 col-md-6">
                <label asp-for="ItemName" class="form-label"></label>
                <input asp-for="ItemName" class="form-control" />
                <span asp-validation-for="ItemName" class="text-danger"></span>
            </div>
            <div class="col-lg-4 col-md-6">
                <label asp-for="PartNumber" class="form-label"></label>
                <input asp-for="PartNumber" class="form-control" />
                <span asp-validation-for="PartNumber" class="text-danger"></span>
            </div>
            <div class="col-lg-4 col-md-6">
                <label asp-for="ItemType" class="form-label"></label>
                <select asp-for="ItemType" asp-items="itemTypeOptions" class="form-select" id="ItemType"></select>
                <span asp-validation-for="ItemType" class="text-danger"></span>
            </div>
            <div class="col-lg-4 col-md-6">
                <label asp-for="Unit" class="form-label"></label>
                <input asp-for="Unit" class="form-control" />
                <div class="form-text">Examples: EA, Set, Box, Job.</div>
                <span asp-validation-for="Unit" class="text-danger"></span>
            </div>
            <div class="col-lg-4 col-md-6">
                <label asp-for="UnitPrice" class="form-label"></label>
                <input asp-for="UnitPrice" class="form-control" />
                <div class="form-text">Public selling price shown on sales transactions.</div>
                <span asp-validation-for="UnitPrice" class="text-danger"></span>
            </div>
        </div>
    </div>

    <div class="form-section">
        <div class="form-section-title">Stock Controls</div>
        <div class="row g-2 quotation-header-grid">
            <div class="col-lg-4 col-md-6">
                <label asp-for="CurrentStock" class="form-label"></label>
                <input asp-for="CurrentStock" class="form-control" />
                <div class="form-text">Current on-hand quantity at product-master level.</div>
                <span asp-validation-for="CurrentStock" class="text-danger"></span>
            </div>
            <div class="col-lg-8 col-md-12">
                <label class="form-label">Control Flags</label>
                <div class="item-control-group">
                    <label class="quotation-inline-check" asp-for="TrackStock">
                        <input asp-for="TrackStock" class="form-check-input" />
                        <span>Track Stock</span>
                    </label>
                    <label class="quotation-inline-check" asp-for="IsSerialControlled">
                        <input asp-for="IsSerialControlled" class="form-check-input" />
                        <span>Serial Controlled</span>
                    </label>
                    <label class="quotation-inline-check" asp-for="IsActive">
                        <input asp-for="IsActive" class="form-check-input" />
                        <span>Active</span>
                    </label>
                </div>
                <span asp-validation-for="TrackStock" class="text-danger"></span>
                <span asp-validation-for="IsSerialControlled" class="text-danger"></span>
            </div>
        </div>
    </div>
</div>

@if (codeReadOnly)
{
    <script type="application/json" id="itemNextCodeMapData">@Html.Raw(JsonSerializer.Serialize(nextItemCodeMap))</script>
}
