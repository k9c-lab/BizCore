@model BizCore.Models.ViewModels.PaginatedList<BizCore.Models.Entities.Item>

@{
    ViewData["Title"] = "Items";
    var search = ViewData["Search"] as string;
    var itemType = ViewData["ItemType"] as string;
    var status = ViewData["Status"] as string;
}

<div class="page-header">
    <div>
        <div class="page-eyebrow">Core Module</div>
        <h1 class="page-title">Items</h1>
        <p class="page-subtitle">Manage stock and sellable items with a more readable catalog-style table.</p>
    </div>
    <div class="page-actions">
        <a asp-action="Create" class="btn btn-primary px-4">New Item</a>
    </div>
</div>

<div class="card content-card table-card">
    <div class="table-card-header">
        <div>
            <h2 class="section-title">Item Catalog</h2>
            <p class="section-subtitle">Operational inventory list with pricing and control flags surfaced clearly.</p>
        </div>
        <div class="table-meta">@Model.TotalCount records</div>
    </div>
    <div class="card-body">
        <form method="get" class="list-filter-bar">
            <div class="list-filter-field grow">
                <label class="form-label" for="search">Search</label>
                <input id="search" name="search" value="@search" class="form-control" placeholder="Code, name, or part number" />
            </div>
            <div class="list-filter-field">
                <label class="form-label" for="itemType">Type</label>
                <select id="itemType" name="itemType" class="form-select">
                    <option value="">All</option>
                    <option value="Product" selected="@(itemType == "Product")">Product</option>
                    <option value="Service" selected="@(itemType == "Service")">Service</option>
                    <option value="Spare Part" selected="@(itemType == "Spare Part")">Spare Part</option>
                </select>
            </div>
            <div class="list-filter-field">
                <label class="form-label" for="status">Status</label>
                <select id="status" name="status" class="form-select">
                    <option value="">All</option>
                    <option value="Active" selected="@(status == "Active")">Active</option>
                    <option value="Inactive" selected="@(status == "Inactive")">Inactive</option>
                </select>
            </div>
            <div class="list-filter-actions">
                <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
                <button type="submit" class="btn btn-primary">Search</button>
            </div>
        </form>
        <div class="table-responsive">
            <table class="table entity-table align-middle">
                <thead>
                    <tr>
                        <th>Item Code</th>
                        <th>Item Name</th>
                        <th>Part Number</th>
                        <th>Type</th>
                        <th>Unit</th>
                        <th>Unit Price</th>
                        <th>Stock</th>
                        <th>Serial</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.Any())
                {
                @foreach (var item in Model)
                {
                    <tr>
                        <td><span class="code-chip">@item.ItemCode</span></td>
                        <td class="fw-semibold">@item.ItemName</td>
                        <td>@(string.IsNullOrWhiteSpace(item.PartNumber) ? "-" : item.PartNumber)</td>
                        <td>@item.ItemType</td>
                        <td>@item.Unit</td>
                        <td>@item.UnitPrice.ToString("N2")</td>
                        <td>@(item.TrackStock ? item.CurrentStock.ToString("N2") : "-")</td>
                        <td>@(item.IsSerialControlled ? "Serial" : "Standard")</td>
                        <td class="text-end">
                            <div class="table-actions">
                                <a asp-action="Details" asp-route-id="@item.ItemId" class="btn btn-sm btn-outline-secondary">Details</a>
                                @if (item.TrackStock)
                                {
                                    <a asp-controller="StockLedger" asp-action="Index" asp-route-itemId="@item.ItemId" class="btn btn-sm btn-outline-primary">Ledger</a>
                                }
                                <a asp-action="Edit" asp-route-id="@item.ItemId" class="btn btn-sm btn-outline-primary">Edit</a>
                                <a asp-action="Delete" asp-route-id="@item.ItemId" class="btn btn-sm btn-outline-danger">Delete</a>
                            </div>
                        </td>
                    </tr>
                }
                }
                else
                {
                    <tr>
                        <td colspan="9" class="table-empty">No items yet. Add products or services to start testing sales and inventory flows.</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
        <partial name="_Pager" model="Model.Pagination" />
    </div>
</div>
