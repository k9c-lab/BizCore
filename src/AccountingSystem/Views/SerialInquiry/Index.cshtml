@model BizCore.Models.ViewModels.SerialInquiryPageViewModel

@{
    ViewData["Title"] = "สอบถาม Serial";
}

<div class="page-header">
    <div>
        <div class="page-eyebrow">สอบถามข้อมูลคลังสินค้า</div>
        <h1 class="page-title">สอบถาม Serial</h1>
        </div>
</div>

<div class="card content-card table-card">
    <div class="table-card-header">
        <div>
            <h2 class="section-title">ทะเบียน Serial</h2>
            </div>
        <div class="table-meta">@Model.Pagination.TotalCount รายการ</div>
    </div>
    <div class="card-body">
        <form method="get" class="list-filter-bar">
            <div class="list-filter-field grow">
                <label for="search" class="form-label">ค้นหา</label>
                <input id="search" name="search" value="@Model.Search" class="form-control" placeholder="Serial, สินค้า, Part Number, ผู้ขาย, ลูกค้า หรือใบแจ้งหนี้" />
            </div>
            <div class="list-filter-field">
                <label for="status" class="form-label">สถานะ</label>
                <select id="status" name="status" class="form-select">
                    <option value="">ทั้งหมด</option>
                    <option value="InStock" selected="@(Model.Status == "InStock")">คงคลัง</option>
                    <option value="Sold" selected="@(Model.Status == "Sold")">ขายแล้ว</option>
                    <option value="CustomerClaim" selected="@(Model.Status == "CustomerClaim")">เคลมลูกค้า</option>
                    <option value="ClaimedToSupplier" selected="@(Model.Status == "ClaimedToSupplier")">ส่งเคลมผู้ขาย</option>
                    <option value="Replaced" selected="@(Model.Status == "Replaced")">เปลี่ยนสินค้าแล้ว</option>
                    <option value="Defective" selected="@(Model.Status == "Defective")">เสีย/ชำรุด</option>
                    <option value="Available" selected="@(Model.Status == "Available")">พร้อมใช้งาน</option>
                </select>
            </div>
            @if (Model.CanAccessAllBranches)
            {
                <div class="list-filter-field">
                    <label for="branchId" class="form-label">สาขา</label>
                    <select id="branchId" name="branchId" asp-items="Model.BranchOptions" class="form-select"></select>
                </div>
            }
            <div class="list-filter-actions">
                <a asp-action="Index" class="btn btn-outline-secondary">ล้างค่า</a>
                <button type="submit" class="btn btn-primary">ค้นหา</button>
            </div>
        </form>
        @if (Model.Results.Any())
        {
            <div class="inquiry-card-list">
                @foreach (var serial in Model.Results)
                {
                    var isWarrantyExpired = !serial.SupplierWarrantyEndDate.HasValue || serial.SupplierWarrantyEndDate.Value.Date < DateTime.Today;
                    <article class="inquiry-card inquiry-card-compact">
                        <div class="inquiry-card-top">
                            <div class="inquiry-card-title-group">
                                <span class="code-chip">@serial.SerialNo</span>
                                <div>
                                    <h3 class="inquiry-card-title">@serial.ItemName</h3>
                                    <p class="inquiry-card-subtitle">@serial.ItemCode | @serial.PartNumber</p>
                                </div>
                            </div>
                            <div class="page-actions">
                                <span class="status-pill active">@serial.Status</span>
                                @if (serial.CanCustomerClaim)
                                {
                                    <a asp-controller="CustomerClaims" asp-action="Create" asp-route-serialId="@serial.SerialId" class="btn btn-sm btn-outline-success">เปิดเคลมลูกค้า</a>
                                }
                                else
                                {
                                    <button type="button" class="btn btn-sm btn-outline-secondary" disabled title="@serial.CustomerClaimBlockedReason">เปิดเคลมลูกค้า</button>
                                }
                                @if (isWarrantyExpired)
                                {
                                    <span class="status-pill inactive">ประกันผู้ขายหมดอายุ</span>
                                    <button type="button" class="btn btn-sm btn-outline-secondary" disabled>เคลมผู้ขาย</button>
                                }
                                else
                                {
                                    <a asp-controller="SupplierClaims" asp-action="Create" asp-route-serialId="@serial.SerialId" class="btn btn-sm btn-outline-primary">เคลมผู้ขาย</a>
                                }
                            </div>
                        </div>

                        <div class="inquiry-card-grid">
                            <div class="inquiry-card-field">
                                <span class="inquiry-card-label">สาขา</span>
                                <span class="inquiry-card-value">@serial.BranchName</span>
                            </div>
                            <div class="inquiry-card-field">
                                <span class="inquiry-card-label">ผู้ขาย</span>
                                <span class="inquiry-card-value">@serial.SupplierName</span>
                            </div>
                            <div class="inquiry-card-field">
                                <span class="inquiry-card-label">ลูกค้า</span>
                                <span class="inquiry-card-value">@serial.CurrentCustomerName</span>
                            </div>
                            <div class="inquiry-card-field">
                                <span class="inquiry-card-label">ประกันผู้ขาย</span>
                                <span class="inquiry-card-value">@(serial.SupplierWarrantyStartDate?.ToString("dd MMM yyyy") ?? "-") ถึง @(serial.SupplierWarrantyEndDate?.ToString("dd MMM yyyy") ?? "-")</span>
                            </div>
                            <div class="inquiry-card-field">
                                <span class="inquiry-card-label">เลขที่ใบแจ้งหนี้</span>
                                <span class="inquiry-card-value">@serial.InvoiceCode</span>
                            </div>
                            <div class="inquiry-card-field">
                                <span class="inquiry-card-label">ประกันลูกค้า</span>
                                <span class="inquiry-card-value">@(serial.CustomerWarrantyStartDate?.ToString("dd MMM yyyy") ?? "-") ถึง @(serial.CustomerWarrantyEndDate?.ToString("dd MMM yyyy") ?? "-")</span>
                            </div>
                        </div>
                    </article>
                }
            </div>
        }
        else
        {
            <div class="table-empty">ไม่พบข้อมูล Serial ตามเงื่อนไขที่ค้นหา</div>
        }
        <partial name="_Pager" model="Model.Pagination" />
    </div>
</div>

