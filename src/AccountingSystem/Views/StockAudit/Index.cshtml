@model BizCore.Models.ViewModels.StockAuditPageViewModel

@{
    ViewData["Title"] = "ตรวจสอบสต็อก";
}

<div class="page-header">
    <div>
        <div class="page-eyebrow">ตรวจสอบข้อมูลคลังสินค้า</div>
        <h1 class="page-title">ตรวจสอบสต็อก</h1>
        </div>
</div>

<div class="quote-summary-grid mb-3">
    <div class="quote-summary-card">
        <span class="quote-summary-label">รายการที่ตรวจสอบ</span>
        <p class="quote-summary-value">@Model.TotalRows</p>
    </div>
    <div class="quote-summary-card">
        <span class="quote-summary-label">ปกติ</span>
        <p class="quote-summary-value">@Model.OkRows</p>
    </div>
    <div class="quote-summary-card">
        <span class="quote-summary-label">ไม่ตรงกัน</span>
        <p class="quote-summary-value">@Model.MismatchRows</p>
    </div>
</div>

<div class="card content-card table-card">
    <div class="table-card-header">
        <div>
            <h2 class="section-title">ผลการตรวจสอบ</h2>
            </div>
        <div class="table-meta">@Model.Pagination.TotalCount รายการ</div>
    </div>
    <div class="card-body">
        <form method="get" class="list-filter-bar">
            <div class="list-filter-field grow">
                <label class="form-label" for="search">ค้นหา</label>
                <input id="search" name="search" value="@Model.Search" class="form-control" placeholder="รหัสสินค้า, ชื่อสินค้า หรือ Part Number" />
            </div>
            <div class="list-filter-field">
                <label class="form-label" for="auditStatus">สถานะ</label>
                <select id="auditStatus" name="auditStatus" class="form-select">
                    <option value="">ทั้งหมด</option>
                    <option value="Mismatch" selected="@(Model.AuditStatus == "Mismatch")">ไม่ตรงกัน</option>
                    <option value="OK" selected="@(Model.AuditStatus == "OK")">ปกติ</option>
                </select>
            </div>
            @if (Model.CanAccessAllBranches)
            {
                <div class="list-filter-field">
                    <label class="form-label" for="branchId">สาขา</label>
                    <select id="branchId" name="branchId" asp-items="Model.BranchOptions" class="form-select"></select>
                </div>
            }
            <div class="list-filter-actions">
                <a asp-action="Index" class="btn btn-outline-secondary">ล้างค่า</a>
                <button type="submit" class="btn btn-primary">ค้นหา</button>
            </div>
        </form>

        <div class="table-responsive">
            <table class="table entity-table align-middle">
                <thead>
                    <tr>
                        <th>สาขา</th>
                        <th>สินค้า</th>
                        <th>Serial</th>
                        <th class="text-end">ยอดคงเหลือ</th>
                        <th class="text-end">Serial คงคลัง</th>
                        <th class="text-end">สมุดสต็อกสุทธิ</th>
                        <th class="text-end">ผลต่างคงเหลือ-สมุด</th>
                        <th class="text-end">ผลต่างคงเหลือ-Serial</th>
                        <th>สถานะ</th>
                        <th>ปัญหาที่พบ</th>
                        <th class="text-end">การทำงาน</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.Results.Any())
                {
                    @foreach (var row in Model.Results)
                    {
                        <tr>
                            <td>
                                <div class="fw-semibold">@row.BranchCode</div>
                                <div class="table-meta">@row.BranchName</div>
                            </td>
                            <td>
                                <div class="fw-semibold">@row.ItemCode</div>
                                <div class="table-meta">@row.ItemName</div>
                                <div class="table-meta">@row.PartNumber</div>
                            </td>
                            <td>@(row.IsSerialControlled ? "ใช่" : "ไม่ใช่")</td>
                            <td class="text-end">@row.BalanceQty.ToString("N2")</td>
                            <td class="text-end">@(row.SerialInStockQty.HasValue ? row.SerialInStockQty.Value.ToString("N2") : "-")</td>
                            <td class="text-end">@row.LedgerNetQty.ToString("N2")</td>
                            <td class="text-end @(row.BalanceLedgerDiff == 0m ? string.Empty : "text-danger fw-semibold")">@row.BalanceLedgerDiff.ToString("N2")</td>
                            <td class="text-end @(row.BalanceSerialDiff.GetValueOrDefault() == 0m ? string.Empty : "text-danger fw-semibold")">@(row.BalanceSerialDiff.HasValue ? row.BalanceSerialDiff.Value.ToString("N2") : "-")</td>
                            <td><span class="status-pill @(row.IsMismatch ? "inactive" : "active")">@row.StatusText</span></td>
                            <td>@row.IssueText</td>
                            <td class="text-end">
                                <div class="table-actions">
                                    <a asp-controller="StockLedger" asp-action="Index" asp-route-itemId="@row.ItemId" asp-route-branchId="@row.BranchId" class="btn btn-sm btn-outline-primary">สมุดสต็อก</a>
                                    @if (row.IsSerialControlled)
                                    {
                                        <a asp-controller="StockInquiry" asp-action="Serials" asp-route-itemId="@row.ItemId" asp-route-branchId="@row.BranchId" class="btn btn-sm btn-outline-secondary">Serial</a>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="11" class="table-empty">ไม่พบข้อมูลตรวจสอบสต็อกตามเงื่อนไขที่ค้นหา</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
        <partial name="_Pager" model="Model.Pagination" />
    </div>
</div>

